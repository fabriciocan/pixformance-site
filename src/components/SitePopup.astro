---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<!-- TIMED POPUP (5s, once per session) -->
<div id="timed-popup" class="fixed inset-0 z-[9998] hidden items-center justify-center p-4">
  <div id="timed-popup-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative bg-white rounded-3xl shadow-2xl max-w-sm w-full overflow-hidden">
    <button id="timed-popup-close" aria-label="Schließen" class="absolute top-3 left-3 z-10 w-8 h-8 rounded-full bg-white/80 hover:bg-white flex items-center justify-center transition-colors cursor-pointer shadow-sm">
      <Icon name="x" size="sm" />
    </button>

    <div class="w-full h-48 overflow-hidden">
      <img
        src="/images/Pixformance-Station-Einzeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
        alt="Pixformance Training"
        class="w-full h-full object-cover object-top"
        width="400"
        height="192"
        loading="eager"
      />
    </div>

    <div class="bg-[#6BDBD1] px-7 py-7 text-center">
      <h2 class="font-display text-3xl font-bold text-white leading-tight mb-1">
        Jetzt 60 Tage
      </h2>
      <p class="text-white/90 text-base underline mb-1">in Ihrem Unternehmen</p>
      <h2 class="font-display text-3xl font-bold text-white leading-tight mb-6">
        testen
      </h2>

      <button id="timed-popup-cta" class="w-full py-3.5 bg-white text-[#02308C] font-bold text-base rounded-xl hover:bg-gray-50 hover:shadow-lg transition-all duration-300 cursor-pointer flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
        Unternehmen (weiter)
      </button>
      <button id="timed-popup-decline" class="w-full mt-3 text-sm text-white/80 hover:text-white underline transition-colors cursor-pointer py-1">
        Privatperson (schließen)
      </button>
    </div>
  </div>
</div>

<!-- POPUP MODAL - 60 Tage Testen -->
<div id="popup-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4">
  <div id="popup-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative bg-white rounded-3xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-8 md:p-10">
    <button id="popup-close" aria-label="Schließen" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors cursor-pointer">
      <Icon name="x" size="md" />
    </button>

    <h2 class="font-display text-2xl md:text-3xl font-bold text-[#02308C] mb-6 text-center">
      Jetzt 60 Tage in Ihrem Unternehmen testen
    </h2>

    <form id="popup-form" class="space-y-4">
      <div data-ab-firma>
        <div data-ab-role="control" style="display:none">
          <label for="popup-firma" class="block text-sm font-bold mb-1 text-gray-700">Firma <span class="text-red-500">*</span></label>
          <input type="text" id="popup-firma" name="company" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div data-ab-role="variant" style="display:none">
          <label for="popup-firma-select" class="block text-sm font-bold mb-1 text-gray-700">Gesundheits- oder Sporteinrichtung <span class="text-red-500">*</span></label>
          <select id="popup-firma-select" name="company" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900 appearance-none cursor-pointer">
            <option value="" disabled selected>Bitte auswählen ...</option>
            <option value="Physiotherapie">Physiotherapie</option>
            <option value="Therapie- / Rehazentrum">Therapie- / Rehazentrum</option>
            <option value="Klinik / Krankenhaus">Klinik / Krankenhaus</option>
            <option value="Fitness- / Gesundheitszentrum">Fitness- / Gesundheitszentrum</option>
            <option value="Hotel / Wellness">Hotel / Wellness</option>
            <option value="Pflegeeinrichtung">Pflegeeinrichtung</option>
            <option value="Betriebliches Gesundheitsmanagement (BGM)">Betriebliches Gesundheitsmanagement (BGM)</option>
            <option value="Sonstiges">Sonstiges</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="popup-vorname" class="block text-sm font-bold mb-1 text-gray-700">Vorname <span class="text-red-500">*</span></label>
          <input type="text" id="popup-vorname" name="first_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div>
          <label for="popup-nachname" class="block text-sm font-bold mb-1 text-gray-700">Nachname <span class="text-red-500">*</span></label>
          <input type="text" id="popup-nachname" name="last_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
      </div>
      <div>
        <label for="popup-email" class="block text-sm font-bold mb-1 text-gray-700">Email <span class="text-red-500">*</span></label>
        <input type="email" id="popup-email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
      </div>
      <div>
        <label for="popup-telefon" class="block text-sm font-bold mb-1 text-gray-700">Telefonnummer <span class="text-red-500">*</span></label>
        <input type="tel" id="popup-telefon" name="phone" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
      </div>
      <div class="flex items-start gap-3 pt-2">
        <input type="checkbox" id="popup-privacy" name="privacy" required class="mt-1 w-5 h-5 rounded border-gray-300 text-[#02308C] focus:ring-[#02308C]/30" />
        <label for="popup-privacy" class="text-xs text-gray-600 leading-relaxed">
          Ich habe die <a href="/datenschutz" class="text-[#02308C] hover:underline font-bold">Datenschutzerklärung</a> gelesen und willige ein, dass die Pixformance Sports GmbH mir ein Testangebot unterbreiten und mich per E-Mail oder Telefon zu Produkten sowie allgemeinen Unternehmens-Infos kontaktieren darf. Die Einwilligung kann jederzeit widerrufen werden.
        </label>
      </div>
      <button type="submit" class="w-full py-4 bg-[#02308C] text-white font-bold text-lg rounded-xl hover:bg-[#02308C]/90 hover:shadow-lg transition-all duration-300 cursor-pointer">
        ANGEBOT ANFORDERN
      </button>
    </form>
    <div id="popup-form-message" class="hidden"></div>
  </div>
</div>

<style>
  #popup-modal.flex,
  #timed-popup.flex {
    animation: popup-in 0.3s ease-out;
  }
  @keyframes popup-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  #popup-modal.flex > div:last-child,
  #timed-popup.flex > div:last-child {
    animation: popup-slide 0.3s ease-out;
  }
  @keyframes popup-slide {
    from { transform: translateY(20px) scale(0.97); }
    to   { transform: translateY(0) scale(1); }
  }
</style>

<script is:inline>
(function () {
  var WEBHOOK_URL = 'https://webhook.pixformance.com/webhook/site-forms';

  function sha256(value) {
    var normalized = (value || '').toLowerCase().trim();
    var encoded = new TextEncoder().encode(normalized);
    return crypto.subtle.digest('SHA-256', encoded).then(function (buffer) {
      return Array.from(new Uint8Array(buffer))
        .map(function (b) { return b.toString(16).padStart(2, '0'); })
        .join('');
    });
  }

  function normalizePhone(phone) {
    var cleaned = (phone || '').trim().replace(/[\s\-().]/g, '');
    if (cleaned && !cleaned.startsWith('+')) {
      cleaned = '+49' + cleaned.replace(/^0/, '');
    }
    return cleaned;
  }

  function hashUserData(formData) {
    var email     = (formData.get('email')      || '').toLowerCase().trim();
    var phone     = normalizePhone(formData.get('phone'));
    var firstName = (formData.get('first_name') || '').toLowerCase().trim();
    var lastName  = (formData.get('last_name')  || '').toLowerCase().trim();
    return Promise.all([
      email     ? sha256(email)     : Promise.resolve(''),
      phone     ? sha256(phone)     : Promise.resolve(''),
      firstName ? sha256(firstName) : Promise.resolve(''),
      lastName  ? sha256(lastName)  : Promise.resolve(''),
    ]).then(function (r) {
      return { em: r[0], ph: r[1], fn: r[2], ln: r[3] };
    });
  }

  function getUrlParams() {
    var params = {};
    new URLSearchParams(window.location.search).forEach(function (v, k) { params[k] = v; });
    return params;
  }

  function getCookies() {
    var cookies = {};
    if (!document.cookie) return cookies;
    document.cookie.split(';').forEach(function (c) {
      var i = c.indexOf('=');
      if (i === -1) return;
      var k = c.slice(0, i).trim();
      var v = c.slice(i + 1).trim();
      try { cookies[k] = decodeURIComponent(v); } catch (e) { cookies[k] = v; }
    });
    return cookies;
  }

  function getFbp(cookies) { return cookies._fbp || ''; }

  function getFbc(cookies) {
    var fbclid = new URLSearchParams(window.location.search).get('fbclid');
    if (fbclid) {
      var sub = window.location.hostname.startsWith('www.') ? 2 : 1;
      return 'fb.' + sub + '.' + Date.now() + '.' + fbclid;
    }
    return cookies._fbc || '';
  }

  function sanitizePhone(phone) {
    return (phone || '').replace(/[^\d\s+\-()]/g, '').trim();
  }

  async function submitForm(formData, messageEl, formEl, formName) {
    var cookies     = getCookies();
    var computedFbc = getFbc(cookies);
    var computedFbp = getFbp(cookies);
    if (computedFbc) cookies._fbc = computedFbc;
    if (computedFbp) cookies._fbp = computedFbp;
    var btn = formEl.querySelector('[type="submit"]');
    if (btn) { btn.disabled = true; btn.style.opacity = '0.7'; }

    var hashed = { em: '', ph: '', fn: '', ln: '' };
    try { hashed = await hashUserData(formData); } catch (err) {}

    var pixConsent = null;
    try { pixConsent = JSON.parse(localStorage.getItem('pix_consent') || 'null'); } catch {}
    if (pixConsent && pixConsent.marketing) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'meta_user_data_ready', em: hashed.em, ph: hashed.ph, fn: hashed.fn, ln: hashed.ln });
    }

    try {
      var META_EVENT_ID = '';
      for (var i = window.dataLayer.length - 1; i >= 0; i--) {
        if (window.dataLayer[i] && window.dataLayer[i].event_id) {
          META_EVENT_ID = window.dataLayer[i].event_id;
          break;
        }
      }

      var payload = {
        form_name:            formName || 'Site - Popup',
        company:              formData.get('company') || '',
        first_name:           formData.get('first_name') || '',
        last_name:            formData.get('last_name') || '',
        email:                formData.get('email') || '',
        phone:                sanitizePhone(formData.get('phone')),
        privacy_accepted:     formData.get('privacy') === 'on',
        page_url:             window.location.href,
        page_path:            window.location.pathname,
        referrer:             document.referrer || '',
        submitted_at:         new Date().toISOString(),
        url_params:           getUrlParams(),
        cookies:              cookies,
        language:             'de',
        version:              'DACH',
        form_source:          'site-popup',
        meta_event_id:        META_EVENT_ID,
        meta_fbp:             getFbp(cookies),
        meta_fbc:             getFbc(cookies),
        meta_user_agent:      navigator.userAgent,
        meta_event_source_url: window.location.href,
        meta_em:              hashed.em,
        meta_ph:              hashed.ph,
        meta_fn:              hashed.fn,
        meta_ln:              hashed.ln,
      };

      var r = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (r && r.ok) {
        formEl.style.display = 'none';
        messageEl.classList.remove('hidden');
        messageEl.className = 'p-8 rounded-2xl bg-white border-2 border-[#02308C]/20 text-center';
        messageEl.innerHTML = '<div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#02308C] flex items-center justify-center"><svg width="32" height="32" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg></div><h3 class="text-xl font-bold text-[#02308C] mb-2">Vielen Dank für Ihre Anfrage!</h3><p class="text-gray-600">Wir werden uns in Kürze bei Ihnen melden.</p>';
      } else {
        messageEl.classList.remove('hidden');
        messageEl.className = 'p-4 rounded-xl bg-red-50 text-red-700 border-2 border-red-200 font-semibold text-center';
        messageEl.textContent = 'Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.';
      }
    } catch {
      messageEl.classList.remove('hidden');
      messageEl.className = 'p-4 rounded-xl bg-red-50 text-red-700 border-2 border-red-200 font-semibold text-center';
      messageEl.textContent = 'Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.';
    } finally {
      if (btn) { btn.disabled = false; btn.style.opacity = ''; }
    }
  }

  function initABTest() {
    var STORAGE_KEY = 'pix_ab_firma_field';
    var urlOverride = new URLSearchParams(window.location.search).get('ab');
    var stored  = (urlOverride === 'control' || urlOverride === 'variant') ? urlOverride : localStorage.getItem(STORAGE_KEY);
    var variant = stored || (Math.random() < 0.5 ? 'control' : 'variant');
    if (!stored) localStorage.setItem(STORAGE_KEY, variant);

    document.querySelectorAll('[data-ab-firma]').forEach(function (group) {
      var controlEl = group.querySelector('[data-ab-role="control"]');
      var variantEl = group.querySelector('[data-ab-role="variant"]');
      var showEl    = variant === 'variant' ? variantEl : controlEl;
      var hideEl    = variant === 'variant' ? controlEl : variantEl;
      if (showEl) { showEl.style.display = ''; var inp = showEl.querySelector('input, select'); if (inp) inp.required = true; }
      if (hideEl) { hideEl.style.display = 'none'; var inp2 = hideEl.querySelector('input, select'); if (inp2) { inp2.required = false; inp2.value = ''; } }
    });
  }

  function init() {
    initABTest();

    var modal      = document.getElementById('popup-modal');
    var closeBtn   = document.getElementById('popup-close');
    var overlay    = document.getElementById('popup-overlay');
    var timedPopup = document.getElementById('timed-popup');

    if (!modal || !timedPopup) return;

    function openPopup() {
      closeTimedPopup();
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function openTimedPopup() {
      timedPopup.classList.remove('hidden');
      timedPopup.classList.add('flex');
    }

    function closeTimedPopup() {
      timedPopup.classList.add('hidden');
      timedPopup.classList.remove('flex');
    }

    if (closeBtn)  closeBtn.addEventListener('click', closePopup);
    if (overlay)   overlay.addEventListener('click', closePopup);

    var timedOverlay = document.getElementById('timed-popup-overlay');
    var timedClose   = document.getElementById('timed-popup-close');
    var timedCta     = document.getElementById('timed-popup-cta');
    var timedDecline = document.getElementById('timed-popup-decline');

    if (timedClose)   timedClose.addEventListener('click', closeTimedPopup);
    if (timedOverlay) timedOverlay.addEventListener('click', closeTimedPopup);
    if (timedDecline) timedDecline.addEventListener('click', closeTimedPopup);
    if (timedCta)     timedCta.addEventListener('click', openPopup);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { closePopup(); closeTimedPopup(); }
    });

    // Popup form submit
    var popupForm = document.getElementById('popup-form');
    var popupMsg  = document.getElementById('popup-form-message');
    if (popupForm) {
      popupForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var formName = 'Site Bar - ' + window.location.pathname.replace(/\/$/, '') || '/';
        submitForm(new FormData(popupForm), popupMsg, popupForm, formName);
      });
    }

    // Timed popup: 5s delay, once per session, waits for cookie consent
    if (!sessionStorage.getItem('pix_timed_popup_seen')) {
      function startTimer() {
        setTimeout(function () {
          if (!modal.classList.contains('flex')) {
            openTimedPopup();
            sessionStorage.setItem('pix_timed_popup_seen', '1');
          }
        }, 5000);
      }

      try {
        var existingConsent = localStorage.getItem('pix_consent');
        if (existingConsent) {
          startTimer();
        } else {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push = (function (origPush) {
            return function () {
              origPush.apply(window.dataLayer, arguments);
              var item = arguments[0];
              if (item && item.event === 'pix_consent_updated') {
                window.dataLayer.push = origPush;
                startTimer();
              }
            };
          })(window.dataLayer.push);
        }
      } catch (e) {
        startTimer();
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
