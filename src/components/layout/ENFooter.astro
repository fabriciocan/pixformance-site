---
/**
 * EN Footer Component - Pixformance USA
 */
import { cn } from '@/lib/cn';
import { footerVariants } from './footer.variants';
import PixformanceLogo from '@/components/PixformanceLogo.astro';

interface Props {
  variant?: 'default' | 'minimal';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const currentYear = new Date().getFullYear();

const footerClasses = cn(footerVariants({ variant }), className);

const solutionsLinks = [
  { label: 'Physical Therapy', href: '/en/physical-therapy/' },
  { label: 'Fitness', href: '/en/fitness/' },
  { label: 'Corporate Fitness', href: '/en/corporate-fitness/' },
];

const companyLinks = [
  { label: 'About us', href: '/en/about-us/' },
  { label: 'Success Stories', href: '/en/success-stories/' },
  { label: 'News', href: '/en/functional-training-and-fitness-news/' },
  { label: 'Blog', href: '/en/blog-articles/' },
  { label: 'FAQ', href: '/en/faq-training-with-pixformance-station/' },
  { label: 'Jobs', href: '/en/jobs/' },
  { label: 'Contact', href: '/en/contact/' },
];

const recentBlogPosts = [
  {
    label: 'Increase Physical Therapy Sales: What Opportunities Does The Self-Pay Sector Have To Offer Now?',
    href: '/en/increase-physical-therapy-sales-what-opportunities-does-the-self-pay-sector-have-to-offer-now/',
  },
  {
    label: 'Digitization: An Opportunity For The Healthcare Industry',
    href: '/en/digitization-an-opportunity-for-the-healthcare-industry/',
  },
  {
    label: "Three Lessons Fitness Clubs Can Learn From Weight Watchers' New Business Strategy",
    href: '/en/three-lessons-fitness-clubs-can-learn-from-weight-watchers/',
  },
];

const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/pixformancesports', icon: '/images/en/if_facebook_online_social_media_734399-2.png' },
  { label: 'Instagram', href: 'https://www.instagram.com/pixformance/', icon: '/images/en/if_instagram_online_social_media_734394-2.png' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/2980658/', icon: '/images/en/if_online_social_media_linked_in_734383-2.png' },
  { label: 'YouTube', href: 'https://www.youtube.com/channel/UCw-sWITx6ElTie7ep57Mz2w', icon: '/images/en/if_youtube_online_social_media_734361-2.png' },
];
---

<footer class={footerClasses}>
  <div class="container">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      {/* Company Info */}
      <div>
        <PixformanceLogo variant="black" size="md" class="mb-4" />
        <p class="text-sm text-foreground-muted mb-4">
          Digital Fitness Devices & Therapy Equipment
        </p>
        <div class="space-y-1 text-sm text-foreground-muted">
          <p class="font-semibold text-foreground">Pixformance USA Inc.</p>
          <p>3 Windward Way</p>
          <p>East Windsor, NJ 08520</p>
          <p>
            <a href="tel:+18884204572" class="hover:text-foreground transition-colors">+1 888 – 420-4572</a>
          </p>
          <p>
            <a href="mailto:info@pixformance.com" class="hover:text-foreground transition-colors">info@pixformance.com</a>
          </p>
        </div>
        {/* Social Links */}
        <div class="flex gap-3 mt-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="opacity-70 hover:opacity-100 transition-opacity"
            >
              <img src={social.icon} alt={social.label} class="h-6 w-6" loading="lazy" />
            </a>
          ))}
        </div>
      </div>

      {/* Solutions */}
      <div>
        <h4 class="font-semibold mb-4">Solutions</h4>
        <ul class="space-y-2">
          {solutionsLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-foreground-muted hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Company */}
      <div>
        <h4 class="font-semibold mb-4">Company</h4>
        <ul class="space-y-2">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-foreground-muted hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Recent Blog Posts */}
      <div>
        <h4 class="font-semibold mb-4">Recent Articles</h4>
        <ul class="space-y-3">
          {recentBlogPosts.map((post) => (
            <li>
              <a
                href={post.href}
                class="text-sm text-foreground-muted hover:text-foreground transition-colors line-clamp-3 leading-relaxed"
              >
                {post.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="border-t border-border mt-8 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-foreground-muted">
        © {currentYear} Pixformance Sports GmbH. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="/en/imprint/" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Imprint</a>
        <a href="/en/privacy-policy/" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
