---
interface Props {
  active: 'physiotherapie' | 'fitness' | 'fitness-entreprise';
}

const { active } = Astro.props;

const tabs = [
  { id: 'physiotherapie', label: 'PHYSIOTHÉRAPIE', href: '/fr/physiotherapie/' },
  { id: 'fitness', label: 'FITNESS', href: '/fr/fitness/' },
  { id: 'fitness-entreprise', label: 'FITNESS EN ENTREPRISE', href: '/fr/fitness-entreprise/' },
];
---

<nav class="bg-[#02308C] sticky top-16 z-40" aria-label="Navigation solutions">
  <div class="container">
    <div class="flex overflow-x-auto">
      {tabs.map((tab) => (
        <a
          href={tab.href}
          class={`px-6 py-4 text-sm font-bold whitespace-nowrap transition-colors duration-200 border-b-2 ${
            active === tab.id
              ? 'text-white border-[#6BDBD1] bg-white/10'
              : 'text-white/70 border-transparent hover:text-white hover:border-white/30'
          }`}
          aria-current={active === tab.id ? 'page' : undefined}
        >
          {tab.label}
        </a>
      ))}
    </div>
  </div>
</nav>
