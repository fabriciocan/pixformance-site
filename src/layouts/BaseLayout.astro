---
import '@/styles/global.css';
import ChatWidget from '@/components/ChatWidget.astro';
import CookieBanner from '@/components/CookieBanner.astro';
import SitePopup from '@/components/SitePopup.astro';
import StickyBar from '@/components/StickyBar.astro';
import montserratFontUrl from '@fontsource-variable/montserrat/files/montserrat-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noSitePopup?: boolean;
}

const {
  title = 'Pixformance – Digitale Fitnessgeräte & Therapiegeräte mit Echtzeit-Feedback',
  description = 'Pixformance: Digitale Bewegungsanalyse für Physiotherapie, Kliniken, Fitness & BGM. 2,5M+ Trainierende/Jahr. 700+ Übungen. Echtzeit-Korrekturfeedback.',
  image = 'https://www.pixformance.com/images/Pixformance-Station-Konzept-voll-vernetzt-Digitales-Trainingsgeraet-Funktionelles-Training-eGym.jpg',
  canonical,
  type = 'website',
  noindex = false,
  jsonLd,
  noSitePopup = false,
} = Astro.props;

const canonicalURL = canonical ?? Astro.url.href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pixformance Sports GmbH',
  legalName: 'Pixformance Sports GmbH',
  url: 'https://www.pixformance.com',
  logo: {
    '@type': 'ImageObject',
    url: 'https://www.pixformance.com/images/pix-favicon.png',
    width: 1024,
    height: 1024,
  },
  foundingDate: '2012',
  description:
    'Pionier in digitaler Bewegungsanalyse und Echtzeit-Feedback für Physiotherapie, Kliniken, Fitness und betriebliches Gesundheitsmanagement.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Hauptstraße 19–20',
    addressLocality: 'Dallgow-Döberitz',
    postalCode: '14624',
    addressCountry: 'DE',
  },
  telephone: '+493039805610',
  email: 'contact@pixformance.com',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'contact@pixformance.com',
    telephone: '+493039805610',
    availableLanguage: ['German', 'English'],
  },
  knowsAbout: [
    'Digitale Bewegungstherapie',
    'Rehabilitation',
    'Physiotherapie',
    'Funktionelles Training',
    'Betriebliches Gesundheitsmanagement',
    'Echtzeit-Bewegungsanalyse',
    'Telerehabilitation',
    'Patientenaktivierung',
  ],
  hasCredential: [
    'CE-Kennzeichnung Medizinprodukt',
    'MDR-konform EU 2017/745',
    'EMV-Richtlinie 2004/108/EG',
  ],
  award: 'FORTEe EU Research Partner',
  sameAs: [
    'https://www.linkedin.com/company/pixformance',
    'https://www.youtube.com/@pixformance',
  ],
  areaServed: ['DE', 'AT', 'CH', 'NL', 'FR', 'IT'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Pixformance',
  url: 'https://www.pixformance.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://www.pixformance.com/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="msvalidate.01" content="5EB1EF624CC06DC3DCB86874F9ABD741" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Pixformance" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Preload critical font to eliminate CLS from FOUT and break CSS→font critical chain -->
    <link rel="preload" href={montserratFontUrl} as="font" type="font/woff2" crossorigin />

    <!-- Favicon & Manifest -->
    <link rel="icon" type="image/png" href="/images/pix-favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#02308C" />

    <!-- Sitewide JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Sitewide JSON-LD: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Per-page JSON-LD -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((schema) => (
            <script type="application/ld+json" set:html={JSON.stringify(schema)} />
          ))
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Per-page head injections (preconnects, etc.) -->
    <slot name="head" />

    <!-- Google Consent Mode v2 defaults — MUST run before GTM -->
    <script is:inline data-cfasync="false">
      (function () {
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        // Set denied defaults first (before GTM fires any tags)
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          wait_for_update: 500
        });
        // Immediately restore saved consent so returning visitors aren't re-blocked
        try {
          var saved = localStorage.getItem('pix_consent');
          if (saved) {
            var c = JSON.parse(saved);
            var now = Date.now();
            // Honour consent for up to 12 months
            if (c.ts && (now - c.ts) < 365 * 24 * 60 * 60 * 1000) {
              gtag('consent', 'update', {
                ad_storage: c.marketing ? 'granted' : 'denied',
                ad_user_data: c.marketing ? 'granted' : 'denied',
                ad_personalization: c.marketing ? 'granted' : 'denied',
                analytics_storage: c.statistics ? 'granted' : 'denied'
              });
              window.__pixConsentRestored = true;
            }
          }
        } catch (e) {}
      })();
    </script>
    <!-- End Google Consent Mode v2 defaults -->

    <!-- Google Tag Manager -->
    <script is:inline data-cfasync="false">
      window.dataLayer = window.dataLayer || [];
    </script>
    <script async data-cfasync="false" src="https://www.googletagmanager.com/gtm.js?id=GTM-55PTFL9"></script>
    <!-- End Google Tag Manager -->


<script is:inline>
  (function () {
    /**
     * Gera um event_id único no formato compatível com o GTM:
     * {timestamp}_{random15digits}
     */
    function generateEventId() {
      return Date.now() + '_' + Math.floor(Math.random() * 1e15);
    }

    /**
     * Inicializa o event_id e empurra para a dataLayer.
     * Chamado no carregamento da página e em cada navegação
     * via View Transitions (astro:page-load).
     */
    function initEventId() {
      window.dataLayer = window.dataLayer || [];

      // Gera um novo event_id para esta pageview
      window.__metaEventId = generateEventId();

      // Empurra para a dataLayer para o GTM/FBA Lead consumir via {{Event ID}}
      window.dataLayer.push({
        event: 'meta_event_id_ready',
        event_id: window.__metaEventId,
      });
    }

    // Inicializa imediatamente no carregamento da página
    initEventId();

    // Suporte a View Transitions do Astro:
    // a cada navegação client-side, gera um novo event_id
    document.addEventListener('astro:page-load', function () {
      initEventId();
    });
  })();
</script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-55PTFL9"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot name="header" />
    {!noSitePopup && <StickyBar />}
    <main><slot /></main>
    <slot name="footer" />
    <ChatWidget />
    <CookieBanner />
    {!noSitePopup && <SitePopup />}
    <script is:inline src="/js/url-params.js"></script>
    <script is:inline src="/js/form-protection.js"></script>
  </body>
</html>
