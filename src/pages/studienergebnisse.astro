---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const clientLogos = [
  { name: 'Charité Berlin', src: '/images/en/Logo-Charite.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'FORTEe EU Projekt', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
];
---

<BaseLayout
  title="Klinische Studienergebnisse – Pixformance CE-Medizinprodukt, peer-reviewed belegt"
  description="Peer-reviewed klinische Studien belegen die Wirksamkeit von Pixformance bei Parkinson, Multipler Sklerose, Mamma-Karzinom und Muskeldystrophie. CE-Medizinprodukt (MDR EU 2017/745), eingesetzt in Charité Berlin, Medical Park, AUVA und Oxford Brookes University."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Klinische Studienergebnisse – Pixformance",
      "description": "Peer-reviewed klinische Studien zur Wirksamkeit von Pixformance (CE-Medizinprodukt, MDR EU 2017/745) in Neurologie, Onkologie und Orthopädie.",
      "url": "https://pixformance.com/studienergebnisse",
      "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com"},
      "about": {"@type": "MedicalDevice", "name": "Pixformance Station", "legalStatus": "CE-Medizinprodukt MDR EU 2017/745"}
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Klinische Studien zu Pixformance",
      "numberOfItems": 6,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Sport bei Mamma-Karzinom: Verbesserung von Lebensqualität und körperlicher Leistungsfähigkeit",
            "about": "Mamma-Karzinom – Sport in der Krebstherapie",
            "datePublished": "2025-08",
            "isPartOf": {"@type": "Periodical", "name": "BMC Cancer", "publisher": {"@type": "Organization", "name": "Springer Nature"}},
            "description": "Peer-reviewed Studie (BMC Cancer, Aug 2025): Wirksamkeit von Bewegungstherapie bei Brustkrebspatientinnen. Nachgewiesene Verbesserungen bei körperlicher Leistungsfähigkeit und Lebensqualität.",
            "keywords": "Mamma-Karzinom, Brustkrebs, Onkologie, Bewegungstherapie, BMC Cancer, peer-reviewed, Springer Nature"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Digitale Bewegungstherapie bei neurologischen Erkrankungen: Wirksamkeit und Patientenzufriedenheit",
            "about": "Neurologie – Digitale Bewegungstherapie",
            "datePublished": "2025-02",
            "isPartOf": {"@type": "Periodical", "name": "Journal of Medical Internet Research (JMIR)", "publisher": {"@type": "Organization", "name": "JMIR Publications"}},
            "description": "Peer-reviewed Studie (JMIR, Feb 2025): Wirksamkeit und Patientenzufriedenheit bei digitalem Bewegungstraining in neurologischen Indikationen (Parkinson, Multiple Sklerose).",
            "keywords": "Neurologie, Parkinson, Multiple Sklerose, digitale Therapie, Patientenzufriedenheit, JMIR, peer-reviewed"
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Effect of Pixformance training on gait ability and mobility in Parkinson patients",
            "about": "Parkinson – Gehfähigkeit & Beweglichkeit",
            "publisher": {"@type": "Organization", "name": "Hochschule Fresenius Frankfurt"},
            "description": "Klinische Studie zur Verbesserung der Gehfähigkeit und Beweglichkeit bei Parkinson-Patienten durch regelmäßiges funktionelles Training mit Pixformance.",
            "keywords": "Parkinson, Bewegungstherapie, Gehfähigkeit, Rehabilitation, digitales Training"
          }
        },
        {
          "@type": "ListItem",
          "position": 4,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Effect of Pixformance training on gait ability and quality of life in Multiple Sclerosis patients",
            "about": "Multiple Sklerose – Gehfähigkeit & Lebensqualität",
            "publisher": {"@type": "Organization", "name": "Hochschule Fresenius Frankfurt"},
            "description": "Klinische Studie zur Verbesserung der Gehfähigkeit und Lebensqualität bei MS-Patienten durch digitale Bewegungstherapie mit Pixformance.",
            "keywords": "Multiple Sklerose, MS, Bewegungstherapie, Lebensqualität, Rehabilitation, Neurologie"
          }
        },
        {
          "@type": "ListItem",
          "position": 5,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Empirical verification of training effects with Pixformance – functional training and muscle strength",
            "about": "Muskeln – Kraft & Funktionelles Training",
            "datePublished": "2023-08",
            "publisher": {"@type": "Organization", "name": "Hochschule Fresenius Frankfurt"},
            "sameAs": "https://www.researchgate.net/publication/pixformance-functional-training",
            "description": "Studie zur Untersuchung der Trainingseffekte durch funktionelles Training mit Pixformance. Empirische Überprüfung der Verbesserungen bei Muskelkraft und Bewegungsqualität.",
            "keywords": "Muskelkraft, funktionelles Training, Bewegungsqualität, Orthopädie, ResearchGate"
          }
        },
        {
          "@type": "ListItem",
          "position": 6,
          "item": {
            "@type": "ScholarlyArticle",
            "name": "Get strong to fight childhood cancer – an exercise intervention for children and adolescents undergoing anti-cancer treatment (FORTEe): Rationale and design of a randomized controlled exercise trial",
            "about": "FORTEe – EU Forschungsprojekt Kinderonkologie",
            "datePublished": "2025",
            "identifier": {"@type": "PropertyValue", "propertyID": "doi", "value": "10.1186/s12885-025-14489-y"},
            "sameAs": "https://bmccancer.biomedcentral.com/articles/10.1186/s12885-025-14489-y",
            "url": "https://pubmed.ncbi.nlm.nih.gov/40775303/",
            "isPartOf": {"@type": "Periodical", "name": "BMC Cancer", "publisher": {"@type": "Organization", "name": "Springer Nature"}},
            "funder": {"@type": "Organization", "name": "Europäische Union – Horizon 2020", "url": "https://cordis.europa.eu/project/id/945153"},
            "description": "Peer-reviewed RCT (BMC Cancer, 2025, DOI: 10.1186/s12885-025-14489-y): Randomisierte, kontrollierte multizentrische Studie zur Bewegungstherapie für Kinder und Jugendliche mit Krebs. Pixformance ist EU-Forschungspartner im FORTEe Horizon-2020-Projekt (€6,3 Mio.).",
            "keywords": "FORTEe, Kinderonkologie, EU Horizon 2020, Bewegungstherapie, Kinderkrebs, BMC Cancer, RCT"
          }
        }
      ]
    }
  ]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/studienergebnisse/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/studienergebnisse/" />
  </Fragment>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.1s;">
          <Icon name="award" size="sm" />
          Wissenschaftlich belegt
        </span>

        <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Klinisch validierte Bewegungstherapie:<br class="hidden md:block" />
          Studienergebnisse zu <span class="text-[#02308C]">Pixformance</span>
        </h1>

        <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Peer-reviewed klinische Studien der Hochschule Fresenius Frankfurt, Oxford Brookes University und weiterer renommierter Institutionen belegen die Wirksamkeit des Pixformance Systems
        </p>

        <p class="text-base md:text-lg text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.35s;">
          Pixformance ist ein CE-gekennzeichnetes Medizinprodukt (MDR-konform EU 2017/745), das in der Charité Berlin, Medical Park, AUVA Klagenfurt und der Oxford Brookes University klinisch eingesetzt wird. Mehrere peer-reviewed Studien — publiziert u. a. in BMC Cancer (Springer Nature) und JMIR — belegen die positive Wirkung auf Gehfähigkeit, Lebensqualität und Bewegungsqualität bei Parkinson, Multipler Sklerose, Mamma-Karzinom und Muskeldystrophie. Als EU-Forschungspartner im Horizon-2020-Projekt FORTEe entwickelt Pixformance Bewegungstherapie für Kinder mit Krebs.
        </p>

        <div class="flex flex-wrap justify-center gap-4 hero-animate" style="animation-delay: 0.4s;">
          <a href="/ressourcen-download?doc=studienergebnisse" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white font-bold text-sm hover:bg-[#6BDBD1] transition-colors">
            <Icon name="download" size="sm" />
            Studienergebnisse 2024 herunterladen (PDF)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-8 md:py-12 bg-gray-50 border-y border-gray-100">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-8" data-scroll="fade-up">
        Forschungspartner &amp; klinische Einrichtungen
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12" data-scroll="fade-up">
        {clientLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-10 md:py-14 bg-white border-b border-gray-100">
    <div class="container">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-scroll="fade-up">
        <div>
          <p class="text-4xl font-bold text-[#02308C]">4+</p>
          <p class="text-sm text-foreground-muted mt-1">Klinische Studien</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">2.5M+</p>
          <p class="text-sm text-foreground-muted mt-1">Trainierende / Jahr</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">1.100+</p>
          <p class="text-sm text-foreground-muted mt-1">Kliniken &amp; Rehazentren</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">700+</p>
          <p class="text-sm text-foreground-muted mt-1">Funktionelle Übungen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Peer-Reviewed Publications -->
  <section class="py-12 md:py-16 bg-[#02308C]/5 border-b border-[#02308C]/10">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-3 text-center" data-scroll="fade-up">
          Peer-reviewed Publikationen
        </h2>
        <p class="text-base text-foreground-muted text-center mb-10 max-w-2xl mx-auto" data-scroll="fade-up">
          Unabhängig begutachtete Studien, die die klinische Evidenz von Pixformance in internationalen Fachzeitschriften dokumentieren
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-2xl p-6 border border-[#02308C]/10 shadow-sm" data-scroll="fade-up" data-delay="1">
            <span class="inline-block px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold mb-3">BMC Cancer · Aug 2025</span>
            <h3 class="font-bold text-base mb-2">Sport bei Mamma-Karzinom: Verbesserung von Lebensqualität und körperlicher Leistungsfähigkeit</h3>
            <p class="text-sm text-foreground-muted">Springer Nature · Peer-reviewed · Onkologie</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-[#02308C]/10 shadow-sm" data-scroll="fade-up" data-delay="2">
            <span class="inline-block px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold mb-3">JMIR · Feb 2025</span>
            <h3 class="font-bold text-base mb-2">Digitale Bewegungstherapie bei neurologischen Erkrankungen: Wirksamkeit und Patientenzufriedenheit</h3>
            <p class="text-sm text-foreground-muted">Journal of Medical Internet Research · Peer-reviewed · Neurologie</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-[#02308C]/10 shadow-sm flex flex-col" data-scroll="fade-up" data-delay="3">
            <span class="inline-block px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold mb-3">BMC Cancer · 2025 · FORTEe RCT</span>
            <h3 class="font-bold text-base mb-2 grow">Get strong to fight childhood cancer – FORTEe: Bewegungstherapie für Kinder mit Krebs (RCT)</h3>
            <div class="space-y-1 mt-2">
              <p class="text-sm text-foreground-muted">Springer Nature · Peer-reviewed · Kinderonkologie · EU Horizon 2020</p>
              <a href="https://bmccancer.biomedcentral.com/articles/10.1186/s12885-025-14489-y" target="_blank" rel="noopener noreferrer" class="inline-block text-xs text-[#02308C] font-semibold hover:underline">
                DOI: 10.1186/s12885-025-14489-y →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Studies Overview -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-4 text-center" data-scroll="fade-up">
          Klinische Studien der Hochschule Fresenius Frankfurt
        </h2>
        <p class="text-lg text-foreground-muted text-center mb-12 max-w-3xl mx-auto" data-scroll="fade-up">
          In Zusammenarbeit mit der Hochschule Fresenius Frankfurt wurden klinische Studien zur Wirksamkeit von Pixformance in verschiedenen Indikationsbereichen durchgeführt.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- Parkinson Study -->
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Parkinson.jpg"
                alt="Klinische Studie Parkinson – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="activity" size="sm" /> Neurologie
                </span>
                <h3 class="font-display text-xl font-bold">Parkinson – Gehfähigkeit &amp; Beweglichkeit</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Verbesserung der Gehfähigkeit und Beweglichkeit bei Parkinson-Patienten durch regelmäßiges funktionelles Training mit Pixformance an der Hochschule Fresenius Frankfurt.
                </p>
              </div>
            </Card>
          </div>

          <!-- Multiple Sklerose Study -->
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Multiple-Sklerose.jpg"
                alt="Klinische Studie Multiple Sklerose – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="activity" size="sm" /> Neurologie
                </span>
                <h3 class="font-display text-xl font-bold">Multiple Sklerose – Gehfähigkeit &amp; Lebensqualität</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Verbesserung der Gehfähigkeit und Lebensqualität bei MS-Patienten durch digitale Bewegungstherapie mit Pixformance an der Hochschule Fresenius Frankfurt.
                </p>
              </div>
            </Card>
          </div>

          <!-- Mamma-Karzinom Study -->
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Mamma-Karzinom.jpg"
                alt="Klinische Studie Mamma-Karzinom – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="heart" size="sm" /> Onkologie
                </span>
                <h3 class="font-display text-xl font-bold">Mamma-Karzinom – Sport in der Krebstherapie</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Wirksamkeit von Bewegungstherapie bei Brustkrebspatientinnen. Nachgewiesene Verbesserungen bei körperlicher Leistungsfähigkeit und Lebensqualität.
                </p>
              </div>
            </Card>
          </div>

          <!-- Muskeln Study -->
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Muskeln.jpg"
                alt="Klinische Studie Muskeln – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="zap" size="sm" /> Orthopädie
                </span>
                <h3 class="font-display text-xl font-bold">Muskeln – Kraft &amp; Funktionelles Training</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Studie zur Untersuchung der Trainingseffekte durch funktionelles Training mit Pixformance. Empirische Überprüfung der Verbesserungen bei Muskelkraft und Bewegungsqualität.
                </p>
              </div>
            </Card>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- PDF Download Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center" data-scroll="fade-up">
          <div>
            <img
              src="/images/studien/Studienergebnisse_Wissenschaftlich-nachgewiesene-positive-Effekte-mit-Pixformance_2024-pdf.jpg"
              alt="Studienergebnisse 2024 – Wissenschaftlich nachgewiesene positive Effekte mit Pixformance"
              class="w-full max-w-xs mx-auto shadow-xl rounded-lg"
              loading="lazy"
            />
          </div>
          <div class="space-y-6">
            <h2 class="font-display text-3xl md:text-3xl font-bold">
              Studienergebnisse 2024
            </h2>
            <p class="text-lg text-foreground-muted leading-relaxed">
              Laden Sie unsere aktuelle Zusammenfassung der wissenschaftlich nachgewiesenen positiven Effekte mit Pixformance herunter. Das Dokument fasst die Ergebnisse klinischer Studien aus verschiedenen Indikationsbereichen zusammen.
            </p>
            <ul class="space-y-2 text-sm text-foreground-muted">
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Parkinson-Behandlung und Gehfähigkeit</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Multiple Sklerose und Lebensqualität</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Onkologie und Sport bei Krebs</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Funktionelles Training und Muskelkraft</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> FORTEe Forschungsprojekt (Kinderonkologie)</li>
            </ul>
            <a href="/ressourcen-download?doc=studienergebnisse" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[#02308C] text-white font-bold hover:bg-[#6BDBD1] transition-colors">
              <Icon name="download" size="sm" />
              PDF herunterladen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MrsSporty Study -->
  <section class="py-12 md:py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white">
          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
            </div>
            <div class="space-y-3">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#02308C]/10 text-[#02308C] text-xs font-bold">
                Fitness &amp; Prävention
              </span>
              <h3 class="font-display text-2xl font-bold">Empirische Überprüfung der Trainingseffekte – Mrs.Sporty</h3>
              <p class="text-foreground-muted leading-relaxed">
                Klinische Studie zur empirischen Überprüfung funktionellen Trainings und der Trainingseffekte bei Mrs.Sporty-Mitgliedern. Die Studie zeigt messbare Verbesserungen bei Kraft, Ausdauer und Beweglichkeit durch regelmäßiges Pixformance-Training.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-3xl font-bold text-foreground">
              Sie wünschen eine individuelle Beratung?
            </h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
