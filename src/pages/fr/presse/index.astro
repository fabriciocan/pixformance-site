---
import FRBaseLayout from '@/layouts/FRBaseLayout.astro';
import FRHeader from '@/components/layout/FRHeader.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<FRBaseLayout
  title="Pixformance dans la presse spécialisée — Études scientifiques & Publications"
  description="Pixformance Station (dispositif médical dispositif médical CE (MDR UE 2017/745)) : études publiées dans JMIR et BMC Cancer, projet de recherche européen FORTEe (Horizon 2020), validé cliniquement — Charité Berlin, Université de Médecine de Mayence, Oxford Brookes University."
  hreflangDe="https://www.pixformance.com/presse/"
  hreflangEn="https://www.pixformance.com/en/press/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance Pressestimmen & Wissenschaftliche Publikationen",
    "description": "Peer-reviewte Studien, EU-Forschungsprojekte und Fachpublikationen belegen die klinische Wirksamkeit der Pixformance Station (CE-Medizinprodukt (MDR EU 2017/745)) in Physiotherapie, Geriatrie und Onkologie.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Get strong to fight childhood cancer (FORTEe): Rationale and design of a randomized controlled exercise trial",
          "description": "Randomisierte kontrollierte Studie (RCT) zur digitalen Bewegungstherapie bei Kinderkrebs. Pixformance als Technologiepartner. 16 Partnerinstitutionen aus 8 Ländern. EU Horizont 2020.",
          "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/",
          "datePublished": "2025-08-07",
          "publisher": { "@type": "Organization", "name": "BMC Cancer" },
          "author": [
            { "@type": "Person", "name": "Marie Astrid Neu" },
            { "@type": "Person", "name": "Tobias Baader" },
            { "@type": "Person", "name": "Joerg Faber" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Use of a Technology-Based Fall Prevention Program With Visual Feedback in Early Geriatric Rehabilitation",
          "description": "Machbarkeitsstudie mit 30 geriatrischen Patienten. Pixformance Station 3x/Woche für 20 Minuten. Primärendpunkt Machbarkeit erreicht. Sekundärendpunkte: Berg Balance Scale, Timed Up and Go Test, Barthel Index.",
          "url": "https://formative.jmir.org/2025/1/e66692",
          "datePublished": "2025-02-11",
          "publisher": { "@type": "Organization", "name": "JMIR Formative Research" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Pixformance — Report zur Nutzung im (außer)klinischen Umfeld",
          "description": "Praxisbericht zur Nutzung der Pixformance Station durch Physiotherapeuten und Therapieleiter in Deutschland und Österreich. Einsatz in Orthopädie, Neurologie und Onkologie.",
          "url": "https://www.researchgate.net/publication/373196981",
          "datePublished": "2023-08-18",
          "publisher": { "@type": "Organization", "name": "ResearchGate" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de"        href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en"        href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="fr"        href="https://www.pixformance.com/fr/presse/" />
    <link rel="alternate" hreflang="nl"        href="https://www.pixformance.com/nl/pers/" />
    <link rel="alternate" hreflang="it"        href="https://www.pixformance.com/it/stampa/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <FRHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </FRHeader>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Presse spécialisée
          </span>
        </div>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance dans la <span class="text-[#02308C]">Presse Spécialisée</span>
        </h1>
        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          La Pixformance Station — le système de thérapie par le mouvement digital avec caméra 2D Full-HD brevetée et analyse en temps réel de 25 points articulaires — est régulièrement présentée dans les principales publications spécialisées en physiothérapie, réhabilitation et gestion de la santé. En tant que dispositif médical dispositif médical CE (MDR UE 2017/745), validé cliniquement à la Charité Berlin et à l'Université Oxford Brookes, Pixformance est une référence reconnue en thérapie du mouvement digital.
        </p>
      </div>
    </div>
  </section>

  <!-- Publications Scientifiques -->
  <section class="py-12 md:py-20 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Publications Scientifiques</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          La Pixformance Station fait l'objet d'études évaluées par des pairs dans des revues spécialisées internationales et des projets de recherche européens. Validée cliniquement en gériatrie, oncologie et neurologie.
        </p>
      </div>
      <div class="space-y-6">

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Août 2025</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Peer-reviewed · BMC Cancer</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              FORTEe — Essai contrôlé randomisé : thérapie par l'exercice dans le cancer pédiatrique
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Projet EU Horizon 2020. 16 institutions partenaires dans 8 pays, sous la direction du Centre Médical Universitaire de Mayence. Pixformance (Tobias Baader) comme partenaire technologique pour la thérapie par le mouvement digital chez les enfants et adolescents en traitement oncologique. En collaboration avec l'Université Oxford Brookes.
            </p>
            <a href="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Lire l'étude (PubMed / BMC Cancer)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Février 2025</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Peer-reviewed · JMIR Formative Research</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Programme digital de prévention des chutes en rééducation gériatrique précoce
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Étude de faisabilité avec 30 patients gériatriques (mars–juin 2024). La Pixformance Station a été utilisée 3 fois par semaine pendant 20 minutes. Critère principal de faisabilité atteint (≥80% de participation à 6 séances en 2 semaines). Critères secondaires : Berg Balance Scale, Timed Up and Go Test, Mesure de l'indépendance fonctionnelle, Indice de Barthel.
            </p>
            <a href="https://formative.jmir.org/2025/1/e66692" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Lire l'étude (JMIR Formative Research)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#6BDBD1] to-[#86C9BC] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide" style="color: #02308C; background: rgba(107,219,209,0.3); border: 1px solid rgba(107,219,209,0.5);">Août 2023</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Rapport clinique · ResearchGate</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Pixformance — Rapport d'utilisation clinique Allemagne &amp; Autriche
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Rapport d'utilisation de la Pixformance Station par des physiothérapeutes et responsables de thérapie en Allemagne et en Autriche. Utilisation en orthopédie, neurologie et oncologie. Rapporte les groupes de patients, les expériences pratiques, l'acceptation par le personnel spécialisé et l'utilisation en rééducation aiguë et en entraînement autonome.
            </p>
            <a href="https://www.researchgate.net/publication/373196981" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Lire le rapport (ResearchGate)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Pixformance en un coup d'œil -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-8 text-[#02308C]">Pixformance en un coup d'œil</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Dispositif médical certifié dispositif médical CE (MDR UE 2017/745)</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Validé cliniquement : Charité Berlin &amp; Oxford Brookes University</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Partenaire de recherche européen : projet FORTEe</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Analyse en temps réel de 25 points articulaires via caméra 2D Full-HD</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">700+ exercices fonctionnels sur la plateforme en ligne</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">6 000+ installations dans des cabinets de physiothérapie, cliniques de rééducation et studios de fitness dans le monde</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">2,5 millions de pratiquants par an</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Études cliniques : Hochschule Fresenius (SEP, Parkinson, dystrophie musculaire, suivi cancer du sein)</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container max-w-4xl">
      <div class="flex flex-col sm:flex-row gap-4" data-scroll="fade-up">
        <Button href="/testen" size="lg">
          Tester sans engagement
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button href="/kontakt" size="lg" variant="outline">
          Demandes presse &amp; Contact
          <Icon name="mail" size="sm" />
        </Button>
      </div>
    </div>
  </section>

</FRBaseLayout>
