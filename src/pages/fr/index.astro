---
import FRBaseLayout from '@/layouts/FRBaseLayout.astro';
import FRHeader from '@/components/layout/FRHeader.astro';
import FRFooter from '@/components/layout/FRFooter.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';

const stats = [
  { value: '750.000', label: 'Pratiquants / An', icon: 'users' },
  { value: '5M', label: 'Entraînements / An', icon: 'activity' },
  { value: '700+', label: 'Exercices fonctionnels', icon: 'zap' },
];

const features = [
  {
    icon: 'camera',
    title: 'La caméra 2D Full-HD intégrée enregistre 25 points articulaires',
  },
  {
    icon: 'monitor',
    title: 'L\'entraîneur personnel virtuel montre les exercices à l\'écran',
  },
  {
    icon: 'message-square',
    title: 'Des retours textuels et visuels s\'affichent à l\'écran',
  },
  {
    icon: 'award',
    title: 'La station brevetée fournit un retour personnalisé pendant et après les exercices',
  },
];

const testimonials = [
  {
    name: 'Gabriele Buchstein',
    role: 'Responsable kinésithérapeute',
    company: 'Sauerlandklinik Hachen, Allemagne',
    quote: 'Les patients sont enthousiastes et très motivés, ce qui n\'est pas souvent le cas. Bien sûr, nous en profitons aussi en tant que thérapeutes, car les patients réalisent leurs exercices mieux et de façon plus ciblée. De plus, nous économisons du temps car, après seulement 30 minutes d\'instruction, les patients peuvent s\'entraîner de façon autonome sous surveillance.',
    image: '/images/Gabriele-Buchstein-Leitung-Physiotherapie-Sauerlandklinik-Hachen.png',
  },
  {
    name: 'Christoph Schneider',
    role: 'Directeur thérapeutique',
    company: 'Niederrhein Klinik | Clinique de rééducation Korschenbroich, Allemagne',
    quote: 'En cherchant un moyen de permettre aux patients d\'être actifs par eux-mêmes, nous avons opté pour Pixformance. L\'offre d\'entraînement individuel est idéale ici, car la thérapie de groupe, par exemple, est parfois trop facile pour certains et trop difficile pour d\'autres. Ainsi, chacun bénéficie d\'un entraînement entièrement individualisé.',
    image: '/images/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich-Pixformance.png',
  },
  {
    name: 'Heike Schaible',
    role: 'Propriétaire',
    company: 'Cabinet de physiothérapie "Raum für Gesundheit", Allemagne',
    quote: 'Je souhaite créer une deuxième zone de paiement direct avec Pixformance et ainsi avant tout accommoder mes employés et leur offrir un travail plus accessible et plus varié.',
    image: '/images/Heike-Schaible-round.png',
  },
  {
    name: 'Erwin Kuglmeier',
    role: 'Propriétaire',
    company: 'Fitness Club California, Allemagne',
    quote: 'Mes membres peuvent être guidés et motivés individuellement pour leur entraînement avec Pixformance. J\'apprécie particulièrement la facilité de prise en main et le faible encombrement de la station !',
    image: '/images/Erwin-Kuglmeier-Fitness-California-Pixformance-300x300.png',
  },
  {
    name: 'Kim Essink',
    role: 'Propriétaire',
    company: 'Fitness Club Essink à Eindhoven, Pays-Bas',
    quote: 'Nous avons délibérément choisi Pixformance car nous avons reconnu l\'opportunité, et nous sommes convaincus que notre investissement sera rapidement rentabilisé.',
    image: '/images/Pixformance-Kim-Essink.png',
  },
  {
    name: 'Christoph Oratsch',
    role: 'Responsable thérapeutique',
    company: 'Hôpital AUVA, Klagenfurt, Autriche',
    quote: 'Du côté des patients, il y a un grand intérêt et une grande curiosité pour les stations Pixformance. Beaucoup viennent même d\'eux-mêmes et veulent un programme d\'entraînement. Nous avons récemment assuré un suivi télésupport pour une jeune femme après une opération de l\'épaule grâce à l\'application Pixformance.',
    image: '/images/Christoph-Oratsch-AUVA-Klagenfurt-1.png',
  },
  {
    name: 'Swetlana Zimmermann & Claas Bickeböller',
    role: 'Physiothérapeute & Propriétaire',
    company: 'Schlossphysio Winterthur, Suisse',
    quote: 'Nous voulions un appareil d\'entraînement holistique couvrant le plus grand nombre possible de groupes musculaires et de schémas de mouvement en thérapie sportive. Avant tout, la flexibilité qu\'offre le concept d\'entraînement digital était un point crucial pour nous.',
    image: '/images/Swetlana-Zimmermann-Schlossphysio-Pixformance-300x300.png',
  },
  {
    name: 'Gunter Hölig',
    role: 'Directeur thérapeutique',
    company: 'Medical Park Bad Rodach, Allemagne',
    quote: 'Nous sommes heureux de constater que nos patients sont ravis et persévérants dans leur entraînement. La composante active de notre équipement de thérapie digital Pixformance y joue certainement un rôle.',
    image: '/images/Pixformance-Gunter-Hoelig.png',
  },
  {
    name: 'Volker Sutor',
    role: 'Propriétaire',
    company: 'Centres de physiothérapie "Reha Rondell", Allemagne',
    quote: 'L\'entraînement santé ciblé avec l\'entraîneur virtuel augmente l\'efficacité du traitement et libère plus de temps pour la prise en charge réelle de mes patients.',
    image: '/images/Pixformance-Volker-Sutor-Testimonial.png',
  },
];

const solutions = [
  {
    title: 'PHYSIOTHÉRAPIE',
    href: '/fr/physiotherapie/',
    icon: 'heart',
    color: '#02308C',
    image: '/images/losungen/Physiotherapie.jpg',
    objectPosition: 'center',
  },
  {
    title: 'FITNESS',
    href: '/fr/fitness/',
    icon: 'zap',
    color: '#02308C',
    image: '/images/Pixformance-Fitness-Digitales-Sportgeraet-Fitnessstudio-eroeffnen-eGym-voll-vernetzt.jpg',
    objectPosition: 'center',
  },
  {
    title: 'ENTREPRISE',
    href: '/fr/fitness-entreprise/',
    icon: 'users',
    color: '#6BDBD1',
    image: '/images/Pixformance-225402_BGM_Pixformance_Funktionelles-Training_Milon_Virtuelles-Training_Sport-im-Buero-bearbeitet.jpg',
    objectPosition: 'center',
  },
];

const partnerLogos = [
  { name: 'SFR Physical Therapy', src: '/images/en/SFR-logo-pixformance.png' },
  { name: 'ICAA', src: '/images/en/ICAA-Pixformance.png' },
  { name: 'FSLA', src: '/images/en/FSLA-logo-pixformance.png' },
  { name: 'GSLA', src: '/images/en/gsla-logo-pixformance.png' },
  { name: 'Omnia', src: '/images/en/Omnia-Lifestyle-Ltd.png' },
  { name: 'Forte', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'Beanieproof', src: '/images/en/beanieproof.png' },
];

const pressLogos = [
  { name: 'Focus Gesundheit', src: '/images/en/Pixformance-Logo-Focus-Gesundheit.png' },
  { name: 'Zeitschrift für Physiotherapeuten', src: '/images/en/Pixformance-Logo-PT-Zeitschrift-fuer-Physiotherapeuten.png' },
  { name: 'Fitness Management', src: '/images/en/Pixformance-Logo-Fitness-Management-fmi.png' },
  { name: 'BILANZ', src: '/images/en/Pixformance-Logo-Bilanz-das-deutsche-Wirtschaftsmagazin.png' },
  { name: 'DIFG', src: '/images/en/Pixformance-Logo-DIFG-Deutscher-Industrieverband-fuer-Fitness-und-Gesundheit-e-V.png' },
  { name: 'Body Life', src: '/images/en/Pixformance-Logo-Body-Life.png' },
  { name: 'Shape Up Business', src: '/images/en/Pixformance-Logo-Shape-Up-Business-Das-Fitnessmagazin-fuer-Studioleiter.png' },
];
---

<FRBaseLayout
  title="Appareils de Fitness Digital – Pixformance"
  description="Pixformance : Analyse du mouvement digital pour la physiothérapie, les cliniques, le fitness & le bien-être en entreprise. 750 000+ pratiquants/an. 700+ exercices. Correction en temps réel."
  hreflangDe="https://www.pixformance.com/"
  hreflangEn="https://www.pixformance.com/en/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Appareils de Fitness Digital – Pixformance",
      "description": "Analyse du mouvement digital pour la physiothérapie, les cliniques, le fitness & le bien-être en entreprise.",
      "url": "https://www.pixformance.com/fr/",
      "isPartOf": {"@type": "WebSite", "url": "https://www.pixformance.com/fr/"}
    }
  ]}
>
  <FRHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </FRHeader>

  <!-- Hero Section -->
  <section class="bg-white overflow-hidden">

    <!-- Hero Image -->
    <div class="relative w-full hero-animate" style="animation-delay: 0.1s;">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/hero-mobile.webp">
        <img
          src="/images/header-2.webp"
          alt="Appareils de fitness digital Pixformance"
          class="w-full object-cover h-auto md:h-170"
          loading="eager"
        />
      </picture>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>

      <!-- Popup CTA overlay -->
      <a
        href="/fr/contact/"
        class="absolute bottom-8 right-8 z-10 hover:scale-105 transition-transform duration-300"
        aria-label="Demander un essai"
      >
        <img
          src="/images/en/image-25.png"
          alt="Demander un essai"
          class="h-24 md:h-32 w-auto"
          loading="eager"
        />
      </a>
    </div>

    <!-- Hero Text -->
    <div class="container pt-6 pb-12 md:pb-16 -mt-16">
      <!-- Partner Logos Carousel -->
      <div class="hero-animate" style="animation-delay: 1.1s;">
        <div class="clients-track-wrapper overflow-hidden">
          <div class="clients-track flex items-center">
            {[...Array(2)].map(() =>
              partnerLogos.map((logo) => (
                <img
                  src={logo.src}
                  alt={logo.name}
                  class="h-16 md:h-20 w-auto max-w-[160px] object-contain opacity-80 hover:opacity-100 transition-all duration-300 shrink-0 mr-10"
                  loading="eager"
                />
              ))
            )}
          </div>
        </div>
      </div>

      <div class="max-w-5xl mx-auto text-center space-y-5 cursor-default mt-8">
        <h1 class="font-display text-xl md:text-xl lg:text-xl font-normal leading-tight hero-animate" style="animation-delay: 0.3s;">
          Appareils de fitness digital
          <span class="text-[#02308C] font-bold"> par Pixformance</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.4s;">
          Plus de chiffre d'affaires. Plus de sérénité.
        </p>

        <p class="text-sm md:text-base text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.5s;">
          Notre mission est de permettre aux professionnels de la santé et du fitness de libérer leur potentiel économique et professionnel grâce à la meilleure technologie d'analyse du mouvement digital.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.6s;">
          <Button
            size="lg"
            href="/fr/essai-gratuit/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Demander un essai
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/fr/concept/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            En savoir plus
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-4 sm:p-6 rounded-2xl hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate" style={`animation-delay: ${0.7 + index * 0.1}s;`}>
              <div class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300">
                {stat.value}
              </div>
              <div class="text-xs sm:text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>

        <p class="text-sm md:text-base text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 1s;">
          C'est là qu'intervient notre solution sportive et thérapeutique digitale et entièrement connectée. Un entraîneur personnel virtuel ou un thérapeute virtuel, ainsi qu'une correction en temps réel à l'écran, rendent l'entraînement à la station Pixformance particulièrement sûr et efficace. L'entraînement avec notre appareil de fitness digital offre de nombreux avantages, tant pour vous, votre entreprise et vos employés que pour l'utilisateur.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 md:gap-20 lg:gap-12 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <div class="inline-block text-center md:text-left w-full">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
              <Icon name="target" size="sm" />
              Notre mission
            </span>
          </div>

          <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight text-center md:text-left">
            Donner du pouvoir aux professionnels de la santé & du fitness
          </h2>

          <p class="text-lg text-foreground-muted leading-relaxed text-center md:text-left">
            Notre mission est de permettre aux professionnels de la santé et du fitness de libérer leur potentiel économique et professionnel grâce à la meilleure technologie d'analyse du mouvement digital.
          </p>

          <div class="grid md:grid-cols-2 gap-6 pt-4">
            <div class="space-y-3 flex flex-col items-center text-center md:items-start md:text-left">
              <div class="w-12 h-12 rounded-xl bg-[#02308C] flex items-center justify-center">
                <Icon name="check" size="md" class="text-white" />
              </div>
              <h3 class="font-bold text-lg">Entraîneur personnel virtuel</h3>
              <p class="text-sm text-foreground-muted">
                Un accompagnement professionnel pour chaque pratiquant.
              </p>
            </div>

            <div class="space-y-3 flex flex-col items-center text-center md:items-start md:text-left">
              <div class="w-12 h-12 rounded-xl bg-[#6BDBD1] flex items-center justify-center">
                <Icon name="zap" size="md" class="text-white" />
              </div>
              <h3 class="font-bold text-lg">Correction en temps réel</h3>
              <p class="text-sm text-foreground-muted">
                Un entraînement sûr et efficace garanti.
              </p>
            </div>
          </div>
        </div>

        <div class="relative" data-scroll="slide-right">
          <img
            src="/images/Digital-Training-Device-eHealth-Telemedicine-Feedback-Pixformance-Station-2020-EN-mobil-web.png"
            alt="Station Pixformance"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-[#6BDBD1]">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white uppercase leading-tight">
          Appareils de fitness digital avec<br/>correction en temps réel
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center" data-scroll="slide-left">
          <picture>
            <source media="(max-width: 768px)" srcset="/images/en/Live-Feedback-mobil-EN-2022.png" />
            <img
              src="/images/en/Live-Feedback-EN-2022.png"
              alt="Retour en temps réel Pixformance"
              class="w-full max-w-lg h-auto object-contain"
              loading="lazy"
            />
          </picture>
        </div>

        <ul class="space-y-8" data-scroll="slide-right">
          {features.map((feature, index) => (
            <li class="flex items-start gap-5 group" data-delay={index + 1}>
              <div class="shrink-0 w-12 h-12 rounded-xl bg-white/20 border border-white/30 flex items-center justify-center group-hover:bg-white/30 transition-colors duration-300">
                <Icon name={feature.icon} size="md" class="text-white" />
              </div>
              <div>
                <p class="text-white font-medium text-lg leading-snug">
                  {feature.title}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="message-circle" size="sm" />
          Témoignages clients
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Des clients satisfaits
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((testimonial, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="bg-white hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 group relative overflow-hidden"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="absolute inset-0 bg-gradient-to-br from-[#02308C]/0 to-[#6BDBD1]/0 group-hover:from-[#02308C]/5 group-hover:to-[#6BDBD1]/5 transition-all duration-500"></div>

            <div class="relative space-y-4">
              <div class="flex items-center gap-3">
                <div class="relative">
                  <div class="absolute inset-0 bg-[#02308C] rounded-full blur-lg opacity-0 group-hover:opacity-60 transition-opacity duration-500"></div>
                  <img
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="relative w-16 h-16 rounded-full object-cover ring-2 ring-white shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-500"
                    loading="lazy"
                  />
                </div>
                <div>
                  <div class="font-bold group-hover:text-[#02308C] transition-colors duration-300">{testimonial.name}</div>
                  <div class="text-sm text-foreground-muted">{testimonial.role}</div>
                  <div class="text-sm text-[#02308C] font-semibold">{testimonial.company}</div>
                </div>
              </div>

              <div class="relative">
                <Icon name="quote" size="lg" class="text-[#6BDBD1]/20 absolute -top-1 -left-1" />
                <p class="text-sm text-foreground-muted italic leading-relaxed pl-6 relative">
                  "{testimonial.quote}"
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Press Logos -->
  <section class="py-10 bg-gray-50">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-8">
        {pressLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-20 md:h-28 w-auto object-contain opacity-70 hover:opacity-100 transition-opacity duration-300 grayscale hover:grayscale-0"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="grid" size="sm" />
          Nos solutions
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
          SOLUTIONS INDIVIDUELLES
        </h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          En tant que pionnier des transformations digitales dans le secteur du fitness et de la santé, nous vous proposons des solutions individuelles avec nos appareils de fitness digital pour rendre votre activité plus efficace et plus prospère.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {solutions.map((solution, index) => (
          <a
            href={solution.href}
            class="group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-4"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class="relative h-80">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent z-10"></div>
              <div class="absolute inset-0 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style={`background: linear-gradient(to top, ${solution.color}dd, transparent);`}></div>
              <img
                src={solution.image}
                alt={solution.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                style={`object-position: ${solution.objectPosition}`}
                loading="lazy"
              />
              <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                <h3 class="font-bold text-lg text-white mb-2 group-hover:translate-x-2 transition-transform duration-300">
                  {solution.title}
                </h3>
                <div class="flex items-center gap-2 text-white text-sm font-semibold opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-300">
                  <span>En savoir plus</span>
                  <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform" />
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-6xl font-bold text-white leading-tight">
          Prêt pour la transformation digitale ?
        </h2>

        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Contactez-nous pour une consultation sans engagement et découvrez comment Pixformance peut révolutionner votre activité.
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button
            size="lg"
            href="/fr/essai-gratuit/"
            class="bg-black text-white hover:bg-black/80"
          >
            Demander un essai
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/fr/concept/"
            class="border-2 border-black text-black hover:bg-black hover:text-white"
          >
            En savoir plus sur nos solutions
          </Button>
        </div>
      </div>
    </div>
  </section>

  <FRFooter slot="footer" />
</FRBaseLayout>

<style>
  .clients-track {
    animation: scroll-logos 25s linear infinite;
    width: max-content;
  }
  .clients-track-wrapper:hover .clients-track {
    animation-play-state: paused;
  }
  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
