---
import FRBaseLayout from '@/layouts/FRBaseLayout.astro';
import FRHeader from '@/components/layout/FRHeader.astro';
import FRFooter from '@/components/layout/FRFooter.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'PHYSIOTHÉRAPIE', href: '/fr/physiotherapie/' },
  { label: 'CLINIQUE', href: '/fr/clinique/' },
  { label: 'FITNESS', href: '/fr/fitness/' },
  { label: 'BGM', href: '/fr/fitness-entreprise/' },
];

const benefits = [
  {
    icon: 'monitor',
    title: '700+ exercices – un seul appareil',
    description: 'Sur la plateforme en ligne, des plans d\'entraînement individuels peuvent être élaborés à partir d\'une collection de plus de 700 exercices fonctionnels.',
  },
  {
    icon: 'users',
    title: 'Suivi simultané',
    description: 'Grâce au logiciel breveté, plusieurs patients peuvent être suivis simultanément sans charge de personnel supplémentaire.',
  },
  {
    icon: 'trending-up',
    title: 'Les patients deviennent des clients',
    description: 'Des séances d\'entraînement individuelles ainsi que des mesures de prévention secondaire peuvent être proposées comme source de revenus supplémentaire.',
  },
  {
    icon: 'table',
    title: 'Gestion efficace',
    description: 'Sur la plateforme en ligne, la progression d\'entraînement de chaque patient est documentée avec précision pour l\'analyse et l\'optimisation.',
  },
  {
    icon: 'heart',
    title: 'Entraînement individuel',
    description: 'Les programmes d\'entraînement peuvent être adaptés à l\'état de santé et aux besoins thérapeutiques de chaque patient.',
  },
  {
    icon: 'zap',
    title: 'Du temps pour l\'essentiel',
    description: 'Le thérapeute n\'a pas besoin de montrer chaque exercice personnellement et gagne du temps – ce qui profite à la prise en charge de tous les patients.',
  },
];

const features = [
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1-NEW.gif',
    title: 'Guide d\'exercices simple',
    description: 'Le pratiquant se place devant la station Pixformance et l\'exercice à réaliser est démontré par un entraîneur virtuel à l\'écran.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-2.gif',
    title: 'Analyse précise du mouvement',
    description: 'Une caméra avec capteur de profondeur scanne en quelques secondes 25 points articulaires et 9 points statiques du pratiquant et analyse les mouvements.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Hinweis-2.gif',
    title: 'Retour en temps réel',
    description: 'La station Pixformance fournit un retour en temps réel. Cela garantit que les exercices sont exécutés correctement et en toute sécurité.',
  },
];

const testimonials = [
  {
    name: 'Heike Schaible',
    role: 'Propriétaire',
    company: 'Physiotherapie Praxis "Raum für Gesundheit"',
    image: '/images/heikeschaible.600x400.jpg',
    quote: 'Je souhaite créer une deuxième zone de paiement direct avec Pixformance et ainsi avant tout accommoder mes employés et leur offrir un travail plus accessible et plus varié.',
  },
  {
    name: 'Axel-André Richter',
    role: 'Propriétaire',
    company: 'Gesundheitspraxis Richter & Lopez',
    image: '/images/Axel-Andre-Richter-und-Lopez-Pixformance.png',
    quote: 'Je peux concevoir le nouvel entraînement de manière totalement individuelle pour chacun de nos patients. Du sportif de haut niveau à la mamie, chacun y trouve son compte.',
  },
  {
    name: 'Volker Sutor',
    role: 'Propriétaire',
    company: 'Physiotherapiezentren »Reha Rondell«',
    image: '/images/Pixformance-Volker-Sutor-Testimonial.png',
    quote: 'Un entraînement santé ciblé avec l\'entraîneur virtuel augmente l\'efficacité du traitement et libère plus de temps pour la prise en charge réelle de mes patients.',
  },
];

const clinicalTestimonials = [
  {
    quote: 'Les patients sont enthousiastes et très motivés, ce qui, avouons-le, n\'est pas toujours le cas. Nous, en tant que thérapeutes, en bénéficions également, car les patients réalisent leurs exercices de manière plus correcte et plus ciblée. De plus, nous gagnons du temps, car après seulement 30 minutes d\'initiation, les patients peuvent s\'entraîner de façon autonome sous surveillance.',
    name: 'Gabriele Buchstein',
    role: 'Responsable Physiothérapie',
    company: 'Sauerlandklinik Hachen – Clinique Neurologique Spécialisée pour la SEP',
  },
  {
    quote: 'À la recherche d\'un moyen de rendre les patients actifs de façon autonome, nous avons choisi Pixformance. L\'offre d\'entraînement individuel est idéale ici, car la thérapie de groupe est souvent trop facile pour certains et trop difficile pour d\'autres patients. Ainsi, chacun bénéficie d\'un entraînement entièrement personnalisé.',
    name: 'Christoph Schneider',
    role: 'Directeur Thérapeutique',
    company: 'Niederrhein-Klinik, Clinique de Réadaptation Korschenbroich',
  },
  {
    quote: 'Du côté des patients, il y a un grand intérêt et une grande curiosité pour les stations Pixformance. Beaucoup nous approchent spontanément et souhaitent un programme d\'entraînement. Nous avons récemment suivi à distance une jeune femme après une opération de l\'épaule. Elle vient à la clinique une fois par semaine — le reste de la thérapie se fait à domicile. C\'est vraiment une excellente option.',
    name: 'Christoph Oratsch',
    role: 'Responsable Thérapie',
    company: 'Hôpital Accidentologique AUVA, Klagenfurt, Autriche',
  },
  {
    quote: 'Nous sommes heureux d\'observer que nos patients apprécient beaucoup l\'entraînement physique et persévèrent. La composante ludique de notre équipement de thérapie numérique Pixformance joue certainement un rôle — et quand nos patients oublient un instant la maladie et s\'amusent simplement, c\'est extrêmement précieux.',
    name: 'Gunter Hölig',
    role: 'Directeur Thérapeutique',
    company: 'Medical Park Bad Rodach',
  },
];

const clientLogos = [
  { name: 'Charité Berlin', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
];

const faqItems = [
  {
    question: 'Qu\'est-ce que la station Pixformance et comment fonctionne-t-elle en physiothérapie ?',
    answer: 'La caméra 2D Full HD avec capteur de profondeur intégré analyse en temps réel 25 points articulaires. Un thérapeute virtuel démontre la séquence d\'exercice correcte à l\'écran pendant que le patient réalise l\'exercice. Le système détecte instantanément les déviations de mouvement et fournit un feedback visuel (flèches, cercles) ainsi qu\'un feedback textuel directement à l\'écran. Après chaque exercice, le score Pixformance quantifie objectivement la qualité du mouvement. Toutes les données sont stockées sur la plateforme en ligne.',
  },
  {
    question: 'Pour quelles indications Pixformance est-il adapté ?',
    answer: 'Sclérose en plaques, syndrome de Parkinson, rééducation postopératoire (hanche, genou, épaule, colonne vertébrale), rééducation neurologique, suivi oncologique, entraînement gériatrique à l\'équilibre et à la prévention des chutes, ainsi que la thérapie fonctionnelle générale du mouvement. Les exercices peuvent être adaptés aux patients en fauteuil roulant, avec déambulateur, sur table de traitement ou au sol.',
  },
  {
    question: 'Combien de patients peuvent s\'entraîner simultanément avec Pixformance ?',
    answer: 'Grâce au logiciel breveté, plusieurs patients peuvent s\'entraîner simultanément sur plusieurs stations sans personnel supplémentaire. Chaque patient scanne son code QR personnel et démarre automatiquement son programme de thérapie individuel.',
  },
  {
    question: 'Pixformance remplace-t-il les physiothérapeutes ?',
    answer: 'Non. Pixformance soutient et soulage les thérapeutes — il ne les remplace pas. Le système prend en charge automatiquement la démonstration des exercices, la correction en temps réel et la documentation. Après seulement 30 minutes d\'initiation, les patients peuvent s\'entraîner de façon autonome sous surveillance.',
  },
  {
    question: 'Pixformance peut-il être utilisé pour la téléréadaptation et l\'entraînement à domicile ?',
    answer: 'Oui. L\'application web Pixformance permet aux patients d\'accéder à leurs programmes depuis leur domicile. L\'Hôpital Accidentologique AUVA de Klagenfurt utilise ce modèle hybride : les patients viennent une fois par semaine à la clinique et réalisent le reste de leur thérapie à domicile.',
  },
  {
    question: 'Quelles études cliniques existent sur Pixformance ?',
    answer: 'L\'Hochschule Fresenius a réalisé plusieurs études : effet sur la capacité de marche chez les patients atteints de SEP, équilibre et qualité de vie dans la maladie de Parkinson, dystrophie musculaire (Emery-Dreifuss) et suivi du cancer du sein. Pixformance est partenaire de recherche européen dans le projet FORTEe pour la thérapie par l\'exercice chez les enfants atteints de cancer. Le système est en usage clinique à la Charité de Berlin, au Medical Park, à l\'AUVA et à l\'Université Oxford Brookes.',
  },
  {
    question: 'Pixformance est-il un dispositif médical certifié ?',
    answer: 'Oui. Pixformance est un dispositif médical certifié CE (conforme MDR UE 2017/745). L\'appareil est conforme à la directive CEM 2004/108/CE et est fabriqué depuis 2012 selon des contrôles stricts de qualité et de sécurité.',
  },
  {
    question: 'Comment Pixformance aide-t-il à créer une zone de paiement direct ?',
    answer: 'Pixformance permet aux cabinets de proposer un entraînement assisté par technologie en dehors du modèle de prescription, créant ainsi une seconde source de revenus. Plusieurs propriétaires de cabinets rapportent un retour sur investissement rapide. Financement disponible à partir de 99 €/mois.',
  },
];
---

<FRBaseLayout
  title="Système numérique de thérapie du mouvement pour cabinets de physiothérapie et cliniques | Pixformance"
  description="Pixformance est le système de rééducation numérique pour les physiothérapeutes : analyse en temps réel de 25 points articulaires, 700+ exercices, 6 000+ installations dans le monde. Dispositif médical dispositif médical CE (MDR UE 2017/745)."
  hreflangDe="https://www.pixformance.com/physiotherapie/"
  hreflangEn="https://www.pixformance.com/en/physical-therapy/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Pixformance Thérapie par le mouvement digital – Physiothérapie",
      "description": "Thérapie par le mouvement digital pour cabinets de physiothérapie. Retour automatisé, suivi de plusieurs patients simultanément, développement d'une zone de paiement direct économique.",
      "provider": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com"},
      "serviceType": "Physiotherapy Technology",
      "areaServed": ["DE", "AT", "CH", "FR"],
      "url": "https://www.pixformance.com/fr/physiotherapie/"
    },
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Station Pixformance",
      "description": "Système de rééducation numérique entièrement connecté composé de la station Pixformance, d'une plateforme en ligne et d'une application web. La station utilise une caméra 2D Full HD avec capteur de profondeur intégré pour l'analyse en temps réel de 25 points articulaires, fournissant un feedback correctif instantané.",
      "manufacturer": { "@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com" },
      "legalStatus": "Dispositif médical dispositif médical CE (MDR UE 2017/745)",
      "relevantSpecialty": ["Physiothérapie", "Réadaptation", "Neurologie", "Orthopédie", "Médecine du sport"]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Qu'est-ce que la station Pixformance et comment fonctionne-t-elle en physiothérapie ?",
          "acceptedAnswer": { "@type": "Answer", "text": "La caméra 2D Full HD avec capteur de profondeur intégré analyse en temps réel 25 points articulaires. Un thérapeute virtuel démontre la séquence d'exercice correcte à l'écran pendant que le patient réalise l'exercice. Le système détecte instantanément les déviations de mouvement et fournit un feedback visuel (flèches, cercles) ainsi qu'un feedback textuel directement à l'écran. Après chaque exercice, le score Pixformance quantifie objectivement la qualité du mouvement." }
        },
        {
          "@type": "Question",
          "name": "Pour quelles indications Pixformance est-il adapté ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sclérose en plaques, syndrome de Parkinson, rééducation postopératoire (hanche, genou, épaule, colonne vertébrale), rééducation neurologique, suivi oncologique, entraînement gériatrique à l'équilibre et à la prévention des chutes. Les exercices peuvent être adaptés aux patients en fauteuil roulant, avec déambulateur, sur table de traitement ou au sol." }
        },
        {
          "@type": "Question",
          "name": "Pixformance remplace-t-il les physiothérapeutes ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Non. Pixformance soutient et soulage les thérapeutes — il ne les remplace pas. Le système prend en charge automatiquement la démonstration des exercices, la correction en temps réel et la documentation. Après seulement 30 minutes d'initiation, les patients peuvent s'entraîner de façon autonome sous surveillance." }
        },
        {
          "@type": "Question",
          "name": "Pixformance est-il un dispositif médical certifié ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Oui. Pixformance est un dispositif médical certifié CE (conforme MDR UE 2017/745). L'appareil est conforme à la directive CEM 2004/108/CE et est fabriqué depuis 2012 selon des normes strictes de qualité et de sécurité." }
        }
      ]
    }
  ]}
>
  <FRHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </FRHeader>

  <BreadcrumbTabs tabs={tabs} activeTab="/fr/physiotherapie/" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 hover:border-[#02308C]/30 transition-all duration-300 cursor-pointer">
            <Icon name="heart" size="sm" />
            Physiothérapie
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Le système thérapeutique numérique qui<br class="hidden md:block" />
          soulage vos thérapeutes —
          <span class="text-[#02308C]"> sans les remplacer</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          La physiothérapie de demain : soins numériques, mieux connectés
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Aucune technologie au monde ne peut remplacer les thérapeutes. La digitalisation en physiothérapie et en rééducation est cependant un moyen efficace de soulager les thérapeutes et d'accompagner les patients encore plus intensément.
        </p>

        <p class="text-base md:text-lg text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.45s;">
          Pixformance est un système de thérapie du mouvement entièrement connecté, utilisé dans plus de 6 000 cabinets de physiothérapie, cliniques de rééducation et hôpitaux dans le monde entier. La station analyse en temps réel 25 points articulaires grâce à une caméra 2D Full HD avec capteur de profondeur intégré, fournissant un feedback correctif instantané. En tant que dispositif médical CE (MDR UE 2017/745), Pixformance est déployé à la Charité de Berlin, au Medical Park, à l'AUVA Klagenfurt et à l'Université Oxford Brookes — et est utilisé cliniquement en continu depuis 2012.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button size="lg" href="/fr/essai-gratuit/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Demander conseil
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button size="lg" variant="outline" href="/fr/concept/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            En savoir plus
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-8 md:py-12 bg-gray-50 border-y border-gray-100">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-8" data-scroll="fade-up">
        Utilisé dans les meilleures cliniques et hôpitaux
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12" data-scroll="fade-up">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt={logo.name} class="h-8 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="target" size="sm" />
            Notre mission
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold leading-tight">
            Responsabiliser les thérapeutes, enthousiasmer les patients
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Notre mission est de créer – avec la meilleure technologie d'analyse du mouvement digital – une solution individuelle pour les thérapeutes et leurs patients particuliers. La thérapie par le mouvement digital de Pixformance soulage les thérapeutes dans la démonstration des exercices et accompagne ainsi les patients très efficacement sur le chemin de la guérison.
          </p>
        </div>
        <div class="relative" data-scroll="slide-right">
          <img src="/images/Pixformance-Physiotherapie-Digitalisierung-Digitales-Trainingsgeraet-Spass-Beim-Training.png" alt="Pixformance Physiothérapie Training" class="rounded-2xl shadow-xl w-full h-auto" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Echtzeit-Korrektur Highlight -->
  <section class="py-20 bg-[#02308C] relative overflow-hidden">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-6" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-sm font-bold text-[#6BDBD1]">
          <Icon name="zap" size="sm" />
          Technologie live
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold text-white leading-tight">
          Correction en temps réel
        </h2>
        <p class="text-xl text-white/70 max-w-2xl mx-auto">
          Retour précis pendant l'exécution des exercices.
        </p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-14" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="sparkles" size="sm" />
          Correction en temps réel
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Comment fonctionne l'entraînement ?
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          La station Pixformance permet un guidage continu en termes de précision, de rythme et d'exactitude de l'exécution des exercices.
        </p>
      </div>
      <div class="space-y-16 md:space-y-24">
        {features.map((feature, index) => (
          <div class={`grid md:grid-cols-2 gap-8 md:gap-12 items-center ${index % 2 !== 0 ? 'md-reverse' : ''}`} data-scroll="fade-up" data-delay={index + 1}>
            <div class={`space-y-4 ${index % 2 !== 0 ? 'md:order-2' : ''}`} data-scroll={index % 2 === 0 ? 'slide-left' : 'slide-right'}>
              <span class="text-6xl md:text-7xl font-bold text-[#6BDBD1] leading-none select-none">{String(index + 1).padStart(2, '0')}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-gray-900">{feature.title}</h3>
              <p class="text-lg text-foreground-muted leading-relaxed">{feature.description}</p>
            </div>
            <div class={`${index % 2 !== 0 ? 'md:order-1' : ''}`} data-scroll={index % 2 === 0 ? 'slide-right' : 'slide-left'}>
              <div class="rounded-2xl overflow-hidden">
                <img src={feature.image} alt={feature.title} class="w-full h-auto object-contain block" loading="lazy" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Indications Section -->
  <section class="py-12 md:py-20 bg-[#02308C]/5 border-y border-[#02308C]/10">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-10">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="activity" size="sm" />
            Application clinique
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-4">
            Indications et domaines d'application clinique
          </h2>
          <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
            Pixformance est adapté à un large spectre d'indications physiothérapeutiques et de rééducation. Les exercices peuvent être adaptés aux patients en fauteuil roulant, avec déambulateur, sur table de traitement ou au sol.
          </p>
        </div>
        <ul class="grid md:grid-cols-2 gap-5 text-base text-gray-800 leading-relaxed">
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center">
              <Icon name="brain" size="sm" class="text-white" />
            </span>
            <div>
              <strong class="block text-gray-900 mb-1">Rééducation neurologique</strong>
              Sclérose en plaques, syndrome de Parkinson, suivi AVC, troubles de l'équilibre et de la coordination
            </div>
          </li>
