---
import FRBaseLayout from '@/layouts/FRBaseLayout.astro';
import FRHeader from '@/components/layout/FRHeader.astro';
import FRFooter from '@/components/layout/FRFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const stats = [
  { value: '6.000+', label: 'Installations mondiales', icon: 'map-pin' },
  { value: '2,5M+', label: 'Pratiquants', icon: 'users' },
  { value: '2012', label: 'Fondée', icon: 'calendar' },
];

const team = [
  { name: 'Valerie Bures-Bönström', role: 'PDG', image: '/images/Valerie_Bönström_CEO_Pixformance.jpg' },
  { name: 'Tobias Baader', role: 'COO', image: '/images/Tobias-Baader-Head-Of-Business-Development-Pixformance.jpg' },
  { name: 'Davi Wazlawick', role: 'Directeur de la croissance', image: '/images/Davi-Wazlawick-Pixformance-3.jpg', imagePosition: 'center 88%' },
  { name: 'Patricia Olear', role: 'Senior Marketing Manager', image: '/images/Patricia-Olear-Marketing-Manager-Pixformance.jpg.webp' },
  { name: 'Laura Alves', role: 'Senior Manager Service & Support', image: '/images/Laura-Alves-Pixformance.jpg' },
  { name: 'Sara Zender', role: 'Responsable financière', image: '/images/Sara-Zender-Finance-Manager-Pixformance.jpg' },
  { name: 'Bita Mohammadi', role: 'Développeuse C++', image: '/images/Bita-Mohammadi-Software-Developer-Pixformance.jpg' },
  { name: 'Kateryna Misarenko', role: 'Junior Marketing Manager', image: '/images/Kateryna-Misarenko-Junior-Marketing-Manager-Pixformance.jpg.webp' },
];
---

<FRBaseLayout
  title="Pixformance Sports GmbH — Pionnière de la thérapie du mouvement digital depuis 2012 | À propos"
  description="Pixformance Sports GmbH : fondée en 2012 par la PDG Valerie Bures-Bönström. Dispositif médical dispositif médical CE (MDR UE 2017/745). Partenaire de recherche UE FORTEe. Validée cliniquement : Charité Berlin, Oxford Brookes University. 6 000+ installations, 2,5M+ pratiquants/an."
  hreflangDe="https://www.pixformance.com/ueber-uns/"
  hreflangEn="https://www.pixformance.com/en/about-us/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Pixformance Sports GmbH",
      "url": "https://www.pixformance.com",
      "foundingDate": "2012",
      "description": "Pixformance Sports GmbH is the pioneer in digital motion analysis and real-time feedback for physiotherapy, rehabilitation and fitness. Founded in 2012 by CEO Valerie Bures-Bönström. Developer of the CE-certified Pixformance Station (MDR EU 2017/745). EU research partner in the FORTEe project. Clinically validated at Charité Berlin and Oxford Brookes University.",
      "founder": {
        "@type": "Person",
        "name": "Valerie Bures-Bönström",
        "jobTitle": "CEO"
      },
      "numberOfEmployees": {"@type": "QuantitativeValue", "value": 20},
      "areaServed": ["DE","AT","CH","NL","FR","IT","US"],
      "award": [
        "CE-certified Medical Device (MDR EU 2017/745)",
        "EU Research Partner FORTEe Project",
        "Clinical Validation Charité Berlin",
        "Clinical Validation Oxford Brookes University"
      ],
      "knowsAbout": [
        "Digital Motion Analysis",
        "Physical Therapy",
        "Rehabilitation",
        "Functional Training",
        "Telerehabilitation",
        "Real-time Feedback"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Valerie Bures-Bönström",
      "jobTitle": "CEO",
      "worksFor": {
        "@type": "Organization",
        "name": "Pixformance Sports GmbH"
      },
      "description": "CEO and co-founder of Pixformance Sports GmbH. Has led the company since its founding in 2012 and developed Pixformance into the market leader in digital movement therapy in the DACH region."
    }
  ]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/over-ons/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/chi-siamo/" />
  </Fragment>
  <FRHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </FRHeader>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#6BDBD1]/10 to-[#86C9BC]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="users" size="sm" />
            À propos
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance Sports GmbH : pionnière de la thérapie du mouvement digital depuis 2012
        </h1>

        <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Une force d'innovation implacable — et cela depuis 2012 déjà
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-6 rounded-2xl bg-white hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate shadow-lg" style={`animation-delay: ${0.4 + index * 0.1}s;`}>
              <div class="w-12 h-12 mx-auto rounded-xl bg-[#02308C] flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
                <Icon name={stat.icon} size="md" class="text-white" />
              </div>
              <div class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300">
                {stat.value}
              </div>
              <div class="text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Company Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="building" size="sm" />
            Notre entreprise
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-6">
            Pionniers de l'analyse du mouvement digital
          </h2>
        </div>

        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <p>
            Pixformance Sports GmbH a été fondée en 2012 et est la pionnière de l'analyse du mouvement digital et du feedback en temps réel pour la kinésithérapie, les cliniques de rééducation et le fitness. Sous la direction de la PDG <span class="font-bold text-[#02308C]">Valerie Bures-Bönström</span>, la société a développé la Station Pixformance comme dispositif médical certifié dispositif médical CE (MDR UE 2017/745) — validé cliniquement à la Charité Berlin et à l'Université Oxford Brookes, et actif en tant que partenaire de recherche UE dans le projet FORTEe. Avec plus de 6 000 installations dans des cabinets de kinésithérapie, des cliniques de rééducation et des studios de fitness dans le monde et 2,5 millions de pratiquants par an, Pixformance établit de nouveaux standards dans la thérapie du mouvement digital.
          </p>

          <p>
            Notre fondatrice et PDG est Valerie Bures-Bönström. Mère de trois enfants et informaticienne, elle figure depuis des années parmi les entrepreneures les plus prospères d'Allemagne. En 2021 encore, elle a été nommée parmi les 50 femmes les plus influentes de la scène tech allemande par le Handelsblatt. En 2012, elle a lancé la Station Pixformance, le premier appareil digital pour l'entraînement fonctionnel avec analyse du mouvement. <strong>Aujourd'hui, notre station d'entraînement digital est déjà utilisée avec succès dans plus de 6 000 centres de fitness, de rééducation et de santé, et compte plus de 2,5 millions de pratiquants dans le monde.</strong>
          </p>

          <p>
            Avec Stefanie Graf, Valerie est également co-fondatrice de la franchise Mrs.Sporty et fondatrice de la start-up derrière la marque VAHA, une solution de fitness interactif pour la maison, qui a déjà reçu un investissement à deux chiffres en millions. Ainsi, Pixformance combine une expertise long-terme du marché avec une agilité start-up vécue, distinguée par une volonté d'innovation tenace, une équipe prête à prendre des risques, des processus raccourcis et un service client véritablement personnel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinical Credentials Section -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-6 text-[#02308C]">
          Validation clinique &amp; certification réglementaire
        </h2>
        <p class="text-lg text-foreground-muted leading-relaxed">
          La Station Pixformance est homologuée comme dispositif médical dispositif médical CE (MDR UE 2017/745) aux États-Unis. Le système a été validé cliniquement par des études à la Charité Berlin (neurologie, orthopédie) et à l'Université Oxford Brookes (médecine du sport, rééducation). Pixformance est partenaire de recherche UE dans le projet FORTEe pour la réhabilitation digitale en Europe. Des études cliniques de l'Université Fresenius démontrent l'efficacité pour la sclérose en plaques, la maladie de Parkinson, la dystrophie musculaire et le suivi post-cancer du sein.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Notre équipe
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          NOTRE ÉQUIPE
        </h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto mt-4">
          Notre succès repose sur des années d'expérience ainsi que sur notre capacité d'innovation. Nous nous appuyons sur notre conseil de direction courageux, passionné et visionnaire, composé de développeurs, designers, consultants, marketeurs et experts en services financiers.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {team.map((member, index) => (
          <Card
            variant="elevated"
            padding="none"
            class="overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 hover:scale-105 group bg-white"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="relative h-80 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 group-hover:from-[#6BDBD1]/80 transition-all duration-500"></div>
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                style={member.imagePosition ? `object-position: ${member.imagePosition}` : undefined}
                loading="lazy"
              />
              <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                <h3 class="font-bold text-xl text-white mb-1 group-hover:translate-x-2 transition-transform duration-300">{member.name}</h3>
                <p class="text-white/90 text-sm font-semibold">{member.role}</p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold text-white leading-tight">
          Rejoignez notre histoire de succès
        </h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Contactez-nous pour une consultation sans engagement et découvrez comment Pixformance peut révolutionner votre activité.
        </p>
        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button size="lg" href="/fr/essai-gratuit/" class="bg-black text-white hover:bg-black/80">
            Demander un essai
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href="/fr/concept/" class="border-2 border-black text-black hover:bg-black hover:text-white">
            Notre concept
          </Button>
        </div>
      </div>
    </div>
  </section>

  <FRFooter slot="footer" />
</FRBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
