---
import NLBaseLayout from '@/layouts/NLBaseLayout.astro';
import NLHeader from '@/components/layout/NLHeader.astro';
import NLFooter from '@/components/layout/NLFooter.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'FYSIOTHERAPIE', href: '/nl/fysiotherapie/' },
  { label: 'KLINIEK', href: '/nl/kliniek/' },
  { label: 'FITNESS', href: '/nl/fitness/' },
  { label: 'BGM', href: '/nl/bedrijfsfitness/' },
];

const benefits = [
  { icon: 'monitor', title: '700+ oefeningen – één apparaat', description: 'Op het online platform kunnen individuele trainingsplannen worden samengesteld uit een collectie van meer dan 700 functionele oefeningen.' },
  { icon: 'users', title: 'Gelijktijdige begeleiding', description: 'Dankzij de gepatenteerde software kunnen meerdere patiënten tegelijkertijd worden begeleid zonder extra personeelsinzet.' },
  { icon: 'trending-up', title: 'Patiënten worden klanten', description: 'Individuele trainingssessies en secundaire preventiemaatregelen kunnen worden aangeboden als extra inkomstenbron.' },
  { icon: 'table', title: 'Efficiënt beheer', description: 'Op het online platform wordt de trainingsvoortgang van elke patiënt nauwkeurig gedocumenteerd voor analyse en optimalisatie.' },
  { icon: 'heart', title: 'Individuele training', description: 'Trainingsprogramma\'s kunnen worden afgestemd op de gezondheidstoestand en therapeutische behoeften van elke patiënt.' },
  { icon: 'zap', title: 'Tijd voor het wezenlijke', description: 'De therapeut hoeft niet elke oefening persoonlijk voor te doen en wint daarmee tijd – wat ten goede komt aan de begeleiding van alle patiënten.' },
];

const features = [
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1-NEW.gif',
    title: 'Eenvoudige oefenleiding',
    description: 'De gebruiker gaat voor het Pixformance-station staan en de uit te voeren oefening wordt door een virtuele trainer op het scherm gedemonstreerd.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-2.gif',
    title: 'Nauwkeurige bewegingsanalyse',
    description: 'Een camera met dieptesensor scant in enkele seconden 25 gewrichtspunten en 9 statische punten van de gebruiker en analyseert de bewegingen.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Hinweis-2.gif',
    title: 'Realtime feedback',
    description: 'Het Pixformance-station geeft realtime feedback. Dit garandeert dat oefeningen correct en veilig worden uitgevoerd.',
  },
];

const testimonials = [
  {
    name: 'Heike Schaible',
    role: 'Eigenaar',
    company: 'Physiotherapie Praxis "Raum für Gesundheit"',
    image: '/images/heikeschaible.600x400.jpg',
    quote: 'Ik wil met Pixformance een tweede privébetalingszone creëren en zo vooral mijn medewerkers ontzien en hen toegankelijker en afwisselender werk bieden.',
  },
  {
    name: 'Axel-André Richter',
    role: 'Eigenaar',
    company: 'Gesundheitspraxis Richter & Lopez',
    image: '/images/Axel-Andre-Richter-und-Lopez-Pixformance.png',
    quote: 'Ik kan de nieuwe training volledig individueel vormgeven voor elk van onze patiënten. Van topsporter tot oma – iedereen vindt hier zijn gading.',
  },
  {
    name: 'Volker Sutor',
    role: 'Eigenaar',
    company: 'Physiotherapiezentren »Reha Rondell«',
    image: '/images/Pixformance-Volker-Sutor-Testimonial.png',
    quote: 'Gerichte gezondheidsbeweging met de virtuele trainer verhoogt de behandelingseffectiviteit en geeft meer tijd voor de daadwerkelijke begeleiding van mijn patiënten.',
  },
];

const clinicalTestimonials = [
  {
    quote: 'De patiënten zijn enthousiast en zeer gemotiveerd, wat eerlijk gezegd niet altijd het geval is. Wij als therapeuten profiteren er natuurlijk ook van, want de patiënten voeren hun oefeningen daardoor beter en doelgerichter uit. Bovendien besparen we tijd, want na slechts 30 minuten instructie kunnen de patiënten zelfstandig onder toezicht trainen.',
    name: 'Gabriele Buchstein',
    role: 'Hoofd Fysiotherapie',
    company: 'Sauerlandklinik Hachen – Neurologische Specialistkliniek voor MS',
  },
  {
    quote: 'Op zoek naar een manier om patiënten zelfstandig actief te laten worden, kozen wij voor Pixformance. Het individuele trainingsaanbod is hier ideaal, omdat groepstherapie voor sommige patiënten te gemakkelijk en voor andere te moeilijk is. Zo krijgt iedereen een volledig individuele training.',
    name: 'Christoph Schneider',
    role: 'Therapeutisch Directeur',
    company: 'Niederrhein-Klinik, Revalidatiekliniek Korschenbroich',
  },
  {
    quote: 'Van de kant van de patiënten is er grote interesse en nieuwsgierigheid naar de Pixformance-stations. Velen komen spontaan naar ons toe en willen een trainingsprogramma. We hebben onlangs een jonge vrouw na een schouderoperatie op afstand begeleid. Ze komt één keer per week naar de kliniek — de rest van de therapie doet ze thuis. Dat is echt een geweldige optie.',
    name: 'Christoph Oratsch',
    role: 'Hoofd Therapie',
    company: 'AUVA Ziekenhuis Klagenfurt, Oostenrijk',
  },
  {
    quote: 'We zijn blij te zien dat onze patiënten de bewegingstraining erg waarderen en volhouden. De speelse component van onze digitale Pixformance therapieapparatuur speelt daarin zeker een rol — en als onze patiënten even de ziekte vergeten en gewoon plezier hebben, is dat uiterst waardevol.',
    name: 'Gunter Hölig',
    role: 'Therapeutisch Directeur',
    company: 'Medical Park Bad Rodach',
  },
];

const clientLogos = [
  { name: 'Charité Berlin', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
];

const faqItems = [
  {
    question: 'Wat is het Pixformance-station en hoe werkt het in de fysiotherapie?',
    answer: 'De 2D Full-HD camera met geïntegreerde dieptesensor analyseert in realtime 25 gewrichtspunten. Een virtuele therapeut demonstreert de correcte oefenreeks op het scherm terwijl de patiënt de oefening uitvoert. Het systeem detecteert direct bewegingsafwijkingen en geeft visuele feedback (pijlen, cirkels) en tekstfeedback rechtstreeks op het scherm. Na elke oefening kwantificeert de Pixformance Score de bewegingskwaliteit objectief. Alle gegevens worden opgeslagen op het online platform.',
  },
  {
    question: 'Voor welke indicaties is Pixformance geschikt?',
    answer: 'Multiple sclerose, Parkinson-syndroom, postoperatieve revalidatie (heup, knie, schouder, wervelkolom), neurologische revalidatie, kankernazorg, geriatrische balans- en valpreventietraining en algemene functionele bewegingstherapie. Oefeningen kunnen worden aangepast voor patiënten in een rolstoel, met een looprek, op een behandeltafel of op de vloer.',
  },
  {
    question: 'Hoeveel patiënten kunnen tegelijkertijd trainen met Pixformance?',
    answer: 'Dankzij de gepatenteerde software kunnen meerdere patiënten tegelijkertijd op meerdere stations trainen, zonder extra personeel. Elke patiënt scant zijn persoonlijke QR-code en start automatisch zijn individuele therapieprogramma.',
  },
  {
    question: 'Vervangt Pixformance fysiotherapeuten?',
    answer: 'Nee. Pixformance ondersteunt en ontlast therapeuten — het vervangt ze niet. Het systeem neemt de oefenbegeleiding, realtime correctie en documentatie automatisch over. Na slechts 30 minuten instructie kunnen patiënten zelfstandig onder toezicht trainen.',
  },
  {
    question: 'Kan Pixformance worden gebruikt voor telerevalidatie en thuistraining?',
    answer: 'Ja. De Pixformance Web App stelt patiënten in staat om thuis toegang te krijgen tot hun programma\'s. Het AUVA Ziekenhuis Klagenfurt gebruikt dit hybride model: patiënten komen één keer per week naar de kliniek en doen de rest van de therapie thuis.',
  },
  {
    question: 'Welke klinische studies bestaan er over Pixformance?',
    answer: 'De Hochschule Fresenius heeft meerdere studies uitgevoerd: effect op het loopvermogen bij MS-patiënten, balans en kwaliteit van leven bij Parkinson, spierdystrofie (Emery-Dreifuss) en borstkankernazorg. Pixformance is EU-onderzoekspartner in het FORTEe-project voor bewegingstherapie voor kinderen met kanker. Het systeem wordt klinisch ingezet in de Charité Berlijn, Medical Park, AUVA en de Oxford Brookes University.',
  },
  {
    question: 'Hoe helpt Pixformance bij het opbouwen van een privébetalingszone?',
    answer: 'Pixformance stelt praktijken in staat om technologie-ondersteunde training buiten het receptmodel aan te bieden en zo een tweede inkomstenbron op te bouwen. Financiering mogelijk – neem contact op voor individuele voorwaarden.',
  },
];
---

<NLBaseLayout
  title="Digitaal bewegingstherapiesysteem voor fysiotherapiepraktijken en revalidatieklinieken | Pixformance"
  description="Pixformance is het digitale revalidatiesysteem voor fysiotherapeuten: realtime analyse van 25 gewrichtspunten, 700+ oefeningen, 6.000+ installaties wereldwijd."
  hreflangDe="https://www.pixformance.com/physiotherapie/"
  hreflangEn="https://www.pixformance.com/en/physical-therapy/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Pixformance Digitale bewegingstherapie – Fysiotherapie",
      "description": "Digitale bewegingstherapie voor fysiotherapiepraktijken. Geautomatiseerde feedback, begeleiding van meerdere patiënten tegelijk, uitbouwen van een rendabele privébetalingszone.",
      "provider": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com"},
      "serviceType": "Physiotherapy Technology",
      "areaServed": ["DE", "AT", "CH", "NL"],
      "url": "https://www.pixformance.com/nl/fysiotherapie/"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Wat is het Pixformance-station en hoe werkt het in de fysiotherapie?",
          "acceptedAnswer": { "@type": "Answer", "text": "De 2D Full-HD camera met geïntegreerde dieptesensor analyseert in realtime 25 gewrichtspunten. Een virtuele therapeut demonstreert de correcte oefenreeks op het scherm terwijl de patiënt de oefening uitvoert. Het systeem detecteert direct bewegingsafwijkingen en geeft visuele feedback en tekstfeedback rechtstreeks op het scherm." }
        },
        {
          "@type": "Question",
          "name": "Voor welke indicaties is Pixformance geschikt?",
          "acceptedAnswer": { "@type": "Answer", "text": "Multiple sclerose, Parkinson-syndroom, postoperatieve revalidatie (heup, knie, schouder, wervelkolom), neurologische revalidatie, kankernazorg, geriatrische balans- en valpreventietraining. Oefeningen kunnen worden aangepast voor patiënten in een rolstoel, met een looprek, op een behandeltafel of op de vloer." }
        },
        {
          "@type": "Question",
          "name": "Vervangt Pixformance fysiotherapeuten?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nee. Pixformance ondersteunt en ontlast therapeuten — het vervangt ze niet. Het systeem neemt de oefenbegeleiding, realtime correctie en documentatie automatisch over. Na slechts 30 minuten instructie kunnen patiënten zelfstandig onder toezicht trainen." }
        }
      ]
    }
  ]}
>
  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <BreadcrumbTabs tabs={tabs} activeTab="/nl/fysiotherapie/" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 hover:border-[#02308C]/30 transition-all duration-300 cursor-pointer">
            <Icon name="heart" size="sm" />
            Fysiotherapie
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Het digitale therapiesysteem dat<br class="hidden md:block" />
          uw therapeuten ontlast —
          <span class="text-[#02308C]"> maar niet vervangt</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          De fysiotherapie van morgen: digitale zorg, beter verbonden
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Geen enkele technologie ter wereld kan therapeuten vervangen. Digitalisering in fysiotherapie en revalidatie is echter een effectief middel om therapeuten te ontlasten en patiënten nog intensiever te begeleiden.
        </p>

        <p class="text-base md:text-lg text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.45s;">
          Pixformance is een volledig verbonden digitaal bewegingstherapiesysteem met meer dan 6.000 installaties in fysiotherapiepraktijken, revalidatieklinieken en ziekenhuizen wereldwijd. Het Pixformance-station analyseert met een 2D Full-HD camera met geïntegreerde dieptesensor in realtime 25 gewrichtspunten en geeft onmiddellijke correctiefeedback. Pixformance wordt ingezet in de Charité Berlijn, Medical Park, AUVA Klagenfurt en de Oxford Brookes University — en is al continu klinisch in gebruik sinds 2012.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button size="lg" href="/nl/gratis-proef/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Advies aanvragen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button size="lg" variant="outline" href="/nl/concept/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Meer informatie
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-8 md:py-12 bg-gray-50 border-y border-gray-100">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-8" data-scroll="fade-up">
        Vertrouwd door toonaangevende klinieken en ziekenhuizen
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12" data-scroll="fade-up">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt={logo.name} class="h-8 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="target" size="sm" />
            Onze missie
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold leading-tight">
            Therapeuten versterken, patiënten enthousiasmeren
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Onze missie is – met de beste digitale bewegingsanalysetechnologie – een individuele oplossing te creëren voor therapeuten en hun bijzondere patiënten. De digitale bewegingstherapie van Pixformance ontlast therapeuten bij het demonstreren van oefeningen en begeleidt patiënten zo zeer effectief op hun weg naar herstel.
          </p>
        </div>
        <div class="relative" data-scroll="slide-right">
          <img src="/images/Pixformance-Physiotherapie-Digitalisierung-Digitales-Trainingsgeraet-Spass-Beim-Training.png" alt="Pixformance Fysiotherapie Training" class="rounded-2xl shadow-xl w-full h-auto" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Realtime correctie Highlight -->
  <section class="py-20 bg-[#02308C] relative overflow-hidden">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-6" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-sm font-bold text-[#6BDBD1]">
          <Icon name="zap" size="sm" />
          Live technologie
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold text-white leading-tight">Realtime correctie</h2>
        <p class="text-xl text-white/70 max-w-2xl mx-auto">Nauwkeurige feedback tijdens de uitvoering van oefeningen.</p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-14" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="sparkles" size="sm" />
          Realtime correctie
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">Hoe werkt de training?</h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Het Pixformance-station biedt doorlopende sturing op nauwkeurigheid, tempo en correcte uitvoering van oefeningen.
        </p>
      </div>
      <div class="space-y-16 md:space-y-24">
        {features.map((feature, index) => (
          <div class={`grid md:grid-cols-2 gap-8 md:gap-12 items-center ${index % 2 !== 0 ? 'md-reverse' : ''}`} data-scroll="fade-up" data-delay={index + 1}>
            <div class={`space-y-4 ${index % 2 !== 0 ? 'md:order-2' : ''}`} data-scroll={index % 2 === 0 ? 'slide-left' : 'slide-right'}>
              <span class="text-6xl md:text-7xl font-bold text-[#6BDBD1] leading-none select-none">{String(index + 1).padStart(2, '0')}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-gray-900">{feature.title}</h3>
              <p class="text-lg text-foreground-muted leading-relaxed">{feature.description}</p>
            </div>
            <div class={`${index % 2 !== 0 ? 'md:order-1' : ''}`} data-scroll={index % 2 === 0 ? 'slide-right' : 'slide-left'}>
              <div class="rounded-2xl overflow-hidden">
                <img src={feature.image} alt={feature.title} class="w-full h-auto object-contain block" loading="lazy" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Indicaties Section -->
  <section class="py-12 md:py-20 bg-[#02308C]/5 border-y border-[#02308C]/10">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-10">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="activity" size="sm" />
            Klinische toepassing
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-4">Indicaties en klinische toepassingsgebieden</h2>
          <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
            Pixformance is geschikt voor een breed spectrum aan fysiotherapeutische en revalidatie-indicaties. Oefeningen kunnen worden aangepast voor patiënten in een rolstoel, met een looprek, op een behandeltafel of op de vloer.
          </p>
        </div>
        <ul class="grid md:grid-cols-2 gap-5 text-base text-gray-800 leading-relaxed">
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="brain" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Neurologische revalidatie</strong>
              Multiple sclerose, Parkinson-syndroom, nazorg na beroerte, balans- en coördinatieproblemen
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#6BDBD1] flex items-center justify-center"><Icon name="bone" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Orthopedische revalidatie</strong>
              Postoperatieve zorg (heup, knie, schouder, wervelkolom), rugpijntherapie, functionele krachtopbouw na blessures
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="heart" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Oncologische revalidatie</strong>
              Kankernazorg (volwassenen en kinderen via FORTEe), nazorg na borstkanker
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#6BDBD1] flex items-center justify-center"><Icon name="users" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Geriatrische revalidatie</strong>
              Valpreventie, balanstraining, functionele zelfstandigheid voor ouderen
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300 md:col-span-2">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="trending-up" size="sm" class="text-white" /></span>
            <div>
