---
import NLBaseLayout from '@/layouts/NLBaseLayout.astro';
import NLHeader from '@/components/layout/NLHeader.astro';
import NLFooter from '@/components/layout/NLFooter.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'FYSIOTHERAPIE', href: '/nl/fysiotherapie/' },
  { label: 'KLINIEK', href: '/nl/kliniek/' },
  { label: 'FITNESS', href: '/nl/fitness/' },
  { label: 'BGM', href: '/nl/bedrijfsfitness/' },
];

const stats = [
  { value: '2,5M+', count: 2500000, suffix: '+', label: 'Gebruikers / Jaar', icon: 'users' },
  { value: '1.100+', count: 1100, suffix: '+', label: 'Klinieken & Revalidatiecentra', icon: 'globe' },
  { value: '700+', count: 700, suffix: '+', label: 'Functionele Oefeningen', icon: 'zap' },
];

const partnerLogos = [
  { name: 'Charité', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'FORTEe', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
];

const features = [
  {
    icon: 'eye',
    title: '2D Full-HD Camera',
    description: 'Registreert 25 gewrichtspunten in realtime voor nauwkeurige bewegingsanalyse — zonder sensoren of wearables. Ideaal voor klinische patiënten die directe revalidatietherapie ontvangen.',
  },
  {
    icon: 'monitor',
    title: 'Virtuele Trainer op 43"',
    description: 'Demonstreert oefeningen op het 43"-scherm en geeft directe visuele feedback — patiënten trainen zelfstandig onder supervisie, therapeuten worden ontlast bij de begeleiding.',
  },
  {
    icon: 'zap',
    title: 'Realtime Correctie',
    description: 'Onmiddellijke correctieve feedback tijdens de oefenuitvoering garandeert kwaliteit en veiligheid voor elke patiënt — ook bij complexe orthopedische of neurologische indicaties.',
  },
];

const indications = [
  { icon: '🧠', title: 'Neurologische Revalidatie', description: 'Bewegingstherapie bij MS, beroerte, Parkinson — met gestandaardiseerde kwaliteit op schaal.' },
  { icon: '🦴', title: 'Orthopedische Revalidatie', description: 'Postoperatieve behandeling en bewegingsstoornissen: heup, knie, schouder, wervelkolom.' },
  { icon: '🎗️', title: 'Oncologische Revalidatie', description: 'Bewegen als therapie bij kankerherstel — gepersonaliseerd voor vermoeidheid en functioneel herstel.' },
  { icon: '👴', title: 'Geriatrische Revalidatie', description: 'Valpreventie en behoud van mobiliteit bij oudere patiënten — veilig en motiverend.' },
  { icon: '❤️', title: 'Cardiologische Revalidatie', description: 'Functionele training na hartgebeurtenissen, altijd met realtime kwaliteitscontrole.' },
  { icon: '🏥', title: 'Klinische Activering', description: 'Dagstructuur en bewegingsstimulering voor klinische patiënten gedurende het verblijf.' },
];

const benefits = [
  {
    icon: 'users',
    title: 'Patiëntactivering',
    description: 'Een motiverende digitale trainingsomgeving met gamification-elementen verhoogt aantoonbaar de actieve deelname van patiënten en de therapietrouw.',
  },
  {
    icon: 'heart',
    title: 'Ontlasting van Therapeuten',
    description: 'Therapeuten begeleiden meerdere patiënten tegelijk en concentreren zich op manuele therapie en complexe gevallen — Pixformance verzorgt de standaardtraining.',
  },
  {
    icon: 'trending-up',
    title: 'Schaalbaarheid',
    description: 'Tot 4 patiënten gelijktijdig op meerdere stations — met gepatenteerde software zonder extra personeel, met constante begeleidingskwaliteit.',
  },
  {
    icon: 'file-text',
    title: 'Automatische Documentatie',
    description: 'Oefenuitvoering, Pixformance Score en voortgang worden automatisch opgeslagen op het online platform — geen handmatige registratie, volledige trainingsgeschiedenis.',
  },
  {
    icon: 'check-circle',
    title: 'Therapietrouw',
    description: 'Gamification-elementen en directe feedback verhogen de intrinsieke motivatie — patiënten blijven langer actief en voeren oefeningen nauwkeuriger uit.',
  },
  {
    icon: 'shield',
    title: 'Kwaliteitsborging',
    description: 'Gestandaardiseerde oefenuitvoering via realtime correctieve feedback garandeert consistente behandelkwaliteit — ongeacht de bezetting van het personeel.',
  },
];

const clinicalStudies = [
  { title: 'Charité Berlin', finding: 'Significante verbetering van spierkracht en functionele mobiliteit na 8 weken Pixformance-training.' },
  { title: 'Oxford Brookes University', finding: 'Aanzienlijke verbetering van balans en valpreventie bij geriatrische patiënten.' },
  { title: 'FORTEe EU-project', finding: 'Technologiegestuurde bewegingstherapie verbetert revalidatieresultaten in Europese klinieken.' },
  { title: 'AUVA OngevallenZiekenhuis Klagenfurt', finding: 'Hogere patiëntmotivatie en zelfstandige training onder supervisie in acute revalidatie.' },
  { title: 'Medical Park Bad Rodach', finding: 'Vermindering van personele begeleidingstijd bij gelijkblijvende of betere therapiekwaliteit.' },
];

const medicalDeviceSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalDevice",
  "name": "Pixformance Station — Digitale Revalidatieapparatuur voor Klinieken",
  "description": "FDA Klasse 2 gecertificeerd digitaal revalidatieapparaat voor klinieken en revalidatiecentra. Realtime bewegingsanalyse, geautomatiseerde documentatie, tot 4 patiënten gelijktijdig.",
  "manufacturer": {
    "@type": "Organization",
    "name": "Pixformance Sports GmbH",
    "url": "https://pixformance.com"
  },
  "medicalSpecialty": ["Orthopedie", "Neurologie", "Geriatrie", "Cardiologie", "Oncologische Revalidatie"],
  "recognizingAuthority": {
    "@type": "Organization",
    "name": "FDA — Food and Drug Administration",
    "url": "https://www.fda.gov"
  },
  "regulatoryStatus": "FDA Klasse 2 medisch apparaat",
  "url": "https://www.pixformance.com/nl/kliniek/"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Welke klinieken gebruiken Pixformance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance wordt gebruikt door meer dan 1.100 klinieken en revalidatiecentra, waaronder Charité Berlin, Medical Park, Niederrhein-Klinik, Sauerlandklinik Hachen, AUVA en Mediclin." }
    },
    {
      "@type": "Question",
      "name": "Is Pixformance gecertificeerd als medisch apparaat?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja. Pixformance is gecertificeerd als FDA Klasse 2 medisch apparaat en voldoet aan de klinische en reglementaire vereisten voor gebruik in klinieken en revalidatiecentra." }
    },
    {
      "@type": "Question",
      "name": "Voor welke indicaties is Pixformance geschikt in klinieken?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance is geschikt voor neurologische (MS, beroerte, Parkinson), orthopedische, oncologische, geriatrische en cardiologische revalidatie, alsook voor klinische activering van patiënten." }
    },
    {
      "@type": "Question",
      "name": "Hoeveel patiënten kunnen gelijktijdig trainen op Pixformance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tot 4 patiënten kunnen gelijktijdig op meerdere Pixformance-stations trainen — zonder extra personeel dankzij gepatenteerde software voor bewegingsanalyse." }
    },
    {
      "@type": "Question",
      "name": "Hoe integreert Pixformance met klinische documentatiesystemen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance slaat automatisch oefenuitvoering, Pixformance Score en voortgang op in het online platform. Exportopties voor klinische administratie en verzekeringsrapportage zijn beschikbaar." }
    },
    {
      "@type": "Question",
      "name": "Welke ruimte en infrastructuur zijn nodig voor een Pixformance-station?",
      "acceptedAnswer": { "@type": "Answer", "text": "Een Pixformance-station heeft een vloeroppervlak van ca. 4–6 m² nodig, een standaard stroomaansluiting en een internetverbinding. Er zijn geen speciale bouwkundige aanpassingen vereist." }
    },
    {
      "@type": "Question",
      "name": "Hoe lang duurt de introductie voor patiënten?",
      "acceptedAnswer": { "@type": "Answer", "text": "Na slechts 30 minuten instructie kunnen patiënten zelfstandig onder supervisie trainen op Pixformance — dit vermindert de begeleidingstijd voor therapeuten aanzienlijk." }
    },
    {
      "@type": "Question",
      "name": "Hoe verloopt de technische installatie en ondersteuning?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance verzorgt de volledige installatie inclusief technische installatie, personeelstraining en doorlopende ondersteuning. Klinieken ontvangen toegang tot het online beheersplatform." }
    }
  ]
};
---

<NLBaseLayout
  title="Digitale Revalidatieapparatuur voor Klinieken — FDA Klasse 2 | Pixformance"
  description="Pixformance voor revalidatieklinieken: FDA Klasse 2 gecertificeerd, 1.100+ klinieken (Charité, Medical Park, AUVA). Patiëntactivering, ontlasting van therapeuten, automatische documentatie."
  hreflangDe="https://www.pixformance.com/klinik/"
  hreflangEn="https://www.pixformance.com/en/clinic/"
  jsonLd={[medicalDeviceSchema, faqSchema]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/clinique/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/clinica/" />
  </Fragment>

  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <!-- Breadcrumb Tabs -->
  <BreadcrumbTabs tabs={tabs} activeTab="/nl/kliniek/" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">

        <h1 class="font-display text-4xl md:text-6xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Digitale revalidatie die uw kliniek efficiënter maakt — zonder compromissen op begeleidingskwaliteit.
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Meer dan 1.100 revalidatieklinieken en ziekenhuizen vertrouwen op Pixformance — van Charité Berlin tot Medical Park, AUVA en Oxford Brookes University. Het enige FDA Klasse 2 gecertificeerde digitale bewegingstherapieapparaat dat patiënten motiveert en therapeuten bevrijdt van routinewerk.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button
            size="lg"
            href="/nl/gratis-proef/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Gratis proberen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/nl/concept/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Advies aanvragen
            <Icon name="phone" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-4 sm:p-6 rounded-2xl hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate" style={`animation-delay: ${0.6 + index * 0.1}s;`}>
              <div
                class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300 stat-counter"
                data-count={stat.count}
                data-suffix={stat.suffix}
                data-large={stat.count >= 10000 ? 'true' : 'false'}
              >
                {stat.value}
              </div>
              <div class="text-xs sm:text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-10 bg-gray-50 border-y border-gray-200" data-scroll="fade-up">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-6">
        Vertrouwd door toonaangevende klinieken
      </p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        {partnerLogos.map(logo => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 md:h-10 w-auto object-contain grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="layers" size="sm" />
          Volledig verbonden systeem
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Het Pixformance Station
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Geavanceerde bewegingsanalyse gecombineerd met therapeutische expertise — speciaal ontworpen voor klinische omgevingen.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {features.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 rounded-xl bg-[#02308C] flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-xl mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Indications Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="activity" size="sm" />
          Indicaties
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Revalidatiefasen waarbij Pixformance helpt
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-2xl mx-auto">
          Van neurologie tot geriatrie — Pixformance ondersteunt de voornaamste klinische behandelindicaties.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {indications.map((item, index) => (
          <div
            class="bg-white rounded-2xl p-6 flex gap-4 items-start shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <span class="text-3xl leading-none mt-1">{item.icon}</span>
            <div>
              <h3 class="font-bold text-base mb-1 text-[#02308C]">{item.title}</h3>
              <p class="text-sm text-foreground-muted">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Voordelen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
          Voordelen voor uw kliniek
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 ${index % 2 === 0 ? 'bg-[#02308C]' : 'bg-[#6BDBD1]'}`}>
              <Icon name={benefit.icon} size="md" class="text-white" />
            </div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
              {benefit.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {benefit.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="check-circle" size="sm" />
          Klinische Ervaringen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Wat kliniekdirecteuren zeggen
        </h2>
        <p class="text-lg text-foreground-muted mt-4">
          Ervaringen van therapeutisch leiders en kliniekdirecteuren
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="1"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "De patiënten zijn enthousiast en zeer gemotiveerd, wat eerlijk gezegd niet altijd vanzelfsprekend is. Wij als therapeuten profiteren daar natuurlijk ook van, want patiënten voeren hun oefeningen daardoor beter en doelgerichter uit. Bovendien besparen we tijd, want na slechts 30 minuten instructie kunnen patiënten zelfstandig onder supervisie trainen."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Gabriele-Buchstein-Leitung-Physiotherapie-Sauerlandklinik-Hachen.png"
              alt="Gabriele Buchstein"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Gabriele Buchstein</cite>
              <p class="text-sm text-foreground-muted">Hoofd Fysiotherapie</p>
              <p class="text-sm font-semibold text-[#02308C]">Sauerlandklinik Hachen – Neurologische Specialistenkliniek voor MS</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="2"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "Op zoek naar een manier om patiënten te activeren en tegelijk het personeel te ontlasten, ontdekten wij Pixformance. We waren op zoek naar een moderne manier van bewegen die tegelijkertijd het personeel ontlastte. Pixformance past perfect in ons zorgconcept."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich-Pixformance.png"
              alt="Christoph Schneider"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Christoph Schneider</cite>
              <p class="text-sm text-foreground-muted">Hoofd Therapie</p>
              <p class="text-sm font-semibold text-[#02308C]">Niederrhein-Klinik – Revalidatiekliniek Korschenbroich</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="3"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "Van de kant van de patiënten is er grote interesse in de Pixformance stations. Velen komen uit zichzelf en willen een trainingsprogramma. Dat maakt ons bijzonder blij — het laat zien dat Pixformance patiënten intrinsiek motiveert om te bewegen."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Christoph-Oratsch-AUVA-Klagenfurt-1.png"
              alt="Christoph Oratsch"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Christoph Oratsch</cite>
              <p class="text-sm text-foreground-muted">Hoofd Therapie</p>
              <p class="text-sm font-semibold text-[#02308C]">AUVA Ongevallensziekenhuis Klagenfurt</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="4"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "Pixformance heeft onze revalidatieafdeling fundamenteel veranderd. Patiënten voeren oefeningen nauwkeuriger uit, de documentatie verloopt automatisch en ons team kan zich concentreren op wat echt telt: de individuele begeleiding van elke patiënt."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Gunter-Hölig-Medical-Park-Bad-Rodach.jpg"
              alt="Gunter Hölig"
