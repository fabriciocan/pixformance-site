---
import NLBaseLayout from '@/layouts/NLBaseLayout.astro';
import NLHeader from '@/components/layout/NLHeader.astro';
import NLFooter from '@/components/layout/NLFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const components = [
  {
    icon: 'monitor',
    title: 'Pixformance Station',
    description: 'Het gepatenteerde station met 2D Full-HD camera registreert 25 gewrichtspunten',
    image: '/images/Pixformance-Station-Konzept-voll-vernetzt-Digitales-Trainingsgeraet-Funktionelles-Training-eGym.jpg',
  },
  {
    icon: 'globe',
    title: 'Online platform',
    description: 'Centraal beheer van alle gebruikers en trainingsprogramma\'s',
    image: '/images/Pixformance-Online-Platform-Functional-Training-fully-connected.jpg',
  },
  {
    icon: 'smartphone',
    title: 'Mobiele webapplicatie',
    description: 'Train overal – thuis of onderweg met de Pixformance webapplicatie',
    image: '/images/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet-1.jpg',
  },
];

const technologies = [
  {
    icon: 'cpu',
    title: 'Innovatieve software',
    color: '#02308C',
    features: [
      'Gebaseerd op 25 gewrichtspunten',
      'Lichaamsmeting in enkele seconden',
      'Nauwkeurige bewegingsanalyse',
      'Gepatenteerde technologie',
    ],
  },
  {
    icon: 'message-square',
    title: 'Digitale feedback',
    color: '#6BDBD1',
    features: [
      'Realtime correctie',
      'Tekstuele feedback',
      'Visuele feedback',
      'Persoonlijke aanpassingen',
    ],
  },
  {
    icon: 'network',
    title: 'Connectiviteit',
    color: '#6BDBD1',
    features: [
      'Station ↔ Online platform',
      'Online platform ↔ Webapplicatie',
      'Naadloze gegevenssynchronisatie',
      'Centraal beheer',
    ],
  },
];

const targetGroups = [
  {
    svgIcon: '/images/konzept-icons/17.svg',
    title: 'Beste revalidatieklinieken van Duitsland',
    description: 'Toonaangevende instellingen vertrouwen op Pixformance',
  },
  {
    svgIcon: '/images/konzept-icons/18.svg',
    title: 'Fysiotherapiepraktijken',
    description: 'Optimale ondersteuning voor therapeuten',
  },
  {
    svgIcon: '/images/konzept-icons/20.svg',
    title: 'Fitnesscentra',
    description: 'Moderne trainingsconcepten voor studios',
  },
  {
    svgIcon: '/images/konzept-icons/16.svg',
    title: 'Bedrijfsgezondheidszorg',
    description: 'Gezonde en productieve medewerkers',
  },
];

const keyFeatures = [
  {
    icon: 'layers',
    title: 'Meer dan 700 functionele oefeningen',
    description: 'Uitgebreide oefenbibliotheek voor elke gezondheidstoestand',
  },
  {
    icon: 'monitor',
    title: 'Virtuele personal trainer',
    description: 'Professionele begeleiding door een digitale trainer op het scherm',
  },
  {
    icon: 'settings',
    title: 'Persoonlijke trainingsplannen',
    description: 'Individueel afgestemd op het fitnessniveau en de doelstellingen',
  },
  {
    icon: 'check-circle',
    title: 'Veilige uitvoering',
    description: 'Realtime correctie voorkomt verkeerde houdingen en blessures',
  },
];
---

<NLBaseLayout
  title="Digitaal trainingsconcept – Station, Platform & Applicatie | Pixformance"
  description="Het Pixformance concept: 2D Full-HD camera, 25 gewrichtspunten, 700+ functionele oefeningen, virtuele personal trainer. Volledig verbonden systeem voor fysiotherapie & fitness."
  hreflangDe="https://www.pixformance.com/konzept"
  hreflangEn="https://www.pixformance.com/en/products-2/"
  jsonLd={[{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Pixformance Station",
    "description": "Digitaal trainingsapparaat met gepatenteerde 2D Full-HD camera voor realtime bewegingsanalyse. 25 gewrichtspunten, virtuele personal trainer, 700+ functionele oefeningen.",
    "brand": {"@type": "Brand", "name": "Pixformance"},
    "manufacturer": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://pixformance.com"},
    "image": "https://www.pixformance.com/images/Pixformance-Station-Konzept-voll-vernetzt-Digitales-Trainingsgeraet-Funktionelles-Training-eGym.jpg",
    "offers": {"@type": "Offer", "availability": "https://schema.org/InStock", "priceCurrency": "EUR"},
    "url": "https://www.pixformance.com/nl/concept/"
  }]}
>
  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden">

    <!-- Hero Banner Image -->
    <div class="relative w-full hero-animate" style="animation-delay: 0.1s;">
      <img
        src="/images/Pixformance-Gruppentraining-Physiotherapie-Digitale-Rehabilitation-eHealth-Funktionelles-Training-Banner.jpg"
        alt="Pixformance groepstraining fysiotherapie digitale revalidatie"
        class="w-full h-auto object-cover"
        loading="eager"
      />
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <div class="container py-12 md:py-16">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white text-sm font-bold shadow-lg">
            <Icon name="zap" size="sm" />
            VOLLEDIG VERBONDEN TRAINING
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Digitaal trainingsconcept voor uw patiënten & leden
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          De Pixformance station met gepatenteerde software, een online platform en een
          webapplicatie – deze componenten vormen ons volledig verbonden digitaal trainingsconcept.
          Met de beste digitale bewegingsanalysetechnologie bieden wij hoogeffectieve functionele
          training voor alle fitnessniveaus en gezondheidstoestanden.
        </p>
      </div>
    </div>
  </section>

  <!-- System Components -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">

      <!-- Title -->
      <div class="text-center mb-10" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          De 3 systeemcomponenten
        </h2>
      </div>

      <!-- Central image showing all 3 components together -->
      <div class="flex justify-center mb-12" data-scroll="fade-up">
        <img
          src="/images/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet-1.jpg"
          alt="De 3 componenten: Pixformance Station, Online platform en Mobiele webapplicatie"
          class="max-w-lg w-full object-contain"
          loading="lazy"
        />
      </div>

      <!-- 3 component columns -->
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {components.map((component, index) => (
          <div class="flex flex-col items-center text-center gap-4" data-scroll="fade-up" data-delay={index + 1}>
            <div class="w-20 h-20 rounded-full border-2 border-[#02308C] flex items-center justify-center flex-shrink-0">
              <Icon name={component.icon} size="lg" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold text-xl text-foreground">
              {component.title}
            </h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              {component.description}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Key Features -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Functies
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Belangrijkste systeemkenmerken
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {keyFeatures.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Highlights -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="cpu" size="sm" />
          Technologie
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Technologische hoogtepunten
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {technologies.map((tech, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold group-hover:text-[#02308C] transition-colors">
                {tech.title}
              </h3>
              <ul class="space-y-3">
                {tech.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <Icon name="check-circle" size="sm" class="text-[#86C9BC] mt-0.5 flex-shrink-0" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Target Groups -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Doelgroepen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
          Met succes ingezet in
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {targetGroups.map((group, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <img src={group.svgIcon} alt={group.title} class="w-8 h-8 object-contain" loading="lazy" />
            </div>
            <h3 class="font-semibold mb-2 group-hover:text-[#02308C] transition-colors">
              {group.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {group.description}
            </p>
          </Card>
        ))}
      </div>

      <div class="text-center" data-scroll="fade-up">
        <div class="inline-block p-8 rounded-2xl bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 border border-[#02308C]/20">
          <p class="text-4xl md:text-5xl font-bold text-[#02308C] mb-2">750 000+</p>
          <p class="text-lg text-foreground-muted">Gebruikers wereldwijd</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-18 md:pb-40 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto pt-8 text-center" data-scroll="fade-up">

        <blockquote class="text-2xl md:text-3xl font-bold text-white mb-8 leading-relaxed">
          "Met Pixformance hebben we een tweede zone voor directe betaling gecreëerd. De digitale bewegingstherapie enthousiasmeert onze patiënten en heeft zich snel terugverdiend."
        </blockquote>

        <div class="flex items-center justify-center gap-4">
          <div class="w-30 h-30 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
            <img src="images/Heike-Schaible-round.png" class="w-30 h-30 rounded-full object-cover" loading="lazy" />
          </div>
          <div class="text-left">
            <p class="font-bold text-white text-lg">Heike Schaible</p>
            <p class="text-white text-sm">Eigenaar</p>
            <p class="text-white text-sm">Fysiotherapiepraktijk Raum für Gesundheit, Stuttgart</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
          <Icon name="headphones" size="sm" />
          Advies
        </span>

        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Wij staan voor u klaar!
        </h2>

        <p class="text-xl text-foreground-muted max-w-2xl mx-auto">
          Veel vragen lossen zich makkelijker op in een persoonlijk gesprek. Wij kijken uit naar uw bericht!
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-4">
          <Button size="lg" href="/nl/gratis-proef/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Vrijblijvend proberen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform" />
          </Button>
          <Button size="lg" variant="outline" href="/nl/contact/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Contact opnemen
            <Icon name="mail" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <NLFooter slot="footer" />
</NLBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, observerOptions);
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
