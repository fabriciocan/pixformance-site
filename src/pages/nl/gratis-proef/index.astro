---
import NLBaseLayout from '@/layouts/NLBaseLayout.astro';
import NLHeader from '@/components/layout/NLHeader.astro';
import NLFooter from '@/components/layout/NLFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const benefits = [
  {
    icon: 'check-circle',
    title: 'Gratis proefperiode',
    description: 'Test Pixformance 60 dagen zonder enige verplichting',
  },
  {
    icon: 'users',
    title: 'Persoonlijk advies',
    description: 'Onze experts begeleiden u bij de configuratie',
  },
  {
    icon: 'settings',
    title: 'Individuele aanpassing',
    description: 'Wij configureren het systeem volgens uw wensen',
  },
  {
    icon: 'award',
    title: 'Training inbegrepen',
    description: 'Volledige training voor uw team ter plaatse',
  },
];
---

<NLBaseLayout
  title="Pixformance gratis proef 60 dagen – Nu aanvragen"
  description="Test Pixformance 60 dagen zonder verplichting: persoonlijk advies, installatie en training inbegrepen. Vraag nu uw adviesgesprek aan."
  hreflangDe="https://www.pixformance.com/testen"
  hreflangEn="https://www.pixformance.com/en/apply-for-trial/"
  jsonLd={[{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Pixformance gratis proef – Adviesaanvraag",
    "description": "Test Pixformance 60 dagen gratis. Persoonlijk advies, installatie en training inbegrepen.",
    "url": "https://www.pixformance.com/nl/gratis-proef/",
    "isPartOf": {"@type": "WebSite", "url": "https://www.pixformance.com/nl/"}
  }]}
>
  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-4 md:py-16">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="zap" size="sm" />
            Vrijblijvend aanbod
          </span>
        </div>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Test Pixformance in uw vestiging
        </h1>
      </div>
    </div>
  </section>

  <section class="py-2 md:py-2 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8" data-scroll="fade-up">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl" data-scroll="scale">
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

            <div class="relative p-8 md:p-12">
              <form class="space-y-8" id="contact-form">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-scroll="fade-up" data-delay="1">
                  <div>
                    <label for="name" class="block text-sm font-bold mb-3 text-white">
                      Naam <span class="text-[#FFED00]">*</span>
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all text-gray-900 placeholder:text-gray-400 shadow-lg"
                      placeholder="Uw naam"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-bold mb-3 text-white">
                      E-mail <span class="text-[#FFED00]">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all text-gray-900 placeholder:text-gray-400 shadow-lg"
                      placeholder="uw.email@voorbeeld.com"
                    />
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-scroll="fade-up" data-delay="2">
                  <div>
                    <label for="company" class="block text-sm font-bold mb-3 text-white">
                      Bedrijf / Vestiging
                    </label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all text-gray-900 placeholder:text-gray-400 shadow-lg"
                      placeholder="Uw bedrijf"
                    />
                  </div>
                  <div>
                    <label for="phone" class="block text-sm font-bold mb-3 text-white">
                      Telefoon
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all text-gray-900 placeholder:text-gray-400 shadow-lg"
                      placeholder="+31 (0) ..."
                    />
                  </div>
                </div>

                <div data-scroll="fade-up" data-delay="3">
                  <label for="interest" class="block text-sm font-bold mb-3 text-white">
                    Interessegebied
                  </label>
                  <select
                    id="interest"
                    name="interest"
                    class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all text-gray-900 shadow-lg"
                  >
                    <option value="">Maak een keuze...</option>
                    <option value="physiotherapie">Fysiotherapie</option>
                    <option value="klinik">Kliniek</option>
                    <option value="fitness">Fitness</option>
                    <option value="bgm">BGM (Bedrijfsgezondheidsbeheer)</option>
                    <option value="other">Overig</option>
                  </select>
                </div>

                <div data-scroll="fade-up" data-delay="4">
                  <label for="message" class="block text-sm font-bold mb-3 text-white">
                    Uw bericht <span class="text-[#FFED00]">*</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="6"
                    class="w-full px-5 py-4 rounded-xl border-0 bg-white/95 backdrop-blur-sm focus:outline-none focus:ring-4 focus:ring-white/50 transition-all resize-none text-gray-900 placeholder:text-gray-400 shadow-lg"
                    placeholder="Vertel ons hoe wij u kunnen helpen..."
                  ></textarea>
                </div>

                <div class="flex items-start gap-3" data-scroll="fade-up" data-delay="5">
                  <input
                    type="checkbox"
                    id="privacy"
                    name="privacy"
                    required
                    class="mt-1 w-5 h-5 rounded border-0 bg-white/95 text-[#02308C] focus:ring-4 focus:ring-white/50 shadow-lg"
                  />
                  <label for="privacy" class="text-sm text-white/95 leading-relaxed">
                    Ik heb het <a href="/datenschutz" class="text-[#FFED00] hover:underline font-bold">privacybeleid</a> gelezen en ga hiermee akkoord. <span class="text-[#FFED00]">*</span>
                  </label>
                </div>

                <div class="flex justify-center pt-4" data-scroll="fade-up" data-delay="6">
                  <Button
                    size="lg"
                    type="submit"
                    class="group bg-white text-[#02308C] hover:bg-white/90 hover:shadow-2xl hover:scale-105 transition-all duration-300 font-bold"
                  >
                    Aanvraag verzenden
                    <Icon name="send" size="sm" class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                  </Button>
                </div>

              </form>
              <div id="form-message" class="hidden"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Benefits Section -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container">
        <div class="text-center mb-12" data-scroll="fade-up">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="star" size="sm" />
            Uw voordelen
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold">
            Waarom Pixformance testen?
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {benefits.map((benefit, index) => (
            <Card
              variant="elevated"
              padding="lg"
              class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
              data-scroll="scale"
              data-delay={index + 1}
            >
              <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
                <Icon name={benefit.icon} size="lg" class="text-white" />
              </div>
              <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
                {benefit.title}
              </h3>
              <p class="text-sm text-foreground-muted">
                {benefit.description}
              </p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Quick Contact Cards -->
    <section class="py-12 md:py-16 bg-gray-50">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-300 hover:-translate-y-2 bg-white group"
            data-scroll="fade-up"
            data-delay="1"
          >
            <div class="flex items-center gap-4">
              <div class="p-3 rounded-xl bg-[#02308C] group-hover:scale-110 transition-transform duration-300 shrink-0">
                <Icon name="phone" size="lg" class="text-white" />
              </div>
              <div class="min-w-0">
                <p class="text-sm text-foreground-muted mb-1">Telefoon</p>
                <a href="tel:+493039805610" class="font-semibold hover:text-[#02308C] transition-colors break-all">
                  +49 (0)30 39 80 56 10
                </a>
              </div>
            </div>
          </Card>

          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-300 hover:-translate-y-2 bg-white group"
            data-scroll="fade-up"
            data-delay="2"
          >
            <div class="flex items-center gap-4">
              <div class="p-3 rounded-xl bg-[#6BDBD1] group-hover:scale-110 transition-transform duration-300 shrink-0">
                <Icon name="mail" size="lg" class="text-white" />
              </div>
              <div class="min-w-0">
                <p class="text-sm text-foreground-muted mb-1">E-mail</p>
                <a href="mailto:contact@pixformance.com" class="font-semibold hover:text-[#02308C] transition-colors break-all">
                  contact@pixformance.com
                </a>
              </div>
            </div>
          </Card>

          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-300 hover:-translate-y-2 bg-white group"
            data-scroll="fade-up"
            data-delay="3"
          >
            <div class="flex items-center gap-4">
              <div class="p-3 rounded-xl bg-[#02308C] group-hover:scale-110 transition-transform duration-300 shrink-0">
                <Icon name="headphones" size="lg" class="text-white" />
              </div>
              <div class="min-w-0">
                <p class="text-sm text-foreground-muted mb-1">Productadvies</p>
                <a href="mailto:beratung@pixformance.com" class="font-semibold hover:text-[#02308C] transition-colors break-all">
                  beratung@pixformance.com
                </a>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Certification Section -->
    <section class="py-12 md:py-20 bg-white">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center" data-scroll="fade-up">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="award" size="sm" />
            Certificering
          </div>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">
            DHfPG-opleidingsinstelling
          </h2>
          <p class="text-lg text-foreground-muted mb-8">
            Deutsche Hochschule für Prävention und Gesundheitsmanagement
          </p>
          <div class="inline-flex items-center gap-4 px-8 py-6 rounded-2xl bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 border border-[#02308C]/20">
            <div class="w-16 h-16 rounded-xl bg-[#02308C] flex items-center justify-center">
              <Icon name="award" size="xl" class="text-white" />
            </div>
            <div class="text-left">
              <p class="font-bold text-lg">Gecertificeerde partner</p>
              <p class="text-sm text-foreground-muted">Gegarandeerde kwaliteit en excellentie</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <NLFooter slot="footer" />
  </section>

  <style>
    @keyframes hero-entry {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-animate {
      opacity: 0;
      animation: hero-entry 0.8s ease-out forwards;
    }
    [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    [data-scroll].is-visible { opacity: 1; }
    [data-scroll="fade-up"] { transform: translateY(30px); }
    [data-scroll="fade-up"].is-visible { transform: translateY(0); }
    [data-scroll="scale"] { transform: scale(0.9); }
    [data-scroll="scale"].is-visible { transform: scale(1); }
    [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
    [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
    [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
    [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
    [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
    [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
  </style>

  <script is:inline>
    (function () {
      var WEBHOOK_URL = 'https://webhook.pixformance.com/webhook/site-forms';

      function getUrlParams() {
        var params = {};
        new URLSearchParams(window.location.search).forEach(function (value, key) { params[key] = value; });
        return params;
      }

      function getCookies() {
        var cookies = {};
        if (!document.cookie) return cookies;
        document.cookie.split(';').forEach(function (cookie) {
          var idx = cookie.indexOf('=');
          if (idx === -1) return;
          var key = cookie.slice(0, idx).trim();
          var value = cookie.slice(idx + 1).trim();
          try { cookies[key] = decodeURIComponent(value); } catch (e) { cookies[key] = value; }
        });
        return cookies;
      }

      function sanitizePhone(phone) {
        return (phone || '').replace(/[^\d\s+\-()]/g, '').trim();
      }

      function initTesteForm() {
        var form = document.getElementById("contact-form");
        var messageDiv = document.getElementById("form-message");
        if (!form || !messageDiv) return;

        form.addEventListener("submit", function (e) {
          e.preventDefault();

          var submitBtn = form.querySelector('[type="submit"]');
          if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.7'; }

          var formData = new FormData(form);
          var payload = {
            form_name: 'Gratis proef NL - Adviesaanvraag',
            name: formData.get('name') || '',
            email: formData.get('email') || '',
            company: formData.get('company') || '',
            phone: sanitizePhone(formData.get('phone')),
            interest: formData.get('interest') || '',
            message: formData.get('message') || '',
            privacy_accepted: formData.get('privacy') === 'on',
            page_url: window.location.href,
            page_path: window.location.pathname,
            referrer: document.referrer || '',
            submitted_at: new Date().toISOString(),
            url_params: getUrlParams(),
            cookies: getCookies(),
            language: 'nl',
            version: 'NL',
          };

          fetch(WEBHOOK_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
            .then(function (response) {
              if (response.ok) {
                form.style.display = 'none';
                messageDiv.classList.remove("hidden");
                messageDiv.className = "p-8 rounded-2xl bg-white border-2 border-[#02308C]/20 text-center shadow-lg";
                messageDiv.innerHTML = '<div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#02308C] flex items-center justify-center"><svg width="32" height="32" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg></div><h3 class="text-xl font-bold text-[#02308C] mb-2">Bedankt voor uw aanvraag!</h3><p class="text-gray-600">We nemen zo snel mogelijk contact met u op.</p>';
              } else {
                messageDiv.classList.remove("hidden");
                messageDiv.className = "p-4 rounded-xl bg-red-50 text-red-700 border-2 border-red-200 font-semibold text-center";
                messageDiv.textContent = "Er is een fout opgetreden. Probeer het opnieuw.";
              }
            })
            .catch(function () {
              messageDiv.classList.remove("hidden");
              messageDiv.className = "p-4 rounded-xl bg-red-50 text-red-700 border-2 border-red-200 font-semibold text-center";
              messageDiv.textContent = "Er is een fout opgetreden. Probeer het opnieuw.";
            })
            .finally(function () {
              if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = ''; }
            });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTesteForm);
      } else {
        initTesteForm();
      }
    })();

    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, observerOptions);

    document.querySelectorAll("[data-scroll]").forEach((el) => {
      observer.observe(el);
    });
  </script>
</NLBaseLayout>
