---
import NLBaseLayout from '@/layouts/NLBaseLayout.astro';
import NLHeader from '@/components/layout/NLHeader.astro';
import NLFooter from '@/components/layout/NLFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const values = [
  {
    icon: 'lightbulb',
    title: 'Innovatie',
    description: 'Creatieve en zeer gemotiveerde mensen met interessante en uitdagende ideeën',
  },
  {
    icon: 'users',
    title: 'Diversiteit',
    description: 'Diversiteit is niet iets waar we over praten – het is wie we zijn',
  },
  {
    icon: 'trending-up',
    title: 'Bijscholing',
    description: 'Voortdurende professionele en persoonlijke ontwikkeling van elk individu',
  },
  {
    icon: 'zap',
    title: 'Lef',
    description: 'Gedurfde perspectieven en een onwankelbare nieuwsgierigheid naar de toekomst',
  },
];

const benefits = [
  { icon: 'briefcase', label: 'Uitdagende projecten' },
  { icon: 'heart', label: 'Work-life balance' },
  { icon: 'book', label: 'Bijscholing' },
  { icon: 'coffee', label: 'Modern kantoor' },
  { icon: 'users', label: 'Hecht team' },
  { icon: 'globe', label: 'Internationale projecten' },
];
---

<NLBaseLayout
  title="Vacatures & Carrière bij Pixformance Sports GmbH"
  description="Werken bij Pixformance: innovatie, diversiteit, internationale projecten. We zoeken chronisch nieuwsgierige geesten. Ontdek de carrièremogelijkheden."
  hreflangDe="https://www.pixformance.com/karriere"
  hreflangEn="https://www.pixformance.com/en/jobs/"
  jsonLd={[{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Vacatures bij Pixformance Sports GmbH",
    "description": "Openstaande functies en carrièremogelijkheden bij Pixformance Sports GmbH – de pionier in digitale bewegingsanalyse.",
    "url": "https://www.pixformance.com/nl/vacatures/",
    "breadcrumb": {"@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Pixformance", "item": "https://www.pixformance.com/nl/"}, {"@type": "ListItem", "position": 2, "name": "Vacatures", "item": "https://www.pixformance.com/nl/vacatures/"}]}
  }]}
>
  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 md:py-24 bg-[#02308C]">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="container relative">
      <div class="max-w-5xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-sm font-bold text-white">
            <Icon name="briefcase" size="sm" />
            Carrière bij Pixformance
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight text-white hero-animate" style="animation-delay: 0.2s;">
          Chronisch nieuwsgierig?
          <br />
          <span class="text-[#6BDBD1]">Uitstekend. Wij ook.</span>
        </h1>

        <p class="text-xl md:text-2xl text-white/90 leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Bij Pixformance is diversiteit niet iets waar we over praten –
          <span class="font-bold text-white">het is wie we zijn.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-12">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="users" size="sm" />
            Over ons
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
            Wie wij zijn
          </h2>
        </div>

        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <p>
            Als <span class="font-bold text-[#02308C]">pioniers van innovatie</span> zijn we altijd op zoek naar
            creatieve en zeer gemotiveerde mensen met interessante en uitdagende ideeën,
            gedurfde perspectieven en een onwankelbare nieuwsgierigheid naar de toekomst.
          </p>

          <p>
            We verbinden ieders individuele achtergrond om onze gezamenlijke toekomst vorm te geven. Onze
            <span class="font-bold text-[#02308C]">bedrijfscultuur</span> draait om de
            voortdurende professionele en persoonlijke ontwikkeling van elk individu, terwijl we
            gedurfd bijdragen aan verandering in een moderne wereld.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="heart" size="sm" />
          Onze waarden
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Wat ons definieert
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 hover:scale-105 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto rounded-2xl bg-[#02308C] flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
              <Icon name={value.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-xl mb-3 text-foreground">{value.title}</h3>
            <p class="text-foreground-muted text-sm leading-relaxed">{value.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/10 border border-[#6BDBD1]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Voordelen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Wat wij bieden
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 max-w-5xl mx-auto">
        {benefits.map((benefit, index) => (
          <Card
            variant="elevated"
            padding="md"
            class="text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-2 hover:scale-105 group bg-white"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="w-12 h-12 mx-auto rounded-xl bg-[#6BDBD1]/10 flex items-center justify-center mb-3 group-hover:bg-[#6BDBD1] group-hover:scale-110 transition-all duration-300">
              <Icon name={benefit.icon} size="md" class="text-[#6BDBD1] group-hover:text-white transition-colors duration-300" />
            </div>
            <p class="text-sm font-semibold text-foreground">{benefit.label}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Job Openings Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="briefcase" size="sm" />
          Vacatures
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
          Actuele vacatures
        </h2>
      </div>

      <div class="max-w-3xl mx-auto" data-scroll="fade-up">
        <Card
          variant="elevated"
          padding="xl"
          class="text-center bg-white"
        >
          <div class="w-20 h-20 mx-auto rounded-2xl bg-[#02308C]/10 flex items-center justify-center mb-6">
            <Icon name="search" size="lg" class="text-[#02308C]" />
          </div>

          <h3 class="font-bold text-2xl mb-4 text-foreground">
            Momenteel geen openstaande vacatures
          </h3>

          <p class="text-lg text-foreground-muted mb-8 leading-relaxed">
            Maar laat u daardoor niet ontmoedigen! We zijn altijd op zoek naar
            getalenteerde mensen die ons team willen versterken.
          </p>

          <div class="space-y-4">
            <p class="text-foreground-muted">
              Stuur ons gerust uw <span class="font-bold text-[#02308C]">open sollicitatie</span>:
            </p>

            <div class="flex items-center justify-center gap-3 text-foreground-muted">
              <Icon name="mail" size="md" class="text-[#02308C]" />
              <a
                href="mailto:contact@pixformance.com"
                class="text-lg font-semibold text-[#02308C] hover:text-[#6BDBD1] transition-colors underline"
              >
                contact@pixformance.com
              </a>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <div class="w-20 h-20 mx-auto rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center mb-6">
          <Icon name="rocket" size="lg" class="text-white" />
        </div>

        <h2 class="font-display text-4xl md:text-6xl font-bold text-white leading-tight">
          Klaar om ons team te versterken?
        </h2>

        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          We kijken ernaar uit om van u te horen en samen de toekomst van
          digitale training vorm te geven!
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button
            size="lg"
            href="mailto:contact@pixformance.com"
            class="bg-black text-white hover:bg-black/80"
          >
            Sollicitatie versturen
            <Icon name="send" size="sm" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/nl/over-ons/"
            class="border-2 border-black text-black hover:bg-black hover:text-white"
          >
            Meer over ons
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <div class="pt-8 space-y-4">
          <p class="text-white/90 text-lg">
            Volg ons op sociale media:
          </p>
          <div class="flex gap-4 justify-center">
            <a
              href="https://www.linkedin.com/company/pixformance-sports-gmbh"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-300 hover:scale-110"
            >
              <Icon name="linkedin" size="md" class="text-white" />
            </a>
            <a
              href="https://www.instagram.com/pixformance/"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-300 hover:scale-110"
            >
              <Icon name="instagram" size="md" class="text-white" />
            </a>
            <a
              href="https://www.facebook.com/Pixformance"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-300 hover:scale-110"
            >
              <Icon name="facebook" size="md" class="text-white" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <NLFooter slot="footer" />
</NLBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, observerOptions);
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
