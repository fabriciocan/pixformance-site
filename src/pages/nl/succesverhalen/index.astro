---

<NLBaseLayout
  title="Succesverhalen – Klanten vertellen over Pixformance"
  description="Echte ervaringen van fysiotherapeuten, kliniekmanagers en fitness-clubeigenaren. Meer dan 1.100 vestigingen. Lees hoe Pixformance hen helpt."
  hreflangDe="https://www.pixformance.com/erfolgsgeschichten"
  hreflangEn="https://www.pixformance.com/en/success-stories/"
  jsonLd={[{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Pixformance Succesverhalen",
    "description": "Ervaringen van klanten uit fysiotherapie, klinieken, fitnessstudio's en bedrijfsgezondheidszorg over hun succes met Pixformance.",
    "url": "https://www.pixformance.com/nl/succesverhalen/",
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }]}
>
  <NLHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </NLHeader>

  <!-- Hero Section -->
  <section
    class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16"
  >
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
        </div>

        <h1
          class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight hero-animate"
          style="animation-delay: 0.2s;"
        >
          Pixformance
          <span class="text-[#02308C]"> Succesverhalen</span>
        </h1>
      </div>
    </div>
  </section>

  <!-- Fysiotherapie Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <div class="flex items-center justify-center mb-8">
          <span
            class="font-display text-2xl font-black uppercase tracking-[0.2em] text-[#02308C]"
            >Fysiotherapie</span
          >
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          physiotherapieStories.map((story, index) => (
            <Card
              variant="elevated"
              padding="none"
              class="overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 hover:scale-105 group bg-white"
              data-scroll="scale"
              data-delay={Math.min(index + 1, 6)}
            >
              <div class="relative h-64 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent z-10 group-hover:from-[#02308C]/90 transition-all duration-500" />
                <img
                  src={story.image}
                  alt={story.person}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />

                <div class="absolute top-4 left-4 z-20">
                  <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white/95 backdrop-blur-sm text-xs font-bold text-[#02308C]">
                    <Icon name="heart" size="sm" />
                    Fysiotherapie
                  </span>
                </div>

                <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                  <p class="text-white/90 text-xs font-semibold mb-2 uppercase tracking-wide">
                    {story.category}
                  </p>
                  <h3 class="font-bold text-lg text-white mb-2 line-clamp-2 group-hover:translate-x-2 transition-transform duration-300">
                    {story.title}
                  </h3>
                </div>
              </div>

              <div class="p-6 space-y-4">
                <div class="space-y-2">
                  <div class="flex items-start gap-2">
                    <Icon
                      name="user"
                      size="sm"
                      class="text-[#02308C] mt-1 flex-shrink-0"
                    />
                    <p class="text-sm font-semibold text-foreground">
                      {story.person}
                    </p>
                  </div>
                  <div class="flex items-start gap-2">
                    <Icon
                      name="map-pin"
                      size="sm"
                      class="text-[#02308C] mt-1 flex-shrink-0"
                    />
                    <p class="text-sm text-foreground-muted">
                      {story.location}
                    </p>
                  </div>
                </div>

                <Button
                  variant="primary"
                  size="sm"
                  href={`/erfolgsgeschichten/${story.id}`}
                  class="w-full group-hover:bg-[#02308C] transition-colors"
                >
                  Lees verder
                  <Icon name="arrow-right" size="sm" />
                </Button>
              </div>
            </Card>
