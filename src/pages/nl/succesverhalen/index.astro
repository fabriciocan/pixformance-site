                    <p class="text-sm text-foreground-muted">
                      {story.location}
                    </p>
                  </div>
                </div>

                <Button
                  variant="primary"
                  size="sm"
                  href={`/erfolgsgeschichten/${story.id}`}
                  class="w-full group-hover:bg-[#6BDBD1] group-hover:text-[#02308C] transition-colors"
                >
                  Lees verder
                  <Icon name="arrow-right" size="sm" />
                </Button>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"
    >
    </div>

    <div class="container relative">
      <div
        class="max-w-4xl mx-auto text-center space-y-8"
        data-scroll="fade-up"
      >
        <h2
          class="font-display text-4xl md:text-6xl font-bold text-white leading-tight"
        >
          Schrijf uw eigen succesverhaal
        </h2>

        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Sluit u aan bij onze groeiende gemeenschap van meer dan 1.100
          succesvolle vestigingen wereldwijd. Neem contact met ons op voor
          een vrijblijvend adviesgesprek.
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button
            size="lg"
            href="/nl/gratis-proef/"
            class="bg-black text-white hover:bg-black/80"
          >
            Vrijblijvend testen
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/nl/concept/"
            class="border-2 border-black text-black hover:bg-black hover:text-white"
