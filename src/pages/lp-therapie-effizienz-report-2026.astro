---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const testimonials = [
  {
    name: 'Gunter Hölig',
    role: 'Therapieleitung',
    company: 'Medical Park Bad Rodach',
    image: '/images/gunter-hoelig-pixformance.webp',
    quote: 'Wenn ein Patient für einen Moment seine Krankheit vergessen kann und einfach Spaß hat, dann ist das auch wertvoll.',
  },
  {
    name: 'Gabriele Buchstein',
    role: 'Leitende Physiotherapeutin',
    company: 'Sauerlandklinik Hachen',
    image: '/images/gabriele-buchstein-sauerlandklinik.webp',
    quote: 'Die Patienten sind begeistert und sehr motiviert. Davon profitieren auch wir als Therapeuten, da die Patienten dadurch besser und zielgerichteter ihre Übungen ausführen.',
  },
  {
    name: 'Swetlana Zimmermann & Claas Bickeböller',
    role: 'Physiotherapeutin & Inhaber',
    company: 'Schlossphysio Winterthur, Schweiz',
    image: '/images/swetlana-zimmermann-schlossphysio.webp',
    quote: 'Wir wollten ein ganzheitliches Trainingsgerät, welches möglichst viele Muskelgruppen und Bewegungsmuster bei der Sporttherapie abdecken kann. Vor allem die Flexibilität, welche man durch das digitale Trainingskonzept erhält, war für uns ein ausschlaggebender Punkt.',
  },
  {
    name: 'Volker Sutor',
    role: 'Inhaber',
    company: 'Physiotherapiezentren »Reha Rondell«',
    image: '/images/volker-sutor-pixformance.webp',
    quote: 'Ein gezieltes Gesundheitstraining mit dem virtuellen Trainer erhöht die Effizienz der Behandlung und schafft mehr Zeit für die eigentliche Betreuung meiner Patienten.',
  },
  {
    name: 'Heike Schaible',
    role: 'Inhaberin',
    company: 'Physiotherapie Praxis "Raum für Gesundheit"',
    image: '/images/heike-schaible-round.webp',
    quote: 'Ich will mit Pixformance einen zweiten Selbstzahlerbereich aufbauen und damit vor allem meinen Mitarbeitenden entgegenkommen und ihnen eine einfachere und abwechslungsreichere Arbeit bieten.',
  },
  {
    name: 'Axel-André Richter',
    role: 'Inhaber',
    company: 'Gesundheitspraxis Richter & Lopez',
    image: '/images/axel-andre-richter-lopez.webp',
    quote: 'Ich kann das neue Training ganz individuell für jeden unserer Patienten gestalten. Vom Leistungssportler bis zur Omi ist für jeden das Richtige dabei.',
  },
];

const clientLogos = [
  'Logo-Medical-Park.png',
  'Logo-Gesundheitsrondell-Reharondell.png',
  'Logo-Charite.png',
  'Logo-GiB-Gesundheit-in-Bewegung-1.png',
  'Logo-Therapiezentrum-Rombach.png',
  'Logo-Essink-Sportscentrum-1.png',
  'Logo-Femme-Fit-1.png',
  'Logo-MrsSporty-Mrs-Sporty.png',
];
---

<BaseLayout
  title="Therapie-Effizienz-Report 2026 – Jetzt kostenlos downloaden | Pixformance"
  description="Erfahren Sie im Therapie-Effizienz-Report 2026, wie digitale Bewegungsanalyse die Therapieeffizienz steigert, Therapeuten entlastet und Behandlungsergebnisse verbessert. Jetzt gratis herunterladen."
  noindex={true}
  noSitePopup={true}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Therapie-Effizienz-Report 2026",
    "description": "Pixformance Therapie-Effizienz-Report 2026: Wissenschaftlich belegte Daten zu Therapieeffizienz, Zeitersparnis und Behandlungsergebnissen.",
    "url": "https://www.pixformance.com/lp-therapie-effizienz-report-2026",
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="bg-[#02308C] py-16 md:py-24">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-4">
        <p class="text-sm md:text-base font-bold text-white/80 uppercase tracking-[0.2em] hero-animate" style="animation-delay: 0.1s;">
          Kostenloser Praxisreport 2026
        </p>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight uppercase hero-animate" style="animation-delay: 0.2s;">
          Therapie-Effizienz-Report 2026
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Messbare Ergebnisse. Wissenschaftlich belegt. Direkt aus der Praxis.
        </p>
      </div>
    </div>
  </section>

  <!-- Report Download Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-6xl mx-auto">

        <!-- Left: Report Cover Image -->
        <div class="flex items-center justify-center" data-scroll="slide-left">
          <div class="relative">
            <div class="absolute -inset-4 bg-[#02308C]/10 rounded-3xl blur-xl"></div>
            <img
              src="/images/therapie-effizienz-report-2026-cover.png"
              alt="Therapie-Effizienz-Report 2026 – Pixformance"
              class="relative w-full h-auto max-h-[480px] object-contain drop-shadow-2xl"
              loading="eager"
              onerror="this.onerror=null; this.src='/images/broschuere-lp-physio-digitalisierung.png';"
            />
          </div>
        </div>

        <!-- Right: Content + CTA -->
        <div class="space-y-8" data-scroll="slide-right">
          <div class="space-y-3">
            <h2 class="font-display text-2xl md:text-3xl font-bold leading-tight text-gray-900">
              Was Sie im Report erfahren:
            </h2>
            <p class="text-base text-gray-500 leading-relaxed">
              Konkrete Zahlen, Daten und Erfahrungen aus Kliniken, Rehazentren und Physiotherapiepraxen.
            </p>
          </div>

          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#02308C] flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="check" size="xs" class="text-white" />
              </div>
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">
                Wie digitale Bewegungsanalyse die <strong class="text-gray-900">Therapieeffizienz messbar steigert</strong> – mit konkreten Kennzahlen aus der Praxis
              </p>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#02308C] flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="check" size="xs" class="text-white" />
              </div>
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">
                Welche <strong class="text-gray-900">Zeitersparnis pro Patient</strong> Therapeuten durch den Einsatz von Pixformance erzielen
              </p>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#02308C] flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="check" size="xs" class="text-white" />
              </div>
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">
                Wissenschaftlich belegte <strong class="text-gray-900">Behandlungsergebnisse</strong> und Patientenzufriedenheit
              </p>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#02308C] flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="check" size="xs" class="text-white" />
              </div>
              <p class="text-base md:text-lg text-gray-600 leading-relaxed">
                Praxisbeispiele und <strong class="text-gray-900">Erfolgsstories</strong> aus führenden Reha- und Therapieeinrichtungen
              </p>
            </li>
          </ul>

          <div class="pt-2">
            <button
              id="download-report-btn"
              class="inline-flex items-center gap-3 px-8 py-4 bg-[#02308C] text-white font-bold text-lg rounded-full hover:bg-[#021d54] hover:scale-105 hover:shadow-xl transition-all duration-300 cursor-pointer uppercase tracking-wide"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Report kostenlos downloaden
            </button>
            <p class="text-sm text-gray-400 mt-3">Kostenlos & unverbindlich – sofort per E-Mail</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download Form Modal -->
  <div id="download-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4">
    <div id="download-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-3xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-8 md:p-10">
      <button id="download-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors cursor-pointer">
        <Icon name="x" size="md" />
      </button>

      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-[#02308C]/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#02308C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-[#02308C] mb-2">
          Report herunterladen
        </h2>
        <p class="text-foreground-muted text-sm">Füllen Sie das Formular aus und erhalten Sie den Therapie-Effizienz-Report 2026 sofort per E-Mail.</p>
      </div>

      <form id="download-form" class="space-y-4">
        <div>
          <label for="dl-firma" class="block text-sm font-bold mb-1 text-gray-700">Einrichtung / Firma <span class="text-red-500">*</span></label>
          <input type="text" id="dl-firma" name="company" required placeholder="z.B. Physiopraxis Muster" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="dl-vorname" class="block text-sm font-bold mb-1 text-gray-700">Vorname <span class="text-red-500">*</span></label>
            <input type="text" id="dl-vorname" name="first_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
          </div>
          <div>
            <label for="dl-nachname" class="block text-sm font-bold mb-1 text-gray-700">Nachname <span class="text-red-500">*</span></label>
            <input type="text" id="dl-nachname" name="last_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
          </div>
        </div>
        <div>
          <label for="dl-email" class="block text-sm font-bold mb-1 text-gray-700">E-Mail <span class="text-red-500">*</span></label>
          <input type="email" id="dl-email" name="email" required placeholder="ihre.email@beispiel.de" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div>
          <label for="dl-telefon" class="block text-sm font-bold mb-1 text-gray-700">Telefonnummer <span class="text-red-500">*</span></label>
          <input type="tel" id="dl-telefon" name="phone" required placeholder="+49" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div class="flex items-start gap-3 pt-2">
          <input type="checkbox" id="dl-privacy" name="privacy" required class="mt-1 w-5 h-5 rounded border-gray-300 text-[#02308C] focus:ring-[#02308C]/30" />
          <label for="dl-privacy" class="text-xs text-gray-600 leading-relaxed">
            Ich habe die <a href="/datenschutz" class="text-[#02308C] hover:underline font-bold">Datenschutzerklärung</a> gelesen und willige ein, dass die Pixformance Sports GmbH mir den Report und weitere Informationen per E-Mail oder Telefon zusenden darf. Die Einwilligung kann jederzeit widerrufen werden.
          </label>
        </div>
        <div id="download-form-message" class="hidden"></div>
        <button type="submit" class="w-full py-4 bg-[#02308C] text-white font-bold text-lg rounded-xl hover:bg-[#021d54] hover:shadow-lg transition-all duration-300 cursor-pointer uppercase tracking-wide">
          Report jetzt anfordern
        </button>
      </form>
    </div>
  </div>

  <!-- Stats Bar -->
  <section class="py-12 md:py-16 bg-[#02308C]">
    <div class="container">
      <div class="grid grid-cols-3 gap-4 md:gap-8 max-w-4xl mx-auto text-center">
        <div class="flex flex-col items-center space-y-2" data-scroll="fade-up">
          <div class="text-3xl md:text-5xl font-bold text-[#6BDBD1] whitespace-nowrap">2,5M+</div>
          <div class="text-xs md:text-sm text-white/70">Trainierende / Jahr</div>
        </div>
        <div class="flex flex-col items-center space-y-2" data-scroll="fade-up">
          <div class="text-3xl md:text-5xl font-bold text-[#6BDBD1] whitespace-nowrap">1.100+</div>
          <div class="text-xs md:text-sm text-white/70">Kliniken & Praxen</div>
        </div>
        <div class="flex flex-col items-center space-y-2" data-scroll="fade-up">
          <div class="text-3xl md:text-5xl font-bold text-[#6BDBD1] whitespace-nowrap">700+</div>
          <div class="text-xs md:text-sm text-white/70">Funktionelle Übungen</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Logos Carousel -->
  <section class="py-8 md:py-12 bg-white border-b border-gray-100">
    <div class="container">
      <div class="clients-track-wrapper overflow-hidden">
        <div class="clients-track flex items-center gap-12">
          {[...Array(2)].map(() =>
            clientLogos.map((logo) => (
              <img
                src={`/images/clients/${logo}`}
                alt={logo.replace(/Logo-|-\d+\.png|\.png/g, ' ').trim()}
                class="h-[100px] md:h-[132px] w-auto max-w-[165px] md:max-w-[220px] object-contain opacity-70 hover:opacity-100 transition-all duration-300 shrink-0"
                loading="lazy"
                width="220"
                height="132"
              />
            ))
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Why it matters section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12" data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-3xl font-bold text-gray-900">
            Warum Therapieeffizienz 2026 entscheidend ist
          </h2>
          <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
            Fachkräftemangel, steigende Patientenzahlen und wachsender Kostendruck – der Report zeigt, wie führende Einrichtungen diesen Herausforderungen begegnen.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center space-y-4" data-scroll="fade-up">
            <div class="w-14 h-14 mx-auto rounded-full bg-[#02308C]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#02308C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900">Zeit sparen</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Pro Patient bis zu 10 Minuten Betreuungszeit einsparen – bei gleichbleibender oder höherer Behandlungsqualität.</p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center space-y-4" data-scroll="fade-up">
            <div class="w-14 h-14 mx-auto rounded-full bg-[#02308C]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#02308C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900">Ergebnisse verbessern</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Messbar bessere Behandlungsergebnisse durch KI-gestütztes Echtzeit-Feedback und präzise Bewegungsanalyse.</p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center space-y-4" data-scroll="fade-up">
            <div class="w-14 h-14 mx-auto rounded-full bg-[#02308C]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#02308C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900">Umsatz steigern</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Mehr Kapazität durch digitale Betreuung – mehr Patienten, mehr Selbstzahlerangebote, mehr Einnahmen.</p>
          </div>
        </div>

        <div class="text-center mt-10">
          <button
            id="download-report-btn-2"
            class="inline-flex items-center gap-3 px-8 py-4 bg-[#02308C] text-white font-bold text-lg rounded-full hover:bg-[#021d54] hover:scale-105 hover:shadow-xl transition-all duration-300 cursor-pointer uppercase tracking-wide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Report jetzt kostenlos herunterladen
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Carousel Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-10" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold text-gray-900">
          Was Therapeuten & Kliniken sagen
        </h2>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="relative" id="testimonial-carousel">
          {testimonials.map((testimonial, index) => (
            <div
              class={`testimonial-slide text-center space-y-6 ${index === 0 ? '' : 'hidden'}`}
              data-slide={index}
            >
              <div class="flex justify-center">
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="w-32 h-32 rounded-full object-cover border-4 border-[#6BDBD1] shadow-lg"
                  loading="lazy"
                  width="128"
                  height="128"
                />
              </div>
              <blockquote class="text-lg md:text-xl text-gray-600 leading-relaxed italic max-w-3xl mx-auto">
                &laquo; {testimonial.quote} &raquo;
              </blockquote>
              <div>
                <p class="font-bold text-lg text-gray-900">{testimonial.name}</p>
                <p class="text-gray-500">{testimonial.role}, {testimonial.company}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-8" id="testimonial-dots">
          {testimonials.map((_, index) => (
            <button
              class={`w-3 h-3 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? 'bg-[#02308C] scale-110' : 'bg-gray-300 hover:bg-gray-400'}`}
              data-dot={index}
              aria-label={`Testimonial ${index + 1}`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-16 md:py-24 bg-[#02308C]">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center space-y-6" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold text-white">
          Jetzt Report kostenlos herunterladen
        </h2>
        <p class="text-lg text-white/80">
          Erfahren Sie, wie führende Therapieeinrichtungen ihre Effizienz mit Pixformance auf das nächste Level heben.
        </p>
        <button
          id="download-report-btn-3"
          class="inline-flex items-center gap-3 px-10 py-5 bg-white text-[#02308C] font-bold text-lg rounded-full hover:bg-gray-100 hover:scale-105 hover:shadow-xl transition-all duration-300 cursor-pointer uppercase tracking-wide"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Report herunterladen
        </button>
        <p class="text-sm text-white/60">Kostenlos & unverbindlich</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }

  .clients-track {
    animation: scroll-logos 25s linear infinite;
    width: max-content;
  }

  .clients-track-wrapper:hover .clients-track {
    animation-play-state: paused;
  }

  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  [data-scroll].is-visible {
    opacity: 1;
  }

  [data-scroll="fade-up"] {
    transform: translateY(30px);
  }

  [data-scroll="fade-up"].is-visible {
    transform: translateY(0);
  }

  [data-scroll="slide-left"] {
    transform: translateX(-40px);
  }

  [data-scroll="slide-left"].is-visible {
    transform: translateX(0);
  }

  [data-scroll="slide-right"] {
    transform: translateX(40px);
  }

  [data-scroll="slide-right"].is-visible {
    transform: translateX(0);
  }

  .testimonial-slide {
    transition: opacity 0.5s ease-in-out;
  }

  #download-modal.flex {
    animation: popup-in 0.3s ease-out;
  }

  @keyframes popup-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  #download-modal.flex > div:last-child {
    animation: popup-slide 0.3s ease-out;
  }

  @keyframes popup-slide {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>

<script>
  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));

  // Testimonial Carousel
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('#testimonial-dots button');
  let currentSlide = 0;
  let autoplayInterval: ReturnType<typeof setInterval>;

  function showSlide(index: number) {
    slides.forEach((slide) => slide.classList.add('hidden'));
    dots.forEach((dot) => {
      dot.classList.remove('bg-[#02308C]', 'scale-110');
      dot.classList.add('bg-gray-300');
    });
    slides[index]?.classList.remove('hidden');
    dots[index]?.classList.remove('bg-gray-300');
    dots[index]?.classList.add('bg-[#02308C]', 'scale-110');
    currentSlide = index;
  }

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => { showSlide(index); resetAutoplay(); });
  });

  function nextSlide() { showSlide((currentSlide + 1) % slides.length); }
  function resetAutoplay() { clearInterval(autoplayInterval); autoplayInterval = setInterval(nextSlide, 6000); }
  autoplayInterval = setInterval(nextSlide, 6000);

  // Modal
  const downloadModal = document.getElementById('download-modal');
  const downloadOverlay = document.getElementById('download-overlay');
  const downloadClose = document.getElementById('download-close');
  const downloadBtns = [
    document.getElementById('download-report-btn'),
    document.getElementById('download-report-btn-2'),
    document.getElementById('download-report-btn-3'),
  ];

  function openModal() {
    downloadModal?.classList.remove('hidden');
    downloadModal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    downloadModal?.classList.add('hidden');
    downloadModal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  downloadBtns.forEach((btn) => btn?.addEventListener('click', openModal));
  downloadOverlay?.addEventListener('click', closeModal);
  downloadClose?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Form submission
  const WEBHOOK_URL = 'https://webhook.pixformance.com/webhook/site-forms';
  let META_EVENT_ID = '';

  function initEventId() {
    (window as any).dataLayer = (window as any).dataLayer || [];
    const dl = (window as any).dataLayer as any[];
    for (let i = dl.length - 1; i >= 0; i--) {
      if (dl[i]?.event_id) { META_EVENT_ID = dl[i].event_id; return; }
    }
    META_EVENT_ID = Date.now() + '_' + Math.floor(Math.random() * 1e15);
    dl.push({ event: 'meta_event_id_ready', event_id: META_EVENT_ID });
  }

  function sha256(value: string): Promise<string> {
    const encoded = new TextEncoder().encode((value || '').toLowerCase().trim());
    return crypto.subtle.digest('SHA-256', encoded).then((buffer) =>
      Array.from(new Uint8Array(buffer)).map((b) => b.toString(16).padStart(2, '0')).join('')
    );
  }

  function normalizePhone(phone: string | null): string {
    let cleaned = (phone || '').trim().replace(/[\s\-().]/g, '');
    if (cleaned && !cleaned.startsWith('+')) cleaned = '+49' + cleaned.replace(/^0/, '');
    return cleaned;
  }

  function hashUserData(formData: FormData) {
    const email = ((formData.get('email') as string) || '').toLowerCase().trim();
    const phone = normalizePhone(formData.get('phone') as string | null);
    const firstName = ((formData.get('first_name') as string) || '').toLowerCase().trim();
    const lastName = ((formData.get('last_name') as string) || '').toLowerCase().trim();
    return Promise.all([
      email     ? sha256(email)     : Promise.resolve(''),
      phone     ? sha256(phone)     : Promise.resolve(''),
      firstName ? sha256(firstName) : Promise.resolve(''),
      lastName  ? sha256(lastName)  : Promise.resolve(''),
    ]).then(([em, ph, fn, ln]) => ({ em, ph, fn, ln }));
  }

  function getUrlParams() {
    const params: Record<string, string> = {};
    new URLSearchParams(window.location.search).forEach((value, key) => { params[key] = value; });
    return params;
  }

  function getCookies() {
    const cookies: Record<string, string> = {};
    if (!document.cookie) return cookies;
    document.cookie.split(';').forEach((cookie) => {
      const idx = cookie.indexOf('=');
      if (idx === -1) return;
      const key = cookie.slice(0, idx).trim();
      const value = cookie.slice(idx + 1).trim();
      try { cookies[key] = decodeURIComponent(value); } catch { cookies[key] = value; }
    });
    return cookies;
  }

  function getFbp(cookies: Record<string, string>): string { return cookies._fbp || ''; }

  function getFbc(cookies: Record<string, string>): string {
    const fbclid = new URLSearchParams(window.location.search).get('fbclid');
    if (fbclid) {
      const subdomainIndex = window.location.hostname.startsWith('www.') ? 2 : 1;
      return 'fb.' + subdomainIndex + '.' + Date.now() + '.' + fbclid;
    }
    return cookies._fbc || '';
  }

  function sanitizePhone(phone: string | null): string {
    return (phone || '').replace(/[^\d\s+\-()]/g, '').trim();
  }

  initEventId();

  const downloadForm = document.getElementById('download-form') as HTMLFormElement;
  const formMessage = document.getElementById('download-form-message');

  downloadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = downloadForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.7'; }

    const formData = new FormData(downloadForm);
    const cookies = getCookies();
    const computedFbc = getFbc(cookies);
    const computedFbp = getFbp(cookies);
    if (computedFbc) cookies._fbc = computedFbc;
    if (computedFbp) cookies._fbp = computedFbp;

    let hashed = { em: '', ph: '', fn: '', ln: '' };
    try { hashed = await hashUserData(formData); } catch {}

    let pixConsent: any = null;
    try { pixConsent = JSON.parse(localStorage.getItem('pix_consent') || 'null'); } catch {}
    if (pixConsent && pixConsent.marketing) {
      ((window as any).dataLayer as any[]).push({
        event: 'meta_user_data_ready',
        em: hashed.em, ph: hashed.ph, fn: hashed.fn, ln: hashed.ln,
      });
    }

    try {
      const payload = {
        form_name: 'LP Therapie-Effizienz-Report 2026 – Download',
        company: formData.get('company') || '',
        first_name: formData.get('first_name') || '',
        last_name: formData.get('last_name') || '',
        email: formData.get('email') || '',
        phone: sanitizePhone(formData.get('phone') as string | null),
        privacy_accepted: formData.get('privacy') === 'on',
        page_url: window.location.href,
        page_path: window.location.pathname,
        referrer: document.referrer || '',
        submitted_at: new Date().toISOString(),
        url_params: getUrlParams(),
        cookies,
        language: 'de',
        version: 'DACH',
        form_source: 'landing-page',
        meta_event_id: META_EVENT_ID,
        meta_fbp: getFbp(cookies),
        meta_fbc: getFbc(cookies),
        meta_user_agent: navigator.userAgent,
        meta_event_source_url: window.location.href,
        meta_em: hashed.em,
        meta_ph: hashed.ph,
        meta_fn: hashed.fn,
        meta_ln: hashed.ln,
      };

      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        window.location.href = '/lp-therapie-effizienz-report-2026-danke';
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (formMessage) {
        formMessage.className = 'text-center text-red-700 bg-red-50 border border-red-200 rounded-xl p-4';
        formMessage.textContent = 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.';
        formMessage.classList.remove('hidden');
      }
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = ''; }
    }
  });
</script>
