---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
---

<BaseLayout title="Seite nicht gefunden | Pixformance" noindex={true} noSitePopup={true}>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <section class="py-24 md:py-32">
    <div class="container max-w-2xl text-center">
      <p class="font-display text-7xl md:text-8xl font-bold text-[#02308C] mb-6">404</p>
      <h1 class="font-display text-2xl md:text-3xl font-bold mb-4">
        Seite nicht gefunden
      </h1>
      <p class="text-lg text-foreground-muted mb-2">
        Die angeforderte Seite existiert nicht oder wurde verschoben.
      </p>
      <p class="text-sm text-foreground-muted mb-10">
        Page not found — the requested page does not exist or has been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white font-bold text-sm hover:bg-[#6BDBD1] hover:text-[#02308C] transition-colors duration-200">
          Zur Startseite
        </a>
        <a href="/kontakt" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-[#02308C]/30 text-[#02308C] font-bold text-sm hover:bg-[#02308C]/5 transition-colors duration-200">
          Kontakt
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
