---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'PHYSIOTHERAPIE', href: '/physiotherapie' },
  { label: 'KLINIK', href: '/klinik' },
  { label: 'FITNESS', href: '/fitness' },
  { label: 'BGM', href: '/firmen-fitness' },
];

const stats = [
  { value: '2.5M+', count: 0, suffix: '+', label: 'Trainierende / Jahr', icon: 'users' },
  { value: '1.100+', count: 1100, suffix: '+', label: 'Kliniken & Rehazentren', icon: 'globe' },
  { value: '700+', count: 700, suffix: '+', label: 'Funktionelle Übungen', icon: 'zap' },
];

const features = [
  {
    icon: 'eye',
    title: '2D Full-HD Kamera',
    description: 'Erfasst 25 Gelenkpunkte in Echtzeit für präzise Bewegungsanalyse — ohne Sensoren oder Wearables am Patienten.',
  },
  {
    icon: 'monitor',
    title: 'Virtueller Trainer',
    description: 'Zeigt Übungen auf dem 43"-Display vor und gibt sofortiges visuelles Feedback — Patienten trainieren selbstständig unter Aufsicht.',
  },
  {
    icon: 'zap',
    title: 'Echtzeit-Korrektur',
    description: 'Sofortiges Korrekturfeedback zur Bewegungsausführung während des Trainings sichert Qualität und Sicherheit für jeden Patienten.',
  },
];

const benefits = [
  {
    icon: 'users',
    title: 'Patientenaktivierung',
    description: 'Motivierende digitale Trainingsumgebung mit spielerischen Elementen steigert die aktive Teilnahme und Therapietreue der Patienten messbar.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
  {
    icon: 'heart',
    title: 'Personalentlastung',
    description: 'Therapeuten überwachen mehrere Patienten gleichzeitig und konzentrieren sich auf manuelle Therapie und komplexe Fälle — Pixformance übernimmt das Standardtraining.',
    gradient: 'from-[#6BDBD1] to-[#02308C]',
  },
  {
    icon: 'trending-up',
    title: 'Skalierbarkeit',
    description: 'Bis zu 4 Patienten gleichzeitig an mehreren Stationen betreuen — mit patentierter Software ohne zusätzlichen Personalaufwand, bei gleichbleibender Betreuungsqualität.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
  {
    icon: 'file-text',
    title: 'Automatische Dokumentation',
    description: 'Übungsausführung, Pixformance Score und Fortschritt werden automatisch auf der Online Plattform gespeichert — keine manuelle Aufzeichnung, vollständige Trainingshistorie für Kostenträger.',
    gradient: 'from-[#6BDBD1] to-[#86C9BC]',
  },
  {
    icon: 'check-circle',
    title: 'Therapietreue',
    description: 'Gamification-Elemente und sofortiges Feedback erhöhen die intrinsische Motivation — Patienten halten Programme länger durch und führen Übungen korrekter aus.',
    gradient: 'from-[#86C9BC] to-[#02308C]',
  },
  {
    icon: 'shield',
    title: 'Qualitätssicherung',
    description: 'Standardisierte Übungsausführung durch Echtzeit-Korrekturfeedback sichert gleichbleibende Behandlungsqualität — unabhängig von der Personalauslastung.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
];

const clinicalTestimonials = [
  {
    quote: 'Die Patienten sind begeistert und hochmotiviert, was zugegebenermaßen nicht oft der Fall ist. Natürlich profitieren auch wir als Therapeuten davon, denn die Patienten führen ihre Übungen dadurch besser und zielgerichteter aus. Außerdem sparen wir Zeit, denn nach nur 30 Minuten Einweisung können die Patienten selbstständig unter Aufsicht trainieren.',
    name: 'Gabriele Buchstein',
    role: 'Leitende Physiotherapeutin',
    company: 'Sauerlandklinik Hachen – Neurologische Fachklinik für MS',
    image: '/images/Gabriele-Buchstein-Leitung-Physiotherapie-Sauerlandklinik-Hachen.png',
  },
  {
    quote: 'Auf der Suche nach einer Möglichkeit, die Patienten selbstständig aktiv werden zu lassen, haben wir uns für Pixformance entschieden. Das individuelle Trainingsangebot ist hier ideal, da Gruppentherapie für manche Patienten zu leicht und für andere zu schwer ist. So bekommt jeder ein komplett individuelles Training.',
    name: 'Christoph Schneider',
    role: 'Therapieleiter',
    company: 'Niederrhein-Klinik Korschenbroich',
    image: '/images/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich-Pixformance.png',
  },
  {
    quote: 'Von Patientenseite kommt ein großes Interesse an den Pixformance Stationen. Viele kommen von sich aus und wollen ein Trainingsprogramm. Wir haben kürzlich eine junge Frau nach Schulteroperation tele-gestützt begleitet. Sie kommt einmal pro Woche in die Klinik — den Rest der Therapie macht sie zu Hause. Das ist eine wirklich tolle Option.',
    name: 'Christoph Oratsch',
    role: 'Leitung Therapie',
    company: 'AUVA Unfallkrankenhaus Klagenfurt',
    image: '/images/Christoph-Oratsch-AUVA-Klagenfurt-1.png',
  },
  {
    quote: 'Wir freuen uns zu beobachten, dass unsere Patienten das Bewegungstraining sehr genießen und durchhalten. Die spielerische Komponente spielt dabei sicher eine Rolle — und wenn unsere Patienten die Krankheit für einen Moment vergessen und einfach Spaß haben, ist das äußerst wertvoll.',
    name: 'Gunter Hölig',
    role: 'Therapieleiter',
    company: 'Medical Park Bad Rodach',
    image: '/images/en/Logo-Medical-Park.png',
  },
];

const clientLogos = [
  { name: 'Charité Berlin', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA Unfallkrankenhaus', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'FORTEe EU-Projekt', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
];

const faqItems = [
  {
    question: 'Wie kann Pixformance den Therapiebetrieb in einer Rehaklinik effizienter gestalten?',
    answer: 'Mehrere Patienten können gleichzeitig an Pixformance Stationen trainieren ohne dauerhaften Therapeuteneinsatz. Jeder Patient scannt seinen QR-Code und startet automatisch sein individuelles Programm. Therapeuten überwachen mehrere Patienten gleichzeitig und können sich auf manuelle Therapie und komplexe Fälle konzentrieren. Die automatische Dokumentation aller Trainingsdaten auf der Online Plattform ersetzt manuelle Aufzeichnungen.',
  },
  {
    question: 'Für welche Indikationen und Rehabilitationsphasen ist Pixformance geeignet?',
    answer: 'Pixformance eignet sich für alle Rehabilitationsphasen: neurologische Reha (MS, Parkinson, Schlaganfall), orthopädische Reha (Hüfte, Knie, Schulter, Wirbelsäule postoperativ), onkologische Reha (Erwachsene und Kinder via FORTEe), geriatrische Reha (Sturzprävention, Gleichgewicht), kardiologische Reha (unter ärztlicher Aufsicht) und allgemeine Aktivierung stationärer Patienten. Übungen können für Patienten im Rollstuhl, mit Gehbarren oder auf der Liege angepasst werden.',
  },
  {
    question: 'Wie viele Patienten können gleichzeitig mit Pixformance betreut werden?',
    answer: 'Mit der patentierten Software können bis zu 4 Patienten gleichzeitig an mehreren Stationen trainieren, ohne dass für jede Station ein Therapeut präsent sein muss. Ein Therapeut kann den gesamten Bereich überwachen während alle Patienten individuell angeleitet werden.',
  },
  {
    question: 'Wie funktioniert die Trainingsdokumentation für die Klinik?',
    answer: 'Alle Trainingsdaten werden automatisch auf der Pixformance Online Plattform gespeichert: Übungsausführung, Wiederholungen, Pixformance Score pro Session, Fortschritt über den Behandlungszeitraum. Therapeuten haben jederzeit Zugriff auf die vollständige Trainingshistorie jedes Patienten. Dies unterstützt die klinische Berichterstattung, Qualitätssicherung und Dokumentation für Kostenträger.',
  },
  {
    question: 'Ist Pixformance für die stationäre und ambulante Rehabilitation geeignet?',
    answer: 'Ja. Pixformance wird sowohl in der stationären als auch in der ambulanten Rehabilitation eingesetzt. Für stationäre Patienten ermöglicht die Station mehrfaches tägliches Training ohne Therapeuteneinsatz. Für ambulante Patienten ermöglicht die Pixformance Web App die Fortsetzung des Therapieprogramms zu Hause zwischen den Klinikterminen — ein hybrides Modell das das AUVA Unfallkrankenhaus Klagenfurt aktiv nutzt.',
  },
  {
    question: 'Welche klinischen Studien und Referenzen gibt es für Pixformance?',
    answer: 'Die Hochschule Fresenius hat klinische Studien mit Pixformance zu MS, Parkinson, Muskeldystrophie und Brustkrebsnachsorge durchgeführt. Pixformance ist EU-Forschungspartner im FORTEe-Projekt für Bewegungstherapie bei krebskranken Kindern. Das System ist im klinischen Einsatz in der Charité Berlin, Medical Park Bad Rodach, Niederrhein-Klinik, Sauerlandklinik Hachen, AUVA Klagenfurt, Mediclin und Oxford Brookes University. Pixformance wurde im FOCUS Gesundheit (Dez./Jan. 2018/19) unter Deutschlands Top-Rehakliniken vorgestellt.',
  },
  {
    question: 'Ist Pixformance ein zertifiziertes Medizinprodukt?',
    answer: 'Ja. Pixformance ist in den USA als Klasse-2-Medizinprodukt (RX) von der FDA zugelassen. Das Gerät erfüllt die EMV-Richtlinie 2004/108/EG und wird seit 2012 unter strengen Qualitäts- und Sicherheitskontrollen gefertigt. Patienten mit Herzschrittmacher oder schwerwiegenden kardiovaskulären Erkrankungen sollten vor dem Training einen Arzt konsultieren.',
  },
  {
    question: 'Was kostet Pixformance für eine Klinik und welche Finanzierungsmodelle gibt es?',
    answer: 'Pixformance ist sowohl als Kauf als auch als Leasing verfügbar. Für Kliniken sind individuelle Konditionen je nach Anzahl der Stationen und Einrichtungsgröße möglich. Kontaktieren Sie unser Team für ein unverbindliches Angebot. Eine persönliche Beratung inklusive Raumplanung, Installation und Therapeutenschulung ist im Service enthalten.',
  },
];
---

<BaseLayout
  title="Digitale Bewegungstherapie für Rehakliniken & Krankenhäuser | Pixformance"
  description="Pixformance ist das digitale Reha-System für Kliniken: Bis zu 4 Patienten gleichzeitig, automatische Dokumentation, 25-Gelenkpunkt-Analyse in Echtzeit. 1.100+ Rehakliniken vertrauen auf Pixformance. FDA Klasse 2 Medizinprodukt."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Pixformance Station",
      "description": "Digitales Rehabilitationssystem für Rehakliniken und Krankenhäuser. 2D Full-HD Kamera mit Tiefensensor analysiert 25 Gelenkpunkte in Echtzeit. Bis zu 4 Patienten können gleichzeitig an mehreren Stationen trainieren. Automatische Trainingsdokumentation auf der Online Plattform. FDA Klasse 2 Medizinprodukt.",
      "manufacturer": { "@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com" },
      "legalStatus": "FDA Klasse 2 Medizinprodukt",
      "relevantSpecialty": ["Rehabilitation", "Neurologie", "Orthopädie", "Onkologie", "Geriatrie", "Sportmedizin"]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Wie kann Pixformance den Therapiebetrieb in einer Rehaklinik effizienter gestalten?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mehrere Patienten können gleichzeitig an Pixformance Stationen trainieren ohne dauerhaften Therapeuteneinsatz. Jeder Patient scannt seinen QR-Code und startet automatisch sein individuelles Programm. Therapeuten überwachen mehrere Patienten gleichzeitig und können sich auf manuelle Therapie und komplexe Fälle konzentrieren. Die automatische Dokumentation aller Trainingsdaten auf der Online Plattform ersetzt manuelle Aufzeichnungen."
          }
        },
        {
          "@type": "Question",
          "name": "Für welche Indikationen und Rehabilitationsphasen ist Pixformance geeignet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pixformance eignet sich für alle Rehabilitationsphasen: neurologische Reha (MS, Parkinson, Schlaganfall), orthopädische Reha (Hüfte, Knie, Schulter, Wirbelsäule postoperativ), onkologische Reha (Erwachsene und Kinder via FORTEe), geriatrische Reha (Sturzprävention, Gleichgewicht), kardiologische Reha (unter ärztlicher Aufsicht) und allgemeine Aktivierung stationärer Patienten. Übungen können für Patienten im Rollstuhl, mit Gehbarren oder auf der Liege angepasst werden."
          }
        },
        {
          "@type": "Question",
          "name": "Wie viele Patienten können gleichzeitig mit Pixformance betreut werden?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mit der patentierten Software können bis zu 4 Patienten gleichzeitig an mehreren Stationen trainieren, ohne dass für jede Station ein Therapeut präsent sein muss. Ein Therapeut kann den gesamten Bereich überwachen während alle Patienten individuell angeleitet werden."
          }
        },
        {
          "@type": "Question",
          "name": "Wie funktioniert die Trainingsdokumentation für die Klinik?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Alle Trainingsdaten werden automatisch auf der Pixformance Online Plattform gespeichert: Übungsausführung, Wiederholungen, Pixformance Score pro Session, Fortschritt über den Behandlungszeitraum. Therapeuten haben jederzeit Zugriff auf die vollständige Trainingshistorie jedes Patienten. Dies unterstützt die klinische Berichterstattung, Qualitätssicherung und Dokumentation für Kostenträger."
          }
        },
        {
          "@type": "Question",
          "name": "Ist Pixformance für die stationäre und ambulante Rehabilitation geeignet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja. Pixformance wird sowohl in der stationären als auch in der ambulanten Rehabilitation eingesetzt. Für stationäre Patienten ermöglicht die Station mehrfaches tägliches Training ohne Therapeuteneinsatz. Für ambulante Patienten ermöglicht die Pixformance Web App die Fortsetzung des Therapieprogramms zu Hause zwischen den Klinikterminen — ein hybrides Modell das das AUVA Unfallkrankenhaus Klagenfurt aktiv nutzt."
          }
        },
        {
          "@type": "Question",
          "name": "Welche klinischen Studien und Referenzen gibt es für Pixformance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die Hochschule Fresenius hat klinische Studien mit Pixformance zu MS, Parkinson, Muskeldystrophie und Brustkrebsnachsorge durchgeführt. Pixformance ist EU-Forschungspartner im FORTEe-Projekt für Bewegungstherapie bei krebskranken Kindern. Das System ist im klinischen Einsatz in der Charité Berlin, Medical Park Bad Rodach, Niederrhein-Klinik, Sauerlandklinik Hachen, AUVA Klagenfurt, Mediclin und Oxford Brookes University. Pixformance wurde im FOCUS Gesundheit (Dez./Jan. 2018/19) unter Deutschlands Top-Rehakliniken vorgestellt."
          }
        },
        {
          "@type": "Question",
          "name": "Ist Pixformance ein zertifiziertes Medizinprodukt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja. Pixformance ist in den USA als Klasse-2-Medizinprodukt (RX) von der FDA zugelassen. Das Gerät erfüllt die EMV-Richtlinie 2004/108/EG und wird seit 2012 unter strengen Qualitäts- und Sicherheitskontrollen gefertigt. Patienten mit Herzschrittmacher oder schwerwiegenden kardiovaskulären Erkrankungen sollten vor dem Training einen Arzt konsultieren."
          }
        },
        {
          "@type": "Question",
          "name": "Was kostet Pixformance für eine Klinik und welche Finanzierungsmodelle gibt es?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pixformance ist sowohl als Kauf als auch als Leasing verfügbar. Für Kliniken sind individuelle Konditionen je nach Anzahl der Stationen und Einrichtungsgröße möglich. Kontaktieren Sie unser Team für ein unverbindliches Angebot. Eine persönliche Beratung inklusive Raumplanung, Installation und Therapeutenschulung ist im Service enthalten."
          }
        }
      ]
    }
  ]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/klinik/" />
    <link rel="alternate" hreflang="en" href="https://www.pixformance.com/en/clinic/" />
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/clinique/" />
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/kliniek/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/clinica/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/clinic/" />
  </Fragment>

  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Breadcrumb Tabs -->
  <BreadcrumbTabs tabs={tabs} activeTab="/klinik" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 hover:border-[#02308C]/30 transition-all duration-300 cursor-pointer">
            <Icon name="zap" size="sm" />
            FDA Klasse 2 Medizinprodukt · 1.100+ Rehakliniken weltweit
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Digitale Rehabilitation, die Ihre Klinik effizienter macht — ohne Abstriche bei der Betreuungsqualität
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Pixformance ist das digitale Bewegungstherapiesystem für Rehakliniken und Krankenhäuser: In über 1.100 Kliniken und Rehabilitationszentren weltweit entlastet die Pixformance Station Therapeuten, aktiviert Patienten und dokumentiert Therapieverläufe automatisch. Mit einer 2D Full-HD Kamera analysiert die Station in Echtzeit 25 Gelenkpunkte jedes Patienten und gibt sofortiges Korrekturfeedback — als FDA Klasse 2 Medizinprodukt im klinischen Einsatz in der Charité Berlin, Medical Park, AUVA und Oxford Brookes University.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button
            size="lg"
            href="/testen"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Jetzt unverbindlich beraten lassen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/konzept"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Konzept ansehen
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-4 sm:p-6 rounded-2xl hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate" style={`animation-delay: ${0.6 + index * 0.1}s;`}>
              <div
                class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300 stat-counter"
                data-count={stat.count}
                data-suffix={stat.suffix}
                data-large={stat.count >= 10000 ? 'true' : 'false'}
              >
                {stat.value}
              </div>
              <div class="text-xs sm:text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos Section -->
  <section class="py-8 md:py-12 bg-gray-50 border-y border-gray-100">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-8" data-scroll="fade-up">
        Vertraut von führenden Rehakliniken und Krankenhäusern
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12" data-scroll="fade-up">
        {clientLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid — Die Pixformance Station -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="layers" size="sm" />
          Voll vernetztes System
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Die Pixformance Station
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Modernste Bewegungsanalyse verbindet sich mit therapeutischer Expertise — für eine Rehabilitation, die Ihren Patienten zugute kommt und Ihr Team entlastet.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {features.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 rounded-xl bg-[#02308C] flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-xl mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Indications Section -->
  <section class="py-12 md:py-20 bg-[#02308C]/5 border-y border-[#02308C]/10">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-10">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="activity" size="sm" />
            Klinische Anwendung
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
            Indikationen und Rehabilitationsphasen
          </h2>
          <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
            Pixformance eignet sich für alle stationären und ambulanten Rehabilitationsphasen. Übungen können für Patienten im Rollstuhl, mit Gehbarren, auf der Liege oder auf dem Boden angepasst werden.
