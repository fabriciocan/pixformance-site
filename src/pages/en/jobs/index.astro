---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<ENBaseLayout
  title="Fitness Innovation Jobs - Pixformance Sports"
  description="Join Pixformance — pioneers of functional fitness innovation. We are always looking for creative and highly motivated people with interesting and provocative ideas."
  hreflangDe="https://neu.pixformance.com/jobs/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <!-- Hero -->
  <section class="py-16 md:py-32 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-6">
        <span class="text-sm font-bold uppercase tracking-widest text-[#6BDBD1]">Jobs</span>
        <!-- Desktop headline -->
        <h1 class="hidden md:block font-display text-4xl md:text-6xl font-bold leading-tight">
          Chronically curious about Fitness innovation?<br />
          <span class="text-[#6BDBD1]">Good, So are we.</span>
        </h1>
        <!-- Mobile headline -->
        <h1 class="md:hidden font-display text-4xl font-bold leading-tight">
          Chronically curious about digital functional fitness and training?<br />
          <span class="text-[#6BDBD1]">Good, So are we.</span>
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          At Pixformance diversity isn't just something we talk about, it's who we are.
        </p>
      </div>
    </div>
  </section>

  <!-- Body Content -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto space-y-8">
        <p class="text-lg text-foreground-muted leading-relaxed">
          As pioneers of functional fitness innovation, we are always on the lookout for creative and highly motivated people with interesting and provocative ideas, courageous perspectives, and unwavering curiosity.
        </p>
        <p class="text-lg text-foreground-muted leading-relaxed">
          We link the unique experiences of each employee to shape our common vision of the future. Our corporate culture revolves around the continuous professional and personal development of each individual while we courageously seek to drive change in this modern world.
        </p>

        <div class="rounded-2xl bg-gray-50 border border-border p-8 space-y-4" data-scroll="fade-up">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-xl bg-[#02308C]/10 flex items-center justify-center">
              <Icon name="briefcase" size="sm" class="text-[#02308C]" />
            </div>
            <h2 class="font-display text-2xl font-bold">Open Positions</h2>
          </div>
          <p class="font-bold text-lg">There are no open job positions.</p>
          <p class="text-foreground-muted">
            Feel free to send us your unsolicited application to{' '}
            <a href="mailto:jobs@pixformance.com" class="text-[#02308C] font-semibold hover:underline">
              jobs@pixformance.com
            </a>.
          </p>
        </div>

        <div class="pt-4" data-scroll="fade-up">
          <Button href="/en/contact/">
            Contact Us
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
