---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ENBaseLayout
  title="Patient Retention in Physiotherapy with Digital Functional Training – Gesundheitsrondell - Pixformance"
  description="Volker Sutor from Gesundheitsrondell explains how digital functional training with Pixformance strengthens patient retention and turns patients into long-term members."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Patient Retention in Physiotherapy with Digital Training – Gesundheitsrondell",
    "description": "Volker Sutor explains how digital training with Pixformance strengthens patient retention and turns patients into long-term members.",
    "url": "https://pixformance.com/en/success-stories/volker-sutor",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <ENHeader slot="header" position="sticky" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" />
            Back to Overview
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="heart" size="sm" />
            Physical Therapy
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Patient retention in physiotherapy with digital functional training
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            How Gesundheitsrondell uses Pixformance to retain patients long-term and unlock new revenue streams
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <p class="text-lg text-foreground-muted leading-relaxed mb-8">
          <strong class="text-foreground">Gesundheitsrondell, with its multiple physiotherapy and rehabilitation centers in the Heilbronn-Franken region,</strong> is one of the largest outpatient therapy providers in southern Germany. With over 90 employees at multiple locations – including Brackenheim, Neckarsulm and Heilbronn – the company has been caring for thousands of patients annually since 1999. Owner Volker Sutor explains how digital functional training with Pixformance strengthens patient retention and opens new economic perspectives.
        </p>

        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-lg">
            "We wanted to be able to offer our patients something after classic physiotherapy that would keep them with us long-term – and at the same time deliver measurable therapy results."
          </p>
          <p class="text-sm text-foreground-muted mt-2">— Volker Sutor, Owner Gesundheitsrondell</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/Volker-Sutor-Portrait.png"
                alt="Volker Sutor – Owner Gesundheitsrondell"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Volker Sutor</h2>
              <p class="text-xl text-[#02308C] font-semibold">Owner – Gesundheitsrondell</p>
            </div>

            <Card variant="elevated" padding="lg" class="bg-white">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="briefcase" size="md" class="text-[#02308C]" />
                Practice Profile
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3">
                  <Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Locations</p>
                    <p class="text-sm">Brackenheim, Neckarsulm, Heilbronn and others</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Founded</p>
                    <p class="text-sm">1999</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Staff</p>
                    <p class="text-sm">90–100 employees</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Focus</p>
                    <p class="text-sm">Physiotherapy, rehabilitation, movement therapy, self-pay offerings</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Logo</p>
                    <img src="/images/erfolgsgeschichten/gesundheitsrondell_logo.png" alt="Gesundheitsrondell Logo" class="h-8 mt-1 object-contain" loading="lazy" />
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            The motivation: retaining patients long-term
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              As one of the first decisions when developing additional offerings, Volker Sutor recognized that physiotherapy needed a concept that goes beyond classic insurance-covered services. Patients who have no reason to return to the practice after completing therapy are lost – both as clients and in terms of their physical health.
            </p>

            <p class="text-base md:text-lg">
              With the Pixformance system, Gesundheitsrondell found a training concept suitable for both active therapy support and aftercare and prevention. Patients train under digital guidance, are accompanied by the system in correct movement execution – and can thus continue training independently and effectively, even when no therapist is standing directly beside them.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "Pixformance is for us the link between therapy and the long-term health of our patients. It closes the gap between the end of the prescription and an active, healthy lifestyle."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Volker Sutor</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img
            src="/images/erfolgsgeschichten/Volker-Sutor-Gesundheitsrondell-Training-an-Pixformance.png"
            alt="Training at the Pixformance station at Gesundheitsrondell"
            class="w-full h-auto max-h-[380px] object-cover object-center"
            loading="lazy"
          />
        </Card>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 text-center">Volker Sutor in Interview</h2>
        <p class="text-center text-foreground-muted mb-8">
          Hear directly how Gesundheitsrondell strengthens patient retention with Pixformance.
        </p>
        <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.12);">
          <iframe
            src="https://www.youtube.com/embed/iXq8-xyXboc"
            title="Volker Sutor – Gesundheitsrondell – Pixformance Success Story"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Economic results and new opportunities</h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              The integration of Pixformance has opened new economic perspectives for Gesundheitsrondell. By building up a self-pay sector, the locations were able to diversify their revenue while simultaneously increasing space utilization – without having to proportionally increase staffing.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "The self-pay area with Pixformance has become a genuine economic mainstay for us. We are less dependent on insurance-covered services and can simultaneously offer our patients a long-term offering."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Volker Sutor</p>
            </Card>

            <p class="text-base md:text-lg">
              Particularly valuable is the measurability of training progress. The system automatically documents each patient's performance development – an argument that convinces patients to keep coming back. Because they can see in black and white what they've achieved and what's possible.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-12 text-center" data-scroll="fade-up">
          Three results that convince
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="users" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Patient Retention</h3>
              <p class="text-foreground-muted text-sm">
                Patients stay on as paying members after completing their classic therapy prescription. Gesundheitsrondell thereby creates a stable regular clientele that continuously generates revenue.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="activity" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Therapy Results</h3>
              <p class="text-foreground-muted text-sm">
                Digital training guidance ensures correct movement execution and measurable progress. Therapists can seamlessly track each patient's development and adapt programs in a targeted way.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="3">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">From Patients to Members</h3>
              <p class="text-foreground-muted text-sm">
                The transition from insurance-funded therapy to self-funded self-pay services happens seamlessly. Patients experience the added value of training and voluntarily choose a long-term membership.
              </p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Would you like individual advice?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-12 py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Your Contact</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/en/apply-for-trial/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contact Us
              <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Back Button -->
  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" />
          Back to Overview
        </a>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
