  },
  {
    image: '/images/en/carina-dworak-mrssporty-wien.jpg',
    category: 'Fitness',
    subtitle: 'Pixformance And Mrs.Sporty – Evolution of a fitness chain through digital, functional training',
    name: 'Carina Dworak from a Mrs.Sporty Studio in Vienna, Austria',
    link: '/en/project/success-story-pixformance-and-mrs-sporty-evolution-of-a-fitness-chain-through-digital-functional-training/',
    external: false,
  },
  {
    image: '/images/en/helga.jpg',
    category: 'Fitness',
    subtitle: 'SPECIAL NEW SEATED EXERCISES: PERSONALIZED TRAINING FOR ALL AGES AND FITNESS LEVELS',
    name: 'More Movement in a Wheelchair Thanks to Digital Support: Helga, 84 Years Old',
    link: '/en/project/success-story-strength-training-for-seniors-in-a-seated-position-more-movement-in-wheelchairs-thanks-to-digital-support/',
    external: false,
  },
  {
    image: '/images/en/Gunter-Hoelig.jpg',
    category: 'Clinic',
    subtitle: 'Support in every rehabilitation phase – with intelligent sensor and robotics systems',
    name: 'Gunter Hölig from the Medical Park Rehab Clinic for Neurology and Orthopeadics, Bad Rodach, Germany',
    link: 'https://www.pixformance.com/wp-content/uploads/2019/02/Pixformance-Partner-Medical-Park-quality-report.pdf',
    external: true,
  },
  {
    image: '/images/en/Swetlana-Zimmermann-Schlossphysio.png',
    category: 'Physiotherapy',
    subtitle: 'CARING FOR MORE PATIENTS AT THE SAME TIME WITH DIGITAL MOVEMENT THERAPY',
    name: 'Swetlana Zimmermann from the Physiotherapy Practice "Schlossphysio", Winterthur, Switzerland',
