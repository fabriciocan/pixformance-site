    category: 'Building a self-pay area successfully',
    title: 'Step by step: successfully building up a self-pay area',
    person: 'Heike Schaible',
    location: 'Physiotherapy Practice "Raum für Gesundheit", Stuttgart, Germany',
    image: '/images/erfolgsgeschichten/heikeschaible.600x400.jpg',
  },
  {
    id: 'axel-richter',
    category: 'Opportunities in the secondary healthcare market',
    title: 'The self-pay sector as a sustainable mainstay',
    person: 'Axel-André Richter',
    location: 'Richter & Lopez Health Practice, Mönchengladbach, Germany',
    image: '/images/erfolgsgeschichten/gesundheitspraxis-richter-und-lopez.jpg',
  },
  {
    id: 'swetlana-zimmermann',
    category: 'Caring for more patients with digital therapy',
    title: 'Caring for more patients at the same time with digital movement therapy',
    person: 'Swetlana Zimmermann',
    location: 'Schlossphysio, Winterthur, Switzerland',
    image: '/images/erfolgsgeschichten/Swetlana-Zimmermann-Schlossphysio.png',
  },
  {
    id: 'volker-sutor',
    category: 'Patient retention through digital training',
    title: 'Patient retention in physiotherapy with digital functional training',
    person: 'Volker Sutor',
    location: 'Gesundheitsrondell (Physiotherapy & Rehab Centers), Germany',
    image: '/images/erfolgsgeschichten/Volker-Sutor-Portrait.png',
  },
];

const clinicStories = [
  {
    id: 'gabriele-buchstein',
    category: 'Digital therapy for MS',
    title: 'More motivated patients through digital therapy for MS',
    person: 'Gabriele Buchstein',
    location: 'Sauerland Clinic Hachen – Neurological Specialist Clinic for MS, Germany',
    image: '/images/erfolgsgeschichten/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Portrait-Gabriele-Buchstein.jpg',
  },
  {
    id: 'christoph-schneider',
    category: 'Patient activation through digital therapy devices',
    title: 'Back to fit in life again with intelligent therapy devices',
    person: 'Christoph Schneider (Head of Therapy)',
    location: 'Niederrhein Rehab Clinic, Korschenbroich, Germany',
    image: '/images/erfolgsgeschichten/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich.jpg',
  },
  {
    id: 'christoph-oratsch',
    category: 'Quality improvement through digital training therapy',
    title: 'Quality improvement through digital training therapy',
    person: 'Christoph Oratsch',
    location: 'AUVA Accident Hospital, Klagenfurt, Austria',
    image: '/images/erfolgsgeschichten/christoph-oratsch-600x400-1.jpg',
  },
  {
    id: 'gunter-hoelig',
    category: 'Intelligent sensor and robotics systems',
    title: 'Support in every rehabilitation phase',
    person: 'Gunter Hölig',
    location: 'Medical Park Rehab Clinic, Bad Rodach, Germany',
    image: '/images/erfolgsgeschichten/Gunter-Hoelig.jpg',
  },
];

const fitnessStories = [
  {
    id: 'kim-essink',
    category: 'Gym investment with ROI',
    title: 'A gym investment that pays off',
    person: 'Kim Essink',
    location: 'Essink Sportcentrum, Eindhoven, Netherlands',
    image: '/images/erfolgsgeschichten/kim-essink-city-gym-1.jpg',
  },
  {
    id: 'carina-dworak',
    category: 'Evolution of a fitness chain',
    title: 'The evolution of a fitness chain through digital, functional training',
    person: 'Carina Dworak',
    location: 'Mrs.Sporty Studio, Vienna, Austria',
    image: '/images/erfolgsgeschichten/carina-dworak-mrssporty-wien.jpg',
  },
  {
    id: 'helga-senioren',
    category: 'Strength training for seniors',
    title: 'More movement in a wheelchair thanks to digital support',
    person: 'Helga (84 years old)',
