    subtitle: 'Back to fit in life again: Patient activation with the help of digital therapy devices',
    name: 'Christoph Schneider from the Niederrhein Rehab Clinic for Neurology, Oncology & Orthopedics, Korschenbroich, Germany',
    link: '/en/project/back-to-fit-in-life-again-patient-activation-with-the-help-of-digital-therapy-devices/',
    external: false,
  },
  {
    image: '/images/en/kim-essink-city-gym-1.jpg',
    category: 'Fitness',
    subtitle: 'A gym investment that pays off – Pixformance as a customer magnet',
    name: 'Kim Essink from the fitnessstudio Essink Sportcentrum, Eindhoven, Netherlands',
    link: '/en/project/success-story-a-gym-investment-that-pays-off-pixformance-as-a-customer-magnet/',
    external: false,
  },
  {
    image: '/images/en/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Portrait-Gabriele-Buchstein.jpg',
    category: 'Clinic',
    subtitle: 'More motivated patients through digital therapy for MS',
    name: 'Gabriele Buchstein from the Sauerlandklinik – Neurological Special Clinic for Multiple Sclerosis, Hachen, Germany',
    link: '/en/project/more-motivated-patients-through-digital-therapy-for-ms/',
    external: false,
  },
  {
    image: '/images/en/christoph-oratsch-600x400-1.jpg',
    category: 'Clinic',
    subtitle: 'Quality improvement through digital training therapy',
    name: 'Christoph Oratsch from the AUVA Accident Hospital in Klagenfurt, Austria',
    link: '/en/project/quality-improvement-through-digital-training-therapy/',
    external: false,
  },
  {
    image: '/images/en/gesundheitspraxis-richter-und-lopez.jpg',
    category: 'Physiotherapy',
    subtitle: 'Opportunities in the secondary healthcare market: The self-payer sector as a sustainable mainstay',
    name: 'Health Practice Richter & Lopez from Mönchengladbach, Germany',
    link: '/en/project/opportunities-in-the-second-healthcare-market-the-self-pay-sector-as-a-sustainable-mainstay/',
