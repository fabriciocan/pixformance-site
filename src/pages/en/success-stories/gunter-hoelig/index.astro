---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ENBaseLayout
  title="Support in Every Rehabilitation Phase - Gunter Hölig - Pixformance"
  description="How Medical Park Bad Rodach uses intelligent sensor and robotics systems including Pixformance to support patients in every phase of rehabilitation."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Support in Every Rehabilitation Phase – Gunter Hölig, Medical Park Bad Rodach",
    "description": "Medical Park Bad Rodach uses intelligent sensor and robotics systems including Pixformance to support patients in every rehabilitation phase.",
    "url": "https://pixformance.com/en/success-stories/gunter-hoelig",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <ENHeader slot="header" position="sticky" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" />
            Back to Overview
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" />
            Clinic
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Support in every rehabilitation phase
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Medical Park Bad Rodach – Intelligent rehabilitation solutions for every patient
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Quote -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">
            "With Pixformance we can offer our patients an individualized, digitally supported training experience in every phase of their rehabilitation – from early mobilization to advanced strength training."
          </p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Gunter Hölig, Medical Park Bad Rodach</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/Gunter-Hoelig.jpg"
                alt="Gunter Hölig – Medical Park Bad Rodach"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Gunter Hölig</h2>
              <p class="text-xl text-[#02308C] font-semibold">Medical Park Bad Rodach</p>
            </div>

            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" />
                Clinic Profile
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3">
                  <Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Location</p>
                    <p class="text-sm">Bad Rodach, Bavaria, Germany</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Specialization</p>
                    <p class="text-sm">Neurological and orthopedic rehabilitation</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Technology</p>
                    <p class="text-sm">Intelligent sensor systems, robotics, digital therapy</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Network</p>
                    <p class="text-sm">Medical Park Group</p>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Intelligent sensor and robotics systems for modern rehabilitation
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Medical Park Bad Rodach is one of Germany's leading rehabilitation clinics, combining state-of-the-art medical technology with evidence-based therapy approaches. The clinic places particular emphasis on the use of intelligent systems that support patients during their rehabilitation journey – with real-time feedback, individualized programs, and measurable outcomes.
            </p>

            <p class="text-base md:text-lg">
              Pixformance has become an integral part of the clinic's digital therapy portfolio. The system bridges the gap between robotics-assisted therapy and independent patient training, enabling a seamless rehabilitation pathway from the early mobilization phase to advanced functional training.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "The combination of intelligent sensor systems and Pixformance's AI-based movement analysis gives us a comprehensive picture of each patient's progress. This allows us to make evidence-based decisions about therapy adjustments."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            From robotics to functional training – a seamless pathway
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              At Medical Park Bad Rodach, rehabilitation is understood as a continuous process. Patients begin with highly specialized robotic systems for early mobilization, then progress through a carefully structured pathway toward functional independence. Pixformance plays a key role in the intermediate and advanced phases of this journey.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "With over 350 exercises and real-time AI-based correction, Pixformance supports our patients in achieving correct movement patterns independently – which is essential for lasting therapy success."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>

            <p class="text-base md:text-lg">
              The system's ability to provide immediate feedback on movement quality – without requiring constant therapist supervision – makes it an invaluable tool for scaling high-quality rehabilitation to more patients simultaneously. Therapists can monitor multiple patients while being available for those who need hands-on intervention.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "The Pixformance web app also allows us to extend therapy support beyond the clinic walls, enabling patients to continue their programs at home with the same quality standards they experience here."
              </p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-12 text-center" data-scroll="fade-up">
          Key benefits at Medical Park Bad Rodach
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="activity" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Real-Time Feedback</h3>
              <p class="text-foreground-muted text-sm">
                AI-based movement analysis provides instant feedback on exercise quality, ensuring patients always train safely and effectively – even without direct therapist supervision.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="users" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Scalable Care</h3>
              <p class="text-foreground-muted text-sm">
                Multiple patients can train simultaneously with individualized programs, allowing therapists to focus their expertise where hands-on intervention is most needed.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="3">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Measurable Progress</h3>
              <p class="text-foreground-muted text-sm">
                Comprehensive data tracking allows therapists and patients to see clear evidence of improvement, motivating continued engagement and enabling data-driven therapy adjustments.
              </p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Would you like individual advice?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Your Contact</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/en/apply-for-trial/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contact Us <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Back to Overview
        </a>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
