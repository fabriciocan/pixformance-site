---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ENBaseLayout
  title="Back to Fit in Life Again - Christoph Schneider - Pixformance"
  description="Patient activation using digital therapy devices at Niederrhein Clinic, Korschenbroich. Christoph Schneider on the use of Pixformance in rehabilitation."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Back to Fit in Life Again – Christoph Schneider, Niederrhein Clinic",
    "description": "Patient activation using digital therapy devices at Niederrhein Clinic, Korschenbroich. Christoph Schneider on Pixformance in rehabilitation.",
    "url": "https://pixformance.com/en/success-stories/christoph-schneider",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <ENHeader slot="header" position="sticky" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" />
            Back to Overview
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" />
            Clinic
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Back to fit in life again
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Patient activation using digital therapy devices at Niederrhein Clinic, Korschenbroich, Germany
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Quote -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">
            "After occasional initial skepticism, our patients are all thoroughly enthusiastic. So we acquired three Pixformance stations. The devices are versatile, easy to use, and simply fun!"
          </p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Christoph Schneider, Head of Therapy, Niederrhein Clinic</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich.jpg"
                alt="Christoph Schneider - Head of Therapy Niederrhein Clinic"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Christoph Schneider</h2>
              <p class="text-xl text-[#02308C] font-semibold">Head of Therapy, Niederrhein Clinic</p>
            </div>

            <Card variant="elevated" padding="lg" class="bg-white">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" />
                Clinic Profile
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3">
                  <Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Location</p>
                    <p class="text-sm">Korschenbroich, North Rhine-Westphalia, Germany</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Founded</p>
                    <p class="text-sm">1997</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Specialization</p>
                    <p class="text-sm">Rehabilitation: oncology, orthopedics, neurology</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Patient Capacity</p>
                    <p class="text-sm">240 beds</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">More Info</p>
                    <a href="https://www.niederrhein-klinik.de" target="_blank" rel="noopener noreferrer" class="text-sm text-[#02308C] hover:underline">
                      www.niederrhein-klinik.de
                    </a>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            From passive to active patient – with digital support
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              The rehab clinic at the Lower Rhine near Mönchengladbach, with over 20 years of history, focuses on local rehabilitation. Patients arrive directly from acute hospitals – after recovering from a serious illness or surgery. The goal of rehabilitation is clear: to get patients physically and mentally fit again so they can participate in all aspects of life.
            </p>

            <p class="text-base md:text-lg">
              In search of a way to convey to patients that they need to become independently active, Head of Therapy Christoph Schneider and his team chose Pixformance's digital therapy devices.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "We wanted to move beyond the approach of 'the therapist does something with me' to 'you have to take your destiny into your own hands.' The individual training offering with Pixformance is ideal for this, since group therapy is otherwise too easy for some and too hard for others. This way, everyone gets completely individual training."
              </p>
            </Card>

            <p class="text-base md:text-lg">
              Initially, Schneider and his team were uncertain whether patients would accept and embrace the new computer-supported offering. To find out, they decided to start with a 6-month trial of the devices.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Niederrheinklinik-Pixformance-Training.jpg" alt="Pixformance training at Niederrhein Clinic Korschenbroich" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            For all age groups and a wide range of health conditions
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              The modern therapy devices are used across all three departments of the Niederrhein Clinic – primarily in oncology. There, patients who have overcome conditions such as gastric, intestinal, lung, or breast cancer and can already move independently. Many still have limitations in endurance and strength, where digital training with targeted movement activation connects and supports.
            </p>

            <p class="text-base md:text-lg">
              Sometimes training is also used in orthopedics, for example after spinal surgery or with artificial joints. Training with Pixformance is now firmly integrated into patients' therapy plans.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "Patients are glad to be able to be active again themselves. They participate with full motivation and are constantly trying to improve. Such enthusiasm is rarely mustered for treatment on a therapy table."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>

            <p class="text-base md:text-lg">
              The 200+ functional exercises for independent training are versatile and range from strength and endurance to balance and stability. Exercises with balls, dumbbells, resistance bands, or in a wheelchair are also possible – all under the watchful eye of the camera, which detects and notes inaccuracies in execution. After each exercise, the patient receives brief feedback on the quality of execution and what to focus on next time.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 3 -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Reminding patients of their everyday life
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              To make rehabilitation as comfortable as possible for patients, the clinic – part of the St. Augustinus Group – considers it important that patients can preserve a piece of home during their stay. This is achieved through local rehabilitation so that relatives can visit, but also through the training itself.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "Independent training reminds them of the gym and thus of their own normal everyday life. And that is good for patients, especially considering how serious an illness some of them have been through. They are very grateful for it."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Personalized training options with minimal staffing effort
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              In addition to benefits for patients, therapists can also benefit from the digital therapy devices. Schneider emphasizes above all the simple and quick induction.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "The devices are uncomplicated and I can induct three patients simultaneously. After a brief introduction by trained therapists and sports instructors, even our oldest patients train with them without difficulty. It works great and saves us a lot of time. So we can offer personalized accompanied training for everyone with minimal staffing effort."
              </p>
            </Card>

            <p class="text-base md:text-lg">
              A contact person is always nearby for questions or adjustments, but therapists don't need to be present for every training session.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "That is a significant relief for us as therapists."
              </p>
            </Card>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "With the QR code cards, training can proceed in a hygienically safe manner, and the devices are also quickly disinfected."
              </p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Patient care beyond the clinic stay
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Alongside the rehabilitation offering, a sports program for outpatient therapy patients is also integrated at the rehab clinic. In the future, it is planned to use Pixformance therapy devices here as well, to also care for patients beyond rehab. Using the Pixformance web app, which enables supervised training beyond on-site therapy, is also a future goal.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "It is definitely in our interest to accompany our patients beyond their clinic stay. The web app will certainly play a role there."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Would you like individual advice?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-12 py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Your Contact</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/en/apply-for-trial/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contact Us <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Back to Overview
        </a>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
