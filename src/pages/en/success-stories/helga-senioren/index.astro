---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ENBaseLayout
  title="Strength Training for Seniors in a Seated Position - Active Even in a Wheelchair - Pixformance"
  description="Helga, 84, trains with Pixformance despite using a wheelchair and integrates movement into her daily life. Personalized training for every age and health condition."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Strength Training for Seniors in a Seated Position – Active Even in a Wheelchair",
    "description": "Helga, 84, trains with Pixformance despite using a wheelchair. Personalized training for every age and health condition.",
    "url": "https://pixformance.com/en/success-stories/helga-senioren",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <ENHeader slot="header" position="sticky" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#6BDBD1]/20 to-[#02308C]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" />
            Back to Overview
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="zap" size="sm" />
            Fitness
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            More movement in a wheelchair thanks to digital support
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Strength training for seniors in a seated position – personalized training for every age and health condition
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Quote -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
          <p class="text-foreground italic text-2xl md:text-3xl font-display font-bold leading-snug">
            "For me it was clear: I want to stay active."
          </p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Helga, 84 years old</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/pixformance-krafttraining-fuer-senioren-im-sitzen-fit-im-rollstuhl-1.jpg"
                alt="Helga, 84, training with Pixformance from her wheelchair"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Helga</h2>
              <p class="text-xl text-[#02308C] font-semibold">84 years old – Fitness Studio Member</p>
            </div>

            <Card variant="elevated" padding="lg" class="bg-white">
              <div class="space-y-6 text-foreground-muted">
                <p class="text-base md:text-lg leading-relaxed">
                  At 84, Helga uses a wheelchair. But that doesn't stop her from regularly visiting the fitness studio with her daughter. Thanks to the Pixformance station, she can diligently train her exercises even while seated.
                </p>

                <Card variant="elevated" padding="md" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
                  <p class="text-foreground italic text-sm md:text-base">
                    "I have to say honestly – it's wonderful. What I'm most happy about is that I'm moving again. When my leg was amputated, I immediately said there has to be something I can do on my own. Just sitting alone in the apartment – that's not for me."
                  </p>
                </Card>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Motivated to integrate movement into everyday life
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Helga can easily perform her exercises at the digital training station while seated. The station recognizes her and analyzes her movements – whether sitting or standing, tall or small. The digital real-time feedback helps her and motivates her to complete exercises with discipline. The stick exercises are her favorites. Boxing can be tough sometimes:
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "Sometimes I'm too slow and don't reach the circles in time. But there has to be a challenge – things can't always just be fun."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>

            <p class="text-base md:text-lg">
              Above all, the training results shown at the end of each exercise give her a big motivational boost:
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "I always pay attention to that – I don't want to boast, but I'm rarely below 60% and very often at 100%."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img
            src="/images/erfolgsgeschichten/pixformance-krafttraining-fuer-senioren-im-sitzen-fit-im-rollstuhl-2.jpg"
            alt="Helga during Pixformance training – strength training for seniors in a seated position"
            class="w-full h-auto max-h-[380px] object-cover object-center"
            loading="lazy"
          />
        </Card>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Noticeable improvements in daily life
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Through regular training, Helga already notices clear improvements in her daily life: she can get up from the wheelchair by herself and sit down on the sofa or in the car. On good days she even manages to walk the stairs without assistance.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "Even if I have a handicap, I don't have to just sit at home. That's why I go to the fitness studio and say: here I am. I do something for myself. And then the day was worth it."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            100 new exercises – many of them seated
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              At Pixformance, it is especially important that every patient, member, and exerciser can be offered the perfect training. For this purpose, around 100 new exercises were developed – including many seated exercises specifically for people in wheelchairs like Helga.
            </p>

            <p class="text-base md:text-lg">
              From a diverse selection of over 270 functional exercises, personalized training plans can be created, tracked, and fact-based optimized based on training progress.
            </p>

            <!-- Feature boxes -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4">
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">270+</p>
                <p class="text-sm text-foreground-muted">functional exercises</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">100+</p>
                <p class="text-sm text-foreground-muted">new exercises including seated options</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">84</p>
                <p class="text-sm text-foreground-muted">years old – training without limits</p>
              </Card>
            </div>

            <p class="text-base md:text-lg">
              Seated strength training for seniors is not only applicable in fitness studios but equally in physiotherapy, rehabilitation, clinics, and nursing homes – for every individual training and health condition.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Would you like individual advice?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-12 py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Your Contact</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/en/apply-for-trial/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contact Us <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Back to Overview
        </a>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
