---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ENBaseLayout
  title="The Evolution of a Fitness Chain Through Digital Training - Carina Dworak - Pixformance"
  description="How Mrs.Sporty owner Carina Dworak recouped her investment in 3 months with 7 Pixformance devices and doubled her membership."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "The Evolution of a Fitness Chain Through Digital Training – Carina Dworak",
    "description": "How Mrs.Sporty owner Carina Dworak recouped her investment in 3 months with 7 Pixformance devices and doubled her membership.",
    "url": "https://pixformance.com/en/success-stories/carina-dworak",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <ENHeader slot="header" position="sticky" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#6BDBD1]/20 to-[#02308C]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" />
            Back to Overview
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="zap" size="sm" />
            Fitness
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            The evolution of a fitness chain through digital, functional training
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Mrs.Sporty Studio Vienna – Pixformance for over 200,000 members across Europe
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Quote -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
          <p class="text-foreground italic text-base md:text-xl">
            "As an entrepreneur, I love investing in my business to stay successful. What matters most to me is that I recoup my investment very quickly. With seven Pixformance devices in my club, I recovered the entire investment within three months."
          </p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Carina Dworak, Owner Mrs.Sporty Studio Vienna</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/carina-dworak-mrssporty-wien.jpg"
                alt="Carina Dworak – Owner Mrs.Sporty Studio Vienna"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Carina Dworak</h2>
              <p class="text-xl text-[#02308C] font-semibold">Owner Mrs.Sporty Studio, Vienna</p>
            </div>

            <!-- Key Numbers -->
            <div class="grid grid-cols-2 gap-4">
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">3</p>
                <p class="text-xs text-foreground-muted">months to full ROI</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">2×</p>
                <p class="text-xs text-foreground-muted">more new members</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">+€3,000</p>
                <p class="text-xs text-foreground-muted">additional revenue after 6 months</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">200K+</p>
                <p class="text-xs text-foreground-muted">members across Europe</p>
              </Card>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <div class="relative w-full" style="padding-bottom: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/MB8PhSlWndI"
              title="Mrs.Sporty and Pixformance – Carina Dworak Vienna"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Ideal training for every age – from 18 to 93
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "Functional training on Pixformance is ideal and optimal for all members. My youngest club member is 18, my oldest is 93 – and everyone can train their exercises individually and brilliantly."
              </p>
            </Card>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "After switching to Pixformance training, our clubs gain on average twice as many new members in the first months compared to before. After six months, clubs see around €3,000 more in revenue against, on average, €1,000 in additional costs."
              </p>
            </Card>

            <p class="text-base md:text-lg">
              The switch also opens the door to winning back former members who are happy to return because of the changes to the training offer and opening hours.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Consistent quality and elevated training standards
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "In my club, Pixformance has massively improved training quality. And thanks to the platform, the same quality is guaranteed regardless of whether the trainer present is relatively new or has years of experience. What the platform provides gives me confidence that a consistently high standard is offered to all members."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Carina Dworak</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 3 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Higher member retention and greater motivation
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "Thanks to longer and more flexible opening hours and especially the variety that Pixformance now offers our members, retention has increased enormously. Members love seeing their results in black and white. And on our side, we can put together new exercises and programs depending on how far along their training progress is."
              </p>
            </Card>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                "When members get a new training program, they go back into the circuit full of enthusiasm and look forward to the new training. Women also come much more regularly – many come three to four times a week, even five, because they can also use the weekend, which makes the value for money fantastic."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Carina Dworak</p>
            </Card>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                "The advantage of Pixformance for Mrs.Sporty clubs is clear: the ability to offer an even more successful training concept in the future."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Carina Dworak</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Would you like individual advice?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-12 py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Your Contact</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/en/apply-for-trial/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contact Us <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/en/success-stories/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Back to Overview
        </a>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
