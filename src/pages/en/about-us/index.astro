---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const stats = [
  { value: '700+', label: 'Functional exercises', icon: 'zap' },
  { value: '750,000+', label: 'Exercisers / year', icon: 'users' },
  { value: '2012', label: 'Founded', icon: 'calendar' },
];

const team = [
  {
    name: 'Valerie Bures-Bönström',
    role: 'CEO',
    image: '/images/Valerie_Bönström_CEO_Pixformance.jpg',
  },
  {
    name: 'Tobias Baader',
    role: 'COO',
    image: '/images/Tobias-Baader-Head-Of-Business-Development-Pixformance.jpg',
  },
  {
    name: 'Davi Wazlawick',
    role: 'Director of Growth',
    image: '/images/Davi-Wazlawick-Pixformance-3.jpg',
    imagePosition: 'center 88%',
  },
  {
    name: 'Patricia Olear',
    role: 'Senior Marketing Manager',
    image: '/images/Patricia-Olear-Marketing-Manager-Pixformance.jpg.webp',
  },
  {
    name: 'Laura Alves',
    role: 'Senior Manager Service & Support',
    image: '/images/Laura-Alves-Pixformance.jpg',
  },
  {
    name: 'Sara Zender',
    role: 'Finance Manager',
    image: '/images/Sara-Zender-Finance-Manager-Pixformance.jpg',
  },
  {
    name: 'Bita Mohammadi',
    role: 'C++ Software Developer',
    image: '/images/Bita-Mohammadi-Software-Developer-Pixformance.jpg',
  },
  {
    name: 'Kateryna Misarenko',
    role: 'Junior Marketing Manager',
    image: '/images/Kateryna-Misarenko-Junior-Marketing-Manager-Pixformance.jpg.webp',
  },
];
---

<ENBaseLayout
  title="Relentless Innovative Strength – And That Already Since 2012"
  description="Pixformance since 2012: Pioneer in digital motion analysis. 600+ installations worldwide, 450,000+ exercisers. CEO Valerie Bures-Bönström."
  hreflangDe="https://neu.pixformance.com/ueber-uns/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Pixformance Sports GmbH",
    "description": "Pixformance was founded in 2012 and is a pioneer in digital motion analysis. Over 600 installations worldwide, 450,000+ exercisers.",
    "url": "https://neu.pixformance.com/en/about-us/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Pixformance Sports GmbH",
      "foundingDate": "2012",
      "description": "Pioneer in digital motion analysis and real-time feedback for physical therapy, clinics, fitness and corporate wellness."
    }
  }}
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#6BDBD1]/10 to-[#86C9BC]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="users" size="sm" />
            About us
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Established market know-how meets
          <span class="text-[#02308C]"> start-up dynamics</span>
        </h1>

        <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Relentless innovative strength — and that already since 2012
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-6 rounded-2xl bg-white hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate shadow-lg" style={`animation-delay: ${0.4 + index * 0.1}s;`}>
              <div class="w-12 h-12 mx-auto rounded-xl bg-[#02308C] flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
                <Icon name={stat.icon} size="md" class="text-white" />
              </div>
              <div class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300">
                {stat.value}
              </div>
              <div class="text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Company Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="building" size="sm" />
            Our Company
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
            Pioneers in digital motion analysis
          </h2>
        </div>

        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <p>
            <strong>Pixformance Sports GmbH is still a 100% owner-managed company characterized by short coördination paths, high product quality, and tireless innovation.</strong>
          </p>

          <p>
            Our founder and CEO is Valerie Bures-Bönström. As a mother of three and a computer scientist, she has been one of Germany's most successful entrepreneurs for years. As recently as 2021, she was named one of the 50 most influential women in the German tech scene by Handelsblatt. In 2012, she launched the Pixformance Station, the first digital device for functional training with motion analysis. <strong>Today, our digital training station is already successfully in use in over 600 fitness, rehab, and health facilities and has over 450,000 exercisers worldwide.</strong>
          </p>

          <p>
            Together with Stefanie Graf, Valerie is also co-founder of the franchise company Mrs.Sporty and founder of the start-up behind the VAHA brand, an interactive fitness solution for the home, which has already received an investment in the double-digit millions. Thus, Pixformance combines long-standing market expertise with lived start-up agility, distinguished by a tenacious drive for innovation, a team willing to take risks, shortened processes, and a truly personal customer service.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Our Team
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          OUR TEAM
        </h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto mt-4">
          Our success is based on years of experience as well as our innovative capacity. We rely on our fearless, passionate, and visionary management board consisting of developers, designers, consultants, marketers, and financial services experts.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {team.map((member, index) => (
          <Card
            variant="elevated"
            padding="none"
            class="overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 hover:scale-105 group bg-white"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="relative h-80 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 group-hover:from-[#6BDBD1]/80 transition-all duration-500"></div>
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                style={member.imagePosition ? `object-position: ${member.imagePosition}` : undefined}
                loading="lazy"
              />

              <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                <h3 class="font-bold text-xl text-white mb-1 group-hover:translate-x-2 transition-transform duration-300">
                  {member.name}
                </h3>
                <p class="text-white/90 text-sm font-semibold">
                  {member.role}
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-6xl font-bold text-white leading-tight">
          Become part of our success story
        </h2>

        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Contact us for a non-binding consultation and find out how Pixformance can revolutionize your business.
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button
            size="lg"
            href="/en/apply-for-trial/"
            class="bg-black text-white hover:bg-black/80"
          >
            Apply For Trial
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/en/products-2/"
            class="border-2 border-black text-black hover:bg-black hover:text-white"
          >
            Our Concept
          </Button>
        </div>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
