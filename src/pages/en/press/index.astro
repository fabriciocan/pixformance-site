---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<ENBaseLayout
  title="Pixformance in the Trade Press — pt Magazine, Clinics & Media"
  description="Pixformance featured in pt – Zeitschrift für Physiotherapeuten and leading specialist media: digital movement therapy, 25-joint-point analysis, FDA Class 2. Press coverage & expert articles."
  hreflangDe="https://www.pixformance.com/presse/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance Press Coverage & Expert Articles",
    "description": "Pixformance featured in specialist publications: pt – Zeitschrift für Physiotherapeuten and other media report on the Pixformance Station digital movement therapy system.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "NewsArticle",
          "headline": "Mehr Zeit für Patienten, weniger Stress im Praxisalltag",
          "datePublished": "2026-01",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2026/01/pixformance-mehr-zeit-fuer-patienten-weniger-stress-im-praxisalltag/",
          "about": {
            "@type": "MedicalDevice",
            "name": "Pixformance Station",
            "description": "Digital movement therapy system with 25-joint-point analysis"
          }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "NewsArticle",
          "headline": "Kontaktlose Physiotherapie? Wie digitale Bewegungsanalyse die Physiotherapie und Rehabilitation revolutioniert",
          "datePublished": "2021-07-07",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2021/07/kontaktlose-physiotherapie-wie-digitale-bewegungsanalyse-die-physiotherapie-und-rehabilitation-revolutioniert/",
          "about": {
            "@type": "MedicalDevice",
            "name": "Pixformance Station",
            "description": "Digital movement therapy system for physiotherapy and rehabilitation"
          }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en" href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ENHeader>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Press Coverage
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance in the <span class="text-[#02308C]">Trade Press</span>
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          The Pixformance Station — the digital movement therapy system with patented 2D Full-HD camera and 25-joint-point real-time analysis — is regularly featured in leading specialist publications for physiotherapy, rehabilitation, and health management. As an FDA Class 2 medical device, clinically validated at Charité Berlin and Oxford Brookes University, Pixformance is a recognised standard in digital movement therapy.
        </p>
      </div>
    </div>
  </section>

  <!-- PT Magazin Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container max-w-4xl">

      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-4xl font-bold">
            pt – Zeitschrift für Physiotherapeuten
          </h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          The pt – Zeitschrift für Physiotherapeuten is the most established German-language specialist journal for physiotherapy. Pixformance has been featured in pt regularly since 2021. Articles are published in German.
        </p>
      </div>

      <div class="space-y-6">

        <!-- Article January 2026 -->
        <article class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">January 2026</span>
              <span class="text-xs text-foreground-muted font-medium">pt – Zeitschrift für Physiotherapeuten</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              More Time for Patients, Less Stress in Daily Practice
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-1 italic text-sm">
              Original title (DE): "Mehr Zeit für Patienten, weniger Stress im Praxisalltag"
            </p>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Pixformance supports physiotherapy practices, rehabilitation centres, and clinics with its 360° concept for digital movement therapy — structuring training, safely accompanying patients, and specifically relieving therapists.
            </p>
            <a
              href="https://physiotherapeuten.de/news/2026/01/pixformance-mehr-zeit-fuer-patienten-weniger-stress-im-praxisalltag/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline"
            >
              Read article (DE)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- Article July 2021 -->
        <article class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide" style="color: #02308C; background: rgba(107,219,209,0.3); border: 1px solid rgba(107,219,209,0.5);">July 2021</span>
              <span class="text-xs text-foreground-muted font-medium">pt – Zeitschrift für Physiotherapeuten</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Contactless Physiotherapy? How Digital Movement Analysis Is Revolutionising Physiotherapy and Rehabilitation
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-1 italic text-sm">
              Original title (DE): "Kontaktlose Physiotherapie? Wie digitale Bewegungsanalyse die Physiotherapie und Rehabilitation revolutioniert"
            </p>
            <p class="text-foreground-muted leading-relaxed mb-4">
              One of the most successful current concepts for digital movement analysis is Pixformance. Whether rehab clinic or physiotherapy practice, the Berlin-based company supports practitioners at renowned institutions including Charité Berlin. Through real-time digital correction, patients can complete supervised training — even without 1-to-1 therapist supervision.
            </p>
            <a
              href="https://physiotherapeuten.de/news/2021/07/kontaktlose-physiotherapie-wie-digitale-bewegungsanalyse-die-physiotherapie-und-rehabilitation-revolutioniert/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline"
            >
              Read article (DE)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Pixformance at a Glance -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 text-[#02308C]">
          Pixformance at a Glance
        </h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">FDA Class 2 certified medical device</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">Clinically validated: Charité Berlin &amp; Oxford Brookes University</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">EU research partner: FORTEe project</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">25 joint points real-time analysis via 2D Full-HD camera</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">700+ functional exercises on the Online Platform</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">6,000+ installations in physiotherapy practices, rehabilitation clinics and fitness studios worldwide</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">2.5 million exercisers per year</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">Clinical studies: Hochschule Fresenius (MS, Parkinson's, muscular dystrophy, breast cancer aftercare)</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container max-w-4xl">
      <div class="flex flex-col sm:flex-row gap-4" data-scroll="fade-up">
        <Button href="/en/free-trial/" size="lg">
          Try Pixformance free of charge
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button href="/en/contact/" size="lg" variant="outline">
          Press enquiries &amp; contact
          <Icon name="mail" size="sm" />
        </Button>
      </div>
    </div>
  </section>

</ENBaseLayout>
