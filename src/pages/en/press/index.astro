---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<ENBaseLayout
  title="Pixformance in Science & Press — Clinical Studies, Peer-reviewed Publications & Trade Press"
  description="Pixformance Station clinically validated: 7 studies by Fresenius University & DHfPG, published in Pädiatrische Praxis (2021;95:680–693), JMIR Formative Research (2025) and BMC Cancer (2025). EU research project FORTEe (Horizon 2020, €6.3M). Proven efficacy in MS, Parkinson's, breast cancer, muscular dystrophy and geriatrics."
  hreflangDe="https://www.pixformance.com/presse/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance — Scientific Studies & Specialist Publications",
    "description": "Clinically validated studies by Fresenius University Frankfurt and DHfPG, peer-reviewed publications in Pädiatrische Praxis, JMIR Formative Research and BMC Cancer, EU research project FORTEe and specialist articles from pt Zeitschrift document the efficacy of the Pixformance Station in neurology, oncology, geriatrics and rehabilitation.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Get strong to fight childhood cancer (FORTEe): Rationale and design of a randomized controlled exercise trial",
          "description": "Randomised controlled trial on digital exercise therapy in childhood cancer. Pixformance (Tobias Baader) as technology partner. 16 partner institutions from 8 countries, led by University Medical Centre Mainz. EU Horizon 2020, €6.3M funding. Oxford Brookes University as academic partner.",
          "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/",
          "datePublished": "2025-08-07",
          "publisher": { "@type": "Organization", "name": "BMC Cancer" },
          "author": [
            { "@type": "Person", "name": "Marie Astrid Neu" },
            { "@type": "Person", "name": "Tobias Baader" },
            { "@type": "Person", "name": "Joerg Faber" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Use of a Technology-Based Fall Prevention Program With Visual Feedback in Early Geriatric Rehabilitation",
          "description": "Feasibility study with 30 geriatric patients (March–June 2024). Pixformance Station 3×/week, 20 min. Primary endpoint: ≥80% attendance at 6 sessions in 2 weeks — achieved. Secondary endpoints: Berg Balance Scale, Timed Up and Go Test, Functional Independence Measure, Barthel Index.",
          "url": "https://formative.jmir.org/2025/1/e66692",
          "datePublished": "2025-02-11",
          "publisher": { "@type": "Organization", "name": "JMIR Formative Research" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Strengthening Programme with Visual Feedback in Emery-Dreifuss Muscular Dystrophy",
          "description": "Single-case study, Fresenius University of Applied Sciences Frankfurt (Jung M., Faustmann M., 2021). 10-year-old patient with Emery-Dreifuss muscular dystrophy, 8 months, ABAB design. Significant improvement in endurance capacity (6MWT). Pixformance confirmed as motivator and exercise monitor. Published in Pädiatrische Praxis 2021;95:680–693.",
          "datePublished": "2021-01-01",
          "publisher": { "@type": "Organization", "name": "Pädiatrische Praxis", "issn": "0030-9338" },
          "author": [
            { "@type": "Person", "name": "M. Jung" },
            { "@type": "Person", "name": "M. Faustmann" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Does Pixformance Have a Positive Effect on Walking Ability in an MS Patient?",
          "description": "Single-case study, Fresenius University Frankfurt (Zientz M., Jung M., 2018). 16 weeks, Multiple Sclerosis. Walking ability improved (Timed Up and Go Test, 10 Metre Walk Test). Balance improved (Berg Balance Scale, Functional Reach Test). Effect persisted after training breaks. Quality of life MSQOL-54 improved after both training phases.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "Fresenius University of Applied Sciences Frankfurt" },
          "author": [
            { "@type": "Person", "name": "Maya Zientz" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Improvement of Strength, Mobility and Balance After Breast Cancer",
          "description": "Single-case study, Fresenius University Frankfurt (Schall K., Jung M., 2017). 11 weeks, 3×/week, breast cancer aftercare. Flexion +20°, abduction +15°. Muscle strength Deltoid + Pectoralis from grade 3 to 4. Single-leg stance +4–4.5 seconds per leg. General health SF-12 improved.",
          "datePublished": "2017-01-01",
          "publisher": { "@type": "Organization", "name": "Fresenius University of Applied Sciences Frankfurt" },
          "author": [
            { "@type": "Person", "name": "K. Schall" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 6,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Effects of Pixformance on Balance, Walking Ability and Quality of Life in Patients with Parkinson's Syndrome",
          "description": "Prospective observational study, Fresenius University Frankfurt (Teschner L., Stuke Y., Jung M., 2018). 24 weeks, 4 participants, ABAB design. Significant balance improvement (Functional Reach Test). Improvement in walking ability over the study period.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "Fresenius University of Applied Sciences Frankfurt" },
          "author": [
            { "@type": "Person", "name": "L. Teschner" },
            { "@type": "Person", "name": "Y. Stuke" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 7,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Empirical Review of Training Effects of a Standardised Training Programme — Mrs. Sporty and Pixformance",
          "description": "Study by the German University of Prevention and Health Management (Loch M., Barth B., 2018). 23 women, 8 weeks, 2-3×/week. Improvements across all measures: body weight, body fat, BMI, muscle mass, waist and hip circumference, arm and leg circumference.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "German University of Prevention and Health Management (DHfPG)" },
          "author": [
            { "@type": "Person", "name": "Meike Loch" },
            { "@type": "Person", "name": "B. Barth" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de"        href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en"        href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="fr"        href="https://www.pixformance.com/fr/presse/" />
    <link rel="alternate" hreflang="nl"        href="https://www.pixformance.com/nl/pers/" />
    <link rel="alternate" hreflang="it"        href="https://www.pixformance.com/it/stampa/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ENHeader>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Science &amp; Press
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance in <span class="text-[#02308C]">Science &amp; Press</span>
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          The Pixformance Station — developed as an FDA Class 2 medical device — is validated by 7 clinical studies and published in international peer-reviewed specialist journals. EU research project FORTEe (Horizon 2020, €6.3M), partnerships with University Medical Centre Mainz, Oxford Brookes University and Fresenius University of Applied Sciences Frankfurt demonstrate efficacy in neurology, oncology, geriatrics and rehabilitation.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 1: Peer-Reviewed Scientific Publications -->
  <section class="py-12 md:py-20 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Peer-Reviewed Scientific Publications</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          Pixformance is the subject of published studies in international medical specialist journals.
        </p>
      </div>
      <div class="space-y-6">

        <!-- BMC Cancer 2025 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">August 2025</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">RCT · BMC Cancer · PubMed</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Paediatric Oncology</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              FORTEe — Randomized Controlled Trial: Exercise Therapy in Childhood Cancer
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-3">
              EU Horizon 2020 research project (€6.3M). 16 partner institutions from 8 countries, led by University Medical Centre Mainz. Pixformance (Tobias Baader) as technology partner for digital exercise therapy in children and adolescents undergoing oncological treatment. Academic partner: Oxford Brookes University.
            </p>
            <p class="text-sm italic text-foreground-muted mb-4">Authors: Neu MA, Baader T, Faber J et al.</p>
            <a href="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Read study (PubMed / BMC Cancer)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- JMIR 2025 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">February 2025</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">Peer-reviewed · JMIR Formative Research</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Geriatrics</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Technology-Based Fall Prevention Programme in Early Geriatric Rehabilitation
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Feasibility study with 30 geriatric patients (March–June 2024). Pixformance Station 3× per week, 20 minutes. Primary endpoint feasibility achieved (≥80% attendance at 6 sessions in 2 weeks). Secondary endpoints: Berg Balance Scale, Timed Up and Go Test, Functional Independence Measure, Barthel Index.
            </p>
            <a href="https://formative.jmir.org/2025/1/e66692" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Read study (JMIR Formative Research)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- Pädiatrische Praxis 2021 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2021</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">Indexed Medical Journal · Pädiatrische Praxis</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Muscular Dystrophy</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Strengthening Programme with Visual Feedback in Emery-Dreifuss Muscular Dystrophy
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Fresenius University of Applied Sciences Frankfurt (Jung M., Faustmann M.). Single-case study: 10-year-old patient, 8 months, ABAB design. Significant improvement in endurance capacity (6MWT). Pixformance confirmed as motivator and independent exercise monitor.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <p class="text-foreground-muted text-sm leading-relaxed">
                Significant improvement in endurance capacity (6-Minute Walk Test). Positive influence on symptom progression.
              </p>
            </div>
            <p class="text-sm italic text-foreground-muted">Published: Pädiatrische Praxis 2021;95:680–693</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Section 2: Clinical Studies Fresenius University Frankfurt -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Clinical Studies — Fresenius University of Applied Sciences Frankfurt</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          In collaboration with Fresenius University of Applied Sciences Frankfurt, single-case and observational studies were conducted on the efficacy of the Pixformance Station in neurology, oncology and geriatrics.
        </p>
      </div>
      <div class="space-y-6">

        <!-- MS -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2018</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Multiple Sclerosis · Fresenius University</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Positive Effects on Walking Ability and Quality of Life in Multiple Sclerosis
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Zientz M., Jung M. (2018). Single-case study, 16 weeks, alternating training and rest phases.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Walking ability improved — Timed Up and Go Test + 10 Metre Walk Test</li>
                <li>✓ Balance improved — Berg Balance Scale + Functional Reach Test</li>
                <li>✓ Training effect persisted even after 4-week rest periods</li>
                <li>✓ Quality of life MSQOL-54: mental and physical health improved</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Breast Cancer -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2017</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Breast Cancer Aftercare · Fresenius University</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Improvement of Strength, Mobility and Balance After Breast Cancer
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Schall K., Jung M. (2017). Single-case study, 11 weeks, 3×/week.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Flexion +20°, abduction +15°</li>
                <li>✓ Muscle strength Deltoid + Pectoralis: from grade 3 to 4</li>
                <li>✓ Single-leg stance: +4–4.5 seconds per leg</li>
                <li>✓ General health status improved (SF-12)</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Parkinson's -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2018</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Parkinson's Disease · Fresenius University</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Significant Balance Improvement in Parkinson's Syndrome
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Teschner L., Stuke Y., Jung M. (2018). Prospective observational study, 24 weeks, 4 participants, ABAB design.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Significant balance improvement — Functional Reach Test</li>
                <li>✓ Improvement in walking ability over the study period</li>
                <li>✓ Amplitude-oriented training programme proven effective</li>
              </ul>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Section 3: Fitness Research -->
  <section class="py-12 md:py-20 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Fitness Research</h2>
        </div>
      </div>
      <div class="space-y-6">

        <!-- Mrs. Sporty DHfPG -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2018</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">DHfPG Saarbrücken · Fitness</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Positive Effects on Body Composition — 23 Women, 8 Weeks
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Loch M., Barth B. (2018). German University of Prevention and Health Management (DHfPG), Saarbrücken. 23 women, 2-3×/week, 30-minute sessions with 16 Pixformance exercises.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Body weight, body fat percentage and BMI reduced</li>
                <li>✓ Muscle mass increased</li>
                <li>✓ Waist and hip circumference reduced</li>
                <li>✓ Arm and leg circumference reduced</li>
                <li>✓ Improvements demonstrated across all tested parameters</li>
              </ul>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Section 4: Voices from Clinical Practice -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Voices from Clinical Practice</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          Leading rehabilitation clinics in Germany use Pixformance and report measurable outcomes in their clinical day-to-day.
        </p>
      </div>
      <div class="space-y-6">

        <!-- Sauerlandklinik -->
        <blockquote class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 relative overflow-hidden" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
