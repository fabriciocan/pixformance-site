---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
---

<ENBaseLayout
  title="Functional Training Devices from Pixformance"
  description="The 360° Pixformance Concept — Professional physical therapy devices and fitness equipment, patented software, a fully connected Online Platform and an App."
  hreflangDe="https://neu.pixformance.com/konzept/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <!-- Hero Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <!-- Popup CTA -->
      <div class="fixed bottom-8 right-8 z-50">
        <a
          href="https://app.monstercampaigns.com/c/ybvlequwgaulmccl90jr/?max-width=650px"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:scale-105 transition-transform duration-300 block"
          aria-label="Apply for trial"
        >
          <img
            src="/images/en/image-25.png"
            alt="Apply for trial"
            class="h-20 md:h-28 w-auto shadow-xl rounded-full"
            loading="lazy"
          />
        </a>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
            Functional Training devices
          </h1>
          <h2 class="text-2xl md:text-3xl font-bold text-[#02308C]">
            The 360° Pixformance Concept
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Professional physical therapy devices and fitness equipment, a patented software, a fully connected Online Platform and an App. Thanks to increased personalization, sustainable technologies and timeless design, we establish innovative training and therapy standards. The goal: to provide highly effective functional training for every fitness level with exercise instructions and live feedback from a virtual trainer.
          </p>
          <div class="flex gap-4 flex-wrap">
            <Button size="lg" href="/en/apply-for-trial/">
              Apply For Trial
              <Icon name="arrow-right" size="sm" />
            </Button>
            <Button size="lg" variant="outline" href="/en/contact/">
              Contact Us
            </Button>
          </div>
        </div>

        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet-1.jpg"
            alt="Pixformance 360 Degree Concept — Online Platform, App, Digital Sports Device"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Product Pillar 01 -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <span class="text-7xl font-bold text-[#02308C]/10">01</span>
          <h2 class="font-display text-4xl md:text-5xl font-bold -mt-4">
            Pixformance Station
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            The patented Pixformance Station is a free-standing digital physical therapy and sports device developed by experts in science, technology, medicine, and fitness. With our innovative software, the station measures the body of each user in a matter of seconds based on 25 joint points. It precisely analyzes the execution of movements and provides live digital feedback — enabling particularly effective and safe rehab and functional training. With more than 350 functional exercises, the station can be used for individual and circuit training.
          </p>
          <Button href="/en/physical-therapy/" variant="outline">
            Physical Therapy
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-Station-2D-Funktionelles-Training-Digital-voll-vernetzt-BGM_Firmenfitness-Personal-Trainer.png"
            alt="Pixformance Station — Digital Functional Training Device"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Product Pillar 02 -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-scroll="slide-left" class="order-2 lg:order-1">
          <img
            src="/images/en/Pixformance-Online-Platform-Functional-Training-fully-connected.jpg"
            alt="Pixformance Online Platform — Functional Training Fully Connected"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>

        <div class="space-y-6 order-1 lg:order-2" data-scroll="slide-right">
          <span class="text-7xl font-bold text-[#02308C]/10">02</span>
          <h2 class="font-display text-4xl md:text-5xl font-bold -mt-4">
            Pixformance Online Platform
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            The Pixformance Online Platform stores all the training data of trainees and patients. This offers both our business partners and their trainees the possibility to track training progress at any time and to optimize their training based on the collected data. With the Pixformance platform you will have access to the exercise catalog with more than 350 functional exercises. With this resource you can compile your own workouts and training plans with just a few clicks while precisely tracking and optimizing them.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Pillar 03 -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <span class="text-7xl font-bold text-[#02308C]/10">03</span>
          <h2 class="font-display text-4xl md:text-5xl font-bold -mt-4">
            Pixformance App
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            The Pixformance App offers access to workout plans, exercise progress and history, any time, any place. For those who train, we offer location-independent, 360-degree Pixformance training as well as numerous functions to improve health and fitness. Upon request, we can design an individual digital fitness world for our business partners in the form of a separate app.
          </p>
        </div>

        <div data-scroll="slide-right">
          <img
            src="/images/Digital-Training-Device-eHealth-Telemedicine-Feedback-Pixformance-Station-2020-EN-mobil-web.png"
            alt="Pixformance App"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Success Stories Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-scroll="slide-left">
          <img
            src="/images/en/heikeschaible.600x400.jpg"
            alt="Woman with short hair and black glasses smiles at camera"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-6" data-scroll="slide-right">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="star" size="sm" />
            Success Stories
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold">
            Success stories
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            With over 450,000 exercisers worldwide, the Pixformance training and therapy concept can already be found in Germany's top rehabilitation clinics, physical therapy practices, and fitness studios. Read our success stories to discover how and why Ms. Schaible from the physical therapy practice "Raum für Gesundheit" and many other customers have integrated the digital movement therapy from Pixformance.
          </p>
          <Button href="/en/success-stories/">
            All success stories
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Let Us Advise You -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-[#6BDBD1] to-[#02308C]">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white">
          Let us advise you
        </h2>
        <p class="text-xl text-white/90">
          Sometimes it is easier to answer questions in person. We are looking forward to your message!
        </p>
        <Button size="lg" href="/en/contact/" class="bg-white text-[#02308C] hover:bg-white/90">
          Write us
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
