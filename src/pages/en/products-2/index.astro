---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const components = [
  {
    icon: 'monitor',
    title: 'Pixformance Station',
    description: 'The Pixformance Station is an FDA Class 2 certified medical device with a patented 2D Full-HD camera. It analyses 25 joint points of each patient in real time and delivers immediate text and visual corrective feedback. A virtual therapist guides the patient through the session — without requiring constant therapist presence.',
  },
  {
    icon: 'globe',
    title: 'Online Platform',
    description: 'The Pixformance Online Platform enables therapists and trainers to create individual training programmes from over 700 functional exercises. Patient management, therapy documentation and progress tracking are all handled centrally and fully digitally.',
  },
  {
    icon: 'smartphone',
    title: 'Mobile Web App',
    description: 'The Pixformance Web App gives patients access to their individual programmes at home or on the go. Therapists can seamlessly continue care between appointments — telerehabilitation without extra effort.',
  },
];

const technologies = [
  {
    icon: 'cpu',
    title: 'Innovative Software',
    color: '#02308C',
    features: [
      'Based on 25 joint points',
      'Body measurement in seconds',
      'Precise motion analysis',
      'Patented technology',
    ],
  },
  {
    icon: 'message-square',
    title: 'Digital Feedback',
    color: '#6BDBD1',
    features: [
      'Real-time correction',
      'Text-based feedback',
      'Visual feedback',
      'Personalized adjustments',
    ],
  },
  {
    icon: 'network',
    title: 'Connectivity',
    color: '#6BDBD1',
    features: [
      'Station ↔ Online Platform',
      'Online Platform ↔ Web App',
      'Seamless data synchronization',
      'Centralized management',
    ],
  },
  {
    icon: 'shield',
    title: 'Clinical Validation & Certification',
    color: '#02308C',
    features: [
      'FDA Class 2 Medical Device (USA)',
      'Clinically validated: Charité Berlin',
      'Clinically validated: Oxford Brookes University',
      'EU research partner: FORTEe project',
      'Studies: Fresenius University (MS, Parkinson, breast cancer aftercare)',
    ],
  },
];

const targetGroups = [
  {
    svgIcon: '/images/konzept-icons/17.svg',
    title: "Germany's Top Rehab Clinics",
    description: 'Sauerlandklinik Hachen, Niederrhein-Klinik, Medical Park, AUVA Klagenfurt, Mediclin',
  },
  {
    svgIcon: '/images/konzept-icons/18.svg',
    title: 'Physical Therapy Practices',
    description: '6,000+ installations worldwide. Independent patient exercise without continuous therapist involvement.',
  },
  {
    svgIcon: '/images/konzept-icons/20.svg',
    title: 'Fitness Studios',
    description: 'Modern training concepts for studios',
  },
  {
    svgIcon: '/images/konzept-icons/16.svg',
    title: 'Corporate Wellness',
    description: 'Healthy and high-performing employees',
  },
];

const keyFeatures = [
  {
    icon: 'layers',
    title: '700+ Functional Exercises',
    description: 'Extensive exercise library for every health condition and fitness level',
  },
  {
    icon: 'monitor',
    title: 'Virtual Personal Trainer',
    description: 'Professional guidance through a digital trainer displayed on screen',
  },
  {
    icon: 'settings',
    title: 'Personalized Training Plans',
    description: 'Individually tailored to fitness level and personal goals',
  },
  {
    icon: 'check-circle',
    title: 'Safe Exercise Execution',
    description: 'Real-time correction prevents incorrect posture and injuries',
  },
];
---

<ENBaseLayout
  title="The Pixformance 360° Concept — Station, Online Platform & Web App | Digital Movement Therapy System"
  description="The Pixformance 360° Concept: Pixformance Station (FDA Class 2 medical device, 2D Full-HD camera, 25 joint points real-time analysis), Online Platform (700+ functional exercises, patient management) and Web App (telerehabilitation). Clinically validated at Charité Berlin and Oxford Brookes University."
  hreflangDe="https://www.pixformance.com/konzept/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Pixformance Station",
      "description": "FDA Class 2 certified digital movement therapy device with patented 2D Full-HD camera. Analyses 25 joint points of each patient in real time and delivers immediate text and visual corrective feedback. Part of the Pixformance 360° Concept for physiotherapy, rehabilitation and fitness.",
      "manufacturer": {
        "@type": "Organization",
        "name": "Pixformance Sports GmbH",
        "url": "https://www.pixformance.com"
      },
      "recognizingAuthority": {
        "@type": "Organization",
        "name": "FDA — Food and Drug Administration"
      },
      "regulatoryStatus": "FDA Class 2 Medical Device",
      "medicalSpecialty": [
        "Physical Therapy",
        "Rehabilitation",
        "Neurology",
        "Orthopaedics",
        "Sports Medicine",
        "Movement Therapy"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Pixformance 360° Concept",
      "description": "Fully connected digital movement therapy system consisting of three components: (1) Pixformance Station — hardware with 2D Full-HD camera, real-time analysis of 25 joint points, virtual trainer and immediate corrective feedback; (2) Pixformance Online Platform — 700+ functional exercises, individual patient programmes, therapy documentation and progress tracking; (3) Pixformance Web App — home training and telerehabilitation for patients between appointments.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web, iOS, Android",
      "featureList": [
        "2D Full-HD camera with 25-joint-point analysis",
        "Real-time corrective feedback",
        "700+ functional exercises",
        "Individual patient programmes",
        "Telerehabilitation via Web App",
        "Seamless data synchronisation",
        "FDA Class 2 certified"
      ],
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock"
      }
    }
  ]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/concept/" />
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/concept/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/prodotti/" />
  </Fragment>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ENHeader>

  <!-- Floating CTA -->
  <div class="fixed bottom-8 right-8 z-50">
    <a
      href="/en/contact/"
      class="hover:scale-105 transition-transform duration-300 block"
      aria-label="Apply for trial"
    >
      <img
        src="/images/en/image-25.png"
        alt="Apply for trial"
        class="h-20 md:h-28 w-auto shadow-xl rounded-full"
        loading="lazy"
      />
    </a>
  </div>

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden">
    <!-- Hero Banner Image -->
    <div class="relative w-full hero-animate" style="animation-delay: 0.1s;">
      <img
        src="/images/Pixformance-Gruppentraining-Physiotherapie-Digitale-Rehabilitation-eHealth-Funktionelles-Training-Banner.jpg"
        alt="Pixformance Group Training Physical Therapy Digital Rehabilitation"
        class="w-full h-auto object-cover"
        loading="eager"
      />
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <div class="container py-12 md:py-16">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white text-sm font-bold shadow-lg">
            <Icon name="zap" size="sm" />
            FULLY CONNECTED TRAINING
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          The Pixformance 360° Concept: Three Components — One Fully Connected Movement Therapy System
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          The Pixformance 360° Concept is a fully connected digital movement therapy system comprising three components: the Pixformance Station (FDA Class 2 medical device with real-time motion analysis of 25 joint points), the Online Platform (700+ functional exercises, individual patient programmes, therapy documentation) and the Web App (telerehabilitation and home training). Clinically validated at Charité Berlin and Oxford Brookes University — deployed in leading rehab clinics including Medical Park, AUVA Klagenfurt and Sauerlandklinik Hachen.
        </p>

        <div class="flex gap-4 flex-wrap justify-center hero-animate" style="animation-delay: 0.4s;">
          <Button size="lg" href="/en/apply-for-trial/">
            Apply For Trial
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href="/en/contact/">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- System Components -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-10" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          The 3 Components of the System
        </h2>
      </div>

      <div class="flex justify-center mb-12" data-scroll="fade-up">
        <img
          src="/images/en/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet-1.jpg"
          alt="The 3 Components: Pixformance Station, Online Platform and Mobile Web App"
          class="max-w-lg w-full object-contain"
          loading="lazy"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {components.map((component, index) => (
          <div class="flex flex-col items-center text-center gap-4" data-scroll="fade-up" data-delay={index + 1}>
            <div class="w-20 h-20 rounded-full border-2 border-[#02308C] flex items-center justify-center flex-shrink-0">
              <Icon name={component.icon} size="lg" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold text-xl text-foreground">
              {component.title}
            </h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              {component.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Features
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Key Features of the System
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {keyFeatures.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Highlights -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="cpu" size="sm" />
          Technology
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Technology Highlights
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {technologies.map((tech, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold group-hover:text-[#02308C] transition-colors">
                {tech.title}
              </h3>
              <ul class="space-y-3">
                {tech.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <Icon name="check-circle" size="sm" class="text-[#86C9BC] mt-0.5 flex-shrink-0" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Target Groups -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Target Groups
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-4">
          Successfully used in
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {targetGroups.map((group, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <img src={group.svgIcon} alt={group.title} class="w-8 h-8 object-contain" loading="lazy" />
            </div>
            <h3 class="font-semibold mb-2 group-hover:text-[#02308C] transition-colors">
              {group.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {group.description}
            </p>
          </Card>
        ))}
      </div>

      <div class="text-center" data-scroll="fade-up">
        <div class="inline-block p-8 rounded-2xl bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 border border-[#02308C]/20">
          <p class="text-4xl md:text-5xl font-bold text-[#02308C] mb-2">2.5M+</p>
          <p class="text-lg text-foreground-muted">Exercisers worldwide</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-18 md:pb-40 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto pt-8 text-center" data-scroll="fade-up">
        <blockquote class="text-2xl md:text-3xl font-bold text-white mb-8 leading-relaxed">
          "With Pixformance we built a second self-pay area. The digital movement therapy inspires our patients and paid for itself quickly."
        </blockquote>

        <div class="flex items-center justify-center gap-4">
          <div class="w-30 h-30 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
            <img src="/images/Heike-Schaible-round.png" class="w-30 h-30 rounded-full object-cover" loading="lazy" alt="Heike Schaible" />
          </div>
          <div class="text-left">
            <p class="font-bold text-white text-lg">Heike Schaible</p>
            <p class="text-white text-sm">Owner</p>
            <p class="text-white text-sm">Physical Therapy Practice "Raum für Gesundheit", Stuttgart</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
          <Icon name="headphones" size="sm" />
          Consultation
        </span>

        <h2 class="font-display text-3xl md:text-3xl font-bold">
          We are happy to advise you!
        </h2>

        <p class="text-xl text-foreground-muted max-w-2xl mx-auto">
          Sometimes questions are easier to answer in person. We look forward to hearing from you!
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-4">
          <Button size="lg" href="/en/apply-for-trial/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Apply For Trial
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform" />
          </Button>
          <Button size="lg" variant="outline" href="/en/contact/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Contact Us
            <Icon name="mail" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
