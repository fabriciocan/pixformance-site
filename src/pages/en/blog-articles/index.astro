---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const posts = [
  {
    image: '/images/en/umsatz-steigern-physiotherapie-pixformance-selbstzahlerbereich-400x250.jpg',
    title: 'Increase Physical Therapy Sales: What Opportunities Does The Self-Pay Sector Have To Offer Now?',
    categories: [{ label: 'Physiotherapy', href: '/en/category/physiotherapy-2/' }],
    excerpt: 'The move into the second healthcare market in physical therapy offers some current opportunities for physical therapists in Germany.',
    link: '/en/increase-physical-therapy-sales-what-opportunities-does-the-self-pay-sector-have-to-offer-now/',
  },
  {
    image: '/images/en/Digitalisierung-Chance-Gesundheitsbranche-Pixformance-Blog-Online-Plattform-Analyse-Ehealth-Physiotherapie-Telemedizin-Telerehabilitation-Rehageraet-400x250.jpg',
    title: 'Digitization: An Opportunity For The Healthcare Industry',
    categories: [
      { label: 'Clinic', href: '/en/category/clinic/' },
      { label: 'Physiotherapy', href: '/en/category/physiotherapy-2/' },
    ],
    excerpt: 'Our everyday lives are already smart and digital in many respects. Digitization is also advancing rapidly in the healthcare industry.',
    link: '/en/digitization-an-opportunity-for-the-healthcare-industry/',
  },
  {
    image: '/images/en/Canva-People-in-Gym-400x250.jpg',
    title: "Three Lessons Fitness Clubs Can Learn From Weight Watchers' New Business Strategy",
    categories: [
      { label: 'Corporate', href: '/en/category/corporate/' },
      { label: 'Corporate Health', href: '/en/category/corporate-health/' },
    ],
    excerpt: "Weight Watchers had been the most dominant player in the dieting market for decades up until 2015 when the company's subscription revenue shrank from $6 billion to $1 billion over a four year period.",
    link: '/en/three-lessons-fitness-clubs-can-learn-from-weight-watchers/',
  },
  {
    image: '/images/en/quantified-self-movement-for-fitness-and-health-400x250.jpg',
    title: 'Why The "Quantified Self" Movement Is A Business Opportunity',
    categories: [{ label: 'Health', href: '/en/category/health/' }],
    excerpt: 'These days everyone is talking about the "quantified self". With the rapid development of new fitness software in the form of apps and wearable devices, we\'ve witnessed a growing interest in collecting data about our lives in order to make self-improvements.',
    link: '/en/why-the-quantified-self-is-a-business-opportunity/',
  },
  {
    image: '/images/en/quantified-self-movement-is-trending-400x250.jpg',
    title: 'Three Strategies On Integrating New Technologies Into Your Functional Fitness Club',
    categories: [
      { label: 'Corporate', href: '/en/category/corporate/' },
      { label: 'Corporate Health', href: '/en/category/corporate-health/' },
    ],
    excerpt: 'Currently, much discussion is taking place about how the "quantified self" movement is reshaping the fitness and health industry. In this post, we introduce three strategies on how to integrate new technologies…',
    link: '/en/three-strategies-on-integrating-new-technologies-into-your-functional-fitness-club/',
  },
  {
    image: null,
    title: 'How "Smart Training" With Pixformance Can Improve The Quality of Life Among People Living With Multiple Sclerosis',
    categories: [{ label: 'Therapy', href: '/en/category/therapy/' }],
    excerpt: 'Multiple Sclerosis is one of the most common neurological conditions among young adults in the U.K. In this article, we discuss a recently released qualitative study that tested the effectiveness…',
    link: '/en/smart-training-with-pixformance-improves-life-quality-of-people-with-multiple-sclerosis/',
  },
  {
    image: '/images/en/physiotherapist-with-woman-patient-400x250.jpg',
    title: 'Top 5 Challenges Faced By Physiotherapists',
    categories: [{ label: 'Physiotherapy', href: '/en/category/physiotherapy/' }],
    excerpt: 'In this article, let us shed some light on the major challenges faced by physiotherapists. Like in any other profession, Physiotherapy has its positives and negatives as well.',
    link: '/en/top-five-challenges-faced-by-physiotherapists/',
  },
];
---

<ENBaseLayout
  title="Blog - Pixformance Sports GmbH"
  description="Read the latest articles on functional training, digital health, physiotherapy, and corporate fitness from the Pixformance blog."
  hreflangDe="https://www.pixformance.com/blog/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ENHeader>

  <!-- Hero -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-4">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-sm font-bold">
          <Icon name="edit" size="sm" />
          Blog
        </span>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
          Blog Articles
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Insights on functional training, digital health, physiotherapy, and corporate fitness.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map((post, index) => (
          <article class="group flex flex-col rounded-2xl overflow-hidden border border-border hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min((index % 2) + 1, 2)}>
            {post.image ? (
              <div class="overflow-hidden aspect-[8/5]">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-[8/5] bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 flex items-center justify-center">
                <Icon name="edit" size="lg" class="text-[#02308C]/30" />
              </div>
            )}
            <div class="flex flex-col flex-1 p-6 space-y-3">
              <div class="flex flex-wrap gap-2">
                {post.categories.map((cat) => (
                  <a href={cat.href} class="px-3 py-1 rounded-full text-xs font-bold bg-[#6BDBD1]/20 text-[#02308C] hover:bg-[#6BDBD1]/40 transition-colors">
                    {cat.label}
                  </a>
                ))}
              </div>
              <h2 class="font-bold text-lg leading-snug flex-1">
                <a href={post.link} class="hover:text-[#02308C] transition-colors">{post.title}</a>
              </h2>
              <p class="text-sm text-foreground-muted leading-relaxed">{post.excerpt}</p>
              <a
                href={post.link}
                class="inline-flex items-center gap-2 text-[#02308C] font-semibold text-sm hover:gap-3 transition-all mt-auto pt-2"
              >
                Read more
                <Icon name="arrow-right" size="sm" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
