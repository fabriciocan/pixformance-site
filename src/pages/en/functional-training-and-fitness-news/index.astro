---

<ENBaseLayout
  title="Functional Training and Fitness News - Pixformance Sports GmbH"
  description="The latest news and press coverage on Pixformance — functional training, digital health, physiotherapy, and fitness innovation."
  hreflangDe="https://neu.pixformance.com/presse/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <!-- Hero -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-4">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-sm font-bold">
          <Icon name="newspaper" size="sm" />
          News & Press
        </span>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
          News
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Functional Training and Fitness News from Pixformance
        </p>
      </div>
    </div>
  </section>

  <!-- Press Download -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center max-w-5xl mx-auto">
        <div data-scroll="slide-left">
          <img
            src="https://www.pixformance.com/wp-content/uploads/2020/03/Pressemappe-EN-Pixformance-web.jpg"
            alt="Pixformance Press Kit"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-6" data-scroll="slide-right">
          <h2 class="font-display text-3xl md:text-4xl font-bold uppercase">PRESS DOWNLOAD</h2>
          <p class="text-foreground-muted leading-relaxed">
            Here you can find our press kit as well as our logos and other pictures for free editorial use for free download.
          </p>
          <p class="text-foreground-muted leading-relaxed">
            Should you require further information, please do not hesitate to contact us.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.pixformance.com/wp-content/uploads/2020/03/Pixformance-Presskit-EN-Functional-Training-Fitness-Physio-Clinic-Corporate-Fitness-1.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 bg-[#02308C] text-white font-semibold rounded-lg hover:bg-[#02308C]/90 transition-colors text-sm"
            >
              <Icon name="download" size="sm" />
              Press kit (PDF)
            </a>
            <a
              href="https://www.pixformance.com/wp-content/uploads/2020/03/Pixformance-Logos.zip"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 border border-[#02308C] text-[#02308C] font-semibold rounded-lg hover:bg-[#02308C]/5 transition-colors text-sm"
            >
              <Icon name="download" size="sm" />
              Logos (ZIP)
            </a>
            <a
              href="https://www.pixformance.com/wp-content/uploads/2020/03/Pixformance-Pictures-Copyright-to-use-for-all-images-Pixformance-Sports-GmbH.zip"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 border border-[#02308C] text-[#02308C] font-semibold rounded-lg hover:bg-[#02308C]/5 transition-colors text-sm"
            >
              <Icon name="download" size="sm" />
              Pictures (ZIP)
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Press Articles Timeline -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="space-y-16">
        {articles.map((article, index) => {
          const isEven = index % 2 === 1;
          return (
            <article class="grid lg:grid-cols-2 gap-12 items-center" data-scroll="fade-up">
              <!-- Text side -->
              <div class={`space-y-4 ${isEven ? 'lg:order-2' : ''}`}>
                <div class="flex items-center gap-4">
                  <span class="text-6xl font-bold text-[#02308C]/10">{article.num}</span>
                  <span class="text-sm font-bold text-foreground-muted uppercase tracking-wide">{article.year}</span>
                </div>
                <h2 class="font-display text-2xl md:text-3xl font-bold -mt-2">{article.title}</h2>
                <p class="text-foreground-muted leading-relaxed">{article.text}</p>
                <a
                  href={article.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:gap-3 transition-all"
                >
                  {article.cta}
                  <Icon name="external-link" size="sm" />
                </a>
              </div>

              <!-- Image side -->
              <div class={isEven ? 'lg:order-1' : ''}>
                {article.image ? (
                  <img
                    src={article.image}
                    alt={article.title}
                    class="rounded-2xl shadow-lg w-full h-auto"
                    loading="lazy"
                  />
                ) : (
                  <div class="rounded-2xl bg-gradient-to-br from-[#02308C]/5 to-[#6BDBD1]/10 aspect-[4/3] flex items-center justify-center">
                    <div class="text-center space-y-3 p-8">
                      <Icon name="newspaper" size="lg" class="text-[#02308C]/30 mx-auto" />
                      <p class="text-sm text-foreground-muted font-medium">{article.title}</p>
                      <p class="text-xs text-foreground-muted">{article.year}</p>
                    </div>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-[#6BDBD1] to-[#02308C]">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white">
          Let us advise you
        </h2>
        <p class="text-xl text-white/90">
          Should you require further information, please do not hesitate to contact us.
        </p>
        <Button size="lg" href="/en/contact/" class="bg-white text-[#02308C] hover:bg-white/90">
          Write us
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
