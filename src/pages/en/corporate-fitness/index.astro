---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import ENSolutionsTabs from '@/components/layout/ENSolutionsTabs.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const benefits = [
  { icon: 'percent', title: 'Tax deductable', text: 'Corporate fitness is tax deductable. A company can invest up to 500 Dollar per employee per year that can be deducted from your tax returns.' },
  { icon: 'users', title: 'Employee retention', text: 'In times when there is a shortage of skilled workers and a high fluctuation rate throughout many industries, a modern fitness setup can encourage long-term employee retention.' },
  { icon: 'star', title: 'Employer branding', text: 'The innovative Pixformance sports concept not only has a positive effect on employees, but also heightens your company\'s attractiveness. This makes your business more appealing to potential employees.' },
  { icon: 'trending-down', title: 'Less absenteeism and lower costs', text: 'Employees who engage in sports activities miss an average of 2 to 6 fewer working days per year. Companies can also reduce healthcare costs with the functional training provided by Pixformance.' },
  { icon: 'clock', title: 'More flexibility and training', text: 'The computer-aided Pixformance functional training concept allows several employees to be supported simultaneously and without a trainer.' },
  { icon: 'settings', title: 'No administrative cost', text: 'On the Online Platform, employees can independently compile their own training plans from a catalog of more than 350 functional exercises.' },
];

const teamMembers = [
  { name: 'Laura Alves', role: 'Sales & Purchasing', image: '/images/en/Laura-Alves-Pixformance-1.png' },
  { name: 'Rebecca Göhrt', role: 'Technical Support', image: '/images/en/Rebecca-Goehrt-Pixformance.png' },
  { name: 'Patricia Olear', role: 'Marketing Support', image: '/images/en/Patricia-Olear-Pixformance.png' },
];
---

<ENBaseLayout
  title="Corporate Health and Fitness - Pixformance Sports"
  description="Pixformance is an innovative solution for effective corporate fitness management and holistic health promotion – with individual training for each employee."
  hreflangDe="https://neu.pixformance.com/firmen-fitness/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <ENSolutionsTabs active="corporate-fitness" />

  <!-- Hero -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="briefcase" size="sm" />
            Corporate Fitness
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          We make your team Stronger,
          <span class="text-[#02308C]"> Better & More efficient</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Corporate health management that actually works
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Pixformance is an innovative solution for effective corporate fitness management and holistic health promotion – with individual training for each employee.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button size="lg" href="/en/apply-for-trial/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Apply For Trial
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button size="lg" variant="outline" href="/en/contact/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Contact Us
            <Icon name="mail" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Just Like a Trainer -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <h2 class="font-display text-4xl md:text-5xl font-bold">
            Just like a trainer
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Pixformance has revolutionized functional training. The patented Pixformance Station instantly measures the body of each trainee based on 25 joint points, precisely analyzes the execution of movements, and gives real time digital feedback. These features enable effective and safe functional training.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            The advantage: real-time correction allows your employees to complete supervised training – without the presence of a trainer. This makes functional training with Pixformance even more effective.
          </p>
        </div>
        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-225402_BGM_Pixformance_Funktionelles-Training_Milon_Virtuelles-Training_Sport-im-Buero-bearbeitet.jpg"
            alt="Pixformance Corporate Fitness — Functional Training in the Office"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Virtual Personal Training -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-scroll="slide-left" class="order-2 lg:order-1">
          <img
            src="/images/en/Pixformance-Station-2D-Funktionelles-Training-Digital-voll-vernetzt-BGM_Firmenfitness-Personal-Trainer.png"
            alt="Pixformance Station — Digital Functional Training for Corporate Fitness"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-6 order-1 lg:order-2" data-scroll="slide-right">
          <h2 class="font-display text-4xl md:text-5xl font-bold">Virtual personal training</h2>
          <p class="text-foreground-muted leading-relaxed">
            The Pixformance Station provides continuous guidance on the accuracy, pace, and precision of employee's exercise routines. This provides the same security of a functional workout supervised by a personal trainer.
          </p>
          <div class="space-y-6">
            {[
              { title: 'Simple exercise instructions', text: 'The trainee positions himself in front of the Pixformance station and the exercise is demonstrated on-screen by a trainer.' },
              { title: 'Precise motion analysis', text: 'During the exercise, a camera with a built-in depth sensor scans 25 joint points of the trainee within seconds and analyzes their movements.' },
              { title: 'Feedback in real time', text: 'The virtual trainer gives real time feedback. This ensures that the exercises are performed correctly and safely like under the guidance of a personal trainer.' },
            ].map((feature, i) => (
              <div class="flex gap-4">
                <div class="shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center">
                  <span class="text-white font-bold text-xs">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div>
                  <h3 class="font-bold mb-1">{feature.title}</h3>
                  <p class="text-sm text-foreground-muted">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 uppercase">ALIGNED WITH YOUR GOALS</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Most employees wish their company would provide sports facilities. Pixformance, as a functional training concept for corporate fitness, offers many advantages over conventional corporate health approaches.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min(index+1,6)}>
            <div class="w-10 h-10 rounded-xl bg-[#6BDBD1]/20 flex items-center justify-center mb-4 mx-auto md:mx-0">
              <Icon name={benefit.icon} size="sm" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold mb-2">{benefit.title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{benefit.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule a Call -->
  <section class="py-12 bg-[#02308C]">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <h2 class="font-display text-2xl font-bold text-white">Schedule a call or ask us a question</h2>
        <Button href="/en/contact/" class="bg-[#6BDBD1] text-[#02308C] hover:bg-[#6BDBD1]/90 shrink-0">
          Write us
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Training Concepts -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold uppercase mb-4">TRAINING CONCEPTS</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          We offer solutions to companies in various stages of development. Together with you, we work out a concept that reflects your requirements and is precisely tailored to your needs.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- 01 Individual Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="1">
          <img
            src="/images/en/Pixformance-Station-Einzeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Individual Training"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">01 INDIVIDUAL TRAINING</h2>
          <p class="text-foreground-muted">With the Pixformance Station, employees can have customized functional fitness workouts with a virtual trainer anytime.</p>

          <div class="space-y-3">
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Training Concepts
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <p class="mb-2"><strong>BETWEEN:</strong> The Pixformance Station is set up easily in offices and features a pre-installed training program. This means that it is also possible to train – without a trainer – in office during work breaks.</p>
                <p class="mb-2"><strong>INTENSIVE:</strong> The trainee receives customized functional training from a coach and is competently instructed during workouts. The station is reserved by the trainee via a booking tool for the time window of their choice. The trainer checks the training results on the online platform at regular intervals (approx. once a month) and adapts the training to achieve the desired development determined through personal discussions.</p>
                <p><strong>SUPPLEMENTARY:</strong> The Pixformance station can be used as an addition to existing fitness spaces and equipment.</p>
              </div>
            </details>
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Details
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <ul class="space-y-1">
                  <li><strong>Required space:</strong> Approx. 65 sq ft</li>
                  <li><strong>Weight:</strong> 143 lbs</li>
                  <li><strong>Camera:</strong> 2D Full HD</li>
                  <li><strong>Computer and screen:</strong> Can be switched on and off separately</li>
                  <li><strong>Touch-Screen:</strong> 49 inch touch display, standard exercises and training programs directly selectable via touch</li>
                  <li><strong>Training distance:</strong> Approx. 5'3" – 7'6" to trainer, 3'3" – 4'11" to each side (depending on exercise)</li>
                  <li><strong>Framework conditions:</strong> Power connection and Internet connection (Ethernet, Wifi Router)</li>
                  <li><strong>Equipment:</strong> Many exercises can be carried out with equipment (e.g. small dumbbells, medicine balls, gymnastics ball, gymnastics band, stick, etc.). Training without equipment is also possible</li>
                  <li><strong>Functionality:</strong> Every exercise or training program is assigned to a QR code. We provide you with an unlimited number of QR codes to use the station.</li>
                </ul>
              </div>
            </details>
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Advantages
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <ul class="space-y-1 list-disc list-inside">
                  <li>An innovative concept</li>
                  <li>Can also be integrated into smaller offices</li>
                  <li>The feedback function enables employees to complete supervised training – even without a trainer offering 1:1 supervision</li>
                  <li>Every employee has the possibility to train at any time with a pre-programmed or a personal training program at a freestanding station</li>
                </ul>
              </div>
            </details>
          </div>
        </div>

        <!-- 02 Circuit Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="2">
          <img
            src="/images/en/Pixformance-Station-Zirkeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Circuit Training"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">02 CIRCUIT TRAINING</h2>
          <p class="text-foreground-muted">With the installation of 3 Pixformance Stations, circuit training is possible for small groups like in any sports and fitness club.</p>

          <div class="space-y-3">
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Training Concepts
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <p class="mb-2"><strong>INTENSIVE:</strong> The trainee receives customized Pixformance training from a trainer and is introduced to the training with Pixformance. The station is reserved by the employee via a booking tool for the time window. The trainer checks the training results on the online platform at regular intervals (approx. once a month) and adapts the training to the training development in personal discussions.</p>
                <p><strong>GROUP TRAINING:</strong> Supervised group training with six people and one trainer is already possible with three Pixformance stations and three intermediate stations (e.g. mat, stepper).</p>
              </div>
            </details>
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Details
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <ul class="space-y-1">
                  <li><strong>Required space:</strong> Approx. 65 sq ft, various arrangement options possible depending on the room situation (e.g. row, circle, star)</li>
                  <li><strong>Weight:</strong> 143 lbs</li>
                  <li><strong>Camera:</strong> 2D Full HD</li>
                  <li><strong>Computer and screen:</strong> Can be switched on and off separately</li>
                  <li><strong>Touch-Screen:</strong> 49 inch touch display, standard exercises and training programs directly selectable via touch</li>
                  <li><strong>Training distance:</strong> Approx. 5'3" – 7'6" to trainer, 3'3" – 4'11" to each side (depending on exercise)</li>
                  <li><strong>Framework conditions:</strong> Power connection and Internet connection (Ethernet, no WLAN)</li>
                  <li><strong>Equipment:</strong> Many exercises can be carried out with equipment (e.g. small dumbbells, medicine balls, gymnastics ball, gymnastics band, stick, etc.). Training without equipment is also possible</li>
                  <li><strong>Functionality:</strong> Every exercise or training program is assigned to a QR code. We provide you with an unlimited number of QR codes to use the station.</li>
                </ul>
              </div>
            </details>
            <details class="border border-border rounded-xl overflow-hidden">
              <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                Advantages
                <span class="text-[#02308C]">+</span>
              </summary>
              <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">
                <ul class="space-y-1 list-disc list-inside">
                  <li>An innovative concept</li>
                  <li>Teambuilding in group training</li>
                  <li>Individual support and tailor-made training plans, also in groups</li>
                </ul>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Better Corporate Fitness -->
  <section class="py-16 md:py-24 bg-[#6BDBD1]">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white uppercase mb-4">BETTER Corporate Fitness and PERFORMANCE THANKS TO FUNCTIONAL TRAINING</h2>
        <p class="text-lg text-white/80 max-w-3xl mx-auto">
          Through real-time feedback, employees can improve their coördination, strength, conditioning, and mobility throughout their whole body with a virtual trainer. These benefits provided by Pixformance promotes employee productivity and concentration.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: 'shield', title: 'Less stress, more flexibility', text: 'Too many meetings and too little time? Employees benefit from the possibility to train safely, flexibly, and independently – even unattended.' },
          { icon: 'smile', title: 'Team spirit, motivation and fun', text: 'Above all, group training increases motivation and community spirit; it promotes the health, performance, and satisfaction of employees.' },
          { icon: 'bar-chart', title: 'Comprehensible results', text: 'Tailor-made workouts can be tracked and adapted for every fitness level and age in just a few simple steps.' },
        ].map((card, index) => (
          <Card variant="elevated" padding="lg" class="bg-white/10 border-white/20 text-white hover:bg-white/20 transition-colors" data-scroll="fade-up" data-delay={index+1}>
            <Icon name={card.icon} size="md" class="text-white mb-4" />
            <h3 class="font-bold text-lg mb-2">{card.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{card.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Your easy start – our strong service</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Behind every strong product is even more vital customer support. Our motivated team puts a lot of heart and soul into honest advice and first-class service every day.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {[
          { title: 'Personal consulting and training', text: 'We advise you individually, starting with the planning of the rooms, through the installation of the necessary equipment, to the optimal training control. With a Pixformance introductory course at your premises, you will also receive comprehensive instruction on how the Pixformance Station works and how to use the online platform.' },
          { title: 'Hard- and software support', text: 'If hardware problems occur (camera, sensor, computer, or screen), we will provide you with the spare parts. Also in case of software problems our support team is always there for you by phone. By the way, automatic updates for the Pixformance Station, new workouts, and updates on the Pixformance online platform are part of our service and are available to you free of charge.' },
          { title: 'Complete 360° marketing package', text: 'As our customer you\'ve got access to your marketing package for print and web, with free downloads and much more. With your customized marketing materials, you can assure an easy start for your company and let your employees know about the new training concept you are offering. Ask us!' },
          { title: 'Financing', text: 'Whether purchasing or leasing, you can structure the financing individually. We will advise and support you right from the start. Call us without obligation or write to us and find out, how you can start with Pixformance already from $99 per month.' },
          { title: 'FAQ | Frequently Asked Questions', text: 'Here you will find answers to the most frequently asked questions about our training concept.', link: '/en/faq-training-with-pixformance-station/' },
        ].map((service, index) => (
          <Card variant="elevated" padding="lg" data-scroll="fade-up" data-delay={Math.min(index+1,5)}>
            <h3 class="font-bold text-lg mb-3">{service.title}</h3>
            <p class="text-sm text-foreground-muted">{service.text}</p>
            {service.link && <a href={service.link} class="text-[#02308C] text-sm font-semibold hover:underline mt-2 inline-block">Learn more →</a>}
          </Card>
        ))}
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {teamMembers.map((member) => (
          <div class="text-center" data-scroll="fade-up">
            <img src={member.image} alt={member.name} class="w-32 h-32 rounded-full object-cover mx-auto mb-4 shadow-lg" loading="lazy" />
            <h3 class="font-bold">{member.name}</h3>
            <p class="text-sm text-foreground-muted">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
