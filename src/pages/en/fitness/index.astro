---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import ENHeader from '@/components/layout/ENHeader.astro';
import ENFooter from '@/components/layout/ENFooter.astro';
import ENSolutionsTabs from '@/components/layout/ENSolutionsTabs.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const testimonials = [
  {
    name: 'Martijn Van Der Pijl',
    role: 'Owner',
    company: 'SlimBezig! from Veldhoven, Netherlands',
    quote: 'With Pixformance, we offer a wide range of functional exercises and digital personal training that our trainers can use to challenge members. In addition, the exercises can be performed responsibly without a trainer.',
    image: '/images/en/SlimBezig_Martijn-Van-Der-Pijl-300x298.png',
  },
  {
    name: 'Esther van der Land',
    role: 'Owner',
    company: 'Boutique Studio FemmeFit from Naarden, Netherlands',
    quote: 'Pixformance stands for continuous and sustainable revenue growth and happier members who stay.',
    image: '/images/en/esther-van-der-land-FemmeFit-Naarden.png',
  },
  {
    name: 'Erwin Kuglmeier',
    role: 'Owner',
    company: 'Fitnessclub California, Germany',
    quote: 'My members can be individually guided and motivated for training with Pixformance. I especially like that the handling is effortless, and the station takes up little space!',
    image: '/images/Erwin-Kuglmeier-Fitness-California-Pixformance-300x300.png',
  },
  {
    name: 'Kim Essink',
    role: 'Owner',
    company: 'Fitnessclub Essink from Eindhoven, Netherlands',
    quote: "We made a conscious decision to go with Pixformance because we recognized the opportunity, and we're confident that our investment would pay off quickly.",
    image: '/images/Pixformance-Kim-Essink.png',
  },
  {
    name: 'Ingeborg Modde',
    role: 'Owner',
    company: 'Sweat Health Center from Oostburg, Netherlands',
    quote: 'It fits perfectly into our Milon concept. Fast, efficient, safe, and my members always get feedback from the station – a logical choice for us and the next step towards future-proof training equipment.',
    image: '/images/en/Pixformance-Ingeborg-Modde.png',
  },
  {
    name: 'Carina Dworak',
    role: 'Owner',
    company: 'Mrs.Sporty Club from Vienna, Austria',
    quote: 'The beauty of Pixformance is that members always work out with a personal trainer for, particularly, effective training results.',
    image: '/images/en/carina-dworak-mrssporty-wien-pixformance.png',
  },
];

const benefits = [
  { icon: 'trending-up', title: 'More training and sales', text: 'Thanks to the patented software, several trainees can be cared for simultaneously without additional personnel expenditure (e.g. in the evening).' },
  { icon: 'award', title: 'High-quality club equipment', text: 'A contemporary functional fitness experience paired with a tailor-made training experience for effective member retention.' },
  { icon: 'clipboard', title: 'Efficient member administration', text: 'On the online platform, the training progress of each patient is precisely documented for training analysis and optimization.' },
  { icon: 'settings', title: 'Individual care', text: 'Training programs can be tailored to the health and age of each member in seconds.' },
  { icon: 'clock', title: 'More time for the essentials', text: 'The trainer does not have to perform each exercise personally, which saves time – and, in turn, benefits and support all club members.' },
  { icon: 'zap', title: '350+ exercises available', text: '350+ functional exercises that are as varied and unique as your members. They can be activated with just a few clicks.' },
];

const clientLogos = [
  { name: "Mrs.Sporty", src: '/images/en/Logo-MrsSporty-Mrs-Sporty.png' },
  { name: 'Healthy Club', src: '/images/en/Healthy-Club.png' },
  { name: 'Fitnessclub California', src: '/images/en/pixformance-logo-fitnessclub-california-straubing-1.png' },
  { name: 'Sissis Gym', src: '/images/en/pixformance-logo-sissis-gym-susanne-willkomm-personal-training-1.png' },
  { name: 'Essink', src: '/images/en/Logo-Essink-Sportscentrum-1.png' },
  { name: 'FemmeFit', src: '/images/en/Logo-Femme-Fit-1.png' },
  { name: 'JustFit', src: '/images/en/JustFit.png' },
  { name: 'SlimBezig', src: '/images/en/Logo-SlimBezig.jpg' },
];

const teamMembers = [
  { name: 'Laura Alves', role: 'Sales & Purchasing', image: '/images/en/Laura-Alves-Pixformance-1.png' },
  { name: 'Rebecca Göhrt', role: 'Technical Support', image: '/images/en/Rebecca-Goehrt-Pixformance.png' },
  { name: 'Patricia Olear', role: 'Marketing Support', image: '/images/en/Patricia-Olear-Pixformance.png' },
];
---

<ENBaseLayout
  title="Innovative, digital sports devices for your gym"
  description="Pixformance fitness software for gyms. Personalized scheduling and functional training support under virtual guidance. Increase revenue and member retention."
  hreflangDe="https://neu.pixformance.com/fitness/"
>
  <ENHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </ENHeader>

  <ENSolutionsTabs active="fitness" />

  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-6">
        <span class="text-sm font-bold uppercase tracking-widest text-[#6BDBD1]">FITNESS</span>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
          Personalized fitness software WITH virtual guidance
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Personalized scheduling- and functional training support under virtual guidance: We provide optimal support to you and your members on the journey to improved fitness.
        </p>
        <div class="flex gap-4 flex-wrap">
          <Button size="lg" href="/en/apply-for-trial/" class="bg-white text-[#02308C] hover:bg-white/90">
            Apply For Trial
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href="/en/contact/" class="border-white text-white hover:bg-white hover:text-[#02308C]">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <h2 class="font-display text-4xl md:text-5xl font-bold">
            Fitness software that provides Better exercise with Simpler supervision
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            The Pixformance station is a digital functional training device developed by experts in the fields of science, sports, and fitness. The idea: State-of-the-art technology for a functional fitness workout that is effective and fun.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            A camera integrated into the device captures 25 joint points, analyzes movement, and provides personalized feedback in real time. The advantage: Fitness software that enables real-time correction and allows users to complete a supervised workout – without the presence of a trainer. This makes functional training even more effective.
          </p>
        </div>
        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-Fitness-Digitales-Sportgeraet-Fitnessstudio-eroeffnen-eGym-voll-vernetzt.jpg"
            alt="Digital Sports Device"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Real-Time Correction -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-scroll="slide-left" class="order-2 lg:order-1">
          <img
            src="/images/en/Station-Single-Test-Menina-White-Rooms.png"
            alt="On-screen training analysis"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-6 order-1 lg:order-2" data-scroll="slide-right">
          <h2 class="font-display text-4xl md:text-5xl font-bold">Real-time correction</h2>
          <p class="text-foreground-muted leading-relaxed">
            The Pixformance station and fitness software provides continuous guidance on the accuracy, tempo, and precision of an exercise's execution and thus offers highly safe functional training – like with a personal trainer.
          </p>
          <div class="space-y-6">
            {[
              { title: 'Simple exercise instructions', text: 'The trainee positions him/herself in front of the Pixformance station and the exercise is demonstrated on-screen by a trainer.' },
              { title: 'Precise motion analysis', text: 'During the exercise, a camera with a built-in depth sensor scans 25 joint points of the trainee within seconds and analyses their movements.' },
              { title: 'Feedback in real time', text: 'The virtual trainer gives feedback in real time. This ensures that the exercises are carried out correctly and safely just like under the guidance of a trainer.' },
            ].map((feature, i) => (
              <div class="flex gap-4">
                <div class="shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center">
                  <span class="text-white font-bold text-xs">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div>
                  <h3 class="font-bold mb-1">{feature.title}</h3>
                  <p class="text-sm text-foreground-muted">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 uppercase">OPERATE MORE ECONOMICALLY</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Pixformance makes functional training a unique experience for everyone and offers fitness studios many advantages over conventional stationary functional training equipment and circuit solutions.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min(index+1,6)}>
            <div class="w-10 h-10 rounded-xl bg-[#6BDBD1]/20 flex items-center justify-center mb-4">
              <Icon name={benefit.icon} size="sm" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold mb-2">{benefit.title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{benefit.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold">Satisfied customers</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-shadow" data-scroll="scale" data-delay={Math.min(index+1,6)}>
            <div class="flex items-start gap-3 mb-4">
              <img src={t.image} alt={t.name} class="w-12 h-12 rounded-full object-cover shrink-0" loading="lazy" />
              <div>
                <p class="font-bold text-sm">{t.name}</p>
                <p class="text-xs text-foreground-muted">{t.role}</p>
                <p class="text-xs text-[#02308C] font-semibold">{t.company}</p>
              </div>
            </div>
            <p class="text-sm text-foreground-muted italic leading-relaxed">"{t.quote}"</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <section class="py-10 bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-8">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt={logo.name} class="h-10 w-auto object-contain opacity-60 hover:opacity-90 transition-opacity grayscale hover:grayscale-0" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule a Call -->
  <section class="py-12 bg-[#02308C]">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <h2 class="font-display text-2xl font-bold text-white">Schedule a call or ask us a question</h2>
        <Button href="/en/contact/" class="bg-[#6BDBD1] text-[#02308C] hover:bg-[#6BDBD1]/90 shrink-0">
          Write us
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Training Concepts -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold uppercase mb-4">Training Concepts</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          We offer solutions to various challenges that fitness studios face. Together with you, we work out a concept that reflects your requirements and is precisely tailored to your needs.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- 01 Individual Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="1">
          <img
            src="/images/en/Pixformance-Station-Einzeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Individual Training"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">01 INDIVIDUAL TRAINING</h2>
          <p class="text-foreground-muted">With a Pixformance station, trainees can take advantage of tailor-made personal functional training at any time.</p>

          <div class="space-y-3" id="training-concepts-01">
            {[
              { title: 'Training Concepts', content: 'As 1:1 training in front of the station or as a supplement to an existing training concept. SUPPLEMENTARY, INTENSIVE, and BETWEEN training options available.' },
              { title: 'Details', content: 'Required space: ~65 sq ft · Weight: 143 lbs · Camera: 2D Full HD · Touch-Screen: 49" touch display · Training distance: ~5\'3" – 7\'6" to trainer, 3\'3" – 4\'11" to each side' },
              { title: 'Advantages', content: 'An innovative concept · Unique selling points · Integrates into smaller training areas · Virtual supervision enables solo training' },
            ].map((item, i) => (
              <details class="border border-border rounded-xl overflow-hidden">
                <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                  {item.title}
                  <span class="text-[#02308C]">+</span>
                </summary>
                <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">{item.content}</div>
              </details>
            ))}
          </div>
        </div>

        <!-- 02 Circuit Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="2">
          <img
            src="/images/en/Pixformance-Station-Zirkeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Circuit Training"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">02 CIRCUIT TRAINING</h2>
          <p class="text-foreground-muted">Circuit training for small groups is possible with a minimum of three Pixformance stations.</p>

          <div class="space-y-3">
            {[
              { title: 'Training Concepts', content: 'As 1:1 training in front of the station. Supervised group training is already possible with three stations. Prevention courses according to §20 are possible with four or more stations.' },
              { title: 'Details', content: 'Required space: ~65 sq ft · Weight: 143 lbs · Camera: 2D Full HD · Touch-Screen: 49" touch display · Training distance: ~5\'3" – 7\'6" to trainer, 3\'3" – 4\'11" to each side' },
              { title: 'Advantages', content: 'Innovative concept · Unique selling proposition · Individual support in groups · Adaptable premises · Interconnected complete solution' },
            ].map((item) => (
              <details class="border border-border rounded-xl overflow-hidden">
                <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                  {item.title}
                  <span class="text-[#02308C]">+</span>
                </summary>
                <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">{item.content}</div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Member Benefits -->
  <section class="py-16 md:py-24 bg-[#6BDBD1]">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white uppercase mb-4">REACHING YOUR GOALS EVEN FASTER</h2>
        <p class="text-lg text-white/80 max-w-3xl mx-auto">
          Through real-time feedback, users can improve their strength, physical condition, and mobility as well as train the whole body effectively.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: 'shield', title: 'Safe, Interactive, Flexible', text: 'Members benefit from the possibility to train safely, flexibly, and individually without a trainer.' },
          { icon: 'smile', title: 'More motivation and fun', text: 'Virtually supervised functional training increases the workout experience and motivates users to reach their goals.' },
          { icon: 'bar-chart', title: 'Clear, visible successes', text: 'Members train even more effectively than in a traditional workout setting and measurably improve coördination, strength, endurance, and mobility.' },
        ].map((card, index) => (
          <Card variant="elevated" padding="lg" class="bg-white/10 border-white/20 text-white hover:bg-white/20 transition-colors" data-scroll="fade-up" data-delay={index+1}>
            <Icon name={card.icon} size="md" class="text-white mb-4" />
            <h3 class="font-bold text-lg mb-2">{card.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{card.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">your easy start – our strong service</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {[
          { title: 'Personal consulting and training', text: 'We advise you individually, starting with the planning of the rooms, through the installation of the necessary equipment, to the optimal training control.' },
          { title: 'Hard- and software support', text: 'If hardware problems occur, we will provide you with the spare parts. Automatic updates are part of our service and are available to you free of charge.' },
          { title: 'Complete 360° marketing package', text: 'As our customer you\'ve got access to your marketing package for print and web, with free downloads and much more.' },
          { title: 'Financing', text: 'Whether purchasing or leasing, you can structure the financing individually. Find out about your options, how you can start with Pixformance already from $99 per month.' },
          { title: 'FAQ | Frequently Asked Questions', text: 'Here you will find answers to the most frequently asked questions about our training concept.', link: '/en/faq-training-with-pixformance-station/' },
        ].map((service, index) => (
          <Card variant="elevated" padding="lg" data-scroll="fade-up" data-delay={Math.min(index+1,5)}>
            <h3 class="font-bold text-lg mb-3">{service.title}</h3>
            <p class="text-sm text-foreground-muted">{service.text}</p>
            {service.link && <a href={service.link} class="text-[#02308C] text-sm font-semibold hover:underline mt-2 inline-block">Learn more →</a>}
          </Card>
        ))}
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {teamMembers.map((member) => (
          <div class="text-center" data-scroll="fade-up">
            <img src={member.image} alt={member.name} class="w-32 h-32 rounded-full object-cover mx-auto mb-4 shadow-lg" loading="lazy" />
            <h3 class="font-bold">{member.name}</h3>
            <p class="text-sm text-foreground-muted">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ENFooter slot="footer" />
</ENBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
