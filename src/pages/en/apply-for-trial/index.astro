---
import ENBaseLayout from '@/layouts/ENBaseLayout.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const partnerLogos = [
  { name: 'ICAA', src: '/images/en/ICAA-Pixformance.png' },
  { name: 'FSLA', src: '/images/en/FSLA-logo-pixformance.png' },
  { name: 'GSLA', src: '/images/en/gsla-logo-pixformance.png' },
  { name: 'Omnia Lifestyle', src: '/images/en/Omnia-Lifestyle-Ltd.png' },
  { name: 'FORTEe', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'Beanieproof', src: '/images/en/beanieproof.png' },
];

const features = [
  {
    titleMobile: 'Real-Time Feedback',
    titleDesktop: 'Real-Time Feedback',
    imageMobile: '/images/en/Live-Feedback-EN-mobil_Physio.jpg',
    imageDesktop: '/images/en/Digital-Training-Device-eHealth-Telemedicine-Feedback-Pixformance-Station-2020-EN-mobil-web.png',
    text: 'The Pixformance Station provides feedback in real-time. This feedback ensures that the exercises are performed correctly and safely – just like under the guidance of an actual therapist.',
  },
  {
    titleMobile: 'Simple Exercise Instructions',
    titleDesktop: 'Simple Exercise Instructions',
    imageMobile: '/images/en/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1.gif',
    imageDesktop: '/images/en/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1.gif',
    text: 'The exerciser stands in front of the Pixformance Station, and a virtual trainer demonstrates the exercise to be performed on-screen.',
  },
  {
    titleMobile: 'Precise Motion Analysis',
    titleDesktop: 'Precise Motion Analysis',
    imageMobile: '/images/en/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-mobil-1.gif',
    imageDesktop: '/images/en/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-2.gif',
    text: 'During exercise execution, a camera with a built-in depth sensor scans 25 joint and nine fixed points of the exerciser within seconds and analyzes the movements.',
  },
];

const benefitCards = [
  { icon: 'list', title: '500+ exercises – one device', text: 'Individual training plans can be compiled from a collection of over 500 functional exercises on the online platform.' },
  { icon: 'users', title: 'Simultaneous care', text: 'Thanks to the patented software, several patients can be cared for simultaneously and without additional staffing.' },
  { icon: 'trending-up', title: 'Patients become clients', text: 'Individual training sessions and secondary prevention measures can be offered as an additional source of revenue.' },
  { icon: 'clipboard', title: 'Efficient administration', text: "Each patient's training history is accurately documented on the online platform for training analysis and optimization." },
  { icon: 'settings', title: 'Individual training', text: "Exercise programs can be tailored to each patient's health condition and therapy needs." },
  { icon: 'clock', title: 'Time for the essential', text: 'The therapist does not have to demonstrate each exercise personally and saves time, which benefits the care of all patients.' },
];
---

<ENBaseLayout
  title="Apply For Trial - Pixformance Sports GmbH"
  description="Apply for a Pixformance trial. Boost efficiency and revenue with the digital functional training concept for physical therapy and fitness businesses."
>
  <!-- Simplified Landing Page Header -->
  <header class="bg-[#02308C] py-4" slot="header">
    <div class="container">
      <a href="/en/" aria-label="Pixformance Home">
        <img
          src="/images/en/PIXFORMANCE-Logo-white.svg"
          alt="Pixformance"
          class="h-8 w-auto"
          loading="eager"
        />
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-6">
        <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight">
          The sports & physical therapy concept for health business owners
        </h1>
        <h2 class="text-2xl font-bold text-[#6BDBD1]">
          Boost Efficiency and Revenue with Pixformance
        </h2>
        <ul class="space-y-3 text-lg text-white/90">
          <li class="flex items-start gap-3">
            <span class="text-2xl">👩‍⚕️</span>
            <span>Streamline Staff Efficiency and Cover Staffing Gaps</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-2xl">🚀</span>
            <span>Boost Patient Throughput and Minimize Wait Times</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-2xl">📈</span>
            <span>Drive Revenue Growth and Unlock Cash-Pay Opportunities</span>
          </li>
        </ul>
        <div>
          <a
            href="#hf-form"
            class="inline-flex items-center gap-2 px-8 py-4 bg-white text-[#02308C] font-bold rounded-xl hover:bg-white/90 transition-colors text-lg"
          >
            Apply For Trial
            <Icon name="arrow-right" size="sm" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-10 bg-white border-b border-border">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-8">
        {partnerLogos.map((logo) => (
          <img src={logo.src} alt={logo.name} class="h-10 w-auto object-contain opacity-60 hover:opacity-90 transition-opacity grayscale hover:grayscale-0" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- What Is Pixformance -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl md:text-5xl font-bold uppercase mb-4">WHAT IS PIXFORMANCE?</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <h3 class="text-xl font-bold">Introducing Our 360° Pixformance Concept, that Includes:</h3>
          <ul class="space-y-2 text-foreground-muted">
            <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> The Pixformance Station</li>
            <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> Online Platform</li>
            <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> Dedicated App</li>
          </ul>
          <p class="text-foreground-muted leading-relaxed">
            Delivering real-time feedback, precise motion analysis, and personalized training plans, enhancing rehabilitation, mobility, and performance outcomes for every patient.
          </p>
          <div class="space-y-2">
            <p class="font-bold">Key features include:</p>
            <ul class="space-y-2 text-foreground-muted">
              <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> Real-time Motion Feedback</li>
              <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> 500+ functional exercises</li>
              <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> Compact design, requiring only 65 ft²</li>
              <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1]" /> Class 2 Certified Medical Equipment</li>
            </ul>
          </div>
          <a
            href="#hf-form"
            class="inline-flex items-center gap-2 px-8 py-4 bg-[#02308C] text-white font-bold rounded-xl hover:bg-[#02308C]/90 transition-colors"
          >
            Apply For Trial
            <Icon name="arrow-right" size="sm" />
          </a>
        </div>
        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet.png"
            alt="Pixformance 360 Degree Concept — Pixformance Station, Online Platform, App"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-8">
        {features.map((feature, index) => (
          <Card variant="elevated" padding="lg" class="text-center hover:shadow-xl transition-all" data-scroll="fade-up" data-delay={index + 1}>
            <!-- Mobile image -->
            <img
              src={feature.imageMobile}
              alt={feature.titleMobile}
              class="w-full h-48 object-cover rounded-xl mb-4 md:hidden"
              loading="lazy"
            />
            <!-- Desktop image -->
            <img
              src={feature.imageDesktop}
              alt={feature.titleDesktop}
              class="hidden md:block w-full h-48 object-cover rounded-xl mb-4"
              loading="lazy"
            />
            <h3 class="font-bold text-lg mb-3">{feature.titleDesktop}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{feature.text}</p>
          </Card>
        ))}
      </div>
      <div class="text-center mt-10" data-scroll="fade-up">
        <a
          href="#hf-form"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#02308C] text-white font-bold rounded-xl hover:bg-[#02308C]/90 transition-colors"
        >
          Apply For Trial
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <Card variant="elevated" padding="lg" class="space-y-4" data-scroll="fade-up" data-delay="1">
          <div class="flex items-start gap-4">
            <img
              src="/images/en/John-Pixformance-1-297x300.png"
              alt="John Dohanic"
              class="w-16 h-16 rounded-full object-cover shrink-0"
              loading="lazy"
            />
            <div>
              <p class="font-bold">John Dohanic, Owner</p>
              <p class="text-sm text-[#02308C] font-semibold">APT Aquatic Performance Training, Monroe & Hamilton, NJ</p>
            </div>
          </div>
          <p class="text-foreground-muted italic leading-relaxed text-sm">
            "With Pix we are increasing our technology to enhance customer experience. Change needed to occur in the industry, and I'm going to keep building the change. Visual aids and proper tracking will be the future of our physical therapy company!"
          </p>
        </Card>

        <Card variant="elevated" padding="lg" class="space-y-4" data-scroll="fade-up" data-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center shrink-0">
              <Icon name="user" size="md" class="text-[#02308C]" />
            </div>
            <div>
              <p class="font-bold">Patrick Chedmail, Manual Therapy Lead</p>
              <p class="text-sm text-[#02308C] font-semibold">Omnia Lifestyle Ltd., London, UK</p>
            </div>
          </div>
          <p class="text-foreground-muted italic leading-relaxed text-sm">
            "Pixformance does save time as to client's assistance freeing therapist time for other things. It has definitely been an asset to our practice, as it has freed up our therapists' time, allowing them to focus on providing more personalised care. Our clients truly enjoy the helpful and watchful eye of the digital PT."
          </p>
        </Card>
      </div>
      <div class="text-center mt-10" data-scroll="fade-up">
        <a
          href="#hf-form"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#02308C] text-white font-bold rounded-xl hover:bg-[#02308C]/90 transition-colors"
        >
          Apply For Trial
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>
    </div>
  </section>

  <!-- Benefit Cards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {benefitCards.map((card, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min(index + 1, 6)}>
            <div class="w-10 h-10 rounded-xl bg-[#6BDBD1]/20 flex items-center justify-center mb-4">
              <Icon name={card.icon} size="sm" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold mb-2">{card.title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{card.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 md:py-24 bg-gray-50" id="hf-form">
    <div class="container">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Apply For Trial</h2>
          <p class="text-lg text-foreground-muted">
            Tell us about your practice or facility and we'll get back to you to schedule your trial.
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-8">
          <form class="space-y-6" id="trial-form">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="trial-name" class="block text-sm font-medium mb-2">Name <span class="text-red-500">*</span></label>
                <input type="text" id="trial-name" name="name" required class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="Your name" />
              </div>
              <div>
                <label for="trial-email" class="block text-sm font-medium mb-2">E-Mail <span class="text-red-500">*</span></label>
                <input type="email" id="trial-email" name="email" required class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="your.email@example.com" />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="trial-company" class="block text-sm font-medium mb-2">Company / Facility</label>
                <input type="text" id="trial-company" name="company" class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="Your facility name" />
              </div>
              <div>
                <label for="trial-phone" class="block text-sm font-medium mb-2">Phone</label>
                <input type="tel" id="trial-phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="+1 (___) ___-____" />
              </div>
            </div>
            <div>
              <label for="trial-interest" class="block text-sm font-medium mb-2">Area of Interest</label>
              <select id="trial-interest" name="interest" class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                <option value="">Please select...</option>
                <option value="physical-therapy">Physical Therapy</option>
                <option value="fitness">Fitness</option>
                <option value="corporate-fitness">Corporate Fitness</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="trial-message" class="block text-sm font-medium mb-2">Tell us about your facility <span class="text-red-500">*</span></label>
              <textarea id="trial-message" name="message" required rows="5" class="w-full px-4 py-3 rounded-lg border border-border bg-background focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none" placeholder="Describe your facility, number of patients/members, and what you'd like to achieve with Pixformance..."></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="trial-privacy" name="privacy" required class="mt-1 rounded border-border focus:ring-2 focus:ring-primary" />
              <label for="trial-privacy" class="text-sm text-foreground-muted">
                I have read the <a href="/en/privacy-policy/" class="text-[#02308C] hover:underline">Privacy Policy</a> and agree to it. <span class="text-red-500">*</span>
              </label>
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#02308C] text-white font-bold rounded-xl hover:bg-[#02308C]/90 transition-colors text-lg">
              Apply For Trial
              <Icon name="arrow-right" size="sm" />
            </button>
            <div id="trial-form-message" class="hidden"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Simplified Footer -->
  <footer class="bg-[#02308C] py-6" slot="footer">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-white/70 text-sm">
        <span>© {new Date().getFullYear()} Pixformance USA Inc.</span>
        <nav class="flex gap-6">
          <a href="/en/imprint/" class="hover:text-white transition-colors">Imprint</a>
          <a href="/en/privacy-policy/" class="hover:text-white transition-colors">Privacy Policy</a>
        </nav>
      </div>
    </div>
  </footer>
</ENBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }

  html { scroll-behavior: smooth; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));

  // Trial form submission
  (function () {
    var WEBHOOK_URL = 'https://webhook.pixformance.com/webhook/site-forms';

    function getUrlParams() {
      var params = {};
      new URLSearchParams(window.location.search).forEach(function (value, key) { params[key] = value; });
      return params;
    }

    function showMessage(el, type, text) {
      el.classList.remove('hidden');
      el.className = type === 'success'
        ? 'p-4 rounded-lg bg-green-50 text-green-700 border border-green-200'
        : 'p-4 rounded-lg bg-red-50 text-red-700 border border-red-200';
      el.textContent = text;
    }

    var form = document.getElementById('trial-form');
    var messageDiv = document.getElementById('trial-form-message');
    if (form && messageDiv) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var submitBtn = form.querySelector('[type="submit"]');
        if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.7'; }

        var formData = new FormData(form);
        var payload = {
          form_name: 'Apply For Trial EN',
          name: formData.get('name') || '',
          email: formData.get('email') || '',
          company: formData.get('company') || '',
          phone: formData.get('phone') || '',
          interest: formData.get('interest') || '',
          message: formData.get('message') || '',
          privacy_accepted: formData.get('privacy') === 'on',
          page_url: window.location.href,
          submitted_at: new Date().toISOString(),
          url_params: getUrlParams(),
          language: 'en',
        };

        fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (response) {
            if (response.ok) {
              showMessage(messageDiv, 'success', 'Thank you for your application! We will be in touch with you shortly.');
              form.reset();
            } else {
              showMessage(messageDiv, 'error', 'An error occurred. Please try again or contact us directly.');
            }
          })
          .catch(function () {
            showMessage(messageDiv, 'error', 'An error occurred. Please try again or contact us directly.');
          })
          .finally(function () {
            if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = ''; }
          });
      });
    }
  })();
</script>
