---
import JPBaseLayout from '@/layouts/JPBaseLayout.astro';
import JPHeader from '@/components/layout/JPHeader.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';

const partnerLogos = [
  { name: 'SFR Physical Therapy', src: '/images/en/SFR-logo-pixformance.png' },
  { name: 'ICAA', src: '/images/en/ICAA-Pixformance.png' },
  { name: 'FSLA', src: '/images/en/FSLA-logo-pixformance.png' },
  { name: 'GSLA', src: '/images/en/gsla-logo-pixformance.png' },
  { name: 'Omnia', src: '/images/en/Omnia-Lifestyle-Ltd.png' },
  { name: 'Forte', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'Beanieproof', src: '/images/en/beanieproof.png' },
];
---

<JPBaseLayout
  title="Pixformance Japan | 株式会社FURDI"
  description="PIXFORMANCEが認定した日本地域正規取扱企業は株式会社FURDIのみです。"
>
  <JPHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </JPHeader>

  <!-- Hero Image -->
  <section class="bg-white overflow-hidden">
    <div class="relative w-full">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/hero-mobile.webp">
        <img
          src="/images/header-2.webp"
          alt="Pixformance"
          class="w-full object-cover h-auto md:h-170"
          loading="eager"
        />
      </picture>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <!-- Partner Logos -->
    <div class="container pt-6 -mt-16">
      <div class="clients-track-wrapper overflow-hidden">
        <div class="clients-track flex items-center">
          {[...Array(2)].map(() =>
            partnerLogos.map((logo) => (
              <img
                src={logo.src}
                alt={logo.name}
                class="h-16 md:h-20 w-auto max-w-[160px] object-contain opacity-80 hover:opacity-100 transition-all duration-300 shrink-0 mr-10"
                loading="eager"
              />
            ))
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="py-20 md:py-32 bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center space-y-12">

        <!-- Main Message -->
        <div class="space-y-4">
          <p class="text-2xl md:text-3xl text-foreground leading-relaxed">
            PIXFORMANCE<br/>
            社が認定した<br/>
            日本地域正規取扱企業は<br/>
            <span class="font-semibold">株式会社FURDI のみです。</span>
          </p>
          <p class="text-lg md:text-xl text-foreground-muted mt-6">
            日本における各種お問い合わせは下記へお願い致します。
          </p>
        </div>

        <!-- Contact Details -->
        <div class="space-y-3 text-lg text-foreground">
          <p class="font-semibold text-xl">株式会社FURDI</p>
          <p>東京都千代田区外神田1ー18ー19</p>
          <p>新秋葉原ビル9F</p>
          <p>植田 滋 様</p>
          <div class="pt-4 space-y-2">
            <p>
              <a href="mailto:info@furdi.jp" class="text-[#02308C] hover:underline">
                info@furdi.jp
              </a>
            </p>
            <p>
              Tel.:&nbsp;
              <a href="tel:+81034500-7093" class="text-[#02308C] font-semibold hover:underline">
                03 – 4500 – 7093
              </a>
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</JPBaseLayout>

<style>
  .clients-track {
    animation: scroll-logos 25s linear infinite;
    width: max-content;
  }

  .clients-track-wrapper:hover .clients-track {
    animation-play-state: paused;
  }

  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
