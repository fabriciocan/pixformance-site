---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'FISIOTERAPIA', href: '/it/fisioterapia/' },
  { label: 'CLINICA', href: '/it/clinica/' },
  { label: 'FITNESS', href: '/it/fitness/' },
  { label: 'FITNESS AZIENDALE', href: '/it/fitness-aziendale/' },
];

const stats = [
  { value: '2,5M+', count: 2500000, suffix: '+', label: 'Utenti / Anno', icon: 'users' },
  { value: '1.100+', count: 1100, suffix: '+', label: 'Cliniche & Centri di Riabilitazione', icon: 'globe' },
  { value: '700+', count: 700, suffix: '+', label: 'Esercizi Funzionali', icon: 'zap' },
];

const partnerLogos = [
  { name: 'Charité', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'FORTEe', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
];

const features = [
  {
    icon: 'eye',
    title: 'Telecamera 2D Full-HD',
    description: 'Rileva 25 punti articolari in tempo reale per un\'analisi precisa del movimento — senza sensori né wearable. Ideale per i pazienti in percorso di riabilitazione clinica.',
  },
  {
    icon: 'monitor',
    title: 'Trainer Virtuale su 43"',
    description: 'Dimostra gli esercizi sullo schermo da 43" e fornisce feedback visivo immediato — i pazienti si allenano autonomamente sotto supervisione, i terapisti vengono alleggeriti.',
  },
  {
    icon: 'zap',
    title: 'Correzione in Tempo Reale',
    description: 'Feedback correttivo istantaneo durante l\'esecuzione degli esercizi garantisce qualità e sicurezza per ogni paziente — anche nelle indicazioni ortopediche o neurologiche più complesse.',
  },
];

const indications = [
  { icon: '🧠', title: 'Riabilitazione Neurologica', description: 'Terapia del movimento per SM, ictus, Parkinson — con qualità standardizzata su larga scala.' },
  { icon: '🦴', title: 'Riabilitazione Ortopedica', description: 'Trattamento post-operatorio e disturbi del movimento: anca, ginocchio, spalla, colonna vertebrale.' },
  { icon: '🎗️', title: 'Riabilitazione Oncologica', description: 'Il movimento come terapia nel percorso di recupero oncologico — personalizzato per affaticamento e recupero funzionale.' },
  { icon: '👴', title: 'Riabilitazione Geriatrica', description: 'Prevenzione delle cadute e mantenimento della mobilità nei pazienti anziani — in modo sicuro e motivante.' },
  { icon: '❤️', title: 'Riabilitazione Cardiologica', description: 'Allenamento funzionale dopo eventi cardiaci, sempre con controllo della qualità in tempo reale.' },
  { icon: '🏥', title: 'Attivazione Clinica', description: 'Struttura giornaliera e stimolazione al movimento per i pazienti durante il ricovero.' },
];

const benefits = [
  {
    icon: 'users',
    title: 'Attivazione del Paziente',
    description: 'Un ambiente di allenamento digitale motivante con elementi di gamification aumenta in modo misurabile la partecipazione attiva dei pazienti e l\'aderenza alla terapia.',
  },
  {
    icon: 'heart',
    title: 'Alleggerimento del Personale',
    description: 'I terapisti supervisionano più pazienti contemporaneamente, concentrandosi sulla terapia manuale e sui casi complessi — Pixformance gestisce l\'allenamento standard.',
  },
  {
    icon: 'trending-up',
    title: 'Scalabilità',
    description: 'Fino a 4 pazienti contemporaneamente su più stazioni — con software brevettato, senza personale aggiuntivo, mantenendo una qualità di assistenza costante.',
  },
  {
    icon: 'file-text',
    title: 'Documentazione Automatica',
    description: 'L\'esecuzione degli esercizi, il Pixformance Score e i progressi vengono salvati automaticamente sulla piattaforma online — nessuna registrazione manuale, storico completo degli allenamenti.',
  },
  {
    icon: 'check-circle',
    title: 'Aderenza alla Terapia',
    description: 'Gli elementi di gamification e il feedback immediato aumentano la motivazione intrinseca — i pazienti mantengono i programmi più a lungo ed eseguono gli esercizi con maggiore precisione.',
  },
  {
    icon: 'shield',
    title: 'Garanzia di Qualità',
    description: 'L\'esecuzione standardizzata degli esercizi tramite feedback correttivo in tempo reale garantisce una qualità di trattamento costante — indipendentemente dai livelli di personale.',
  },
];

const clinicalStudies = [
  { title: 'Charité Berlin', finding: 'Miglioramento significativo della forza muscolare e della mobilità funzionale dopo 8 settimane di allenamento Pixformance.' },
  { title: 'Oxford Brookes University', finding: 'Notevole miglioramento dell\'equilibrio e della prevenzione delle cadute nei pazienti geriatrici.' },
  { title: 'Progetto UE FORTEe', finding: 'La terapia del movimento guidata dalla tecnologia migliora i risultati riabilitativi nelle cliniche europee.' },
  { title: 'AUVA Unfallkrankenhaus Klagenfurt', finding: 'Maggiore motivazione del paziente e allenamento autonomo supervisionato nella riabilitazione acuta.' },
  { title: 'Medical Park Bad Rodach', finding: 'Riduzione del tempo di accompagnamento del personale con qualità terapeutica invariata o migliorata.' },
];

const medicalDeviceSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalDevice",
  "name": "Pixformance Station — Dispositivo di Riabilitazione Digitale per Cliniche",
  "description": "Dispositivo di riabilitazione digitale certificato dispositif médical CE (MDR UE 2017/745) per cliniche e centri di riabilitazione. Analisi del movimento in tempo reale, documentazione automatizzata, fino a 4 pazienti contemporaneamente.",
  "manufacturer": {
    "@type": "Organization",
    "name": "Pixformance Sports GmbH",
    "url": "https://pixformance.com"
  },
  "medicalSpecialty": ["Ortopedia", "Neurologia", "Geriatria", "Cardiologia", "Riabilitazione Oncologica"],
  "recognizingAuthority": {
    "@type": "Organization",
    "name": "CE-Kennzeichnung — MDR EU 2017/745",
    "url": "https://www.fda.gov"
  },
  "regulatoryStatus": "Dispositivo medico dispositif médical CE (MDR UE 2017/745)",
  "url": "https://www.pixformance.com/it/clinica/"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quali cliniche usano Pixformance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance è utilizzato da oltre 1.100 cliniche e centri di riabilitazione, tra cui Charité Berlin, Medical Park, Niederrhein-Klinik, Sauerlandklinik Hachen, AUVA e Mediclin." }
    },
    {
      "@type": "Question",
      "name": "Pixformance è certificato come dispositivo medico?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sì. Pixformance è certificato come dispositivo medico dispositif médical CE (MDR UE 2017/745) e soddisfa i requisiti clinici e normativi per l'utilizzo in cliniche e centri di riabilitazione." }
    },
    {
      "@type": "Question",
      "name": "Per quali indicazioni è adatto Pixformance nelle cliniche?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance è adatto per la riabilitazione neurologica (SM, ictus, Parkinson), ortopedica, oncologica, geriatrica e cardiologica, nonché per l'attivazione clinica dei pazienti." }
    },
    {
      "@type": "Question",
      "name": "Quanti pazienti possono allenarsi contemporaneamente su Pixformance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Fino a 4 pazienti possono allenarsi contemporaneamente su più stazioni Pixformance — senza personale aggiuntivo grazie al software brevettato per l'analisi del movimento." }
    },
    {
      "@type": "Question",
      "name": "Come si integra Pixformance con i sistemi di documentazione clinica?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance salva automaticamente l'esecuzione degli esercizi, il Pixformance Score e i progressi sulla piattaforma online. Sono disponibili opzioni di esportazione per l'amministrazione clinica e la reportistica assicurativa." }
    },
    {
      "@type": "Question",
      "name": "Quale spazio e infrastruttura sono necessari per una stazione Pixformance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Una stazione Pixformance richiede una superficie di circa 4–6 m², una presa elettrica standard e una connessione internet. Non sono necessari adattamenti strutturali speciali." }
    },
    {
      "@type": "Question",
      "name": "Quanto tempo richiede l'introduzione per i pazienti?",
      "acceptedAnswer": { "@type": "Answer", "text": "Dopo soli 30 minuti di istruzione, i pazienti possono allenarsi autonomamente sotto supervisione su Pixformance — riducendo significativamente il tempo di accompagnamento dei terapisti." }
    },
    {
      "@type": "Question",
      "name": "Come avviene l'installazione e il supporto tecnico?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pixformance gestisce l'installazione completa inclusa l'installazione tecnica, la formazione del personale e il supporto continuo. Le cliniche ricevono accesso alla piattaforma di gestione online." }
    }
  ]
};
---

<ITBaseLayout
  title="Dispositivi di Riabilitazione Digitale per Cliniche — dispositif médical CE (MDR UE 2017/745) | Pixformance"
  description="Pixformance per cliniche di riabilitazione: certificato dispositif médical CE (MDR UE 2017/745), 1.100+ cliniche (Charité, Medical Park, AUVA). Attivazione pazienti, alleggerimento terapisti, documentazione automatica."
  hreflangDe="https://www.pixformance.com/klinik/"
  hreflangEn="https://www.pixformance.com/en/clinic/"
  jsonLd={[medicalDeviceSchema, faqSchema]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/clinique/" />
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/kliniek/" />
  </Fragment>

  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Breadcrumb Tabs -->
  <BreadcrumbTabs tabs={tabs} activeTab="/it/clinica/" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <h1 class="font-display text-4xl md:text-6xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Riabilitazione digitale che rende la vostra clinica più efficiente — senza compromessi sulla qualità dell'assistenza.
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Oltre 1.100 cliniche di riabilitazione e ospedali si affidano a Pixformance — dalla Charité Berlin a Medical Park, AUVA e Oxford Brookes University. L'unico dispositivo di terapia del movimento digitale certificato dispositif médical CE (MDR UE 2017/745) che motiva i pazienti e libera i terapisti dal lavoro di routine.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button
            size="lg"
            href="/it/prova-gratuita/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Prova gratuita
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/it/contatto/"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Richiedi consulenza
            <Icon name="phone" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-4 sm:p-6 rounded-2xl hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate" style={`animation-delay: ${0.6 + index * 0.1}s;`}>
              <div
                class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300 stat-counter"
                data-count={stat.count}
                data-suffix={stat.suffix}
                data-large={stat.count >= 10000 ? 'true' : 'false'}
              >
                {stat.value}
              </div>
              <div class="text-xs sm:text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="py-10 bg-gray-50 border-y border-gray-200" data-scroll="fade-up">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-6">
        Scelto dalle principali cliniche
      </p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        {partnerLogos.map(logo => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 md:h-10 w-auto object-contain grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="layers" size="sm" />
          Sistema completamente connesso
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          La Stazione Pixformance
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Analisi avanzata del movimento combinata con l'esperienza terapeutica — progettata appositamente per ambienti clinici.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {features.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 rounded-xl bg-[#02308C] flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-xl mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Indications Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="activity" size="sm" />
          Indicazioni
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Fasi di riabilitazione supportate da Pixformance
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-2xl mx-auto">
          Dalla neurologia alla geriatria — Pixformance supporta le principali indicazioni cliniche.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {indications.map((item, index) => (
          <div
            class="bg-white rounded-2xl p-6 flex gap-4 items-start shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <span class="text-3xl leading-none mt-1">{item.icon}</span>
            <div>
              <h3 class="font-bold text-base mb-1 text-[#02308C]">{item.title}</h3>
              <p class="text-sm text-foreground-muted">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Vantaggi
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-4">
          Vantaggi per la vostra clinica
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 ${index % 2 === 0 ? 'bg-[#02308C]' : 'bg-[#6BDBD1]'}`}>
              <Icon name={benefit.icon} size="md" class="text-white" />
            </div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
              {benefit.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {benefit.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="check-circle" size="sm" />
          Esperienze Cliniche
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Cosa dicono i direttori delle cliniche
        </h2>
        <p class="text-lg text-foreground-muted mt-4">
          Esperienze di responsabili terapeutici e direttori di cliniche
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="1"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "I pazienti sono entusiasti e molto motivati, il che sinceramente non è sempre scontato. Naturalmente anche noi terapisti ne beneficiamo, poiché i pazienti eseguono i loro esercizi in modo migliore e più mirato. Inoltre risparmiamo tempo, perché dopo soli 30 minuti di istruzioni i pazienti possono esercitarsi autonomamente sotto supervisione."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Gabriele-Buchstein-Leitung-Physiotherapie-Sauerlandklinik-Hachen.png"
              alt="Gabriele Buchstein"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Gabriele Buchstein</cite>
              <p class="text-sm text-foreground-muted">Responsabile Fisioterapia</p>
              <p class="text-sm font-semibold text-[#02308C]">Sauerlandklinik Hachen – Clinica Neurologica Specializzata per la Sclerosi Multipla</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="2"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "Cercando un modo per attivare i pazienti e alleggerire allo stesso tempo il personale, abbiamo scoperto Pixformance. Stavamo cercando un modo moderno di fare movimento che alleggerisse allo stesso tempo il personale. Pixformance si adatta perfettamente al nostro concetto di cura."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich-Pixformance.png"
              alt="Christoph Schneider"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Christoph Schneider</cite>
              <p class="text-sm text-foreground-muted">Responsabile Terapia</p>
              <p class="text-sm font-semibold text-[#02308C]">Niederrhein-Klinik – Clinica di Riabilitazione Korschenbroich</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="3"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
            "Da parte dei pazienti c'è grande interesse per le stazioni Pixformance. Molti vengono spontaneamente e vogliono un programma di allenamento. Questo ci rende particolarmente felici — dimostra che Pixformance motiva intrinsecamente i pazienti a muoversi."
          </p>
          <footer class="flex items-center gap-4">
            <img
              src="/images/Christoph-Oratsch-AUVA-Klagenfurt-1.png"
              alt="Christoph Oratsch"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-[#6BDBD1]"
              loading="lazy"
            />
            <div>
              <cite class="font-bold not-italic text-[#02308C]">Christoph Oratsch</cite>
              <p class="text-sm text-foreground-muted">Responsabile Terapia</p>
              <p class="text-sm font-semibold text-[#02308C]">AUVA Unfallkrankenhaus Klagenfurt</p>
            </div>
          </footer>
        </blockquote>

        <blockquote
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-all duration-300 border-l-4 border-[#6BDBD1]"
          data-scroll="fade-up"
          data-delay="4"
        >
          <p class="text-base text-foreground-muted italic leading-relaxed mb-6">
