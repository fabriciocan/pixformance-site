---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const components = [
  {
    icon: 'monitor',
    title: 'Stazione Pixformance',
    description: 'La stazione brevettata con telecamera 2D Full-HD cattura 25 punti articolari per un\'analisi precisa del movimento',
  },
  {
    icon: 'globe',
    title: 'Piattaforma Online',
    description: 'Gestione centralizzata di tutti gli utenti e dei programmi di allenamento con storico completo dei dati',
  },
  {
    icon: 'smartphone',
    title: 'App Web Mobile',
    description: 'Allenati ovunque — a casa o in viaggio con la Web App Pixformance',
  },
];

const technologies = [
  {
    icon: 'cpu',
    title: 'Software Innovativo',
    color: '#02308C',
    features: [
      'Basato su 25 punti articolari',
      'Misurazione del corpo in pochi secondi',
      'Analisi precisa del movimento',
      'Tecnologia brevettata',
    ],
  },
  {
    icon: 'message-square',
    title: 'Feedback Digitale',
    color: '#6BDBD1',
    features: [
      'Correzione in tempo reale',
      'Feedback testuale',
      'Feedback visivo',
      'Adeguamenti personalizzati',
    ],
  },
  {
    icon: 'network',
    title: 'Connettività',
    color: '#6BDBD1',
    features: [
      'Stazione ↔ Piattaforma Online',
      'Piattaforma Online ↔ App Web',
      'Sincronizzazione dati senza interruzioni',
      'Gestione centralizzata',
    ],
  },
];

const targetGroups = [
  {
    svgIcon: '/images/konzept-icons/17.svg',
    title: 'Le Migliori Cliniche Riabilitative',
    description: 'Le strutture leader si fidano di Pixformance',
  },
  {
    svgIcon: '/images/konzept-icons/18.svg',
    title: 'Studi di Fisioterapia',
    description: 'Supporto ottimale per i terapisti',
  },
  {
    svgIcon: '/images/konzept-icons/20.svg',
    title: 'Palestre e Fitness',
    description: 'Concetti di allenamento moderni per le palestre',
  },
  {
    svgIcon: '/images/konzept-icons/16.svg',
    title: 'Benessere Aziendale',
    description: 'Dipendenti sani e ad alte prestazioni',
  },
];

const keyFeatures = [
  {
    icon: 'layers',
    title: '700+ Esercizi Funzionali',
    description: 'Ampia libreria di esercizi per ogni condizione di salute e livello di fitness',
  },
  {
    icon: 'monitor',
    title: 'Personal Trainer Virtuale',
    description: 'Guida professionale tramite un trainer digitale visualizzato sullo schermo',
  },
  {
    icon: 'settings',
    title: 'Piani di Allenamento Personalizzati',
    description: 'Adattati individualmente al livello di fitness e agli obiettivi personali',
  },
  {
    icon: 'check-circle',
    title: 'Esecuzione Sicura degli Esercizi',
    description: 'La correzione in tempo reale previene posture errate e infortuni',
  },
];
---

<ITBaseLayout
  title="Dispositivi di Functional Training Pixformance – Il Concetto 360°"
  description="Il Concetto Pixformance 360° — Dispositivi professionali per fisioterapia e fitness, software brevettato, Piattaforma Online completamente connessa e App."
  hreflangDe="https://www.pixformance.com/konzept/"
  hreflangEn="https://www.pixformance.com/en/products-2/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Dispositivi di Functional Training Pixformance – Il Concetto 360°",
    "description": "Il Concetto Pixformance 360° comprende stazione, piattaforma online e app per un allenamento funzionale completamente connesso.",
    "url": "https://www.pixformance.com/it/prodotti/"
  }}
>
  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden">
    <div class="relative w-full hero-animate" style="animation-delay: 0.1s;">
      <img
        src="/images/Pixformance-Gruppentraining-Physiotherapie-Digitale-Rehabilitation-eHealth-Funktionelles-Training-Banner.jpg"
        alt="Pixformance Allenamento di Gruppo Fisioterapia Riabilitazione Digitale"
        class="w-full h-auto object-cover"
        loading="eager"
      />
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <div class="container py-12 md:py-16">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white text-sm font-bold shadow-lg">
            <Icon name="zap" size="sm" />
            ALLENAMENTO COMPLETAMENTE CONNESSO
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Concetto di Allenamento Digitale per i Tuoi Pazienti e Membri
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          La Stazione Pixformance con software brevettato, una Piattaforma Online e una Web App — questi tre componenti formano il nostro concetto di allenamento digitale completamente connesso. Utilizzando la migliore tecnologia per l'analisi digitale del movimento, offriamo un functional training altamente efficace per ogni livello di fitness e condizione di salute.
        </p>

        <div class="flex gap-4 flex-wrap justify-center hero-animate" style="animation-delay: 0.4s;">
          <Button size="lg" href="/it/prova-gratuita/">
            Richiedi Prova
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href="/it/contatto/">
            Contattaci
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- System Components -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-10" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          I 3 Componenti del Sistema
        </h2>
      </div>

      <div class="flex justify-center mb-12" data-scroll="fade-up">
        <img
          src="/images/en/Pixformance-360-Grad-Konzept-Online-Plattform-App-Digitales-Sportgeraet-1.jpg"
          alt="I 3 componenti: Stazione Pixformance, Piattaforma Online e App Web Mobile"
          class="max-w-lg w-full object-contain"
          loading="lazy"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {components.map((component, index) => (
          <div class="flex flex-col items-center text-center gap-4" data-scroll="fade-up" data-delay={index + 1}>
            <div class="w-20 h-20 rounded-full border-2 border-[#02308C] flex items-center justify-center flex-shrink-0">
              <Icon name={component.icon} size="lg" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold text-xl text-foreground">
              {component.title}
            </h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              {component.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="star" size="sm" />
          Funzionalità
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Funzionalità Chiave del Sistema
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {keyFeatures.map((feature, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <Icon name={feature.icon} size="lg" class="text-white" />
            </div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-[#02308C] transition-colors">
              {feature.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {feature.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Highlights -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="cpu" size="sm" />
          Tecnologia
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Punti di Forza della Tecnologia
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {technologies.map((tech, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold group-hover:text-[#02308C] transition-colors">
                {tech.title}
              </h3>
              <ul class="space-y-3">
                {tech.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <Icon name="check-circle" size="sm" class="text-[#86C9BC] mt-0.5 flex-shrink-0" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Target Groups -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Destinatari
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
          Utilizzato con successo in
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {targetGroups.map((group, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="text-center hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group bg-white"
            data-scroll="scale"
            data-delay={index + 1}
          >
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-[#02308C] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
              <img src={group.svgIcon} alt={group.title} class="w-8 h-8 object-contain" loading="lazy" />
            </div>
            <h3 class="font-semibold mb-2 group-hover:text-[#02308C] transition-colors">
              {group.title}
            </h3>
            <p class="text-sm text-foreground-muted">
              {group.description}
            </p>
          </Card>
        ))}
      </div>

      <div class="text-center" data-scroll="fade-up">
        <div class="inline-block p-8 rounded-2xl bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 border border-[#02308C]/20">
          <p class="text-4xl md:text-5xl font-bold text-[#02308C] mb-2">2,5M+</p>
          <p class="text-lg text-foreground-muted">Utenti in tutto il mondo</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-18 md:pb-40 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto pt-8 text-center" data-scroll="fade-up">
        <blockquote class="text-2xl md:text-3xl font-bold text-white mb-8 leading-relaxed">
          "Con Pixformance abbiamo creato un secondo settore self-pay. La terapia del movimento digitale entusiasma i nostri pazienti e si è ripagata rapidamente."
        </blockquote>

        <div class="flex items-center justify-center gap-4">
          <div class="w-30 h-30 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
            <img src="/images/Heike-Schaible-round.png" class="w-30 h-30 rounded-full object-cover" loading="lazy" alt="Heike Schaible" />
          </div>
          <div class="text-left">
            <p class="font-bold text-white text-lg">Heike Schaible</p>
            <p class="text-white text-sm">Titolare</p>
            <p class="text-white text-sm">Studio di Fisioterapia "Raum für Gesundheit", Stoccarda</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
          <Icon name="headphones" size="sm" />
          Consulenza
        </span>

        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Siamo lieti di consigliarti!
        </h2>

        <p class="text-xl text-foreground-muted max-w-2xl mx-auto">
          A volte le domande sono più facili da rispondere di persona. Non vediamo l'ora di sentirti!
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-4">
          <Button size="lg" href="/it/prova-gratuita/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Richiedi Prova
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform" />
          </Button>
          <Button size="lg" variant="outline" href="/it/contatto/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Contattaci
            <Icon name="mail" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
