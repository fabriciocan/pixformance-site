---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const clientLogos = [
  { name: 'Gesundheitsrondell', src: '/images/en/Logo-Gesundheitsrondell-Reharondell.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrheinklinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Charité', src: '/images/en/Logo-Charite.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'FORTEe', src: '/images/en/fortee-eu-poject-pixformance-partner.png' },
  { name: 'AUVA', src: '/images/en/2560px-Logo_AUVA.svg.png' },
];

const testimonials = [
  {
    name: 'Gabriele Buchstein',
    role: 'Responsabile Fisioterapia',
    company: 'Sauerlandklinik Hachen | Clinica Neurologica Specializzata per la Sclerosi Multipla, Germania',
    quote: 'I pazienti sono entusiasti e molto motivati, il che sinceramente non è sempre scontato. Naturalmente anche noi terapisti ne beneficiamo, poiché i pazienti eseguono i loro esercizi in modo migliore e più mirato. Inoltre risparmiamo tempo, perché dopo soli 30 minuti di istruzioni i pazienti possono esercitarsi autonomamente sotto supervisione.',
    image: '/images/Gabriele-Buchstein-Leitung-Physiotherapie-Sauerlandklinik-Hachen.png',
  },
  {
    name: 'Christoph Schneider',
    role: 'Direttore Terapia',
    company: 'Niederrhein-Klinik | Clinica Riabilitativa Korschenbroich, Germania',
    quote: 'Cercando un modo per rendere i pazienti autonomi, abbiamo scelto Pixformance. L\'offerta di allenamento individuale è ideale, poiché la terapia di gruppo è spesso troppo facile per alcuni e troppo difficile per altri. Così ognuno riceve un allenamento completamente personalizzato.',
    image: '/images/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich-Pixformance.png',
  },
  {
    name: 'Christoph Oratsch',
    role: 'Direttore Terapia',
    company: 'Ospedale Infortuni AUVA, Klagenfurt, Austria',
    quote: 'Da parte dei pazienti c\'è grande interesse e curiosità per le stazioni Pixformance. Molti si avvicinano spontaneamente e chiedono un programma di allenamento. Recentemente abbiamo seguito da remoto una giovane donna dopo un intervento alla spalla. Viene in clinica una volta a settimana – il resto della terapia lo fa a casa. È un\'opzione davvero eccellente per i pazienti che non possono muoversi molto.',
    image: '/images/Christoph-Oratsch-AUVA-Klagenfurt-1.png',
  },
  {
    name: 'Gunter Hölig',
    role: 'Direttore Terapia',
    company: 'Medical Park, Bad Rodach, Germania',
    quote: 'Siamo lieti di osservare che i nostri pazienti apprezzano molto l\'allenamento e perseverano. La componente ludica delle nostre attrezzature terapeutiche digitali Pixformance gioca sicuramente un ruolo importante – e quando i pazienti dimenticano per un momento la malattia e si divertono semplicemente, questo è estremamente prezioso.',
    image: '/images/Pixformance-Gunter-Hoelig.png',
  },
];

const cashPayBenefits = [
  { icon: 'zap', title: '700+ esercizi – un solo dispositivo', text: 'Piani di allenamento individuali possono essere compilati da una raccolta di oltre 700 esercizi funzionali sulla piattaforma online.' },
  { icon: 'users', title: 'Assistenza simultanea', text: 'Grazie al software brevettato, è possibile assistere più pazienti contemporaneamente senza personale aggiuntivo.' },
  { icon: 'trending-up', title: 'I pazienti diventano clienti', text: 'Sessioni di allenamento individuali e misure di prevenzione secondaria possono essere offerte come fonte di entrate aggiuntiva.' },
  { icon: 'clipboard', title: 'Amministrazione efficiente', text: 'La cronologia degli allenamenti di ogni paziente è documentata con precisione sulla piattaforma online per l\'analisi e l\'ottimizzazione.' },
  { icon: 'settings', title: 'Allenamento individuale', text: 'I programmi di esercizi possono essere adattati alle condizioni di salute e alle esigenze terapeutiche di ogni paziente.' },
  { icon: 'clock', title: 'Tempo per l\'essenziale', text: 'Il terapista non deve dimostrare personalmente ogni esercizio e risparmia tempo, a beneficio di tutti i pazienti.' },
];

const patientBenefits = [
  { icon: 'zap', title: '700+ Esercizi, un Solo Dispositivo', text: 'A seconda dell\'indicazione, sono possibili esercizi speciali su sedia a rotelle, con deambulatori, su lettino o sul pavimento. Ogni esercizio può essere adattato alle esigenze individuali del paziente.' },
  { icon: 'shield', title: 'Maggiore Empowerment e Autocontrollo', text: 'I pazienti sono in grado di valutare autonomamente la qualità del proprio movimento e di influenzare le deviazioni motorie in modo indipendente.' },
  { icon: 'clock', title: 'Più Tempo per Ciò che Conta', text: 'Il terapista non deve dimostrare personalmente ogni esercizio e risparmia tempo – a beneficio dell\'assistenza di tutti i pazienti.' },
  { icon: 'award', title: 'Attrezzature Innovative', text: 'Un concetto terapeutico innovativo e moderno con Pixformance ha un effetto positivo sull\'immagine e la percezione della struttura.' },
  { icon: 'heart', title: 'Sollievo per i Terapisti', text: 'Trattamento mirato e individuale senza personale aggiuntivo e più tempo per l\'assistenza personale di ogni paziente.' },
  { icon: 'smile', title: 'Più Voglia di Muoversi', text: 'Si crea un\'esperienza terapeutica positiva e i pazienti sono motivati a raggiungere i propri obiettivi terapeutici con divertimento e motivazione.' },
  { icon: 'bar-chart', title: 'Successo Terapeutico Tangibile', text: 'L\'archiviazione dei dati di allenamento permette un confronto prima-dopo e rende tangibili i progressi clinici e i successi del trattamento.' },
];

const teamMembers = [
  { name: 'Laura Alves', role: 'Vendite & Acquisti', image: '/images/en/Laura-Alves-Pixformance-1.png' },
  { name: 'Patricia Olear', role: 'Supporto Marketing', image: '/images/en/Patricia-Olear-Pixformance.png' },
];

const studies = [
  {
    institution: 'Hochschule Fresenius | University of Applied Sciences',
    topic: 'L\'uso di Pixformance con il programma di esercizi a casa raccomandato ha un effetto positivo sulla capacità di camminare di un paziente con SM?',
    pdf: '/ressourcen-download?doc=studie-ms',
  },
  {
    institution: 'Hochschule Fresenius | University of Applied Sciences',
    topic: 'Influenza di un programma di rafforzamento con feedback visivo sulla condizione di un paziente con distrofia muscolare Emery-Dreifuss – studio su singolo caso',
    pdf: '/ressourcen-download?doc=studie-muskeldystrophie',
  },
  {
    institution: 'Hochschule Fresenius | University of Applied Sciences',
    topic: 'Quale effetto ha l\'uso di Pixformance su equilibrio, capacità di camminare e qualità della vita nel trattamento di pazienti con sindrome di Parkinson?',
    pdf: '/ressourcen-download?doc=studie-parkinson',
  },
  {
    institution: 'Hochschule Fresenius | University of Applied Sciences',
    topic: 'Indagine sull\'effetto di Pixformance sull\'arto superiore in un paziente dopo Mamma-Ca',
    pdf: '/ressourcen-download?doc=studie-brustkrebs',
  },
  {
    institution: 'German University for Prevention and Health Management',
    topic: 'Revisione empirica degli effetti dell\'allenamento di un programma standardizzato sull\'esempio Mrs.Sporty e Pixformance',
    pdf: '/ressourcen-download?doc=studie-mrs-sporty',
  },
];
---

<ITBaseLayout
  title="Dispositivo Digitale di Terapia del Movimento per Studi di Fisioterapia e Cliniche | Pixformance"
  description="Pixformance: sistema di riabilitazione digitale per fisioterapisti. Analisi in tempo reale di 25 punti articolari, 700+ esercizi, 6.000+ installazioni in tutto il mondo. Dispositivo medico dispositif médical CE (MDR UE 2017/745)."
  hreflangDe="https://www.pixformance.com/physiotherapie/"
  hreflangEn="https://www.pixformance.com/en/physical-therapy/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Stazione Pixformance",
      "description": "Sistema di riabilitazione digitale completamente connesso con una telecamera 2D Full HD con sensore di profondità integrato per l'analisi in tempo reale di 25 punti articolari, fornendo feedback correttivo istantaneo durante l'esercizio.",
      "manufacturer": { "@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com" },
      "legalStatus": "Dispositivo Medico dispositif médical CE (MDR UE 2017/745)",
      "relevantSpecialty": ["Fisioterapia", "Riabilitazione", "Neurologia", "Ortopedia", "Medicina Sportiva"]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Cos'è la Stazione Pixformance e come funziona in fisioterapia?",
          "acceptedAnswer": { "@type": "Answer", "text": "La telecamera 2D Full HD con sensore di profondità integrato analizza in tempo reale 25 punti articolari. Un terapista virtuale dimostra la sequenza di esercizio corretta sullo schermo mentre il paziente esegue l'esercizio. Il sistema rileva istantaneamente le deviazioni del movimento e fornisce feedback visivo e testuale direttamente sullo schermo." }
        },
        {
          "@type": "Question",
          "name": "Per quali indicazioni è adatto Pixformance?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sclerosi multipla, sindrome di Parkinson, riabilitazione postoperatoria (anca, ginocchio, spalla, colonna vertebrale), riabilitazione neurologica, follow-up oncologico, allenamento geriatrico per l'equilibrio e la prevenzione delle cadute. Gli esercizi possono essere adattati per pazienti in sedia a rotelle, con deambulatori, su lettino o sul pavimento." }
        },
        {
          "@type": "Question",
          "name": "Pixformance sostituisce i fisioterapisti?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Pixformance supporta e alleggerisce i terapisti — non li sostituisce. Il sistema gestisce automaticamente la guida degli esercizi, la correzione in tempo reale e la documentazione. Dopo soli 30 minuti di istruzioni, i pazienti possono esercitarsi autonomamente sotto supervisione." }
        },
        {
          "@type": "Question",
          "name": "Pixformance è un dispositivo medico certificato?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì. Pixformance è un dispositivo medico certificato CE (conforme MDR UE 2017/745). Il dispositivo è conforme alla Direttiva EMC 2004/108/CE ed è prodotto dal 2012 secondo rigorosi standard di qualità e sicurezza." }
        }
      ]
    }
  ]}
>
  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Solutions Tabs -->
  <div class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="container">
      <div class="flex gap-0 overflow-x-auto">
        <a href="/it/fisioterapia/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold border-b-2 border-[#02308C] text-[#02308C] whitespace-nowrap">
          <Icon name="heart" size="sm" />
          Fisioterapia
        </a>
        <a href="/it/fitness/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold border-b-2 border-transparent text-foreground-muted hover:text-foreground transition-colors whitespace-nowrap">
          <Icon name="activity" size="sm" />
          Fitness
        </a>
        <a href="/it/fitness-aziendale/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold border-b-2 border-transparent text-foreground-muted hover:text-foreground transition-colors whitespace-nowrap">
          <Icon name="briefcase" size="sm" />
          Fitness Aziendale
        </a>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="heart" size="sm" />
            Fisioterapia
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Dispositivi di riabilitazione
          <span class="text-[#02308C]"> digitali e innovativi</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Aumenta il numero di pazienti e alleggerisci i tuoi terapisti
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Nessuna tecnologia al mondo può sostituire i terapisti. Tuttavia, la digitalizzazione in fisioterapia e riabilitazione alleggerisce efficacemente i terapisti e offre ai pazienti un'assistenza ancora più intensiva.
        </p>

        <p class="text-base md:text-lg text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.43s;">
          Pixformance è un sistema di terapia del movimento completamente connesso, utilizzato in oltre 6.000 studi fisioterapici, cliniche riabilitative e ospedali in tutto il mondo. La stazione Pixformance analizza in tempo reale 25 punti articolari tramite una telecamera 2D Full HD con sensore di profondità integrato, fornendo feedback correttivo istantaneo. Come dispositivo medico CE (MDR UE 2017/745), Pixformance è utilizzato alla Charité di Berlino, al Medical Park, all'AUVA Klagenfurt e all'Oxford Brookes University — ed è in uso clinico continuo dal 2012.
        </p>

        <div class="flex items-center justify-center gap-4 p-4 bg-[#02308C]/5 rounded-xl border border-[#02308C]/10 max-w-md mx-auto hero-animate" style="animation-delay: 0.45s;">
          <img
            src="/images/en/RX-Logo.png"
            alt="RX Dispositivo Medico Classe 2"
            class="h-14 w-auto shrink-0"
            loading="lazy"
          />
          <p class="text-sm text-foreground-muted">Pixformance è classificato come dispositivo medico di Classe 2 negli USA.</p>
        </div>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button size="lg" href="/it/prova-gratuita/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Richiedi Prova
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button size="lg" variant="outline" href="/it/prodotti/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Il Nostro Concetto
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <section class="py-10 bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-8">
        {clientLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-10 w-auto object-contain opacity-60 hover:opacity-90 transition-opacity duration-300 grayscale hover:grayscale-0"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold text-[#02308C]">
          Dispositivo di riabilitazione completamente connesso
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Il Concetto Pixformance 360° è una soluzione digitale completamente connessa composta da una stazione, una piattaforma online e un'app. Il nostro concetto terapeutico partecipativo accompagna i pazienti digitalmente e in sicurezza attraverso ogni movimento.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-scroll="slide-left" class="flex justify-center">
          <img
            src="/images/en/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil.gif"
            alt="Pixformance Live Feedback"
            class="max-w-sm w-full rounded-2xl shadow-xl"
            loading="lazy"
          />
        </div>
        <div class="space-y-8" data-scroll="slide-right">
          {[
            { title: 'Guida Esercizi con Buona Pratica', text: 'L\'esercizio è dimostrato da un terapista virtuale sullo schermo con la sequenza di movimento ottimale. Il paziente si vede sullo schermo mentre esegue l\'esercizio.' },
            { title: 'Sensore di Profondità per l\'Analisi del Movimento', text: 'Durante l\'esercizio, una telecamera con sensore di profondità integrato scansiona 25 punti articolari dell\'esercitante in pochi secondi e li confronta con la sequenza di movimento ottimale.' },
            { title: 'Feedback in Tempo Reale', text: 'Il paziente riceve feedback individualizzato che copre aspetti specifici dell\'esecuzione del movimento. Il feedback è evidenziato visivamente e testualmente nel video del paziente in tempo reale.' },
          ].map((feature, index) => (
            <div class="flex flex-col items-center text-center md:flex-row md:items-start md:text-left gap-4" data-delay={index + 1}>
              <div class="shrink-0 w-10 h-10 rounded-xl bg-[#02308C] flex items-center justify-center">
                <span class="text-white font-bold text-sm">{String(index + 1).padStart(2, '0')}</span>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-2">{feature.title}</h3>
                <p class="text-foreground-muted">{feature.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Indicazioni Section -->
  <section class="py-12 md:py-20 bg-[#02308C]/5 border-y border-[#02308C]/10">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-10">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="activity" size="sm" />
            Applicazione Clinica
          </span>
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-4">Indicazioni e Aree di Applicazione Clinica</h2>
          <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
            Pixformance è adatto a un ampio spettro di indicazioni fisioterapeutiche e riabilitative. Gli esercizi possono essere adattati per pazienti in sedia a rotelle, con deambulatori, su lettino o sul pavimento.
          </p>
        </div>
        <ul class="grid md:grid-cols-2 gap-5 text-base text-gray-800 leading-relaxed">
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="brain" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Riabilitazione Neurologica</strong>
              Sclerosi multipla, sindrome di Parkinson, follow-up ictus, disturbi dell'equilibrio e della coordinazione
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#6BDBD1] flex items-center justify-center"><Icon name="bone" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Riabilitazione Ortopedica</strong>
              Cura postoperatoria (anca, ginocchio, spalla, colonna), terapia del dolore alla schiena, rafforzamento funzionale dopo infortuni
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="heart" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Riabilitazione Oncologica</strong>
              Follow-up oncologico (adulti e bambini via FORTEe), follow-up post-cancro al seno
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#6BDBD1] flex items-center justify-center"><Icon name="users" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Riabilitazione Geriatrica</strong>
              Prevenzione delle cadute, allenamento dell'equilibrio, autonomia funzionale per gli anziani
            </div>
          </li>
          <li class="flex gap-4 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow duration-300 md:col-span-2">
            <span class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center"><Icon name="trending-up" size="sm" class="text-white" /></span>
            <div>
              <strong class="block text-gray-900 mb-1">Prevenzione Secondaria & Programmi Cash Pay</strong>
              Follow-up post-riabilitazione, prevenzione degli infortuni, programmi di allenamento self-pay
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Success Stories -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-12">
        <div data-scroll="slide-left">
          <img
            src="/images/en/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Portrait-Gabriele-Buchstein.jpg"
            alt="Gabriele Buchstein, Responsabile Fisioterapia, Sauerlandklinik Hachen"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-4" data-scroll="slide-right">
          <h2 class="font-display text-3xl md:text-3xl font-bold">Storie di Successo</h2>
          <p class="text-foreground-muted font-semibold">Gabriele Buchstein, Responsabile Fisioterapia, Sauerlandklinik Hachen, Germania</p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Con oltre 2,5 milioni di esercitanti in tutto il mondo, il concetto di allenamento e terapia Pixformance è già presente nelle migliori cliniche riabilitative della Germania, negli studi di fisioterapia e nelle palestre. Leggi le nostre storie di successo per scoprire come e perché la Sig.ra Buchstein della "Clinica Specializzata Sauerland per la SM" e molti altri clienti hanno integrato la terapia del movimento digitale di Pixformance.
          </p>
          <div class="flex justify-center md:justify-start">
            <Button href="/it/storie-di-successo/">
              Tutte le Storie di Successo
              <Icon name="arrow-right" size="sm" />
            </Button>
          </div>
