---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const posts = [
  {
    image: '/images/en/umsatz-steigern-physiotherapie-pixformance-selbstzahlerbereich-400x250.jpg',
    title: 'Aumentare le entrate in fisioterapia: quali opportunità offre oggi il settore self-pay?',
    categories: [{ label: 'Fisioterapia', href: '/en/category/physiotherapy-2/' }],
    excerpt: 'Il passaggio al secondo mercato sanitario in fisioterapia offre alcune opportunità concrete per i fisioterapisti.',
    link: '/en/increase-physical-therapy-sales-what-opportunities-does-the-self-pay-sector-have-to-offer-now/',
  },
  {
    image: '/images/en/Digitalisierung-Chance-Gesundheitsbranche-Pixformance-Blog-Online-Plattform-Analyse-Ehealth-Physiotherapie-Telemedizin-Telerehabilitation-Rehageraet-400x250.jpg',
    title: 'Digitalizzazione: un\'opportunità per il settore sanitario',
    categories: [
      { label: 'Clinica', href: '/en/category/clinic/' },
      { label: 'Fisioterapia', href: '/en/category/physiotherapy-2/' },
    ],
    excerpt: 'La nostra vita quotidiana è già smart e digitale sotto molti aspetti. La digitalizzazione avanza rapidamente anche nel settore sanitario.',
    link: '/en/digitization-an-opportunity-for-the-healthcare-industry/',
  },
  {
    image: '/images/en/Canva-People-in-Gym-400x250.jpg',
    title: 'Tre lezioni che i club fitness possono imparare dalla nuova strategia di business di Weight Watchers',
    categories: [
      { label: 'Aziendale', href: '/en/category/corporate/' },
      { label: 'Salute Aziendale', href: '/en/category/corporate-health/' },
    ],
    excerpt: 'Weight Watchers era stato il player dominante nel mercato delle diete per decenni fino al 2015, quando le entrate da abbonamento dell\'azienda sono diminuite da 6 miliardi a 1 miliardo di dollari in quattro anni.',
    link: '/en/three-lessons-fitness-clubs-can-learn-from-weight-watchers/',
  },
  {
    image: '/images/en/quantified-self-movement-for-fitness-and-health-400x250.jpg',
    title: 'Perché il movimento "Quantified Self" è un\'opportunità di business',
    categories: [{ label: 'Salute', href: '/en/category/health/' }],
    excerpt: 'Tutti parlano del "quantified self". Con il rapido sviluppo di nuovi software fitness sotto forma di app e dispositivi indossabili, stiamo assistendo a un crescente interesse nel raccogliere dati sulla nostra vita per migliorarci.',
    link: '/en/why-the-quantified-self-is-a-business-opportunity/',
  },
  {
    image: '/images/en/quantified-self-movement-is-trending-400x250.jpg',
    title: 'Tre strategie per integrare le nuove tecnologie nel tuo club di fitness funzionale',
    categories: [
      { label: 'Aziendale', href: '/en/category/corporate/' },
      { label: 'Salute Aziendale', href: '/en/category/corporate-health/' },
    ],
    excerpt: 'Attualmente si discute molto di come il movimento "quantified self" stia ridisegnando il settore fitness e salute. In questo articolo, presentiamo tre strategie su come integrare le nuove tecnologie…',
    link: '/en/three-strategies-on-integrating-new-technologies-into-your-functional-fitness-club/',
  },
  {
    image: null,
    title: 'Come il "Smart Training" con Pixformance può migliorare la qualità della vita delle persone con sclerosi multipla',
    categories: [{ label: 'Terapia', href: '/en/category/therapy/' }],
    excerpt: 'La sclerosi multipla è una delle condizioni neurologiche più comuni tra i giovani adulti. In questo articolo, discutiamo uno studio qualitativo recente che ha testato l\'efficacia…',
    link: '/en/smart-training-with-pixformance-improves-life-quality-of-people-with-multiple-sclerosis/',
  },
  {
    image: '/images/en/physiotherapist-with-woman-patient-400x250.jpg',
    title: 'Le 5 principali sfide affrontate dai fisioterapisti',
    categories: [{ label: 'Fisioterapia', href: '/en/category/physiotherapy/' }],
    excerpt: 'In questo articolo, facciamo luce sulle principali sfide affrontate dai fisioterapisti. Come in qualsiasi altra professione, la fisioterapia ha i suoi aspetti positivi e negativi.',
    link: '/en/top-five-challenges-faced-by-physiotherapists/',
  },
];
---

<ITBaseLayout
  title="Articoli Blog – Pixformance Sports GmbH"
  description="Leggi gli ultimi articoli sul functional training, la salute digitale, la fisioterapia e il fitness aziendale dal blog Pixformance."
  hreflangDe="https://www.pixformance.com/blog/"
  hreflangEn="https://www.pixformance.com/en/blog-articles/"
>
  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Hero -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-[#02308C] to-[#6BDBD1] text-white">
    <div class="container">
      <div class="max-w-3xl space-y-4">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-sm font-bold">
          <Icon name="edit" size="sm" />
          Blog
        </span>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
          Articoli Blog
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Approfondimenti sul functional training, la salute digitale, la fisioterapia e il fitness aziendale.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map((post, index) => (
          <article class="group flex flex-col rounded-2xl overflow-hidden border border-border hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min((index % 2) + 1, 2)}>
            {post.image ? (
              <div class="overflow-hidden aspect-[8/5]">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-[8/5] bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 flex items-center justify-center">
                <Icon name="edit" size="lg" class="text-[#02308C]/30" />
              </div>
            )}
            <div class="flex flex-col flex-1 p-6 space-y-3">
              <div class="flex flex-wrap gap-2">
                {post.categories.map((cat) => (
                  <a href={cat.href} class="px-3 py-1 rounded-full text-xs font-bold bg-[#6BDBD1]/20 text-[#02308C] hover:bg-[#6BDBD1]/40 transition-colors">
                    {cat.label}
                  </a>
                ))}
              </div>
              <h2 class="font-bold text-lg leading-snug flex-1">
                <a href={post.link} class="hover:text-[#02308C] transition-colors">{post.title}</a>
              </h2>
              <p class="text-sm text-foreground-muted leading-relaxed">{post.excerpt}</p>
              <a
                href={post.link}
                class="inline-flex items-center gap-2 text-[#02308C] font-semibold text-sm hover:gap-3 transition-all mt-auto pt-2"
              >
                Leggi di più
                <Icon name="arrow-right" size="sm" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
