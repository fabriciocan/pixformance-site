---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Costruire con Successo un'Area a Pagamento Privato - Heike Schaible - Pixformance"
  description="Come Heike Schaible ha costruito passo dopo passo un'area a pagamento privato di successo presso la sua pratica fisioterapica 'Raum für Gesundheit' a Stoccarda."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/heike-schaible/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="heart" size="sm" /> Fisioterapia
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Passo dopo passo: costruire con successo un'area a pagamento privato
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Studio Fisioterapico "Raum für Gesundheit" – Stoccarda, Germania
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <p class="text-lg text-foreground-muted leading-relaxed mb-8">
          <strong class="text-foreground">Fondato oltre 30 anni fa come studio di massaggio e benessere, lo studio fisioterapico "Raum für Gesundheit" a Stoccarda ha subito da allora significativi cambiamenti e ha ampliato la sua offerta.</strong> Su una superficie totale di 400 m², la titolare Heike Schaible e i suoi colleghi hanno costruito con successo uno studio fisioterapico con un'offerta completa a pagamento privato.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/heikeschaible.600x400.jpg" alt="Heike Schaible - Titolare dello Studio Fisioterapico Raum für Gesundheit" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Heike Schaible</h2>
              <p class="text-xl text-[#02308C] font-semibold">Titolare dello Studio Fisioterapico "Raum für Gesundheit"</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="briefcase" size="md" class="text-[#02308C]" /> Profilo dello Studio
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sede</p><p class="text-sm">Stoccarda, Baden-Württemberg, Germania</p></div></div>
                <div class="flex items-start gap-3"><Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Fondato</p><p class="text-sm">1987</p></div></div>
                <div class="flex items-start gap-3"><Icon name="home" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Dimensione</p><p class="text-sm">400 m² su 3 sedi separate</p></div></div>
                <div class="flex items-start gap-3"><Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Focus</p><p class="text-sm">Fisioterapia, promozione della salute sostenibile, osteopatia, psicoterapia corporea</p></div></div>
                <div class="flex items-start gap-3"><Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Personale</p><p class="text-sm">7 terapisti</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sito web</p><a href="https://www.rfg-stuttgart.de" target="_blank" rel="noopener noreferrer" class="text-sm text-[#02308C] hover:underline">www.rfg-stuttgart.de</a></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Una tradizione trentennale – e la sfida di restare attuali</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Dopo aver lavorato come massaggiatrice nello studio, Heike Schaible ha rilevato l'attività 10 anni dopo la sua fondazione. Nel processo, si è formata anche come fisioterapista e naturopata, e in seguito come osteopata, per continuare ad ampliare l'offerta dello studio e restare aggiornata.</p>
            <p class="text-base md:text-lg">Per aggirare le barriere di fatturazione per i servizi osteopatici, Heike Schaible ha deciso nel 2009 di costruire la prima area a pagamento privato. Sperava che questa mossa nel mercato sanitario secondario aggiungesse valore in due aree chiave:</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Da un lato, l'area a pagamento privato dà la possibilità di avere più tempo per i pazienti. Come terapisti, siamo naturalmente molto meno stressati di conseguenza. Dall'altro, si tratta anche di indipendenza dalle assicurazioni sanitarie obbligatorie, poiché il rimborso per i fisioterapisti è molto basso. Quindi sia i pazienti che i terapisti beneficiano dell'offerta privata ampliata."</p>
            </Card>
            <p class="text-base md:text-lg">In uno spazio separato di fronte al suo studio fisioterapico, era già riuscita a consolidarsi nel mercato sanitario secondario nel 2009 insieme ai suoi colleghi.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Da un lato abbiamo l'offerta fisio per pazienti sia assicurati che privati, e dall'altra parte il cosiddetto 'Wirkraum' – esclusivamente per clienti privati."</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Rendere visibile la distinzione tra i servizi</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">La separazione fisica ha reso la distinzione tra i servizi molto più chiara per i pazienti. In precedenza, incontrava spesso incomprensioni da parte dei pazienti su cosa fosse privato e cosa non lo fosse.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"È una grande sfida: costruire l'area a pagamento privato e stabilirla come tale, distinguendola chiaramente dallo studio."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"A volte le persone non capiscono che non tutto può essere addebitato tramite una prescrizione."</p>
            </Card>
            <p class="text-base md:text-lg">Tuttavia, Schaible nota un trend positivo verso un cambiamento di mentalità. Rispetto a dieci anni fa, c'è un chiaro miglioramento nella comprensione del settore a pagamento privato in fisioterapia. Varie offerte after-work sono ben accolte, ma il riconoscimento dei servizi a pagamento privato rimane una delle sfide centrali.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/heike-raum-fuer-gesundheit-bewegungsraum.jpg" alt="Sala movimento con postazioni Pixformance a Raum für Gesundheit a Stoccarda" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Allenamento digitale come estensione dell'area a pagamento privato</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Per ampliare l'area a pagamento privato nel campo della terapia del movimento, Heike Schaible ha scelto il concetto di allenamento digitale di Pixformance.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"La medicina – e naturalmente anche le esigenze dei pazienti e le richieste dei terapisti – si è evoluta. Quindi naturalmente si va al passo, si sviluppa ulteriormente e si guarda a cosa c'è di nuovo, cosa c'è di diverso."</p>
            </Card>
            <p class="text-base md:text-lg">Così è nata una seconda area a pagamento privato in una terza sede non lontana dallo studio e dal Wirkraum: il "Bewegungsraum" (sala movimento). Lì sono state allestite quattro postazioni di allenamento Pixformance in uno spazio di 80 m².</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Sentiamo spesso dai nostri pazienti che non si sentono a proprio agio in una palestra convenzionale. Quindi penso che questo sia un ottimo modo per supportare le persone nel restare attive."</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Scegliere Pixformance – dalla convinzione personale</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Conosceva già Pixformance attraverso la sua iscrizione alla catena di fitness femminile Mrs.Sporty, co-fondata dalla proprietaria di Pixformance Valerie Bures-Bönström. Con oltre 200.000 utenti all'anno, il concetto Pixformance è in uso lì dal 2013 in diversi paesi europei.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Mi sono allenata con Pixformance e mi è piaciuto tantissimo. L'allenamento funzionale aveva immediatamente senso per me. Poi ho pensato che potrebbe essere in realtà un ottimo complemento alla terapia per i nostri clienti. Sentiamo spesso dai pazienti che non si sentono a proprio agio in una palestra convenzionale. Quindi trovo questo un modo meraviglioso per supportare le persone nel restare attive."</p>
            </Card>
            <p class="text-base md:text-lg">Molti pazienti trovano questo tipo di allenamento facile da accedere, il che aumenta anche la comprensione del concetto a pagamento privato.</p>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Alleggerire il personale come obiettivo centrale</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Il concetto di allenamento praticamente supervisionato e il conseguente sollievo per il proprio personale è stato un altro motivo chiave per la decisione di acquisto di Heike Schaible.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Specialmente quando penso alla carenza di personale qualificato: così tanti colleghi sono completamente esauriti."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Soprattutto, voglio venire incontro al mio personale e offrire loro un lavoro più semplice e vario. Grazie al concetto digitale, il mio personale è significativamente alleggerito nel supervisionare i pazienti alle postazioni Pixformance."</p>
            </Card>
            <p class="text-base md:text-lg">Le istruzioni di allenamento del personal trainer virtuale e le correzioni in tempo reale rendono anche possibile supervisionare più pazienti contemporaneamente – senza richiedere molto sforzo di supervisione aggiuntivo.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"La seconda area a pagamento privato, la sala movimento, è quindi un altro passo verso una migliore retribuzione e una giornata lavorativa più piacevole."</p>
            </Card>
            <p class="text-base md:text-lg">La maggior parte dei pazienti è immediatamente entusiasta delle postazioni Pixformance e le trova fantastiche – ulteriore prova che la svolta verso la terapia del movimento digitale è stata la decisione giusta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
