---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="L'Evoluzione di una Catena di Fitness grazie alla Formazione Digitale - Carina Dworak - Pixformance"
  description="Come la titolare di Mrs.Sporty Carina Dworak ha recuperato l'investimento in 3 mesi con 7 dispositivi Pixformance e raddoppiato le iscrizioni."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/carina-dworak/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#6BDBD1]/20 to-[#02308C]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="zap" size="sm" /> Fitness
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            L'evoluzione di una catena di fitness grazie alla formazione funzionale digitale
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Mrs.Sporty Studio Vienna – Pixformance per oltre 200.000 iscritti in tutta Europa
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
          <p class="text-foreground italic text-base md:text-xl">"Come imprenditrice, amo investire nella mia attività per rimanere competitiva. La cosa più importante per me è recuperare l'investimento molto rapidamente. Con sette dispositivi Pixformance nel mio club, ho recuperato l'intero investimento in tre mesi."</p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Carina Dworak, Titolare Mrs.Sporty Studio Vienna</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/carina-dworak-mrssporty-wien.jpg" alt="Carina Dworak – Titolare Mrs.Sporty Studio Vienna" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Carina Dworak</h2>
              <p class="text-xl text-[#02308C] font-semibold">Titolare Mrs.Sporty Studio, Vienna</p>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">3</p>
                <p class="text-xs text-foreground-muted">mesi per il ROI completo</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">2×</p>
                <p class="text-xs text-foreground-muted">più nuovi iscritti</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">+€3.000</p>
                <p class="text-xs text-foreground-muted">ricavi aggiuntivi dopo 6 mesi</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-1">200K+</p>
                <p class="text-xs text-foreground-muted">iscritti in tutta Europa</p>
              </Card>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <div class="relative w-full" style="padding-bottom: 56.25%;">
            <iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/MB8PhSlWndI" title="Mrs.Sporty e Pixformance – Carina Dworak Vienna" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Allenamento ideale per ogni età – dai 18 ai 93 anni</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"La formazione funzionale su Pixformance è ideale e ottimale per tutti gli iscritti. Il mio iscritto più giovane ha 18 anni, il più anziano ne ha 93 – e tutti possono allenarsi individualmente e in modo eccellente."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Dopo il passaggio alla formazione Pixformance, i nostri club guadagnano in media il doppio dei nuovi iscritti nei primi mesi rispetto a prima. Dopo sei mesi, i club vedono circa €3.000 in più di ricavi a fronte di, in media, €1.000 di costi aggiuntivi."</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Qualità costante e standard di formazione elevati</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Nel mio club, Pixformance ha migliorato enormemente la qualità della formazione. E grazie alla piattaforma, la stessa qualità è garantita indipendentemente dal fatto che il trainer presente sia relativamente nuovo o abbia anni di esperienza."</p>
              <p class="text-sm text-foreground-muted mt-2">— Carina Dworak</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Maggiore fidelizzazione degli iscritti e più motivazione</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Quando gli iscritti ricevono un nuovo programma di allenamento, rientrano nel circuito pieni di entusiasmo e aspettano con ansia il nuovo allenamento. Le donne vengono anche molto più regolarmente – molte vengono tre o quattro volte a settimana, anche cinque."</p>
              <p class="text-sm text-foreground-muted mt-2">— Carina Dworak</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
