---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Fidelizzazione dei Pazienti in Fisioterapia con l'Allenamento Funzionale Digitale - Gesundheitsrondell - Pixformance"
  description="Volker Sutor del Gesundheitsrondell spiega come l'allenamento funzionale digitale con Pixformance rafforza la fidelizzazione dei pazienti e trasforma i pazienti in iscritti a lungo termine."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/volker-sutor/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="heart" size="sm" /> Fisioterapia
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Fidelizzazione dei pazienti in fisioterapia con l'allenamento funzionale digitale
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Come Gesundheitsrondell usa Pixformance per fidelizzare i pazienti a lungo termine e sbloccare nuovi flussi di entrate
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <p class="text-lg text-foreground-muted leading-relaxed mb-8">
          <strong class="text-foreground">Gesundheitsrondell, con i suoi molteplici centri di fisioterapia e riabilitazione nella regione Heilbronn-Franken,</strong> è uno dei più grandi fornitori di terapia ambulatoriale del sud della Germania. Con oltre 90 dipendenti in diverse sedi – tra cui Brackenheim, Neckarsulm e Heilbronn – l'azienda assiste migliaia di pazienti all'anno dal 1999. Il proprietario Volker Sutor spiega come l'allenamento funzionale digitale con Pixformance rafforza la fidelizzazione dei pazienti e apre nuove prospettive economiche.
        </p>
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-lg">"Volevamo poter offrire ai nostri pazienti qualcosa dopo la classica fisioterapia che li mantenesse con noi a lungo termine – e allo stesso tempo offrire risultati terapeutici misurabili."</p>
          <p class="text-sm text-foreground-muted mt-2">— Volker Sutor, Proprietario Gesundheitsrondell</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Volker-Sutor-Portrait.png" alt="Volker Sutor – Proprietario Gesundheitsrondell" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Volker Sutor</h2>
              <p class="text-xl text-[#02308C] font-semibold">Proprietario – Gesundheitsrondell</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="briefcase" size="md" class="text-[#02308C]" /> Profilo dello Studio
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sedi</p><p class="text-sm">Brackenheim, Neckarsulm, Heilbronn e altre</p></div></div>
                <div class="flex items-start gap-3"><Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Fondato</p><p class="text-sm">1999</p></div></div>
                <div class="flex items-start gap-3"><Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Personale</p><p class="text-sm">90–100 dipendenti</p></div></div>
                <div class="flex items-start gap-3"><Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Focus</p><p class="text-sm">Fisioterapia, riabilitazione, terapia del movimento, offerte a pagamento privato</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Logo</p><img src="/images/erfolgsgeschichten/gesundheitsrondell_logo.png" alt="Logo Gesundheitsrondell" class="h-8 mt-1 object-contain" loading="lazy" /></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">La motivazione: fidelizzare i pazienti a lungo termine</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Come una delle prime decisioni nello sviluppo di offerte aggiuntive, Volker Sutor ha riconosciuto che la fisioterapia aveva bisogno di un concetto che andasse oltre i classici servizi coperti dall'assicurazione. I pazienti che non hanno motivo di tornare allo studio dopo aver completato la terapia vengono persi – sia come clienti che in termini di salute fisica.</p>
            <p class="text-base md:text-lg">Con il sistema Pixformance, Gesundheitsrondell ha trovato un concetto di allenamento adatto sia al supporto terapeutico attivo che all'aftercare e alla prevenzione. I pazienti si allenano sotto guida digitale, sono accompagnati dal sistema nella corretta esecuzione del movimento – e possono quindi continuare ad allenarsi autonomamente ed efficacemente, anche quando nessun terapista è direttamente accanto a loro.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Pixformance è per noi il collegamento tra la terapia e la salute a lungo termine dei nostri pazienti. Colma il divario tra la fine della prescrizione e uno stile di vita attivo e sano."</p>
              <p class="text-sm text-foreground-muted mt-2">— Volker Sutor</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Volker-Sutor-Gesundheitsrondell-Training-an-Pixformance.png" alt="Allenamento alla postazione Pixformance al Gesundheitsrondell" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 text-center">Volker Sutor in Intervista</h2>
        <p class="text-center text-foreground-muted mb-8">Ascolta direttamente come Gesundheitsrondell rafforza la fidelizzazione dei pazienti con Pixformance.</p>
        <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.12);">
          <iframe src="https://www.youtube.com/embed/iXq8-xyXboc" title="Volker Sutor – Gesundheitsrondell – Storia di Successo Pixformance" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Risultati economici e nuove opportunità</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">L'integrazione di Pixformance ha aperto nuove prospettive economiche per Gesundheitsrondell. Costruendo un settore privato a pagamento, le sedi hanno potuto diversificare le entrate aumentando simultaneamente l'utilizzo degli spazi – senza dover aumentare proporzionalmente il personale.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"L'area privata a pagamento con Pixformance è diventata un genuino pilastro economico per noi. Siamo meno dipendenti dai servizi coperti dall'assicurazione e possiamo allo stesso tempo offrire ai nostri pazienti un'offerta a lungo termine."</p>
              <p class="text-sm text-foreground-muted mt-2">— Volker Sutor</p>
            </Card>
            <p class="text-base md:text-lg">Particolarmente prezioso è la misurabilità dei progressi dell'allenamento. Il sistema documenta automaticamente lo sviluppo delle prestazioni di ogni paziente – un argomento che convince i pazienti a continuare a tornare. Perché possono vedere in nero su bianco cosa hanno raggiunto e cosa è possibile.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-12 text-center" data-scroll="fade-up">Tre risultati che convincono</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="users" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Fidelizzazione dei Pazienti</h3>
              <p class="text-foreground-muted text-sm">I pazienti rimangono come iscritti paganti dopo aver completato la loro classica prescrizione terapeutica. Gesundheitsrondell crea così una clientela abituale stabile che genera continuamente entrate.</p>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="activity" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Risultati Terapeutici</h3>
              <p class="text-foreground-muted text-sm">La guida digitale dell'allenamento garantisce la corretta esecuzione del movimento e progressi misurabili. I terapisti possono monitorare senza interruzioni lo sviluppo di ogni paziente e adattare i programmi in modo mirato.</p>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="3">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Da Pazienti a Iscritti</h3>
              <p class="text-foreground-muted text-sm">La transizione dalla terapia finanziata dall'assicurazione ai servizi autofinanziati a pagamento privato avviene in modo fluido. I pazienti sperimentano il valore aggiunto dell'allenamento e scelgono volontariamente un'iscrizione a lungo termine.</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
