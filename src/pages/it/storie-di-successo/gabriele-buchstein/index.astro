---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Pazienti Più Motivati con la Terapia Digitale per la SM - Gabriele Buchstein - Pixformance"
  description="Come la Clinica Sauerland Hachen aiuta i pazienti con SM a ottenere maggiore motivazione, più ripetizioni e risultati terapeutici più rapidi con Pixformance."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/gabriele-buchstein/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" /> Clinica
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Pazienti più motivati grazie alla terapia digitale per la SM
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Clinica Sauerland Hachen – Clinica Specialistica Neurologica per la Sclerosi Multipla
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">"Con Pixformance abbiamo un risparmio di tempo significativo. Dopo una sola introduzione di 30 minuti, i pazienti possono allenarsi autonomamente sotto supervisione. Questo ci permette di assistere più pazienti contemporaneamente e – nel frattempo – è possibile persino completare la documentazione."</p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Gabriele Buchstein, Responsabile Fisioterapia, Clinica Sauerland Hachen</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Portrait-Gabriele-Buchstein.jpg" alt="Gabriele Buchstein - Responsabile Fisioterapia Clinica Sauerland Hachen" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Gabriele Buchstein</h2>
              <p class="text-xl text-[#02308C] font-semibold">Responsabile Fisioterapia</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" /> Profilo della Clinica
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sede</p><p class="text-sm">Hachen, Renania Settentrionale-Vestfalia, Germania</p></div></div>
                <div class="flex items-start gap-3"><Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Fondato</p><p class="text-sm">1964</p></div></div>
                <div class="flex items-start gap-3"><Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Specializzazione</p><p class="text-sm">Sclerosi Multipla (SM)</p></div></div>
                <div class="flex items-start gap-3"><Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Capacità Pazienti</p><p class="text-sm">125 posti letto</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sito web</p><a href="https://www.sauerlandklinik-hachen.de" target="_blank" rel="noopener noreferrer" class="text-sm text-[#02308C] hover:underline">www.sauerlandklinik-hachen.de</a></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Più tempo, più ripetizioni, più motivazione: terapia digitale per la SM</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Nella clinica neurologica per acuti nella regione del Sauerland specializzata nella Sclerosi Multipla, i pazienti sono assistiti in sei reparti: fisioterapia, terapia fisica, terapia occupazionale, logopedia, musicoterapia e assistenza infermieristica. Gabriele Buchstein e il suo team offrono un concetto terapeutico mirato alla SM – combinando terapie neurofisiologiche consolidate con approcci terapeutici all'avanguardia, tra cui la terapia motoria digitale e la teleriabilitazione.</p>
            <p class="text-base md:text-lg">Per ampliare l'offerta e fornire ai pazienti un'ulteriore motivazione all'allenamento, Buchstein ha scelto due postazioni Pixformance dopo una prova di successo. Attualmente circa 30 pazienti si allenano alle postazioni. È richiesto un certo livello di mobilità – l'allenamento in sedia a rotelle è facilmente possibile grazie a molti esercizi in posizione seduta. Oltre ai 350+ esercizi, la clinica ha sviluppato esercizi personalizzati insieme a Pixformance specificamente adattati ai pazienti con SM.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Therapie-1.jpg" alt="Terapia Pixformance alla Clinica Sauerland Hachen" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Indipendenza per i pazienti, sollievo per i terapisti</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Dopo una breve introduzione, i pazienti possono già allenarsi autonomamente alle postazioni. Un referente è sempre nelle vicinanze, ma può occuparsi di altri pazienti o della documentazione.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Tutte le fasce d'età possono davvero utilizzare le postazioni Pixformance. È meraviglioso che così tanti pazienti possano beneficiare dell'allenamento, purché le capacità cognitive lo consentano. E grazie al risparmio di tempo, non sono solo i pazienti ma anche noi terapisti a beneficiarne concretamente."</p>
              <p class="text-sm text-foreground-muted mt-2">— Gabriele Buchstein</p>
            </Card>
            <p class="text-base md:text-lg">La digitalizzazione svolge un ruolo importante alla Clinica Sauerland. Buchstein fa riferimento anche alla ricerca sul focus attentivo interno vs. esterno:</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"A differenza del focus attentivo interno, dove guidi il paziente di persona, l'allenamento Pixformance prevede un focus attentivo esterno."</p>
            </Card>
            <p class="text-base md:text-lg">Il paziente riceve il compito di esercizio esternamente tramite la postazione e quindi non è più così concentrato sul proprio corpo, ma si concentra invece sull'esecuzione dell'esercizio – il che produce un maggiore effetto di miglioramento.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"È come giocare a un gioco – a volte non si nota quanto tempo passa. E questo è scientificamente supportato: i movimenti vengono eseguiti in modo più riflessivo e si migliora significativamente."</p>
              <p class="text-sm text-foreground-muted mt-2">— Gabriele Buchstein</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Pixformance-Sauerland-Klinik-Hachen-Telerehabilitation-Therapie-2.jpg" alt="Paziente SM in allenamento con Pixformance alla Clinica Sauerland" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/pixformance-uebungen-im-sitzen-sauerland-klinik.jpg" alt="Esercizi Pixformance in posizione seduta per pazienti SM" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Più ripetizioni, risultati terapeutici più rapidi</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Buchstein vede un altro grande vantaggio nella notevolmente maggiore motivazione dei pazienti. Scientificamente dimostrato: l'effetto dell'allenamento aumenta significativamente con il numero di ripetizioni.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"La cosa fantastica di Pixformance è che la postazione incoraggia i pazienti a fare più ripetizioni. I pazienti sono entusiasti e molto motivati – il che, devo ammettere, non è sempre il caso. Naturalmente noi terapisti ne beneficiamo anche, poiché i pazienti eseguono quindi i loro esercizi meglio e in modo più mirato."</p>
              <p class="text-sm text-foreground-muted mt-2">— Gabriele Buchstein</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Sarebbe naturalmente meraviglioso poter vedere se i pazienti continuano ad allenarsi a casa. Quindi è sicuramente un obiettivo futuro supportare i pazienti anche oltre il loro soggiorno in clinica a casa."</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Esercizi personalizzati per le esigenze speciali dei pazienti con SM</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Insieme al team terapeutico in loco ad Hachen, Pixformance ha sviluppato nuovi esercizi. Oltre ai 350+ esercizi del catalogo Pixformance, sono disponibili ulteriori sequenze di allenamento – sviluppate specificamente per i vari stadi della SM, inclusi molti esercizi in posizione seduta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/pixformance-uebungen-im-sitzen-sauerland-klinik-ms.jpg" alt="Esercizi in posizione seduta specifici per SM con Pixformance alla Clinica Sauerland Hachen" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
