---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Assistere Più Pazienti con la Terapia del Movimento Digitale - Schlossphysio - Pixformance"
  description="Lo studio fisioterapico Schlossphysio a Winterthur, Svizzera, utilizza Pixformance per assistere più pazienti contemporaneamente – senza personale aggiuntivo."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/swetlana-zimmermann/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="heart" size="sm" /> Fisioterapia
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Assistere più pazienti contemporaneamente con la terapia del movimento digitale
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Studio piccolo, grandi progressi – Schlossphysio, Winterthur, Svizzera
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <p class="text-lg text-foreground-muted leading-relaxed mb-8">
          <strong class="text-foreground">Lo studio fisioterapico Schlossphysio a Winterthur, Svizzera, fondato nel 2020,</strong> è un piccolo studio dedicato alla terapia manuale e alla terapia respiratoria. Fin dall'inizio, l'allenamento interattivo con Pixformance è stato integrato nell'area di terapia del movimento – con l'obiettivo di assistere più pazienti contemporaneamente e creare sollievo nella routine quotidiana dello studio.
        </p>
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-lg">"Volevamo un dispositivo di allenamento olistico in grado di coprire il maggior numero possibile di gruppi muscolari e schemi di movimento nella terapia sportiva."</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Pixformance-in-der-Schweiz.jpg" alt="Allenamento Pixformance allo Schlossphysio Winterthur" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Swetlana Zimmermann</h2>
              <p class="text-xl text-[#02308C] font-semibold">Fisioterapista Principale – Schlossphysio</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="briefcase" size="md" class="text-[#02308C]" /> Profilo dello Studio
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sede</p><p class="text-sm">Winterthur, Svizzera</p></div></div>
                <div class="flex items-start gap-3"><Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Fondato</p><p class="text-sm">2020</p></div></div>
                <div class="flex items-start gap-3"><Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Focus</p><p class="text-sm">Terapia manuale, terapia respiratoria, allenamento interattivo</p></div></div>
                <div class="flex items-start gap-3"><Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Personale</p><p class="text-sm">1 terapista</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sito web</p><a href="https://www.schlossphysio.ch" target="_blank" rel="noopener noreferrer" class="text-sm text-[#02308C] hover:underline">www.schlossphysio.ch</a></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">La motivazione dietro l'integrazione del concetto di allenamento Pixformance</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Alla fondazione dello studio, Swetlana Zimmermann era chiara che voleva integrare un dispositivo che consentisse una terapia del movimento completa – coprendo il maggior numero possibile di gruppi muscolari e schemi di movimento, individualmente adattabile per ogni paziente. Avendo già avuto esperienza con la postazione Pixformance, è nata rapidamente una collaborazione.</p>
            <p class="text-base md:text-lg">Insieme a pochi piccoli attrezzi e a una spalliera, Pixformance ha potuto sostituire tutte le altre attrezzature terapeutiche necessarie nello studio ed è completamente centrale nella terapia del movimento. Alcuni pazienti allo Schlossphysio conoscono già Pixformance dal proprio allenamento presso la catena di fitness femminile Mrs.Sporty.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Pixformance-Fitness-Digitales-Sportgeraet-Fitnessstudio-eroeffnen-eGym-voll-vernetzt.jpg" alt="Terapia del movimento digitale Pixformance allo Schlossphysio" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Supporto e sollievo nella terapia sportiva</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Con pochissime eccezioni, tutti i nostri pazienti utilizzano l'offerta Pixformance."</p>
            </Card>
            <p class="text-base md:text-lg">Quando un paziente arriva allo Schlossphysio con la sua prescrizione terapeutica, la postazione Pixformance viene presentata come supporto per la terapia del movimento – a seconda dello stato di salute – dopo la prima o la seconda sessione. I pazienti si allenano poi autonomamente sotto guida virtuale, il che fornisce un sollievo significativo.</p>
            <p class="text-base md:text-lg">Anche l'app web Pixformance si è dimostrata efficace per un successo terapeutico più rapido. Dopo le prime sessioni viene presentata e installata – così i pazienti possono accedere al loro programma individuale sul loro smartphone in qualsiasi momento ed eseguire gli esercizi anche a casa.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Soprattutto, la flessibilità offerta dal concetto di allenamento digitale è stata un fattore decisivo per noi."</p>
            </Card>
            <p class="text-base md:text-lg">Il Direttore Claas Bickeböller spiega la decisione per Pixformance:</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Sappiamo dall'esperienza: nella terapia del movimento, puoi spiegare gli esercizi e i movimenti cento volte. Eppure la maggior parte delle persone dimentica dopo mezz'ora che deve assicurarsi, ad esempio, che il ginocchio rimanga dritto. Con Pixformance, vengono costantemente ricordati durante la terapia del movimento. Quindi sappiamo che i pazienti si allenano sempre in modo sicuro e eseguono gli esercizi correttamente."</p>
              <p class="text-sm text-foreground-muted mt-2">— Claas Bickeböller, Direttore Schlossphysio</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Il mercato sanitario svizzero – il paziente al primo posto</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">La motivazione principale per Schlossphysio era diversa da quella degli studi tedeschi: non il percorso nel settore privato a pagamento per liberarsi dall'assicurazione sanitaria obbligatoria. Il sistema assicurativo in Svizzera funziona in modo fondamentalmente diverso.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"In Svizzera puoi ottenere una prescrizione molto più rapidamente, quindi non è un problema ricevere una nuova referenza fisioterapica ogni tre mesi per condizioni croniche. Questo significa che il settore privato a pagamento non ha quasi la stessa importanza che ha certamente in Germania."</p>
              <p class="text-sm text-foreground-muted mt-2">— Claas Bickeböller</p>
            </Card>
            <p class="text-base md:text-lg">In Svizzera, l'assicurazione sanitaria è per natura una questione privata – l'assicurazione di base è obbligatoria e deve essere coperta dall'individuo. La fisioterapia è tra i servizi coperti dall'assicurazione di base. Il risultato: dal punto di vista del terapista, il paziente è più fermamente al centro – non la domanda di quanto pagherà l'assicuratore.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
