---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Un Investimento Palestra che Ripaga - Kim Essink - Pixformance"
  description="Pixformance come magnete per clienti all'Essink Sportcentrum di Eindhoven. Approfondimenti dal proprietario Kim Essink, dal personal trainer Sil Hoving e da due iscritti."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/kim-essink/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#6BDBD1]/20 to-[#02308C]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="zap" size="sm" /> Fitness
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Un investimento palestra che ripaga
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Pixformance come magnete per clienti all'Essink Sportcentrum, Eindhoven, Paesi Bassi
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <p class="text-lg text-foreground-muted leading-relaxed">Approfondimenti speciali sul concetto Pixformance – dalla prospettiva del proprietario, di un personal trainer e di due iscritti dell'Essink Sportcentrum di Eindhoven.</p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-start">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/kim-essink-city-gym-1.jpg" alt="Kim Essink - Proprietario Essink Sportcentrum Eindhoven" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-6" data-scroll="fade-up" data-delay="1">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-xs font-bold text-[#02308C] mb-3">
                <Icon name="user" size="sm" /> Proprietario
              </div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-1">Kim Essink</h2>
              <p class="text-lg text-[#02308C] font-semibold mb-6">Essink Sportcentrum, Eindhoven</p>
            </div>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Abbiamo scelto consapevolmente Pixformance perché vi abbiamo visto anche un'opportunità per recuperare rapidamente il capitale investito. Abbiamo scoperto il concetto Pixformance al FIBO – una delle più grandi fiere del fitness al mondo. Ha attirato la nostra attenzione perché aveva vinto il premio per l'innovazione. Siamo stati immediatamente entusiasti."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-white">
              <h3 class="font-bold text-base mb-4 flex items-center gap-2 text-[#02308C]">
                <Icon name="star" size="sm" class="text-[#6BDBD1]" /> I punti salienti di Kim
              </h3>
              <ul class="space-y-2 text-sm text-foreground-muted">
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1] flex-shrink-0" /> Investimento facilmente recuperato</li>
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1] flex-shrink-0" /> Pixformance garantisce alta fidelizzazione degli iscritti</li>
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#6BDBD1] flex-shrink-0" /> Nuovi iscritti grazie a Pixformance</li>
              </ul>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-6" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Fidelizzazione degli iscritti e ritorno sull'investimento</h2>
        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
            <p class="text-foreground italic text-base md:text-lg">"Il feedback dei nostri clienti riguarda principalmente cose come: 'Offre molta varietà' e 'Gli esercizi sono divertenti e stimolanti.' Questo è ciò che i nostri iscritti vogliono e hanno bisogno per restare motivati. Le reazioni sono assolutamente positive. Notiamo anche che i nostri clienti si allenano con il concetto Pixformance per molto tempo e non vanno rapidamente a cercare un altro metodo di allenamento."</p>
          </Card>
          <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
            <p class="text-foreground italic text-base md:text-lg">"Con Pixformance puoi vedere i tuoi risultati dopo l'allenamento sullo schermo. Quando gli utenti vedono che sono migliorati dal 60% all'80%, crea soddisfazione e motivazione extra. Questo progresso visibile dà loro una buona sensazione."</p>
          </Card>
          <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
            <p class="text-foreground italic text-base md:text-lg">"Offriamo l'uso delle postazioni ai nostri iscritti a un costo aggiuntivo. Coloro che vogliono usare Pixformance pagano un piccolo extra al mese. In questo modo, abbiamo recuperato il capitale investito abbastanza rapidamente. Siamo stati anche in grado di attrarre molti nuovi iscritti grazie a Pixformance. L'investimento ha ripagato per noi."</p>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="space-y-6" data-scroll="fade-up">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#02308C]/10 text-xs font-bold text-[#02308C] mb-3">
                <Icon name="user" size="sm" /> Personal Trainer
              </div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-1">Sil Hoving</h2>
              <p class="text-lg text-[#02308C] font-semibold mb-6">Personal Trainer all'Essink Sportcentrum</p>
            </div>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Vedo Pixformance non come concorrenza per i trainer, ma come supporto. È un modo molto efficiente e intelligente di allenarsi in modo ottimale. È fantastico che gli atleti ricevano sia feedback visivo tramite lo schermo che feedback da un trainer. Quando si è supportati da uno schermo, si impara a eseguire i movimenti correttamente. Questo previene gli infortuni nello sport."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-white">
              <h3 class="font-bold text-base mb-4 flex items-center gap-2 text-[#02308C]">
                <Icon name="star" size="sm" class="text-[#02308C]" /> I punti salienti di Sil
              </h3>
              <ul class="space-y-2 text-sm text-foreground-muted">
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#02308C] flex-shrink-0" /> Pixformance supporta il trainer</li>
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#02308C] flex-shrink-0" /> I piani di allenamento possono essere personalizzati individualmente</li>
                <li class="flex items-center gap-2"><Icon name="check" size="sm" class="text-[#02308C] flex-shrink-0" /> Immediatamente visibile se un esercizio è stato eseguito correttamente</li>
              </ul>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Sil-Hoving-Personal-Trainer.jpg" alt="Sil Hoving - Personal Trainer Essink Sportcentrum" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-6" data-scroll="fade-up">
        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
            <p class="text-foreground italic text-base md:text-lg">"Possiamo mettere insieme piani di allenamento per i nostri iscritti in vari modi. Se qualcuno ha un infortunio alla spalla o al ginocchio, o vuole concentrarsi su una regione corporea specifica, possiamo progettare il loro piano di allenamento in modo completamente individuale. In questo modo, tutti si allenano in modo ottimale verso il loro obiettivo personale."</p>
          </Card>
          <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
            <p class="text-foreground italic text-base md:text-lg">"Mi sto davvero godendo il lavoro con Pixformance finora. Trovo fantastico poter guidare i nostri iscritti così professionalmente mentre loro stessi scelgono cosa e come vogliono allenarsi. Il fatto che gli esercizi siano sempre mostrati sullo schermo e che gli utenti possano vedere da soli cosa stanno facendo bene o sbagliato è molto importante. Si è anche più concentrati e meno distratti da altre cose. La mia esperienza è quindi molto positiva."</p>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Sil-Hoving-Pixformance-Training.jpg" alt="Allenamento con Pixformance all'Essink Sportcentrum" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-8">
          <h2 class="font-display text-3xl md:text-4xl font-bold">Essink Sportcentrum in Video</h2>
        </div>
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <div class="relative w-full" style="padding-bottom: 56.25%;">
            <iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/h54tMPuasTs" title="Pixformance all'Essink Sportcentrum Eindhoven" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12" data-scroll="fade-up">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] mb-4">
            <Icon name="users" size="sm" /> Cosa Dicono gli Iscritti
          </span>
          <h2 class="font-display text-3xl md:text-4xl font-bold">Iscritti entusiasti condividono la loro esperienza</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div data-scroll="fade-up">
            <Card variant="elevated" padding="lg" class="h-full space-y-4 bg-white">
              <div class="overflow-hidden rounded-xl">
                <img src="/images/erfolgsgeschichten/Essink-Mitglied-1.jpg" alt="Sylvia Beerens - Iscritta Essink Sportcentrum" class="w-full h-56 object-cover" loading="lazy" />
              </div>
              <div>
                <p class="font-bold text-lg text-foreground">Sylvia Beerens</p>
                <p class="text-sm text-[#02308C] font-semibold mb-4">Impiegata Amministrativa</p>
                <Card variant="elevated" padding="md" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
                  <p class="text-foreground italic text-sm md:text-base">"Mi alleno da abbastanza tempo, ma non ho mai amato il fitness convenzionale. Con Pixformance ho trovato, per la prima volta, un concetto che mi rende davvero felice. Noto un'enorme differenza dopo così poco tempo. Trovo fantastico poter vedere i miei risultati dopo ogni sessione di allenamento. Poter tenere traccia dei propri progressi è molto motivante."</p>
                </Card>
              </div>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full space-y-4 bg-white">
              <div class="overflow-hidden rounded-xl">
                <img src="/images/erfolgsgeschichten/Essink-Mitglied-2.jpg" alt="Huub Janssen - Iscritto Essink Sportcentrum" class="w-full h-56 object-cover" loading="lazy" />
              </div>
              <div>
                <p class="font-bold text-lg text-foreground">Huub Janssen</p>
                <p class="text-sm text-[#02308C] font-semibold mb-4">Imprenditore</p>
                <Card variant="elevated" padding="md" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
                  <p class="text-foreground italic text-sm md:text-base">"La cosa fantastica di Pixformance è che c'è praticamente sempre un personal trainer presente. Ricevi sempre feedback e ti viene costantemente mostrato se stai eseguendo correttamente un esercizio o no. In passato ho fatto boxe professionistica per circa 15 anni. Da quando uso Pixformance noto che riesco genuinamente ad allenarmi senza infortuni."</p>
                </Card>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
