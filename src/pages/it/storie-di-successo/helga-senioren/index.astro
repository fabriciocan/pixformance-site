---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Allenamento della Forza per Anziani in Posizione Seduta - Attivi Anche in Sedia a Rotelle - Pixformance"
  description="Helga, 84 anni, si allena con Pixformance nonostante usi una sedia a rotelle e integra il movimento nella sua vita quotidiana. Allenamento personalizzato per ogni età e condizione di salute."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/helga-senioren/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#6BDBD1]/20 to-[#02308C]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6BDBD1]/20 border border-[#6BDBD1]/40 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="zap" size="sm" /> Fitness
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Più movimento in sedia a rotelle grazie al supporto digitale
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Allenamento della forza per anziani in posizione seduta – allenamento personalizzato per ogni età e condizione di salute
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
          <p class="text-foreground italic text-2xl md:text-3xl font-display font-bold leading-snug">"Per me era chiaro: voglio restare attiva."</p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Helga, 84 anni</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/pixformance-krafttraining-fuer-senioren-im-sitzen-fit-im-rollstuhl-1.jpg" alt="Helga, 84 anni, si allena con Pixformance dalla sua sedia a rotelle" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Helga</h2>
              <p class="text-xl text-[#02308C] font-semibold">84 anni – Iscritta allo Studio Fitness</p>
            </div>
            <Card variant="elevated" padding="lg" class="bg-white">
              <div class="space-y-6 text-foreground-muted">
                <p class="text-base md:text-lg leading-relaxed">A 84 anni, Helga usa una sedia a rotelle. Ma questo non le impedisce di visitare regolarmente la palestra con sua figlia. Grazie alla postazione Pixformance, può allenarsi diligentemente anche da seduta.</p>
                <Card variant="elevated" padding="md" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
                  <p class="text-foreground italic text-sm md:text-base">"Devo dire onestamente – è meraviglioso. Di quello che sono più felice è che mi sto muovendo di nuovo. Quando mi hanno amputato la gamba, ho detto subito che deve esserci qualcosa che posso fare da sola. Stare seduta da sola nell'appartamento – non fa per me."</p>
                </Card>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Motivata a integrare il movimento nella vita quotidiana</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Helga può facilmente eseguire i suoi esercizi alla postazione di allenamento digitale da seduta. La postazione la riconosce e analizza i suoi movimenti – che sia seduta o in piedi, alta o bassa. Il feedback digitale in tempo reale la aiuta e la motiva a completare gli esercizi con disciplina. Gli esercizi con i bastoni sono i suoi preferiti. Il pugilato può essere impegnativo a volte:</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"A volte sono troppo lenta e non raggiungo i cerchi in tempo. Ma ci deve essere una sfida – le cose non possono essere sempre solo divertenti."</p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>
            <p class="text-base md:text-lg">Soprattutto, i risultati dell'allenamento mostrati alla fine di ogni esercizio le danno un grande slancio motivazionale:</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Ci faccio sempre attenzione – non voglio vantarmi, ma sono raramente sotto il 60% e molto spesso al 100%."</p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/pixformance-krafttraining-fuer-senioren-im-sitzen-fit-im-rollstuhl-2.jpg" alt="Helga durante l'allenamento Pixformance – allenamento della forza per anziani in posizione seduta" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Miglioramenti notevoli nella vita quotidiana</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Grazie all'allenamento regolare, Helga nota già chiari miglioramenti nella sua vita quotidiana: riesce ad alzarsi dalla sedia a rotelle da sola e a sedersi sul divano o in macchina. Nei giorni buoni riesce persino a fare le scale senza assistenza.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Anche se ho un handicap, non devo stare seduta a casa. Ecco perché vado in palestra e dico: eccomi qui. Faccio qualcosa per me stessa. E poi la giornata è valsa la pena."</p>
              <p class="text-sm text-foreground-muted mt-2">— Helga</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">100 nuovi esercizi – molti in posizione seduta</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">A Pixformance è particolarmente importante che ogni paziente, iscritto e sportivo possa ricevere l'allenamento perfetto. A tale scopo, sono stati sviluppati circa 100 nuovi esercizi – inclusi molti esercizi in posizione seduta specificamente per persone in sedia a rotelle come Helga.</p>
            <p class="text-base md:text-lg">Da una selezione diversificata di oltre 270 esercizi funzionali, è possibile creare piani di allenamento personalizzati, monitorati e ottimizzati in base ai progressi dell'allenamento.</p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4">
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">270+</p>
                <p class="text-sm text-foreground-muted">esercizi funzionali</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">100+</p>
                <p class="text-sm text-foreground-muted">nuovi esercizi incluse opzioni in seduta</p>
              </Card>
              <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 text-center">
                <p class="text-3xl font-bold text-[#02308C] mb-2">84</p>
                <p class="text-sm text-foreground-muted">anni – allenamento senza limiti</p>
              </Card>
            </div>
            <p class="text-base md:text-lg">L'allenamento della forza in posizione seduta per anziani è applicabile non solo nelle palestre ma anche in fisioterapia, riabilitazione, cliniche e case di cura – per ogni individuo e condizione di salute.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
