---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Supporto in Ogni Fase della Riabilitazione - Gunter Hölig - Pixformance"
  description="Come Medical Park Bad Rodach utilizza sistemi intelligenti di sensori e robotica incluso Pixformance per supportare i pazienti in ogni fase della riabilitazione."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/gunter-hoelig/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" /> Clinica
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Supporto in ogni fase della riabilitazione
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Medical Park Bad Rodach – Soluzioni riabilitative intelligenti per ogni paziente
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">"Con Pixformance possiamo offrire ai nostri pazienti un'esperienza di allenamento individualizzata e digitalmente supportata in ogni fase della loro riabilitazione – dalla mobilizzazione precoce all'allenamento avanzato della forza."</p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Gunter Hölig, Medical Park Bad Rodach</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Gunter-Hoelig.jpg" alt="Gunter Hölig – Medical Park Bad Rodach" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Gunter Hölig</h2>
              <p class="text-xl text-[#02308C] font-semibold">Medical Park Bad Rodach</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" /> Profilo della Clinica
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sede</p><p class="text-sm">Bad Rodach, Baviera, Germania</p></div></div>
                <div class="flex items-start gap-3"><Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Specializzazione</p><p class="text-sm">Riabilitazione neurologica e ortopedica</p></div></div>
                <div class="flex items-start gap-3"><Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Tecnologia</p><p class="text-sm">Sistemi di sensori intelligenti, robotica, terapia digitale</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Rete</p><p class="text-sm">Gruppo Medical Park</p></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Sistemi intelligenti di sensori e robotica per la riabilitazione moderna</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Medical Park Bad Rodach è una delle principali cliniche riabilitative della Germania, che combina la tecnologia medica all'avanguardia con approcci terapeutici basati sull'evidenza. La clinica pone particolare enfasi sull'uso di sistemi intelligenti che supportano i pazienti durante il loro percorso riabilitativo – con feedback in tempo reale, programmi individualizzati e risultati misurabili.</p>
            <p class="text-base md:text-lg">Pixformance è diventato parte integrante del portfolio di terapia digitale della clinica. Il sistema colma il divario tra la terapia assistita dalla robotica e l'allenamento autonomo del paziente, consentendo un percorso riabilitativo continuo dalla fase di mobilizzazione precoce all'allenamento funzionale avanzato.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"La combinazione di sistemi di sensori intelligenti e l'analisi del movimento basata sull'IA di Pixformance ci dà un quadro completo dei progressi di ogni paziente. Questo ci permette di prendere decisioni basate sull'evidenza sulle modifiche della terapia."</p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Dalla robotica all'allenamento funzionale – un percorso continuo</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">A Medical Park Bad Rodach, la riabilitazione è intesa come un processo continuo. I pazienti iniziano con sistemi robotici altamente specializzati per la mobilizzazione precoce, quindi progrediscono attraverso un percorso strutturato con cura verso l'indipendenza funzionale. Pixformance svolge un ruolo chiave nelle fasi intermedie e avanzate di questo percorso.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Con oltre 350 esercizi e correzione in tempo reale basata sull'IA, Pixformance supporta i nostri pazienti nel raggiungere schemi di movimento corretti in modo indipendente – il che è essenziale per un successo terapeutico duraturo."</p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>
            <p class="text-base md:text-lg">La capacità del sistema di fornire feedback immediato sulla qualità del movimento – senza richiedere una supervisione costante del terapista – lo rende uno strumento prezioso per portare una riabilitazione di alta qualità a più pazienti contemporaneamente. I terapisti possono monitorare più pazienti rimanendo disponibili per coloro che necessitano di intervento pratico.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"L'app web Pixformance ci consente anche di estendere il supporto terapeutico oltre le mura della clinica, consentendo ai pazienti di continuare i loro programmi a casa con gli stessi standard di qualità che sperimentano qui."</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-12 text-center" data-scroll="fade-up">
          Principali vantaggi a Medical Park Bad Rodach
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="activity" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Feedback in Tempo Reale</h3>
              <p class="text-foreground-muted text-sm">L'analisi del movimento basata sull'IA fornisce feedback immediato sulla qualità degli esercizi, garantendo che i pazienti si allenino sempre in modo sicuro ed efficace – anche senza supervisione diretta del terapista.</p>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="users" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Assistenza Scalabile</h3>
              <p class="text-foreground-muted text-sm">Più pazienti possono allenarsi contemporaneamente con programmi individualizzati, consentendo ai terapisti di concentrare la loro competenza dove l'intervento pratico è maggiormente necessario.</p>
            </Card>
          </div>
          <div data-scroll="fade-up" data-delay="3">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Progressi Misurabili</h3>
              <p class="text-foreground-muted text-sm">Il monitoraggio completo dei dati consente a terapisti e pazienti di vedere prove chiare del miglioramento, motivando il coinvolgimento continuato e consentendo adattamenti terapeutici basati sui dati.</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
