---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<ITBaseLayout
  title="Tornare in Forma nella Vita - Christoph Schneider - Pixformance"
  description="Attivazione dei pazienti tramite dispositivi di terapia digitale alla Clinica Niederrhein, Korschenbroich. Christoph Schneider sull'utilizzo di Pixformance nella riabilitazione."
  type="article"
  hreflangEn="https://www.pixformance.com/en/success-stories/christoph-schneider/"
>
  <ITHeader slot="header" position="sticky" />

  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
            <Icon name="arrow-left" size="sm" /> Torna alla panoramica
          </a>
        </div>
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" /> Clinica
          </span>
          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Tornare in forma nella vita di tutti i giorni
          </h1>
          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Attivazione dei pazienti tramite dispositivi di terapia digitale alla Clinica Niederrhein, Korschenbroich, Germania
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">"Dopo un iniziale scetticismo occasionale, i nostri pazienti sono tutti entusiasti. Abbiamo quindi acquistato tre postazioni Pixformance. I dispositivi sono versatili, facili da usare e semplicemente divertenti!"</p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Christoph Schneider, Responsabile Terapia, Clinica Niederrhein</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img src="/images/erfolgsgeschichten/Christoph-Schneider-Therapieleiter-Niederrheinklinik-Reha-Klinik-Korschenbroich.jpg" alt="Christoph Schneider - Responsabile Terapia Clinica Niederrhein" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
            </Card>
          </div>
          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">Christoph Schneider</h2>
              <p class="text-xl text-[#02308C] font-semibold">Responsabile Terapia, Clinica Niederrhein</p>
            </div>
            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" /> Profilo della Clinica
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3"><Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sede</p><p class="text-sm">Korschenbroich, Renania Settentrionale-Vestfalia, Germania</p></div></div>
                <div class="flex items-start gap-3"><Icon name="calendar" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Fondato</p><p class="text-sm">1997</p></div></div>
                <div class="flex items-start gap-3"><Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Specializzazione</p><p class="text-sm">Riabilitazione: oncologia, ortopedia, neurologia</p></div></div>
                <div class="flex items-start gap-3"><Icon name="users" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Capacità Pazienti</p><p class="text-sm">240 posti letto</p></div></div>
                <div class="flex items-start gap-3"><Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" /><div><p class="text-sm font-semibold text-foreground">Sito web</p><a href="https://www.niederrhein-klinik.de" target="_blank" rel="noopener noreferrer" class="text-sm text-[#02308C] hover:underline">www.niederrhein-klinik.de</a></div></div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Dal paziente passivo a quello attivo – con supporto digitale</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">La clinica di riabilitazione sul Basso Reno, con oltre 20 anni di storia, si concentra sulla riabilitazione locale. I pazienti arrivano direttamente dagli ospedali per acuti – dopo aver superato una malattia grave o un intervento chirurgico. L'obiettivo della riabilitazione è chiaro: rimettere i pazienti in forma fisicamente e mentalmente, in modo che possano partecipare a tutti gli aspetti della vita.</p>
            <p class="text-base md:text-lg">In cerca di un modo per trasmettere ai pazienti che devono diventare indipendentemente attivi, il Responsabile Terapia Christoph Schneider e il suo team hanno scelto i dispositivi di terapia digitale di Pixformance.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Volevamo superare l'approccio 'il terapista fa qualcosa con me' verso 'devi prendere il tuo destino nelle tue mani.' L'offerta di allenamento individuale con Pixformance è ideale per questo, poiché la terapia di gruppo è altrimenti troppo facile per alcuni e troppo difficile per altri. In questo modo, ognuno riceve un allenamento completamente individuale."</p>
            </Card>
            <p class="text-base md:text-lg">Inizialmente, Schneider e il suo team erano incerti se i pazienti avrebbero accettato e abbracciato la nuova offerta supportata dal computer. Per scoprirlo, hanno deciso di iniziare con una prova di 6 mesi dei dispositivi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-xl mx-auto" data-scroll="scale">
        <Card variant="elevated" padding="none" class="overflow-hidden">
          <img src="/images/erfolgsgeschichten/Niederrheinklinik-Pixformance-Training.jpg" alt="Allenamento Pixformance alla Clinica Niederrhein Korschenbroich" class="w-full h-auto max-h-[380px] object-cover object-center" loading="lazy" />
        </Card>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Per tutte le fasce d'età e un'ampia gamma di condizioni di salute</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">I moderni dispositivi di terapia sono utilizzati in tutti e tre i reparti della Clinica Niederrhein – principalmente in oncologia. Lì, i pazienti che hanno superato condizioni come cancro allo stomaco, intestinale, polmonare o al seno e possono già muoversi autonomamente. Molti hanno ancora limitazioni nella resistenza e nella forza, dove l'allenamento digitale con attivazione mirata del movimento si collega e supporta.</p>
            <p class="text-base md:text-lg">A volte l'allenamento viene utilizzato anche in ortopedia, ad esempio dopo un intervento chirurgico alla colonna vertebrale o con articolazioni artificiali. L'allenamento con Pixformance è ora saldamente integrato nei piani terapeutici dei pazienti.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"I pazienti sono felici di poter essere nuovamente attivi da soli. Partecipano con piena motivazione e cercano costantemente di migliorare. Un tale entusiasmo viene raramente mostrato per il trattamento su un lettino terapeutico."</p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>
            <p class="text-base md:text-lg">I 200+ esercizi funzionali per l'allenamento autonomo sono versatili e spaziano dalla forza alla resistenza, dall'equilibrio alla stabilità. Sono possibili esercizi con palle, manubri, fasce elastiche o in sedia a rotelle – tutto sotto l'occhio attento della telecamera, che rileva e registra le imprecisioni nell'esecuzione. Dopo ogni esercizio, il paziente riceve un breve feedback sulla qualità dell'esecuzione e su cosa concentrarsi la prossima volta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-12">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Ricordare ai pazienti la vita quotidiana</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Per rendere la riabilitazione il più confortevole possibile per i pazienti, la clinica – parte del Gruppo St. Augustinus – ritiene importante che i pazienti possano conservare un pezzo di casa durante il soggiorno. Ciò si ottiene attraverso la riabilitazione locale in modo che i parenti possano visitare, ma anche attraverso l'allenamento stesso.</p>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"L'allenamento autonomo ricorda loro la palestra e quindi la loro normale vita quotidiana. E questo fa bene ai pazienti, specialmente considerando quanto seria fosse la malattia che alcuni di loro hanno attraversato. Ne sono molto grati."</p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Opzioni di allenamento personalizzate con minimo sforzo di personale</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Oltre ai benefici per i pazienti, anche i terapisti possono beneficiare dei dispositivi di terapia digitale. Schneider sottolinea soprattutto la semplice e rapida introduzione.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"I dispositivi sono semplici e posso introdurre tre pazienti contemporaneamente. Dopo una breve introduzione da parte di terapisti e istruttori sportivi qualificati, anche i nostri pazienti più anziani si allenano senza difficoltà. Funziona benissimo e ci fa risparmiare molto tempo. Possiamo quindi offrire a tutti un allenamento personalizzato accompagnato con il minimo sforzo di personale."</p>
            </Card>
            <p class="text-base md:text-lg">Un referente è sempre nelle vicinanze per domande o aggiustamenti, ma i terapisti non devono essere presenti a ogni sessione di allenamento.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"Questo è un sollievo significativo per noi come terapisti."</p>
            </Card>
            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">"Con le schede QR code, l'allenamento può procedere in modo igienicamente sicuro, e i dispositivi vengono anche disinfettati rapidamente."</p>
            </Card>
          </div>
        </div>

        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Assistenza ai pazienti oltre il soggiorno in clinica</h2>
          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">Accanto all'offerta riabilitativa, nella clinica di riabilitazione è integrato anche un programma sportivo per i pazienti in terapia ambulatoriale. In futuro è previsto di utilizzare qui anche i dispositivi di terapia Pixformance, per assistere i pazienti anche oltre la riabilitazione. L'utilizzo dell'app web Pixformance, che consente un allenamento supervisionato oltre la terapia in sede, è anch'esso un obiettivo futuro.</p>
            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">"È certamente nel nostro interesse accompagnare i nostri pazienti oltre il loro soggiorno in clinica. L'app web avrà certamente un ruolo lì."</p>
              <p class="text-sm text-foreground-muted mt-2">— Christoph Schneider</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Desideri una consulenza individuale?</h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Il tuo contatto</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/it/prova-gratuita/" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Contattaci <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/it/storie-di-successo/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Torna alla panoramica
        </a>
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="scale"] { transform: scale(0.95); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
