---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<ITBaseLayout
  title="Pixformance sulla stampa specializzata — Studi scientifici & Pubblicazioni"
  description="Pixformance Station (dispositivo medico dispositif médical CE (MDR UE 2017/745)): pubblicato su JMIR e BMC Cancer, progetto di ricerca europeo FORTEe (Orizzonte 2020), validato clinicamente — Charité Berlino, Università di Medicina di Magonza, Oxford Brookes University."
  hreflangDe="https://www.pixformance.com/presse/"
  hreflangEn="https://www.pixformance.com/en/press/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance Pressestimmen & Wissenschaftliche Publikationen",
    "description": "Peer-reviewte Studien, EU-Forschungsprojekte und Fachpublikationen belegen die klinische Wirksamkeit der Pixformance Station (CE-Medizinprodukt (MDR EU 2017/745)) in Physiotherapie, Geriatrie und Onkologie.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Get strong to fight childhood cancer (FORTEe): Rationale and design of a randomized controlled exercise trial",
          "description": "Randomisierte kontrollierte Studie (RCT) zur digitalen Bewegungstherapie bei Kinderkrebs. Pixformance als Technologiepartner. 15 Partnerinstitutionen aus 8 Ländern. EU Horizont 2020.",
          "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/",
          "datePublished": "2025-08-07",
          "publisher": { "@type": "Organization", "name": "BMC Cancer" },
          "author": [
            { "@type": "Person", "name": "Marie Astrid Neu" },
            { "@type": "Person", "name": "Tobias Baader" },
            { "@type": "Person", "name": "Joerg Faber" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Use of a Technology-Based Fall Prevention Program With Visual Feedback in Early Geriatric Rehabilitation",
          "description": "Machbarkeitsstudie mit 30 geriatrischen Patienten. Pixformance Station 3x/Woche für 20 Minuten. Primärendpunkt Machbarkeit erreicht. Sekundärendpunkte: Berg Balance Scale, Timed Up and Go Test, Barthel Index.",
          "url": "https://formative.jmir.org/2025/1/e66692",
          "datePublished": "2025-02-11",
          "publisher": { "@type": "Organization", "name": "JMIR Formative Research" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Pixformance — Report zur Nutzung im (außer)klinischen Umfeld",
          "description": "Praxisbericht zur Nutzung der Pixformance Station durch Physiotherapeuten und Therapieleiter in Deutschland und Österreich. Einsatz in Orthopädie, Neurologie und Onkologie.",
          "url": "https://www.researchgate.net/publication/373196981",
          "datePublished": "2023-08-18",
          "publisher": { "@type": "Organization", "name": "ResearchGate" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de"        href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en"        href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="fr"        href="https://www.pixformance.com/fr/presse/" />
    <link rel="alternate" hreflang="nl"        href="https://www.pixformance.com/nl/pers/" />
    <link rel="alternate" hreflang="it"        href="https://www.pixformance.com/it/stampa/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Stampa specializzata
          </span>
        </div>
        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance sulla <span class="text-[#02308C]">Stampa Specializzata</span>
        </h1>
        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Il Pixformance Station — il sistema di terapia del movimento digitale con telecamera 2D Full-HD brevettata e analisi in tempo reale di 25 punti articolari — è presentato regolarmente nelle principali pubblicazioni specializzate in fisioterapia, riabilitazione e gestione della salute. Come dispositivo medico dispositif médical CE (MDR UE 2017/745), validato clinicamente presso la Charité Berlino e l'Università Oxford Brookes, Pixformance è un riferimento riconosciuto nella terapia del movimento digitale.
        </p>
      </div>
    </div>
  </section>

  <!-- Pubblicazioni Scientifiche -->
  <section class="py-12 md:py-20 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-3xl font-bold">Pubblicazioni Scientifiche</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          Il Pixformance Station è oggetto di studi peer-reviewed su riviste specializzate internazionali e progetti di ricerca europei. Validato clinicamente in geriatria, oncologia e neurologia.
        </p>
      </div>
      <div class="space-y-6">

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Agosto 2025</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Peer-reviewed · BMC Cancer</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              FORTEe — Studio controllato randomizzato: terapia dell'esercizio nel cancro pediatrico
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Progetto EU Horizon 2020. 15 istituzioni partner in 8 paesi, guidate dall'Università di Medicina di Magonza. Pixformance (Tobias Baader) come partner tecnologico per la terapia del movimento digitale in bambini e adolescenti in trattamento oncologico. In collaborazione con Oxford Brookes University.
            </p>
            <a href="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Leggi lo studio (PubMed / BMC Cancer)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Febbraio 2025</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Peer-reviewed · JMIR Formative Research</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Programma digitale di prevenzione delle cadute nella riabilitazione geriatrica precoce
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Studio di fattibilità con 30 pazienti geriatrici (marzo–giugno 2024). Il Pixformance Station è stato utilizzato 3 volte a settimana per 20 minuti. Endpoint primario di fattibilità raggiunto (≥80% di partecipazione a 6 sessioni in 2 settimane). Endpoint secondari: Berg Balance Scale, Timed Up and Go Test, Misura dell'Indipendenza Funzionale, Indice di Barthel.
            </p>
            <a href="https://formative.jmir.org/2025/1/e66692" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Leggi lo studio (JMIR Formative Research)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#6BDBD1] to-[#86C9BC] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide" style="color: #02308C; background: rgba(107,219,209,0.3); border: 1px solid rgba(107,219,209,0.5);">Agosto 2023</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Rapporto clinico · ResearchGate</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Pixformance — Rapporto sull'utilizzo clinico Germania &amp; Austria
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Rapporto sull'utilizzo del Pixformance Station da parte di fisioterapisti e responsabili della terapia in Germania e Austria. Utilizzo in ortopedia, neurologia e oncologia. Riporta gruppi di pazienti, esperienze pratiche, accettazione da parte degli specialisti e utilizzo nella riabilitazione acuta e nell'allenamento autonomo.
            </p>
            <a href="https://www.researchgate.net/publication/373196981" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Leggi il rapporto (ResearchGate)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Pixformance in sintesi -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-8 text-[#02308C]">Pixformance in sintesi</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Dispositivo medico certificato dispositif médical CE (MDR UE 2017/745)</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Validato clinicamente: Charité Berlino &amp; Oxford Brookes University</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Partner di ricerca europeo: progetto FORTEe</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Analisi in tempo reale di 25 punti articolari tramite telecamera 2D Full-HD</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">700+ esercizi funzionali sulla piattaforma online</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">6.000+ installazioni in studi di fisioterapia, cliniche di riabilitazione e centri fitness nel mondo</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">2,5 milioni di utenti all'anno</span></li>
          <li class="flex items-start gap-3"><Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" /><span class="text-foreground-muted">Studi clinici: Hochschule Fresenius (SEP, Parkinson, distrofia muscolare, follow-up cancro al seno)</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container max-w-4xl">
      <div class="flex flex-col sm:flex-row gap-4" data-scroll="fade-up">
        <Button href="/testen" size="lg">
          Prova senza impegno
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button href="/kontakt" size="lg" variant="outline">
          Richieste stampa &amp; Contatto
          <Icon name="mail" size="sm" />
        </Button>
      </div>
    </div>
  </section>

</ITBaseLayout>
