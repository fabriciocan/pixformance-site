---
import ITBaseLayout from '@/layouts/ITBaseLayout.astro';
import ITHeader from '@/components/layout/ITHeader.astro';
import ITFooter from '@/components/layout/ITFooter.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';

const testimonials = [
  {
    name: 'Martijn Van Der Pijl',
    role: 'Proprietario',
    company: 'SlimBezig! di Veldhoven, Paesi Bassi',
    quote: 'Con Pixformance offriamo un\'ampia gamma di esercizi funzionali e personal training digitale che i nostri istruttori possono usare per sfidare i soci. Inoltre, gli esercizi possono essere eseguiti responsabilmente senza un istruttore.',
    image: '/images/en/SlimBezig_Martijn-Van-Der-Pijl-300x298.png',
  },
  {
    name: 'Esther van der Land',
    role: 'Proprietaria',
    company: 'Boutique Studio FemmeFit di Naarden, Paesi Bassi',
    quote: 'Pixformance significa crescita continua e sostenibile del fatturato e soci più soddisfatti che restano.',
    image: '/images/en/esther-van-der-land-FemmeFit-Naarden.png',
  },
  {
    name: 'Erwin Kuglmeier',
    role: 'Proprietario',
    company: 'Fitnessclub California, Germania',
    quote: 'I miei soci possono essere guidati e motivati individualmente con Pixformance. Mi piace soprattutto che sia facile da usare e che la stazione occupi poco spazio!',
    image: '/images/Erwin-Kuglmeier-Fitness-California-Pixformance-300x300.png',
  },
  {
    name: 'Kim Essink',
    role: 'Proprietario',
    company: 'Fitnessclub Essink di Eindhoven, Paesi Bassi',
    quote: 'Abbiamo scelto consapevolmente Pixformance perché abbiamo riconosciuto l\'opportunità e siamo certi che il nostro investimento si ripagherà rapidamente.',
    image: '/images/Pixformance-Kim-Essink.png',
  },
  {
    name: 'Ingeborg Modde',
    role: 'Proprietaria',
    company: 'Sweat Health Center di Oostburg, Paesi Bassi',
    quote: 'Si integra perfettamente nel nostro concetto Milon. Veloce, efficiente, sicuro e i miei soci ricevono sempre feedback dalla stazione – una scelta logica per noi e il passo successivo verso attrezzature future.',
    image: '/images/en/Pixformance-Ingeborg-Modde.png',
  },
  {
    name: 'Carina Dworak',
    role: 'Proprietaria',
    company: 'Mrs.Sporty Club di Vienna, Austria',
    quote: 'La bellezza di Pixformance è che i soci si allenano sempre con un personal trainer per risultati particolarmente efficaci.',
    image: '/images/en/carina-dworak-mrssporty-wien-pixformance.png',
  },
];

const benefits = [
  { icon: 'trending-up', title: 'Più allenamento e vendite', text: 'Grazie al software brevettato, più allievi possono essere seguiti contemporaneamente senza personale aggiuntivo (ad es. la sera).' },
  { icon: 'award', title: 'Attrezzatura di alta qualità', text: 'Un\'esperienza fitness funzionale moderna abbinata a un\'esperienza di allenamento su misura per un\'efficace fidelizzazione dei soci.' },
  { icon: 'clipboard', title: 'Amministrazione efficiente', text: 'Sulla piattaforma online, i progressi di ogni paziente sono documentati con precisione per l\'analisi e l\'ottimizzazione dell\'allenamento.' },
  { icon: 'settings', title: 'Assistenza individuale', text: 'I programmi di allenamento possono essere personalizzati in pochi secondi in base alla salute e all\'età di ciascun socio.' },
  { icon: 'clock', title: 'Più tempo per l\'essenziale', text: 'L\'istruttore non deve eseguire ogni esercizio personalmente, il che fa risparmiare tempo – e a sua volta avvantaggia tutti i soci.' },
  { icon: 'zap', title: '700+ esercizi disponibili', text: '700+ esercizi funzionali, vari e unici come i tuoi soci. Possono essere attivati con pochi clic.' },
];

const clientLogos = [
  { name: "Mrs.Sporty", src: '/images/en/Logo-MrsSporty-Mrs-Sporty.png' },
  { name: 'Healthy Club', src: '/images/en/Healthy-Club.png' },
  { name: 'Fitnessclub California', src: '/images/en/pixformance-logo-fitnessclub-california-straubing-1.png' },
  { name: 'Sissis Gym', src: '/images/en/pixformance-logo-sissis-gym-susanne-willkomm-personal-training-1.png' },
  { name: 'Essink', src: '/images/en/Logo-Essink-Sportscentrum-1.png' },
  { name: 'FemmeFit', src: '/images/en/Logo-Femme-Fit-1.png' },
  { name: 'JustFit', src: '/images/en/JustFit.png' },
  { name: 'SlimBezig', src: '/images/en/Logo-SlimBezig.jpg' },
];

const teamMembers = [
  { name: 'Laura Alves', role: 'Service & Support', image: '/images/en/Laura-Alves-Pixformance-1.png' },
  { name: 'Patricia Olear', role: 'Marketing Support', image: '/images/en/Patricia-Olear-Pixformance.png' },
];
---

<ITBaseLayout
  title="Dispositivi sportivi digitali innovativi per la tua palestra – Pixformance"
  description="Software fitness Pixformance per palestre. Pianificazione personalizzata e supporto al functional training con guida virtuale. Aumenta le entrate e la fidelizzazione dei soci."
  hreflangDe="https://www.pixformance.com/fitness/"
  hreflangEn="https://www.pixformance.com/en/fitness/"
>
  <ITHeader slot="header" position="sticky">
    <PixformanceLogo slot="logo" variant="en" />
  </ITHeader>

  <!-- Solutions Tabs -->
  <div class="bg-white border-b border-border sticky top-0 z-30">
    <div class="container">
      <div class="flex overflow-x-auto gap-0 -mb-px">
        <a href="/it/fisioterapia/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold whitespace-nowrap border-b-2 border-transparent text-foreground-muted hover:text-foreground transition-colors">
          <Icon name="heart" size="sm" />
          Fisioterapia
        </a>
        <a href="/it/fitness/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold whitespace-nowrap border-b-2 border-[#02308C] text-[#02308C]">
          <Icon name="zap" size="sm" />
          Fitness
        </a>
        <a href="/it/fitness-aziendale/" class="flex items-center gap-2 px-6 py-4 text-sm font-semibold whitespace-nowrap border-b-2 border-transparent text-foreground-muted hover:text-foreground transition-colors">
          <Icon name="briefcase" size="sm" />
          Fitness Aziendale
        </a>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="zap" size="sm" />
            Fitness
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Allenamento personalizzato con
          <span class="text-[#02308C]"> guida virtuale</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Allenamento migliore. Supervisione più semplice.
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Allenamento personalizzato, indipendente da tempo e supporto, con guida virtuale: offriamo supporto ottimale a te e ai tuoi soci nel percorso verso una migliore forma fisica.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button size="lg" href="/it/prova-gratuita/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Richiedi Prova
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button size="lg" variant="outline" href="/it/prodotti/" class="group hover:shadow-lg hover:scale-105 transition-all duration-300">
            Il Nostro Concetto
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold">
            Esercizio migliore.<br />Supervisione più semplice.
          </h2>
          <p class="text-base font-medium text-[#02308C]">
            Software fitness che guida ogni allenamento – senza bisogno di un istruttore.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            La stazione Pixformance è un dispositivo digitale per il functional training sviluppato da esperti di scienza, sport e fitness. L'idea: tecnologia all'avanguardia per un allenamento fitness funzionale efficace e divertente.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Una fotocamera integrata nel dispositivo cattura 25 punti articolari, analizza il movimento e fornisce feedback personalizzato in tempo reale. Il vantaggio: software fitness che consente la correzione in tempo reale e permette agli utenti di completare un allenamento supervisionato – senza la presenza di un istruttore. Questo rende il functional training ancora più efficace.
          </p>
        </div>
        <div data-scroll="slide-right">
          <img
            src="/images/en/Pixformance-Fitness-Digitales-Sportgeraet-Fitnessstudio-eroeffnen-eGym-voll-vernetzt.jpg"
            alt="Dispositivo Sportivo Digitale"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Real-Time Correction -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-scroll="slide-left" class="order-2 lg:order-1">
          <img
            src="/images/en/Station-Single-Test-Menina-White-Rooms.png"
            alt="Analisi dell'allenamento su schermo"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
        <div class="space-y-6 order-1 lg:order-2" data-scroll="slide-right">
          <h2 class="font-display text-4xl md:text-5xl font-bold">Correzione in tempo reale</h2>
          <p class="text-foreground-muted leading-relaxed">
            La stazione e il software fitness Pixformance forniscono una guida continua sulla precisione, il ritmo e l'accuratezza dell'esecuzione degli esercizi, offrendo così un functional training sicuro – come con un personal trainer.
          </p>
          <div class="space-y-6">
            {[
              { title: 'Istruzioni semplici per l\'esercizio', text: 'L\'allievo si posiziona davanti alla stazione Pixformance e l\'esercizio viene dimostrato sullo schermo da un istruttore.' },
              { title: 'Analisi precisa del movimento', text: 'Durante l\'esercizio, una fotocamera con sensore di profondità integrato scansiona 25 punti articolari dell\'allievo in pochi secondi e analizza i suoi movimenti.' },
              { title: 'Feedback in tempo reale', text: 'Il trainer virtuale dà feedback in tempo reale. Ciò garantisce che gli esercizi siano eseguiti correttamente e in sicurezza, come sotto la guida di un istruttore.' },
            ].map((feature, i) => (
              <div class="flex gap-4">
                <div class="shrink-0 w-8 h-8 rounded-lg bg-[#02308C] flex items-center justify-center">
                  <span class="text-white font-bold text-xs">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div>
                  <h3 class="font-bold mb-1">{feature.title}</h3>
                  <p class="text-sm text-foreground-muted">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 uppercase">GESTISCI IN MODO PIÙ ECONOMICO</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Pixformance rende il functional training un'esperienza unica per tutti e offre alle palestre numerosi vantaggi rispetto alle attrezzature tradizionali.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-all hover:-translate-y-1" data-scroll="fade-up" data-delay={Math.min(index+1,6)}>
            <div class="w-10 h-10 rounded-xl bg-[#6BDBD1]/20 flex items-center justify-center mb-4 mx-auto md:mx-0">
              <Icon name={benefit.icon} size="sm" class="text-[#02308C]" />
            </div>
            <h3 class="font-bold mb-2">{benefit.title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{benefit.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold">Clienti soddisfatti</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, index) => (
          <Card variant="elevated" padding="lg" class="hover:shadow-xl transition-shadow" data-scroll="scale" data-delay={Math.min(index+1,6)}>
            <div class="flex items-start gap-3 mb-4">
              <img src={t.image} alt={t.name} class="w-12 h-12 rounded-full object-cover shrink-0" loading="lazy" />
              <div>
                <p class="font-bold text-sm">{t.name}</p>
                <p class="text-xs text-foreground-muted">{t.role}</p>
                <p class="text-xs text-[#02308C] font-semibold">{t.company}</p>
              </div>
            </div>
            <p class="text-sm text-foreground-muted italic leading-relaxed">"{t.quote}"</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <section class="py-10 bg-white">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-8">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt={logo.name} class="h-10 w-auto object-contain opacity-60 hover:opacity-90 transition-opacity grayscale hover:grayscale-0" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule a Call -->
  <section class="py-12 bg-[#02308C]">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <h2 class="font-display text-2xl font-bold text-white">Prenota una chiamata o facci una domanda</h2>
        <Button href="/it/contatto/" class="bg-[#6BDBD1] text-[#02308C] hover:bg-[#6BDBD1]/90 shrink-0">
          Scrivici
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Training Concepts -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold uppercase mb-4">Concetti di Allenamento</h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Offriamo soluzioni alle diverse sfide che le palestre devono affrontare. Insieme a voi elaboriamo un concetto che riflette i vostri requisiti ed è precisamente adattato alle vostre esigenze.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- 01 Individual Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="1">
          <img
            src="/images/en/Pixformance-Station-Einzeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Allenamento Individuale"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">01 ALLENAMENTO INDIVIDUALE</h2>
          <p class="text-foreground-muted">Con una stazione Pixformance, gli allievi possono usufruire in qualsiasi momento di un personal training funzionale su misura.</p>

          <div class="space-y-3">
            {[
              { title: 'Concetti di Allenamento', content: 'Come allenamento 1:1 davanti alla stazione o come complemento a un concetto esistente. Disponibili le opzioni COMPLEMENTARE, INTENSIVO e TRA UNA SESSIONE E L\'ALTRA.' },
              { title: 'Dettagli', content: 'Spazio necessario: ~6 m² · Peso: 65 kg · Fotocamera: 2D Full HD · Touch-Screen: display touch da 49" · Distanza di allenamento: ~1,60 – 2,30 m dall\'istruttore, 1,0 – 1,5 m per lato' },
              { title: 'Vantaggi', content: 'Concetto innovativo · Punti di forza unici · Si integra in aree di allenamento più piccole · La supervisione virtuale consente l\'allenamento autonomo' },
            ].map((item) => (
              <details class="border border-border rounded-xl overflow-hidden">
                <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                  {item.title}
                  <span class="text-[#02308C]">+</span>
                </summary>
                <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">{item.content}</div>
              </details>
            ))}
          </div>
        </div>

        <!-- 02 Circuit Training -->
        <div class="space-y-6" data-scroll="fade-up" data-delay="2">
          <img
            src="/images/en/Pixformance-Station-Zirkeltraining-Digitales-Sportgeraet-voll-vernetzt-Personal-Trainer.jpg"
            alt="Allenamento a Circuito"
            class="w-full h-48 object-cover rounded-2xl"
            loading="lazy"
          />
          <h2 class="text-2xl font-bold">02 ALLENAMENTO A CIRCUITO</h2>
          <p class="text-foreground-muted">L'allenamento a circuito per piccoli gruppi è possibile con un minimo di tre stazioni Pixformance.</p>

          <div class="space-y-3">
            {[
              { title: 'Concetti di Allenamento', content: 'Come allenamento 1:1 davanti alla stazione. L\'allenamento di gruppo supervisionato è già possibile con tre stazioni. I corsi di prevenzione sono possibili con quattro o più stazioni.' },
              { title: 'Dettagli', content: 'Spazio necessario: ~6 m² · Peso: 65 kg · Fotocamera: 2D Full HD · Touch-Screen: display touch da 49" · Distanza di allenamento: ~1,60 – 2,30 m dall\'istruttore, 1,0 – 1,5 m per lato' },
              { title: 'Vantaggi', content: 'Concetto innovativo · Proposta di valore unica · Supporto individuale nei gruppi · Locali adattabili · Soluzione completa interconnessa' },
            ].map((item) => (
              <details class="border border-border rounded-xl overflow-hidden">
                <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                  {item.title}
                  <span class="text-[#02308C]">+</span>
                </summary>
                <div class="px-4 pb-4 text-sm text-foreground-muted leading-relaxed">{item.content}</div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Member Benefits -->
  <section class="py-16 md:py-24 bg-[#6BDBD1]">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white uppercase mb-4">RAGGIUNGI I TUOI OBIETTIVI ANCORA PIÙ IN FRETTA</h2>
        <p class="text-lg text-white/80 max-w-3xl mx-auto">
          Grazie al feedback in tempo reale, gli utenti possono migliorare forza, condizione fisica e mobilità, allenando efficacemente tutto il corpo.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: 'shield', title: 'Sicuro, Interattivo, Flessibile', text: 'I soci beneficiano della possibilità di allenarsi in modo sicuro, flessibile e individuale senza un istruttore.' },
          { icon: 'smile', title: 'Più motivazione e divertimento', text: 'Il functional training con supervisione virtuale aumenta l\'esperienza di allenamento e motiva gli utenti a raggiungere i loro obiettivi.' },
          { icon: 'bar-chart', title: 'Successi chiari e visibili', text: 'I soci si allenano in modo ancora più efficace rispetto all\'ambiente di allenamento tradizionale e migliorano misurabili coordinazione, forza, resistenza e mobilità.' },
        ].map((card, index) => (
          <Card variant="elevated" padding="lg" class="bg-white/10 border-white/20 text-white hover:bg-white/20 transition-colors" data-scroll="fade-up" data-delay={index+1}>
            <Icon name={card.icon} size="md" class="text-white mb-4" />
            <h3 class="font-bold text-lg mb-2">{card.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{card.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Il Tuo Avvio Facile – Il Nostro Servizio Forte</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {[
          { title: 'Consulenza e formazione personalizzata', text: 'Ti consigliamo individualmente, dalla pianificazione degli spazi, all\'installazione delle attrezzature necessarie, fino al controllo ottimale dell\'allenamento.' },
          { title: 'Supporto hardware e software', text: 'In caso di problemi hardware, ti forniremo i pezzi di ricambio. Gli aggiornamenti automatici fanno parte del nostro servizio e sono disponibili gratuitamente.' },
          { title: 'Pacchetto marketing completo a 360°', text: 'Come nostro cliente hai accesso al tuo pacchetto marketing per stampa e web, con download gratuiti e molto altro.' },
          { title: 'Finanziamento', text: 'Che si tratti di acquisto o leasing, puoi strutturare il finanziamento individualmente. Scopri come puoi iniziare con Pixformance già da 99 € al mese.' },
          { title: 'FAQ | Domande frequenti', text: 'Qui troverai le risposte alle domande più frequenti sul nostro concetto di allenamento.', link: '/it/faq/' },
        ].map((service, index) => (
          <Card variant="elevated" padding="lg" data-scroll="fade-up" data-delay={Math.min(index+1,5)}>
            <h3 class="font-bold text-lg mb-3">{service.title}</h3>
            <p class="text-sm text-foreground-muted">{service.text}</p>
            {service.link && <a href={service.link} class="text-[#02308C] text-sm font-semibold hover:underline mt-2 inline-block">Scopri di più →</a>}
          </Card>
        ))}
      </div>
      <div class="flex flex-wrap justify-center gap-12">
        {teamMembers.map((member) => (
          <div class="text-center w-40" data-scroll="fade-up">
            <img src={member.image} alt={member.name} class="w-32 h-32 rounded-full object-cover mx-auto mb-4 shadow-lg" loading="lazy" />
            <h3 class="font-bold">{member.name}</h3>
            <p class="text-sm text-foreground-muted">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ITFooter slot="footer" />
</ITBaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll="slide-left"] { transform: translateX(-40px); }
  [data-scroll="slide-left"].is-visible { transform: translateX(0); }
  [data-scroll="slide-right"] { transform: translateX(40px); }
  [data-scroll="slide-right"].is-visible { transform: translateX(0); }
  [data-scroll="scale"] { transform: scale(0.9); }
  [data-scroll="scale"].is-visible { transform: scale(1); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
  [data-scroll][data-delay="4"] { transition-delay: 0.4s; }
  [data-scroll][data-delay="5"] { transition-delay: 0.5s; }
  [data-scroll][data-delay="6"] { transition-delay: 0.6s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
