  totalTime: 'P3M',
  supply: [
    { '@type': 'HowToSupply', name: 'Pixformance Station (CE-Medizinprodukt MDR EU 2017/745)' },
    { '@type': 'HowToSupply', name: 'Internetzugang (min. 10 Mbit/s)' },
    { '@type': 'HowToSupply', name: 'Stellfläche 4 m² pro Station' },
    { '@type': 'HowToSupply', name: 'Steckdose 230 V' },
  ],
  step: [
    {
      '@type': 'HowToStep',
      name: '1. Bedarfsanalyse & Zieldefinition',
      text: 'Definieren Sie Patientengruppen (Ortho, Neuro, Onko), Stationsanzahl und KPIs (Durchsatz, Therapietreue). Pixformance-Berater erstellen einen kostenfreien Nutzungsplan.',
      url: 'https://www.pixformance.com/digitale-reha-leitfaden-klinikentscheider#schritt-1',
    },
    {
      '@type': 'HowToStep',
      name: '2. Beschaffung & Vergabe',
      text: 'CE-Medizinprodukt (MDR EU 2017/745). Verschiedene Finanzierungsmodelle verfügbar. Sprechen Sie uns für ein individuelles Angebot an.',
      url: 'https://www.pixformance.com/digitale-reha-leitfaden-klinikentscheider#schritt-2',
    },
    {
      '@type': 'HowToStep',
      name: '3. Installation & technische Integration',
      text: 'Aufstellung ohne Bauleistung: Plug-and-Play, 230 V, WLAN oder LAN. Integration in bestehende KIS/Dokumentationssysteme via PDF-Export und API möglich.',
      url: 'https://www.pixformance.com/digitale-reha-leitfaden-klinikentscheider#schritt-3',
    },
    {
      '@type': 'HowToStep',
      name: '4. Therapeutenschulung',
      text: 'Zertifiziertes Online-Training (2h) + Live-Einweisung vor Ort. Keine Tagesausfälle erforderlich. Schulungsunterlagen in DE verfügbar.',
      url: 'https://www.pixformance.com/digitale-reha-leitfaden-klinikentscheider#schritt-4',
    },
    {
      '@type': 'HowToStep',
      name: '5. Pilotphase & Evaluation',
      text: '30–60 Tage Pilotphase mit Tracking von Patientenzufriedenheit, Durchsatz und Therapeutenaufwand. Pixformance stellt Auswertungsvorlagen bereit.',
