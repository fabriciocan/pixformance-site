const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Ist Pixformance ein zugelassenes Medizinprodukt für Kliniken?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. Die Pixformance Station ist ein CE-gekennzeichnetes Medizinprodukt (MDR-konform EU 2017/745) und erfüllt die EMV-Richtlinie 2004/108/EG. Das System ist klinisch validiert in Studien der Hochschule Fresenius und der Charité Berlin und wird in über 1.100 Partnereinrichtungen — darunter über 150 Kliniken und Rehazentren — eingesetzt.',
      },
    },
    {
      '@type': 'Question',
      name: 'Welche Infrastruktur ist für den Betrieb in einer Klinik nötig?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die Pixformance Station benötigt ca. 4 m² Stellfläche, einen 230-V-Anschluss und einen stabilen Internetzugang (min. 10 Mbit/s). Es sind keine Umbaumaßnahmen erforderlich. Das System ist Plug-and-Play und betriebsbereit in unter 2 Stunden.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wie erfolgt die Abrechnung in der Klinik – über Kassenleistungen oder Selbstzahler?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Pixformance-Einheiten können als KGG/KGM-Ziffern in der Physiotherapie abgerechnet werden. Zusätzlich ist ein Selbstzahlermodell für nicht kassenfinanzierte Einheiten möglich, z. B. im Bereich Prävention oder Reha-Sport. Die genaue Abrechnung hängt von Ihrer Kassenzulassung ab.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wie lange dauert die Implementierung von der Bestellung bis zum Regelbetrieb?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Bitte sprechen Sie uns direkt an – unsere Berater geben Ihnen genaue Angaben zu Lieferzeit und Implementierung für Ihre Einrichtung.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kann Pixformance für Telerehabilitation (Heimtraining) eingesetzt werden?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. Das hybride Modell kombiniert klinisches Training (1×/Woche in der Einrichtung) mit Heimtraining (bis 6×/Woche) über die Pixformance Web App. Therapeuten überwachen die Compliance und passen Trainingspläne digital an. Das Hybridmodell ist bereits in der AUVA Klagenfurt und weiteren Rehazentren im Einsatz.',
      },
    },
  ],
};
---

<BaseLayout
  title="Digitale Reha: Leitfaden für Klinikentscheider | Pixformance"
  description="Praxisleitfaden für Chefärzte und Klinikleitung: Wie digitale Bewegungstherapie (CE-Medizinprodukt) beschafft, integriert und wirtschaftlich betrieben wird. Checkliste, ROI-Rechnung, Erfahrungen aus 1.100+ Partnereinrichtungen."
  jsonLd={[articleSchema, howToSchema, faqSchema]}
>
  <HeaderWithDropdown />

  <!-- Hero -->
  <section class="bg-[#02308C] text-white py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-[#6BDBD1] text-sm font-semibold uppercase tracking-widest mb-4">
        Leitfaden für Klinikentscheider
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Digitale Reha: Wie Kliniken digitale Bewegungstherapie erfolgreich einführen
      </h1>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl">
        Von der Bedarfsanalyse über Beschaffung und Integration bis zum Regelbetrieb – ein
        strukturierter Leitfaden für Chefärzte, Klinikleitungen und Einkauf.
      </p>
      <div class="flex flex-wrap gap-3 text-sm">
        <span class="bg-white/10 rounded-full px-4 py-1">CE-Medizinprodukt MDR EU 2017/745</span>
        <span class="bg-white/10 rounded-full px-4 py-1">1.100+ Partnereinrichtungen</span>
        <span class="bg-white/10 rounded-full px-4 py-1">Klinisch validiert</span>
      </div>
    </div>
  </section>

  <!-- Intro / Kontext -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto prose prose-lg">
      <h2 class="text-3xl font-bold text-[#02308C] mb-6">
        Warum digitale Bewegungstherapie für Kliniken relevant ist
      </h2>
      <p>
        Rehabilitationskliniken, Krankenhäuser und Rehazentren stehen vor einer strukturellen
        Herausforderung: Der Fachkräftemangel im therapeutischen Bereich wächst, während
        Patientenvolumen und Dokumentationsaufwand steigen. Gleichzeitig verlangen Kostenträger
        nachweisbare Therapieergebnisse und Effizienzgewinne.
      </p>
      <p>
        Digitale Bewegungstherapiesysteme wie die Pixformance Station bieten eine klinisch
        validierte Antwort: Patienten trainieren bis zu 6 Mal täglich selbstständig – gesteuert
        und überwacht durch ein CE-zertifiziertes Medizinprodukt (MDR-konform EU 2017/745).
        Therapeuten werden entlastet und können ihre Kapazitäten dort einsetzen, wo menschliche
        Expertise tatsächlich gefordert ist.
      </p>
      <p>
        Dieser Leitfaden richtet sich an Entscheider, die konkret planen: Chefärzte,
        Klinikleitungen, Einkauf und Qualitätsmanagement. Er fasst die wesentlichen
        Beschaffungs-, Integrations- und Betriebsfragen zusammen – basierend auf Erfahrungen
        aus über 1.100 Partnereinrichtungen — darunter über 150 Kliniken und Rehazentren.
      </p>
    </div>
  </section>

  <!-- Schritt-für-Schritt-Leitfaden -->
  <section class="py-16 px-4 bg-gray-50" id="schritt-1">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-[#02308C] mb-10 text-center">
        Einführung in 6 Schritten
      </h2>

      <div class="space-y-8">
        <!-- Schritt 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-1">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">1</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Bedarfsanalyse & Zieldefinition</h3>
              <p class="text-gray-700 mb-4">
                Der Einstieg beginnt mit der Frage: Für welche Patientengruppen soll das System
                primär eingesetzt werden? Orthopädie, Neurologie, Onkologie und Prävention haben
                unterschiedliche Anforderungen an Übungsprogramme und Dokumentation.
              </p>
              <ul class="list-disc list-inside text-gray-700 space-y-1 text-sm">
                <li>Definieren Sie KPIs: Patientendurchsatz, Therapietreue, Therapeutenstunden</li>
                <li>Legen Sie die Anzahl der benötigten Stationen fest (Faustregel: 1 Station je 32 Einheiten/Tag)</li>
                <li>Klären Sie Stellflächen: min. 4 m² pro Station, empfohlen 6–8 m²</li>
                <li>Pixformance-Berater erstellen auf Anfrage einen kostenfreien Raumplan</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Schritt 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-2">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">2</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Beschaffung & Vergabe</h3>
              <p class="text-gray-700 mb-4">
                Für Informationen zur Beschaffung und zu verfügbaren Finanzierungsmodellen sprechen Sie bitte unsere Berater an:
              </p>
              <div class="grid md:grid-cols-1 gap-4 text-sm">
                <div class="bg-blue-50 rounded-lg p-4">
                  <p class="font-semibold text-[#02308C] mb-2">Zertifizierung & Compliance</p>
                  <p class="text-gray-700">CE-Medizinprodukt (MDR EU 2017/745). Vollständige technische Dokumentation und Konformitätserklärung werden mitgeliefert.</p>
                </div>
                <div class="bg-blue-50 rounded-lg p-4">
                  <p class="font-semibold text-[#02308C] mb-2">Finanzierung & Beschaffung</p>
                  <p class="text-gray-700">Verschiedene Finanzierungsmodelle verfügbar. Sprechen Sie uns für ein individuelles Angebot und Informationen zur Beschaffung an.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Schritt 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-3">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">3</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Installation & technische Integration</h3>
              <p class="text-gray-700 mb-4">
                Die Station ist als Plug-and-Play-System konzipiert. Es sind keine Bauleistungen,
                Wandmontagen oder IT-Spezialsoftware erforderlich.
              </p>
              <ul class="list-disc list-inside text-gray-700 space-y-1 text-sm">
                <li>Anschluss: 230 V Schutzkontaktsteckdose, Leistungsaufnahme &lt;200 W</li>
                <li>Netzwerk: WLAN (WPA2) oder LAN (RJ45), min. 10 Mbit/s symmetrisch</li>
                <li>Datenschutz: DSGVO-konformer Cloud-Betrieb auf deutschen Servern</li>
                <li>Dokumentation: Therapiedaten exportierbar als PDF und CSV</li>
                <li>KIS-Integration: API-Anbindung auf Anfrage verfügbar</li>
              </ul>
              <p class="text-gray-700 mt-4 text-sm">
                Betriebsbereit typischerweise in unter 2 Stunden nach Lieferung.
              </p>
            </div>
          </div>
        </div>

        <!-- Schritt 4 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-4">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">4</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Therapeutenschulung</h3>
              <p class="text-gray-700 mb-4">
                Das therapeutische Team benötigt keine technischen Vorkenntnisse. Die Schulung
                umfasst zwei Module:
              </p>
              <div class="grid md:grid-cols-2 gap-4 text-sm">
                <div class="bg-teal-50 rounded-lg p-4">
                  <p class="font-semibold text-[#02308C] mb-1">Online-Zertifizierung</p>
                  <p class="text-gray-700">~2 Stunden, asynchron absolvierbar. Enthält Bedienung, Patientenanlage, Programmauswahl und Dokumentation.</p>
                </div>
                <div class="bg-teal-50 rounded-lg p-4">
                  <p class="font-semibold text-[#02308C] mb-1">Live-Einweisung vor Ort</p>
                  <p class="text-gray-700">Halbtägig durch zertifizierten Pixformance-Trainer. Praxisteil mit eigenem Patientenfall. Keine Stationsschließung erforderlich.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Schritt 5 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-5">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">5</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Pilotphase & Evaluation</h3>
              <p class="text-gray-700 mb-4">
                Eine strukturierte Pilotphase von 30–60 Tagen ermöglicht die fundierte
                Entscheidungsgrundlage für den Rollout.
              </p>
              <p class="text-gray-700 text-sm mb-3">Empfohlene Messwerte in der Pilotphase:</p>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                {[
                  'Patientendurchsatz / Woche',
                  'Therapieeinheiten / Station / Tag',
                  'Patientenzufriedenheit (NRS)',
                  'Therapeutenstunden eingespart',
                ].map((m) => (
                  <div class="bg-gray-50 rounded-lg p-3 text-center text-gray-700 text-xs font-medium">
                    {m}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Schritt 6 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border-l-4 border-[#6BDBD1]" id="schritt-6">
          <div class="flex items-start gap-4">
            <div class="bg-[#02308C] text-white rounded-full w-10 h-10 flex items-center justify-center font-bold text-lg shrink-0">6</div>
            <div>
              <h3 class="text-xl font-bold text-[#02308C] mb-3">Regelbetrieb & Skalierung</h3>
              <p class="text-gray-700 mb-4">
                Im Regelbetrieb ermöglicht jede Station den gleichzeitigen, selbstständigen Betrieb
                für 4 Patienten – ohne durchgehende therapeutische Betreuung. Bei 8 Betriebsstunden
                täglich ergibt das bis zu 32 Einheiten pro Station pro Tag.
              </p>
              <div class="bg-[#02308C] text-white rounded-xl p-5 text-sm mb-4">
                <p class="font-semibold mb-2 text-[#6BDBD1]">Kapazitätsrechnung (1 Station)</p>
                <p>1 Station × 4 Patienten × 8h/Tag × 45-min-Einheiten = <strong>32 Einheiten/Tag</strong></p>
                <p class="mt-1 text-blue-200 text-xs">Quelle: Erfahrungswerte aus dem Klinikbetrieb</p>
              </div>
              <p class="text-gray-700 text-sm">
                Skalierung durch weitere Stationen oder Aktivierung des Telerehabilitation-Moduls
                (bis 6× Heimtraining/Woche via Web App). Beides ohne neue Hardware-Infrastruktur.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI-Rechnung -->
  <section class="py-16 px-4 bg-[#02308C] text-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-10 text-center">Wirtschaftlichkeit: Typischer ROI im Klinikbetrieb</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <div class="bg-white/10 rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold text-[#6BDBD1] mb-2">32+</p>
          <p class="text-blue-100 text-sm">Therapieeinheiten/Tag<br/>pro Station</p>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold text-[#6BDBD1] mb-2">4×</p>
          <p class="text-blue-100 text-sm">Patienten gleichzeitig<br/>pro Therapeut</p>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold text-[#6BDBD1] mb-2">✓</p>
          <p class="text-blue-100 text-sm">Finanzierung möglich<br/>Konditionen auf Anfrage</p>
        </div>
      </div>
      <div class="bg-white/10 rounded-2xl p-8 text-center">
        <p class="text-blue-100 leading-relaxed">Für eine individuelle Wirtschaftlichkeitsberechnung für Ihre Einrichtung sprechen Sie bitte unsere Berater an.</p>
        <a href="/testen" class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-[#6BDBD1] text-[#02308C] font-bold rounded-full hover:bg-white transition-colors duration-300">
          Beratungsgespräch vereinbaren
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Klinische Validierung -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-[#02308C] mb-8 text-center">Klinische Evidenz & Referenzen</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">
        Pixformance ist nicht nur CE-zertifiziert – das System ist in klinischen Studien validiert
        und in Leitkliniken im Einsatz.
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-[#02308C] mb-4">Peer-reviewte Studien</h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>BMC Cancer:</strong> Bewegungstherapie bei onkologischen Patienten – signifikante Verbesserung von Ausdauer und Lebensqualität</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>Hochschule Fresenius:</strong> Studien zu MS, Parkinson, Muskeldystrophie und Brustkrebs-Nachsorge</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>FORTEe (Horizon 2020, €6,3 Mio.):</strong> EU-Forschungsprojekt zur Bewegungstherapie bei krebskranken Kindern</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>Oxford Brookes University:</strong> Klinische Validierung und laufende Studienpartnerschaft</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-[#02308C] mb-4">Referenzeinrichtungen (Auswahl)</h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>Charité Berlin</strong> – Universitätsmedizin, Neurologie & Rehabilitation</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>AUVA Klagenfurt</strong> – Unfallchirurgische Rehabilitation, Hybridmodell</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#6BDBD1] font-bold mt-0.5">▸</span>
              <span><strong>Medical Park Bad Rodach</strong> – Orthopädische Rehabilitation</span>
            </li>
