---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Digitale Reha: Leitfaden für Klinikentscheider – Beschaffung, Integration und ROI',
  description:
    'Praxisleitfaden für Klinikleitungen, Chefärzte und Einkauf: Wie digitale Bewegungstherapie (CE-Medizinprodukt MDR EU 2017/745) beschafft, integriert und wirtschaftlich betrieben wird. Mit Checkliste, ROI-Rechnung und Erfahrungswerten aus 1.100+ Partnereinrichtungen.',
  author: {
    '@type': 'Organization',
    name: 'Pixformance Sports GmbH',
    url: 'https://www.pixformance.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Pixformance Sports GmbH',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.pixformance.com/img/logos/pixformance-logo-1024x1024.png',
    },
  },
  datePublished: '2026-01-01',
  dateModified: '2026-06-24',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://www.pixformance.com/digitale-reha-leitfaden-klinikentscheider',
  },
  about: [
    { '@type': 'Thing', name: 'Digitale Rehabilitation' },
    { '@type': 'Thing', name: 'Bewegungstherapie' },
    { '@type': 'Thing', name: 'Medizinprodukt CE MDR EU 2017/745' },
    { '@type': 'Thing', name: 'Telerehabilitation' },
  ],
  keywords:
    'digitale Reha, Klinikentscheider, Bewegungstherapie Beschaffung, CE Medizinprodukt Klinik, Telerehabilitation, ROI Rehabilitation, Pixformance Klinik',
