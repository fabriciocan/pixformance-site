---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<BaseLayout
  noindex={true}
  title="Unterstützung in jeder Rehabilitationsphase - Gunter Hölig - Pixformance"
  description="Wie der Medical Park Bad Rodach intelligente Sensorik- und Robotiksysteme einschließlich Pixformance einsetzt, um Patienten in jeder Rehabilitationsphase zu unterstützen."
  type="article"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Unterstützung in jeder Rehabilitationsphase – Gunter Hölig, Medical Park Bad Rodach",
    "description": "Der Medical Park Bad Rodach nutzt intelligente Sensorik- und Robotiksysteme einschließlich Pixformance, um Patienten in jeder Rehabilitationsphase zu unterstützen.",
    "url": "https://pixformance.com/erfolgsgeschichten/gunter-hoelig",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH", "logo": {"@type": "ImageObject", "url": "https://pixformance.com/images/pix-favicon.png"}},
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <a
            href="/erfolgsgeschichten"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors"
          >
            <Icon name="arrow-left" size="sm" />
            Zurück zur Übersicht
          </a>
        </div>

        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.2s;">
            <Icon name="activity" size="sm" />
            Klinik
          </span>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.3s;">
            Unterstützung in jeder Rehabilitationsphase
          </h1>

          <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed hero-animate" style="animation-delay: 0.4s;">
            Medical Park Bad Rodach – Intelligente Rehabilitationslösungen für jeden Patienten
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Quote -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
          <p class="text-foreground italic text-base md:text-xl">
            „Mit Pixformance können wir unseren Patienten in jeder Phase ihrer Rehabilitation eine individualisierte, digital unterstützte Trainingserfahrung bieten – von der Frühmobilisation bis hin zum fortgeschrittenen Krafttraining."
          </p>
          <p class="text-sm text-foreground-muted mt-3 font-semibold">— Gunter Hölig, Medical Park Bad Rodach</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Profile Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 items-center">
          <div class="order-2 lg:order-1" data-scroll="fade-up">
            <Card variant="elevated" padding="none" class="overflow-hidden">
              <img
                src="/images/erfolgsgeschichten/Gunter-Hoelig.jpg"
                alt="Gunter Hölig – Medical Park Bad Rodach"
                class="w-full h-auto max-h-[380px] object-cover object-center"
                loading="lazy"
              />
            </Card>
          </div>

          <div class="order-1 lg:order-2 space-y-8" data-scroll="fade-up" data-delay="1">
            <div>
              <h2 class="font-display text-3xl md:text-3xl font-bold mb-2">Gunter Hölig</h2>
              <p class="text-xl text-[#02308C] font-semibold">Medical Park Bad Rodach</p>
            </div>

            <Card variant="elevated" padding="none" class="bg-white p-4 md:p-8">
              <h3 class="font-bold text-xl mb-4 flex items-center gap-2">
                <Icon name="activity" size="md" class="text-[#02308C]" />
                Klinik Kurzprofil
              </h3>
              <div class="space-y-3 text-foreground-muted">
                <div class="flex items-start gap-3">
                  <Icon name="map-pin" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Standort</p>
                    <p class="text-sm">Bad Rodach, Bayern, Deutschland</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="heart" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Schwerpunkt</p>
                    <p class="text-sm">Neurologische und orthopädische Rehabilitation</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="activity" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Technologie</p>
                    <p class="text-sm">Intelligente Sensorsysteme, Robotik, digitale Therapie</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="globe" size="sm" class="text-[#02308C] mt-1 flex-shrink-0" />
                  <div>
                    <p class="text-sm font-semibold text-foreground">Netzwerk</p>
                    <p class="text-sm">Medical Park Gruppe</p>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 1 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-6">
            Intelligente Sensorik- und Robotiksysteme für moderne Rehabilitation
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Der Medical Park Bad Rodach gehört zu den führenden Rehabilitationskliniken Deutschlands und verbindet modernste Medizintechnologie mit evidenzbasierten Therapieansätzen. Die Klinik legt besonderen Wert auf den Einsatz intelligenter Systeme, die Patienten auf ihrem Rehabilitationsweg begleiten – mit Echtzeit-Feedback, individualisierten Programmen und messbaren Ergebnissen.
            </p>

            <p class="text-base md:text-lg">
              Pixformance ist zu einem festen Bestandteil des digitalen Therapieportfolios der Klinik geworden. Das System überbrückt die Lücke zwischen robotikgestützter Therapie und selbstständigem Patiententraining und ermöglicht einen nahtlosen Rehabilitationsweg von der Frühmobilisation bis hin zum fortgeschrittenen funktionellen Training.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                „Die Kombination aus intelligenten Sensorsystemen und der KI-gestützten Bewegungsanalyse von Pixformance gibt uns ein umfassendes Bild des Fortschritts jedes Patienten. So können wir evidenzbasierte Entscheidungen über Therapieanpassungen treffen."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 2 -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto space-y-8">
        <div data-scroll="fade-up">
          <h2 class="font-display text-3xl md:text-3xl font-bold mb-6">
            Von der Robotik bis zum funktionellen Training – ein nahtloser Weg
          </h2>

          <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
            <p class="text-base md:text-lg">
              Im Medical Park Bad Rodach wird Rehabilitation als kontinuierlicher Prozess verstanden. Patienten beginnen mit hochspezialisierten Robotiksystemen zur Frühmobilisation und durchlaufen dann einen sorgfältig strukturierten Weg zur funktionellen Selbstständigkeit. Pixformance spielt in den mittleren und fortgeschrittenen Phasen dieses Weges eine entscheidende Rolle.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#02308C]/5 border-l-4 border-[#02308C]">
              <p class="text-foreground italic text-base md:text-lg">
                „Mit über 350 Übungen und KI-gestützten Echtzeit-Korrekturen unterstützt Pixformance unsere Patienten dabei, korrekte Bewegungsmuster eigenständig zu erlernen – was für einen nachhaltigen Therapieerfolg unerlässlich ist."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>

            <p class="text-base md:text-lg">
              Die Fähigkeit des Systems, sofortiges Feedback zur Bewegungsqualität zu geben – ohne ständige Therapeutenaufsicht –, macht es zu einem unschätzbaren Werkzeug, um hochwertige Rehabilitation für mehr Patienten gleichzeitig zu skalieren. Therapeuten können mehrere Patienten gleichzeitig betreuen und sind für diejenigen verfügbar, die eine direkte Intervention benötigen.
            </p>

            <Card variant="elevated" padding="lg" class="bg-[#6BDBD1]/10 border-l-4 border-[#6BDBD1]">
              <p class="text-foreground italic text-base md:text-lg">
                „Die Pixformance Web App ermöglicht es uns zudem, die Therapieunterstützung über die Klinik hinaus zu erweitern und Patienten zu befähigen, ihre Programme zu Hause mit den gleichen Qualitätsstandards fortzuführen, die sie hier erleben."
              </p>
              <p class="text-sm text-foreground-muted mt-2">— Gunter Hölig</p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-12 text-center" data-scroll="fade-up">
          Zentrale Vorteile im Medical Park Bad Rodach
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="activity" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Echtzeit-Feedback</h3>
              <p class="text-foreground-muted text-sm">
                KI-gestützte Bewegungsanalyse liefert sofortiges Feedback zur Übungsqualität und stellt sicher, dass Patienten stets sicher und effektiv trainieren – auch ohne direkte Therapeutenaufsicht.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="users" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Skalierbare Betreuung</h3>
              <p class="text-foreground-muted text-sm">
                Mehrere Patienten können gleichzeitig mit individualisierten Programmen trainieren, sodass Therapeuten ihre Expertise dort einsetzen können, wo direkte Intervention am meisten gebraucht wird.
              </p>
            </Card>
          </div>

          <div data-scroll="fade-up" data-delay="3">
            <Card variant="elevated" padding="lg" class="h-full border-t-4 border-[#02308C] text-center">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center mx-auto mb-4">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
              <h3 class="font-bold text-xl mb-3 text-[#02308C]">Messbarer Fortschritt</h3>
              <p class="text-foreground-muted text-sm">
                Umfassendes Daten-Tracking ermöglicht es Therapeuten und Patienten, klare Verbesserungen zu sehen, motiviert zur weiteren Teilnahme und ermöglicht datengestützte Therapieanpassungen.
              </p>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-3xl font-bold text-foreground">
              Sie wünschen eine individuelle Beratung?
            </h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Ihr Ansprechpartner</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/testen" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Schreiben Sie uns <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <a href="/erfolgsgeschichten" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 transition-colors">
          <Icon name="arrow-left" size="sm" /> Zurück zur Übersicht
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
  [data-scroll][data-delay="3"] { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
