---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import BreadcrumbTabs from '@/components/ui/navigation/BreadcrumbTabs.astro';

const tabs = [
  { label: 'PHYSIOTHERAPIE', href: '/physiotherapie' },
  { label: 'KLINIK', href: '/klinik' },
  { label: 'FITNESS', href: '/fitness' },
  { label: 'BGM', href: '/firmen-fitness' },
];

const benefits = [
  {
    icon: 'monitor',
    title: '700+ Übungen – ein Gerät',
    description: 'Auf der Online Plattform können individuelle Trainingspläne aus einer Sammlung von über 700 funktionellen Übungen zusammengestellt werden.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
  {
    icon: 'users',
    title: 'Zeitgleiche Betreuung',
    description: 'Dank der patentierten Software können mehrere Patienten gleichzeitig und ohne personellen Mehraufwand betreut werden.',
    gradient: 'from-[#6BDBD1] to-[#02308C]',
  },
  {
    icon: 'trending-up',
    title: 'Patienten werden Kunden',
    description: 'Individuelle Trainingseinheiten sowie Maßnahmen zur Sekundärprävention können als eine zusätzliche Einnahmequelle angeboten werden.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
  {
    icon: 'table',
    title: 'Effiziente Verwaltung',
    description: 'Auf der Online Plattform wird der Trainingsverlauf jedes Patienten für eine Trainingsanalyse und -optimierung exakt dokumentiert.',
    gradient: 'from-[#6BDBD1] to-[#86C9BC]',
  },
  {
    icon: 'heart',
    title: 'Individuelles Training',
    description: 'Trainingsprogramme können auf den Gesundheitszustand und den Therapiebedarf jedes Patienten zugeschnitten werden.',
    gradient: 'from-[#86C9BC] to-[#02308C]',
  },
  {
    icon: 'zap',
    title: 'Zeit für das Wesentliche',
    description: 'Der Therapeut muss nicht jede Übung persönlich vormachen und spart Zeit – was wiederum der Betreuung aller Patienten zugutekommt.',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
  },
];

const features = [
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1-NEW.gif',
    title: 'Einfache Übungsanleitung',
    description: 'Der Trainierende stellt sich vor die Pixformance Station und die auszuführende Übung wird von einem virtuellen Trainer auf dem Bildschirm vorgeführt.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-2.gif',
    title: 'Präzise Bewegungsanalyse',
    description: 'Eine Kamera mit Tiefensensor scannt sekundenschnell 25 Gelenk- und 9 statische Punkte des Trainierenden und analysiert die Bewegungen.',
  },
  {
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Hinweis-2.gif',
    title: 'Feedback in Echtzeit',
    description: 'Die Pixformance Station gibt Feedback in Echtzeit. So ist sichergestellt, dass die Übungen richtig und sicher ausgeführt werden.',
  },
];

const testimonials = [
  {
    name: 'Heike Schaible',
    role: 'Inhaberin',
    company: 'Physiotherapie Praxis "Raum für Gesundheit"',
    image: '/images/heikeschaible.600x400.jpg',
    quote: 'Ich will mit Pixformance einen zweiten Selbstzahlerbereich aufbauen und damit vor allem meinen Mitarbeitenden entgegenkommen und ihnen eine einfachere und abwechslungsreichere Arbeit bieten.',
  },
  {
    name: 'Axel-André Richter',
    role: 'Inhaber',
    company: 'Gesundheitspraxis Richter & Lopez',
    image: '/images/Axel-Andre-Richter-und-Lopez-Pixformance.png',
    quote: 'Ich kann das neue Training ganz individuell für jeden unserer Patienten gestalten. Vom Leistungssportler bis zur Omi ist für jeden das Richtige dabei.',
  },
  {
    name: 'Volker Sutor',
    role: 'Inhaber',
    company: 'Physiotherapiezentren »Reha Rondell«',
    image: '/images/Pixformance-Volker-Sutor-Testimonial.png',
    quote: 'Ein gezieltes Gesundheitstraining mit dem virtuellen Trainer erhöht die Effizienz der Behandlung und schafft mehr Zeit für die eigentliche Betreuung meiner Patienten.',
  },
];

const clinicalTestimonials = [
  {
    quote: 'Die Patienten sind begeistert und hochmotiviert, was zugegebenermaßen nicht oft der Fall ist. Natürlich profitieren auch wir als Therapeuten davon, denn die Patienten führen ihre Übungen dadurch besser und zielgerichteter aus. Außerdem sparen wir Zeit, denn nach nur 30 Minuten Einweisung können die Patienten selbstständig unter Aufsicht trainieren.',
    name: 'Gabriele Buchstein',
    role: 'Leiterin Physiotherapie',
    company: 'Sauerlandklinik Hachen – Neurologische Fachklinik für MS',
  },
  {
    quote: 'Auf der Suche nach einer Möglichkeit, die Patienten selbstständig aktiv werden zu lassen, haben wir uns für Pixformance entschieden. Das individuelle Trainingsangebot ist hier ideal, da Gruppentherapie für manche Patienten zu leicht und für andere zu schwer ist. So bekommt jeder ein komplett individuelles Training.',
    name: 'Christoph Schneider',
    role: 'Therapieleiter',
    company: 'Niederrhein-Klinik, Rehaklinik Korschenbroich',
  },
  {
    quote: 'Von Patientenseite kommt ein großes Interesse an den Pixformance Stationen. Viele kommen von sich aus und wollen ein Trainingsprogramm. Wir haben kürzlich eine junge Frau nach Schulteroperation tele-gestützt begleitet. Sie kommt einmal pro Woche in die Klinik — den Rest der Therapie macht sie zu Hause. Das ist eine wirklich tolle Option.',
    name: 'Christoph Oratsch',
    role: 'Leitung Therapie',
    company: 'AUVA Unfallkrankenhaus Klagenfurt',
  },
  {
    quote: 'Wir freuen uns zu beobachten, dass unsere Patienten das Bewegungstraining sehr genießen und durchhalten. Die spielerische Komponente spielt dabei sicher eine Rolle — und wenn unsere Patienten die Krankheit für einen Moment vergessen und einfach Spaß haben, ist das äußerst wertvoll.',
    name: 'Gunter Hölig',
    role: 'Therapieleiter',
    company: 'Medical Park Bad Rodach',
  },
];

const clientLogos = [
  { name: 'Charité Berlin', src: '/images/en/Logo-Charite.png' },
  { name: 'Medical Park', src: '/images/en/Logo-Medical-Park.png' },
  { name: 'Niederrhein-Klinik', src: '/images/en/AK_logo_Niederrhein_Klinik.png' },
  { name: 'Sauerlandklinik Hachen', src: '/images/en/SKH_Logo_4c-scaled-1.jpg' },
  { name: 'AUVA Unfallkrankenhaus', src: '/images/en/2560px-Logo_AUVA.svg.png' },
  { name: 'Mediclin', src: '/images/en/Pixformance-Logo-Mediclin.png' },
  { name: 'Oxford Brookes University', src: '/images/en/pixformance-logo-oxford-brookes-university.png' },
];

const faqItems = [
  {
    question: 'Was ist die Pixformance Station und wie funktioniert sie in der Physiotherapie?',
    answer: 'Die 2D Full-HD Kamera mit integriertem Tiefensensor analysiert in Echtzeit 25 Gelenkpunkte. Ein virtueller Therapeut demonstriert die korrekte Übungsausführung auf dem Bildschirm, während der Patient die Übung ausführt. Das System erkennt Bewegungsabweichungen sofort und gibt visuelles Feedback (Pfeile, Kreise) sowie textliches Feedback direkt auf dem Bildschirm aus. Nach jeder Übung quantifiziert der Pixformance Score die Bewegungsqualität objektiv. Alle Daten werden auf der Online Plattform gespeichert.',
  },
  {
    question: 'Für welche Indikationen ist Pixformance geeignet?',
    answer: 'Multiple Sklerose, Parkinson-Syndrom, postoperative Rehabilitation (Hüfte, Knie, Schulter, Wirbelsäule), neurologische Rehabilitation, Krebsnachsorge, geriatrisches Gleichgewichts- und Sturzpräventionstraining sowie allgemeine funktionelle Bewegungstherapie. Übungen können für Patienten im Rollstuhl, mit Gehbarren, auf der Liege oder auf dem Boden angepasst werden.',
  },
  {
    question: 'Wie viele Patienten können gleichzeitig mit Pixformance trainieren?',
    answer: 'Dank der patentierten Software können mehrere Patienten gleichzeitig an mehreren Stationen trainieren, ohne zusätzlichen Personalaufwand. Jeder Patient scannt seinen persönlichen QR-Code und startet automatisch sein individuelles Therapieprogramm.',
  },
  {
    question: 'Ersetzt Pixformance Physiotherapeuten?',
    answer: 'Nein. Pixformance unterstützt Therapeuten und entlastet sie — es ersetzt sie nicht. Das System übernimmt Übungsanleitung, Echtzeit-Korrektur und Dokumentation automatisch. Nach nur 30 Minuten Einweisung können Patienten selbstständig unter Aufsicht trainieren.',
  },
  {
    question: 'Kann Pixformance für Telerehabilitation und Heimtraining genutzt werden?',
    answer: 'Ja. Die Pixformance Web App ermöglicht Patienten den Zugriff auf ihre Programme zu Hause. Das AUVA Unfallkrankenhaus Klagenfurt nutzt dieses hybride Modell: Patienten kommen einmal pro Woche in die Klinik und absolvieren den Rest der Therapie zu Hause.',
  },
  {
    question: 'Welche klinischen Studien gibt es zu Pixformance?',
    answer: 'Die Hochschule Fresenius hat mehrere Studien durchgeführt: Wirkung auf die Gehfähigkeit bei MS-Patienten, Gleichgewicht und Lebensqualität bei Parkinson, Muskeldystrophie (Emery-Dreifuss) und Brustkrebsnachsorge. Pixformance ist EU-Forschungspartner im FORTEe-Projekt zur Bewegungstherapie für krebskranke Kinder. Das System ist in der Charité Berlin, Medical Park, AUVA und der Oxford Brookes University im klinischen Einsatz.',
  },
  {
    question: 'Ist Pixformance ein zertifiziertes Medizinprodukt?',
    answer: 'Ja. Pixformance ist ein CE-gekennzeichnetes Medizinprodukt (MDR-konform EU 2017/745) und erfüllt die EMV-Richtlinie 2004/108/EG. Das Gerät wird seit 2012 unter strengen Qualitäts- und Sicherheitsstandards gefertigt.',
  },
  {
    question: 'Wie hilft Pixformance beim Aufbau eines Selbstzahlerbereichs?',
    answer: 'Pixformance ermöglicht Praxen, technologiegestütztes Training außerhalb des Rezeptmodells anzubieten und damit eine zweite Einnahmequelle aufzubauen.',
  },
];
---

<BaseLayout
  noindex={true}
  title="Digitale Bewegungstherapie für Physiotherapiepraxen & Rehakliniken | Pixformance"
  description="Pixformance ist das digitale Rehabilitationssystem für Physiotherapeuten: Echtzeit-Analyse von 25 Gelenkpunkten, 700+ Übungen auf der Online Plattform, 6.000+ Installationen weltweit. CE-Medizinprodukt (MDR EU 2017/745)."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Pixformance Digitale Bewegungstherapie – Physiotherapie",
      "description": "Digitale Bewegungstherapie für Physiotherapiepraxen. Automatisiertes Feedback, Betreuung von bis zu 4 Patienten gleichzeitig, Aufbau eines wirtschaftlichen Selbstzahlerbereichs.",
      "provider": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com"},
      "serviceType": "Physiotherapy Technology",
      "areaServed": ["DE", "AT", "CH"],
      "url": "https://www.pixformance.com/physiotherapie/"
    },
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Pixformance Station",
      "description": "Vollvernetztes digitales Rehabilitationssystem bestehend aus der Pixformance Station, einer Online Plattform und einer Web App. Die Station nutzt eine 2D Full-HD Kamera mit integriertem Tiefensensor zur Echtzeit-Analyse von 25 Gelenkpunkten und gibt Patienten sofortiges Korrekturfeedback bei der Übungsausführung.",
      "manufacturer": { "@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://www.pixformance.com" },
      "legalStatus": "CE-Medizinprodukt (MDR EU 2017/745)",
      "relevantSpecialty": ["Physiotherapie", "Rehabilitation", "Neurologie", "Orthopädie", "Sportmedizin"]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was ist die Pixformance Station und wie funktioniert sie in der Physiotherapie?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die 2D Full-HD Kamera mit integriertem Tiefensensor analysiert in Echtzeit 25 Gelenkpunkte. Ein virtueller Therapeut demonstriert die korrekte Übungsausführung auf dem Bildschirm, während der Patient die Übung ausführt. Das System erkennt Bewegungsabweichungen sofort und gibt visuelles Feedback (Pfeile, Kreise) sowie textliches Feedback direkt auf dem Bildschirm aus. Nach jeder Übung quantifiziert der Pixformance Score die Bewegungsqualität objektiv. Alle Daten werden auf der Online Plattform gespeichert."
          }
        },
        {
          "@type": "Question",
          "name": "Für welche Indikationen ist Pixformance geeignet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Multiple Sklerose, Parkinson-Syndrom, postoperative Rehabilitation (Hüfte, Knie, Schulter, Wirbelsäule), neurologische Rehabilitation, Krebsnachsorge, geriatrisches Gleichgewichts- und Sturzpräventionstraining sowie allgemeine funktionelle Bewegungstherapie. Übungen können für Patienten im Rollstuhl, mit Gehbarren, auf der Liege oder auf dem Boden angepasst werden."
          }
        },
        {
          "@type": "Question",
          "name": "Wie viele Patienten können gleichzeitig mit Pixformance trainieren?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dank der patentierten Software können mehrere Patienten gleichzeitig an mehreren Stationen trainieren, ohne zusätzlichen Personalaufwand. Jeder Patient scannt seinen persönlichen QR-Code und startet automatisch sein individuelles Therapieprogramm."
          }
        },
        {
          "@type": "Question",
          "name": "Ersetzt Pixformance Physiotherapeuten?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Pixformance unterstützt Therapeuten und entlastet sie — es ersetzt sie nicht. Das System übernimmt Übungsanleitung, Echtzeit-Korrektur und Dokumentation automatisch. Nach nur 30 Minuten Einweisung können Patienten selbstständig unter Aufsicht trainieren."
          }
        },
        {
          "@type": "Question",
          "name": "Kann Pixformance für Telerehabilitation und Heimtraining genutzt werden?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja. Die Pixformance Web App ermöglicht Patienten den Zugriff auf ihre Programme zu Hause. Das AUVA Unfallkrankenhaus Klagenfurt nutzt dieses hybride Modell: Patienten kommen einmal pro Woche in die Klinik und absolvieren den Rest der Therapie zu Hause."
          }
        },
        {
          "@type": "Question",
          "name": "Welche klinischen Studien gibt es zu Pixformance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die Hochschule Fresenius hat mehrere Studien durchgeführt: Wirkung auf die Gehfähigkeit bei MS-Patienten, Gleichgewicht und Lebensqualität bei Parkinson, Muskeldystrophie (Emery-Dreifuss) und Brustkrebsnachsorge. Pixformance ist EU-Forschungspartner im FORTEe-Projekt zur Bewegungstherapie für krebskranke Kinder. Das System ist in der Charité Berlin, Medical Park, AUVA und der Oxford Brookes University im klinischen Einsatz."
          }
        },
        {
          "@type": "Question",
          "name": "Ist Pixformance ein zertifiziertes Medizinprodukt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja. Pixformance ist ein CE-gekennzeichnetes Medizinprodukt (MDR-konform EU 2017/745) und erfüllt die EMV-Richtlinie 2004/108/EG. Das Gerät wird seit 2012 unter strengen Qualitäts- und Sicherheitsstandards gefertigt."
          }
        },
        {
          "@type": "Question",
          "name": "Wie hilft Pixformance beim Aufbau eines Selbstzahlerbereichs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pixformance ermöglicht Praxen, technologiegestütztes Training außerhalb des Rezeptmodells anzubieten und damit eine zweite Einnahmequelle aufzubauen."
          }
        }
      ]
    }
  ]}
>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Breadcrumb Tabs -->
  <BreadcrumbTabs tabs={tabs} activeTab="/physiotherapie" />

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hover:bg-[#02308C]/20 hover:border-[#02308C]/30 transition-all duration-300 cursor-pointer">
            <Icon name="heart" size="sm" />
            Physiotherapie
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Das digitale Therapiesystem,<br class="hidden md:block" />
          das Ihre Therapeuten entlastet —
          <span class="text-[#02308C]"> nicht ersetzt</span>
        </h1>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.3s;">
          Physiotherapie von morgen: Digital versorgt, gesünder vernetzt
        </p>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.4s;">
          Keine Technik der Welt kann Therapeuten ersetzen. Die Digitalisierung in der Physiotherapie und Rehabilitation ist jedoch ein effektiver Weg, Therapeuten zu entlasten und Patienten noch intensiver zu betreuen.
        </p>

        <p class="text-base md:text-lg text-foreground-muted leading-relaxed max-w-4xl mx-auto hero-animate" style="animation-delay: 0.45s;">
          Pixformance ist ein vollvernetztes digitales Bewegungstherapiesystem, das in über 6.000 Physiotherapiepraxen, Rehakliniken und Krankenhäusern weltweit eingesetzt wird. Die Pixformance Station analysiert mit einer 2D Full-HD Kamera mit integriertem Tiefensensor in Echtzeit 25 Gelenkpunkte des Patienten und liefert sofortiges Korrekturfeedback. Als CE-Medizinprodukt (MDR EU 2017/745) ist Pixformance in der Charité Berlin, Medical Park, AUVA Klagenfurt und der Oxford Brookes University im Einsatz — und wird seit 2012 kontinuierlich klinisch genutzt.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.5s;">
          <Button
            size="lg"
            href="/testen"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Jetzt beraten lassen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/konzept"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Mehr erfahren
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos Section -->
  <section class="py-8 md:py-12 bg-gray-50 border-y border-gray-100">
    <div class="container">
      <p class="text-center text-sm font-semibold text-foreground-muted uppercase tracking-widest mb-8" data-scroll="fade-up">
        Vertraut von führenden Kliniken und Krankenhäusern
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12" data-scroll="fade-up">
        {clientLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            class="h-8 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <div class="inline-block">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
              <Icon name="target" size="sm" />
              Unsere Mission
            </span>
          </div>

          <h2 class="font-display text-3xl md:text-3xl font-bold leading-tight">
            Therapeuten befähigen, Patienten begeistern
          </h2>

          <p class="text-lg text-foreground-muted leading-relaxed">
            Unsere Mission ist es – mit der besten Technologie für digitale Bewegungsanalyse – eine individuelle Lösung für Therapeuten und deren ganz spezielle Patienten zu kreieren.
            Die digitale Bewegungstherapie von Pixformance entlastet bei der Übungsanleitung und begleitet Patienten somit höchst effektiv auf dem Genesungsweg.
          </p>

        </div>

        <div class="relative" data-scroll="slide-right">
          <img
            src="/images/Pixformance-Physiotherapie-Digitalisierung-Digitales-Trainingsgeraet-Spass-Beim-Training.png"
            alt="Pixformance Physiotherapie Training"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Echtzeit-Korrektur Highlight -->
  <section class="py-20 bg-[#02308C] relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-white/5 pointer-events-none"></div>
    <div class="absolute top-1/2 right-1/3 w-40 h-40 rounded-full bg-[#6BDBD1]/10 pointer-events-none"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-6" data-scroll="fade-up">

        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-sm font-bold text-[#6BDBD1]">
          <Icon name="zap" size="sm" />
          Live-Technologie
        </span>

        <h2 class="font-display text-3xl md:text-3xl font-bold text-white leading-tight">
          Echtzeit-Korrektur
        </h2>

        <p class="text-xl text-white/70 max-w-2xl mx-auto">
          Präzises Feedback während der Übungsausführung.
        </p>


      </div>
    </div>
  </section>

  <!-- Features Section (3 Schritte — unverändert) -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center mb-14" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="sparkles" size="sm" />
          Korrektur in Echtzeit
        </span>
        <h2 class="font-display text-3xl md:text-3xl font-bold">
          Wie funktioniert das Training?
        </h2>
        <p class="text-lg text-foreground-muted mt-4 max-w-3xl mx-auto">
          Die Pixformance Station ermöglicht durchgehende Anleitung hinsichtlich Genauigkeit, Tempo sowie Präzision einer Übungsausführung.
        </p>
      </div>

      <div class="space-y-16 md:space-y-24">
        {features.map((feature, index) => (
          <div
            class={`grid md:grid-cols-2 gap-8 md:gap-12 items-center  ${index % 2 !== 0 ? 'md-reverse' : ''}`}
