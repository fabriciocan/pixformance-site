---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<BaseLayout
  noindex={true}
  title="Studienergebnisse – Wissenschaftlich nachgewiesene positive Effekte mit Pixformance"
  description="Klinische Studien belegen die Wirksamkeit von Pixformance bei Parkinson, Multipler Sklerose, Mamma-Karzinom, Muskeldystrophie und funktionellem Training."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Studienergebnisse – Pixformance",
    "description": "Wissenschaftlich nachgewiesene positive Effekte mit Pixformance – Klinische Studien der Hochschule Fresenius Frankfurt.",
    "url": "https://pixformance.com/studienergebnisse",
    "publisher": {"@type": "Organization", "name": "Pixformance Sports GmbH"}
  }}
>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] hero-animate" style="animation-delay: 0.1s;">
          <Icon name="award" size="sm" />
          Wissenschaftlich belegt
        </span>

        <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Studienergebnisse
        </h1>

        <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Wissenschaftlich nachgewiesene positive Effekte mit Pixformance – klinische Studien der Hochschule Fresenius Frankfurt und weiterer renommierter Institutionen
        </p>

        <div class="flex flex-wrap justify-center gap-4 hero-animate" style="animation-delay: 0.4s;">
          <a href="/downloads/Studienergebnisse_Wissenschaftlich-nachgewiesene-positive-Effekte-mit-Pixformance_2024.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#02308C] text-white font-bold text-sm hover:bg-[#6BDBD1] transition-colors">
            <Icon name="download" size="sm" />
            Studienergebnisse 2024 herunterladen (PDF)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-10 md:py-14 bg-white border-b border-gray-100">
    <div class="container">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-scroll="fade-up">
        <div>
          <p class="text-4xl font-bold text-[#02308C]">4+</p>
          <p class="text-sm text-foreground-muted mt-1">Klinische Studien</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">2.5M+</p>
          <p class="text-sm text-foreground-muted mt-1">Trainierende / Jahr</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">1.100+</p>
          <p class="text-sm text-foreground-muted mt-1">Kliniken &amp; Rehazentren</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#02308C]">700+</p>
          <p class="text-sm text-foreground-muted mt-1">Funktionelle Übungen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Studies Overview -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-3xl md:text-3xl font-bold mb-4 text-center" data-scroll="fade-up">
          Klinische Studien der Hochschule Fresenius Frankfurt
        </h2>
        <p class="text-lg text-foreground-muted text-center mb-12 max-w-3xl mx-auto" data-scroll="fade-up">
          In Zusammenarbeit mit der Hochschule Fresenius Frankfurt wurden klinische Studien zur Wirksamkeit von Pixformance in verschiedenen Indikationsbereichen durchgeführt.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- Parkinson Study -->
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Parkinson.jpg"
                alt="Klinische Studie Parkinson – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="activity" size="sm" /> Neurologie
                </span>
                <h3 class="font-display text-xl font-bold">Parkinson – Gehfähigkeit &amp; Beweglichkeit</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Verbesserung der Gehfähigkeit und Beweglichkeit bei Parkinson-Patienten durch regelmäßiges funktionelles Training mit Pixformance an der Hochschule Fresenius Frankfurt.
                </p>
              </div>
            </Card>
          </div>

          <!-- Multiple Sklerose Study -->
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Multiple-Sklerose.jpg"
                alt="Klinische Studie Multiple Sklerose – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="activity" size="sm" /> Neurologie
                </span>
                <h3 class="font-display text-xl font-bold">Multiple Sklerose – Gehfähigkeit &amp; Lebensqualität</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Verbesserung der Gehfähigkeit und Lebensqualität bei MS-Patienten durch digitale Bewegungstherapie mit Pixformance an der Hochschule Fresenius Frankfurt.
                </p>
              </div>
            </Card>
          </div>

          <!-- Mamma-Karzinom Study -->
          <div data-scroll="fade-up" data-delay="1">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Mamma-Karzinom.jpg"
                alt="Klinische Studie Mamma-Karzinom – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="heart" size="sm" /> Onkologie
                </span>
                <h3 class="font-display text-xl font-bold">Mamma-Karzinom – Sport in der Krebstherapie</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Klinische Studie zur Wirksamkeit von Bewegungstherapie bei Brustkrebspatientinnen. Nachgewiesene Verbesserungen bei körperlicher Leistungsfähigkeit und Lebensqualität.
                </p>
              </div>
            </Card>
          </div>

          <!-- Muskeln Study -->
          <div data-scroll="fade-up" data-delay="2">
            <Card variant="elevated" padding="none" class="h-full overflow-hidden">
              <img
                src="/images/studien/Pixformance-Klinik-Klinische-Studien-Muskeln.jpg"
                alt="Klinische Studie Muskeln – Pixformance"
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6 space-y-3">
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#6BDBD1]/20 text-[#02308C] text-xs font-bold">
                  <Icon name="zap" size="sm" /> Orthopädie
                </span>
                <h3 class="font-display text-xl font-bold">Muskeln – Kraft &amp; Funktionelles Training</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">
                  Studie zur Untersuchung der Trainingseffekte durch funktionelles Training mit Pixformance. Empirische Überprüfung der Verbesserungen bei Muskelkraft und Bewegungsqualität.
                </p>
              </div>
            </Card>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- PDF Download Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center" data-scroll="fade-up">
          <div>
            <img
              src="/images/studien/Studienergebnisse_Wissenschaftlich-nachgewiesene-positive-Effekte-mit-Pixformance_2024-pdf.jpg"
              alt="Studienergebnisse 2024 – Wissenschaftlich nachgewiesene positive Effekte mit Pixformance"
              class="w-full max-w-xs mx-auto shadow-xl rounded-lg"
              loading="lazy"
            />
          </div>
          <div class="space-y-6">
            <h2 class="font-display text-3xl md:text-3xl font-bold">
              Studienergebnisse 2024
            </h2>
            <p class="text-lg text-foreground-muted leading-relaxed">
              Laden Sie unsere aktuelle Zusammenfassung der wissenschaftlich nachgewiesenen positiven Effekte mit Pixformance herunter. Das Dokument fasst die Ergebnisse klinischer Studien aus verschiedenen Indikationsbereichen zusammen.
            </p>
            <ul class="space-y-2 text-sm text-foreground-muted">
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Parkinson-Behandlung und Gehfähigkeit</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Multiple Sklerose und Lebensqualität</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Onkologie und Sport bei Krebs</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> Funktionelles Training und Muskelkraft</li>
              <li class="flex items-center gap-2"><Icon name="check-circle" size="sm" class="text-[#6BDBD1]" /> FORTEe Forschungsprojekt (Kinderonkologie)</li>
            </ul>
            <a href="/downloads/Studienergebnisse_Wissenschaftlich-nachgewiesene-positive-Effekte-mit-Pixformance_2024.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[#02308C] text-white font-bold hover:bg-[#6BDBD1] transition-colors">
              <Icon name="download" size="sm" />
              PDF herunterladen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MrsSporty Study -->
  <section class="py-12 md:py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white">
          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0">
              <div class="w-16 h-16 rounded-full bg-[#02308C]/10 flex items-center justify-center">
                <Icon name="trending-up" size="lg" class="text-[#02308C]" />
              </div>
            </div>
            <div class="space-y-3">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#02308C]/10 text-[#02308C] text-xs font-bold">
                Fitness &amp; Prävention
              </span>
              <h3 class="font-display text-2xl font-bold">Empirische Überprüfung der Trainingseffekte – Mrs.Sporty</h3>
              <p class="text-foreground-muted leading-relaxed">
                Klinische Studie zur empirischen Überprüfung funktionellen Trainings und der Trainingseffekte bei Mrs.Sporty-Mitgliedern. Die Studie zeigt messbare Verbesserungen bei Kraft, Ausdauer und Beweglichkeit durch regelmäßiges Pixformance-Training.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <Card variant="elevated" padding="lg" class="bg-white/95 backdrop-blur-sm">
          <div class="text-center space-y-6">
            <h2 class="font-display text-3xl md:text-3xl font-bold text-foreground">
              Sie wünschen eine individuelle Beratung?
            </h2>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-12 py-4 md:py-8">
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 flex-shrink-0 border-[#02308C]">
                <img src="/images/erfolgsgeschichten/Pixformance-Tobias-Produktberater-rund.png.webp" alt="Tobias Baader" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="text-center md:text-left space-y-2">
                <p class="text-xs uppercase tracking-widest text-foreground-muted font-semibold">Ihr Ansprechpartner</p>
                <h3 class="font-bold text-3xl text-foreground">Tobias Baader</h3>
              </div>
            </div>
            <Button size="lg" href="/testen" class="bg-[#02308C] hover:bg-[#6BDBD1] text-white">
              Schreiben Sie uns <Icon name="mail" size="sm" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate { opacity: 0; animation: hero-entry 0.8s ease-out forwards; }
  [data-scroll] { opacity: 0; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  [data-scroll].is-visible { opacity: 1; }
  [data-scroll="fade-up"] { transform: translateY(30px); }
  [data-scroll="fade-up"].is-visible { transform: translateY(0); }
  [data-scroll][data-delay="1"] { transition-delay: 0.1s; }
  [data-scroll][data-delay="2"] { transition-delay: 0.2s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
