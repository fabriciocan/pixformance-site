---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const testimonials = [
  {
    name: 'Swetlana Zimmermann & Claas Bickeböller',
    role: 'Physiotherapeutin & Inhaber',
    company: 'Schlossphysio Winterthur, Schweiz',
    image: '/images/swetlana-zimmermann-schlossphysio.webp',
    quote: 'Wir wollten ein ganzheitliches Trainingsgerät, welches möglichst viele Muskelgruppen und Bewegungsmuster bei der Sporttherapie abdecken kann. Vor allem die Flexibilität, welche man durch das digitale Trainingskonzept erhält, war für uns ein ausschlaggebender Punkt.',
  },
  {
    name: 'Gunter Hölig',
    role: 'Therapieleitung',
    company: 'Medical Park Bad Rodach',
    image: '/images/gunter-hoelig-pixformance.webp',
    quote: 'Wenn ein Patient für einen Moment seine Krankheit vergessen kann und einfach Spaß hat, dann ist das auch wertvoll.',
  },
  {
    name: 'Heike Schaible',
    role: 'Inhaberin',
    company: 'Physiotherapie Praxis "Raum für Gesundheit"',
    image: '/images/heike-schaible-round.webp',
    quote: 'Ich will mit Pixformance einen zweiten Selbstzahlerbereich aufbauen und damit vor allem meinen Mitarbeitenden entgegenkommen und ihnen eine einfachere und abwechslungsreichere Arbeit bieten.',
  },
  {
    name: 'Volker Sutor',
    role: 'Inhaber',
    company: 'Physiotherapiezentren »Reha Rondell«',
    image: '/images/volker-sutor-pixformance.webp',
    quote: 'Ein gezieltes Gesundheitstraining mit dem virtuellen Trainer erhöht die Effizienz der Behandlung und schafft mehr Zeit für die eigentliche Betreuung meiner Patienten.',
  },
  {
    name: 'Gabriele Buchstein',
    role: 'Leitende Physiotherapeutin',
    company: 'Sauerlandklinik Hachen',
    image: '/images/gabriele-buchstein-sauerlandklinik.webp',
    quote: 'Die Patienten sind begeistert und sehr motiviert. Davon profitieren auch wir als Therapeuten, da die Patienten dadurch besser und zielgerichteter ihre Übungen ausführen.',
  },
  {
    name: 'Axel-André Richter',
    role: 'Inhaber',
    company: 'Gesundheitspraxis Richter & Lopez',
    image: '/images/axel-andre-richter-lopez.webp',
    quote: 'Ich kann das neue Training ganz individuell für jeden unserer Patienten gestalten. Vom Leistungssportler bis zur Omi ist für jeden das Richtige dabei.',
  },
];

const clientLogos = [
  'Logo-Medical-Park.png',
  'Logo-Gesundheitsrondell-Reharondell.png',
  'Logo-Charite.png',
  'Logo-GiB-Gesundheit-in-Bewegung-1.png',
  'Logo-Therapiezentrum-Rombach.png',
  'Logo-Essink-Sportscentrum-1.png',
  'Logo-Femme-Fit-1.png',
  'Logo-MrsSporty-Mrs-Sporty.png',
];
---

<BaseLayout
  title="Die Therapieinnovation für Ihre Physio Praxis – Broschüre | Pixformance"
  description="Erfahren Sie, warum Sie jetzt in digitale Trainingsangebote investieren sollten und wie unser digitales 360°-Konzept funktioniert. Jetzt Broschüre downloaden."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Die Therapieinnovation für Ihre Physio Praxis – Broschüre",
    "description": "Pixformance Broschüre: Digitalisierung in der Physiotherapie. Digitale Trainingsangebote und 360°-Konzept.",
    "url": "https://neu.pixformance.com/lp-physio-digitalisierung",
    "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
  }}
>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section - Blue Background -->
  <section class="bg-[#02308C] py-16 md:py-24">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-4">
        <p class="text-sm md:text-base font-bold text-white/80 uppercase tracking-[0.2em] hero-animate" style="animation-delay: 0.1s;">
          Effektive Entlastung & Unterstützung
        </p>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight uppercase hero-animate" style="animation-delay: 0.2s;">
          Die Therapieinnovation für Ihre Physio Praxis
        </h1>
      </div>
    </div>
  </section>

  <!-- Brochure Download Section - Two Columns -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-6xl mx-auto">
        <!-- Left: Image -->
        <div class="flex items-center justify-center" data-scroll="slide-left">
          <img
            src="/images/broschuere-lp-physio-digitalisierung.png"
            alt="Pixformance Broschüre – Digitalisierung in der Physiotherapie"
            class="w-full h-auto max-h-[420px] object-contain"
            loading="eager"
          />
        </div>

        <!-- Right: Text + Download Button -->
        <div class="space-y-6" data-scroll="slide-right">
          <h2 class="font-display text-2xl md:text-3xl font-bold leading-tight">
            Erfahren Sie in der Broschüre:
          </h2>

          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-[#02308C] mt-2.5 shrink-0"></div>
              <p class="text-base md:text-lg text-foreground-muted leading-relaxed">
                Warum Sie jetzt in <strong class="text-foreground">digitale Trainingsangebote investieren</strong> sollten
              </p>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-[#02308C] mt-2.5 shrink-0"></div>
              <p class="text-base md:text-lg text-foreground-muted leading-relaxed">
                Wie unser <strong class="text-foreground">digitales 360°-Konzept</strong> funktioniert
              </p>
            </li>
          </ul>

          <div class="pt-4 flex justify-center lg:justify-start">
            <button
              id="download-brochure-btn"
              class="inline-flex items-center gap-3 px-8 py-4 bg-[#C41E3A] text-white font-bold text-lg rounded-full hover:bg-[#A31830] hover:scale-105 hover:shadow-xl transition-all duration-300 cursor-pointer uppercase tracking-wide"
            >
              Broschüre downloaden
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download Form Modal -->
  <div id="download-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4">
    <div id="download-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-3xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-8 md:p-10">
      <button id="download-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors cursor-pointer">
        <Icon name="x" size="md" />
      </button>

      <h2 class="font-display text-2xl md:text-3xl font-bold text-[#02308C] mb-2 text-center">
        Broschüre herunterladen
      </h2>
      <p class="text-center text-foreground-muted mb-6">Füllen Sie das Formular aus und erhalten Sie die Broschüre sofort per E-Mail.</p>

      <form id="download-form" class="space-y-4">
        <div>
          <label for="dl-firma" class="block text-sm font-bold mb-1 text-gray-700">Firma <span class="text-red-500">*</span></label>
          <input type="text" id="dl-firma" name="company" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="dl-vorname" class="block text-sm font-bold mb-1 text-gray-700">Vorname <span class="text-red-500">*</span></label>
            <input type="text" id="dl-vorname" name="first_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
          </div>
          <div>
            <label for="dl-nachname" class="block text-sm font-bold mb-1 text-gray-700">Nachname <span class="text-red-500">*</span></label>
            <input type="text" id="dl-nachname" name="last_name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
          </div>
        </div>
        <div>
          <label for="dl-email" class="block text-sm font-bold mb-1 text-gray-700">E-Mail <span class="text-red-500">*</span></label>
          <input type="email" id="dl-email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div>
          <label for="dl-telefon" class="block text-sm font-bold mb-1 text-gray-700">Telefonnummer <span class="text-red-500">*</span></label>
          <input type="tel" id="dl-telefon" name="phone" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#02308C]/30 focus:border-[#02308C] transition-all text-gray-900" />
        </div>
        <div class="flex items-start gap-3 pt-2">
          <input type="checkbox" id="dl-privacy" name="privacy" required class="mt-1 w-5 h-5 rounded border-gray-300 text-[#02308C] focus:ring-[#02308C]/30" />
          <label for="dl-privacy" class="text-xs text-gray-600 leading-relaxed">
            Ich habe die <a href="/datenschutz" class="text-[#02308C] hover:underline font-bold">Datenschutzerklärung</a> gelesen und willige ein, dass die Pixformance Sports GmbH mir die Broschüre und weitere Informationen per E-Mail oder Telefon zusenden darf. Die Einwilligung kann jederzeit widerrufen werden.
          </label>
        </div>
        <div id="download-form-message" class="hidden"></div>
        <button type="submit" class="w-full py-4 bg-[#02308C] text-white font-bold text-lg rounded-xl hover:bg-[#021d54] hover:shadow-lg transition-all duration-300 cursor-pointer uppercase">
          Broschüre anfordern
        </button>
      </form>
    </div>
  </div>

  <!-- Client Logos Carousel -->
  <section class="py-8 md:py-12 bg-white">
    <div class="container">
      <div class="clients-track-wrapper overflow-hidden">
        <div class="clients-track flex items-center gap-12">
          {[...Array(2)].map(() =>
            clientLogos.map((logo) => (
              <img
                src={`/images/clients/${logo}`}
                alt={logo.replace(/Logo-|-\d+\.png|\.png/g, ' ').trim()}
                class="h-[100px] md:h-[132px] w-auto max-w-[165px] md:max-w-[220px] object-contain opacity-80 hover:opacity-100 transition-all duration-300 shrink-0"
                loading="lazy"
                width="220"
                height="132"
              />
            ))
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Carousel Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div class="relative" id="testimonial-carousel">
          {testimonials.map((testimonial, index) => (
            <div
              class={`testimonial-slide text-center space-y-6 ${index === 0 ? '' : 'hidden'}`}
              data-slide={index}
            >
              <div class="flex justify-center">
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="w-32 h-32 rounded-full object-cover border-4 border-[#6BDBD1] shadow-lg"
                  loading="lazy"
                  width="128"
                  height="128"
                />
              </div>
              <blockquote class="text-lg md:text-xl text-gray-600 leading-relaxed italic max-w-3xl mx-auto">
                &laquo; {testimonial.quote} &raquo;
              </blockquote>
              <div>
                <p class="font-bold text-lg text-gray-900">{testimonial.name}</p>
                <p class="text-gray-500">{testimonial.role}, {testimonial.company}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-8" id="testimonial-dots">
          {testimonials.map((_, index) => (
            <button
              class={`w-3 h-3 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? 'bg-[#02308C] scale-110' : 'bg-gray-300 hover:bg-gray-400'}`}
              data-dot={index}
              aria-label={`Testimonial ${index + 1}`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 360° Konzept CTA Card Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 lg:gap-12 items-center bg-white rounded-3xl shadow-xl p-8 md:p-12 overflow-hidden max-w-6xl mx-auto" data-scroll="fade-up">
        <div class="space-y-6 text-center md:text-left">
          <p class="text-lg text-foreground-muted leading-relaxed">
            Das voll vernetzte 360°-Pixformance Trainings- und Therapiekonzept bietet eine sinnvolle und zeitgemäße Ergänzung, um Physiotherapeuten bei der Betreuung zu entlasten und auf lange Sicht mehr Umsatz durch erhöhte Betreuungsmöglichkeiten oder den Aufbau eines Selbstzahlerbereichs zu generieren. Bestellen Sie noch heute Ihre Teststellung und finden Sie heraus, ob das Konzept zu Ihrer Einrichtung passt!
          </p>
          <div class="flex justify-center md:justify-start">
            <a
              href="/testen"
              class="inline-flex items-center gap-3 px-8 py-4 bg-[#C41E3A] text-white font-bold rounded-full hover:bg-[#A31830] hover:scale-105 hover:shadow-xl transition-all duration-300 cursor-pointer uppercase tracking-wide"
            >
              Mehr erfahren
              <Icon name="arrow-right" size="sm" />
            </a>
          </div>
        </div>
        <div>
          <img
            src="/images/imgs-lp/pixformance-360-grad-konzept-online-plattform-app-digitales-sportgeraet-png-to-webp-converter-500.webp"
            alt="Pixformance 360° Konzept"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes hero-entry {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }

  .clients-track {
    animation: scroll-logos 25s linear infinite;
    width: max-content;
  }

  .clients-track-wrapper:hover .clients-track {
    animation-play-state: paused;
  }

  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  [data-scroll].is-visible {
    opacity: 1;
  }

  [data-scroll="fade-up"] {
    transform: translateY(30px);
  }

  [data-scroll="fade-up"].is-visible {
    transform: translateY(0);
  }

  [data-scroll="slide-left"] {
    transform: translateX(-40px);
  }

  [data-scroll="slide-left"].is-visible {
    transform: translateX(0);
  }

  [data-scroll="slide-right"] {
    transform: translateX(40px);
  }

  [data-scroll="slide-right"].is-visible {
    transform: translateX(0);
  }

  [data-scroll="scale"] {
    transform: scale(0.9);
  }

  [data-scroll="scale"].is-visible {
    transform: scale(1);
  }

  .testimonial-slide {
    transition: opacity 0.5s ease-in-out;
  }

  #download-modal.flex {
    animation: popup-in 0.3s ease-out;
  }

  @keyframes popup-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  #download-modal.flex > div:last-child {
    animation: popup-slide 0.3s ease-out;
  }

  @keyframes popup-slide {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-scroll]').forEach((el) => {
    observer.observe(el);
  });

  // Testimonial Carousel
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('#testimonial-dots button');
  let currentSlide = 0;
  let autoplayInterval: ReturnType<typeof setInterval>;

  function showSlide(index: number) {
    slides.forEach((slide) => slide.classList.add('hidden'));
    dots.forEach((dot) => {
      dot.classList.remove('bg-[#02308C]', 'scale-110');
      dot.classList.add('bg-gray-300');
    });

    slides[index]?.classList.remove('hidden');
    dots[index]?.classList.remove('bg-gray-300');
    dots[index]?.classList.add('bg-[#02308C]', 'scale-110');
    currentSlide = index;
  }

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      showSlide(index);
      resetAutoplay();
    });
  });

  function nextSlide() {
    showSlide((currentSlide + 1) % slides.length);
  }

  function resetAutoplay() {
    clearInterval(autoplayInterval);
    autoplayInterval = setInterval(nextSlide, 6000);
  }

  autoplayInterval = setInterval(nextSlide, 6000);

  // Download Modal
  const downloadBtn = document.getElementById('download-brochure-btn');
  const downloadModal = document.getElementById('download-modal');
  const downloadOverlay = document.getElementById('download-overlay');
  const downloadClose = document.getElementById('download-close');

  function openModal() {
    downloadModal?.classList.remove('hidden');
    downloadModal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    downloadModal?.classList.add('hidden');
    downloadModal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  downloadBtn?.addEventListener('click', openModal);
  downloadOverlay?.addEventListener('click', closeModal);
  downloadClose?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Form submission — webhook + redirect
  const WEBHOOK_URL = 'https://webhook.pixformance.com/webhook/site-forms';

  function getUrlParams() {
    const params: Record<string, string> = {};
    new URLSearchParams(window.location.search).forEach((value, key) => {
      params[key] = value;
    });
    return params;
  }

  function getCookies() {
    const cookies: Record<string, string> = {};
    if (!document.cookie) return cookies;
    document.cookie.split(';').forEach((cookie) => {
      const idx = cookie.indexOf('=');
      if (idx === -1) return;
      const key = cookie.slice(0, idx).trim();
      const value = cookie.slice(idx + 1).trim();
      try { cookies[key] = decodeURIComponent(value); } catch { cookies[key] = value; }
    });
    return cookies;
  }

  function sanitizePhone(phone: string | null): string {
    return (phone || '').replace(/[^\d\s+\-()]/g, '').trim();
  }

  const downloadForm = document.getElementById('download-form') as HTMLFormElement;
  const formMessage = document.getElementById('download-form-message');

  downloadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = downloadForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.7'; }

    const formData = new FormData(downloadForm);
    const payload = {
      form_name: 'LP Physio Digitalisierung – Broschüre Download',
      company: formData.get('company') || '',
      first_name: formData.get('first_name') || '',
      last_name: formData.get('last_name') || '',
      email: formData.get('email') || '',
      phone: sanitizePhone(formData.get('phone')),
      privacy_accepted: formData.get('privacy') === 'on',
      page_url: window.location.href,
      page_path: window.location.pathname,
      referrer: document.referrer || '',
      submitted_at: new Date().toISOString(),
      url_params: getUrlParams(),
      cookies: getCookies(),
      language: 'de',
      version: 'DACH',
    };

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        window.location.href = '/lp-physio-digitalisierung-danke';
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (formMessage) {
        formMessage.className = 'text-center text-red-700 bg-red-50 border border-red-200 rounded-xl p-4';
        formMessage.textContent = 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.';
        formMessage.classList.remove('hidden');
      }
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = ''; }
    }
  });
</script>
