const stats = [
  { value: '6.000+', label: 'Installationen weltweit', icon: 'map-pin' },
  { value: '2.5M+', label: 'Trainierende', icon: 'users' },
  { value: '2012', label: 'Gegründet', icon: 'calendar' },
