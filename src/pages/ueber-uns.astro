---

<BaseLayout
  title="Pixformance Sports GmbH — Pionier der digitalen Bewegungstherapie seit 2012 | Über uns"
  description="Pixformance Sports GmbH: Gegründet 2012 von CEO Valerie Bures-Bönström. FDA Klasse 2 Medizinprodukt. EU-Forschungspartner FORTEe. Klinisch validiert: Charité Berlin, Oxford Brookes University. 6.000+ Installationen, 2.5M+ Trainierende/Jahr."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Pixformance Sports GmbH",
      "url": "https://www.pixformance.com",
      "foundingDate": "2012",
      "description": "Pixformance Sports GmbH ist der Pionier in digitaler Bewegungsanalyse und Echtzeit-Feedback für Physiotherapie, Rehabilitation und Fitness. Gegründet 2012 von CEO Valerie Bures-Bönström. Entwickler der FDA Klasse 2 zertifizierten Pixformance Station. EU-Forschungspartner im FORTEe-Projekt. Klinisch validiert an der Charité Berlin und Oxford Brookes University.",
      "founder": {
        "@type": "Person",
        "name": "Valerie Bures-Bönström",
        "jobTitle": "CEO"
      },
      "numberOfEmployees": {"@type": "QuantitativeValue", "value": 20},
      "areaServed": ["DE","AT","CH","NL","FR","IT","US"],
      "award": [
        "FDA Klasse 2 Medizinprodukt",
        "EU-Forschungspartner FORTEe-Projekt",
        "Klinische Validierung Charité Berlin",
        "Klinische Validierung Oxford Brookes University"
      ],
      "knowsAbout": [
        "Digitale Bewegungsanalyse",
        "Physiotherapie",
        "Rehabilitation",
        "Funktionelles Training",
        "Telerehabilitation",
        "Echtzeit-Feedback"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Valerie Bures-Bönström",
      "jobTitle": "CEO",
      "worksFor": {
        "@type": "Organization",
        "name": "Pixformance Sports GmbH"
      },
      "description": "CEO und Mitgründerin der Pixformance Sports GmbH. Führt das Unternehmen seit der Gründung 2012 und hat Pixformance zum Marktführer in digitaler Bewegungstherapie in der DACH-Region entwickelt."
    }
  ]}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/ueber-uns/" />
    <link rel="alternate" hreflang="en" href="https://www.pixformance.com/en/about-us/" />
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/a-propos/" />
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/over-ons/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/chi-siamo/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/about-us/" />
  </Fragment>
  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#6BDBD1]/10 to-[#86C9BC]/10 overflow-hidden py-12 md:py-16">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center space-y-5">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="users" size="sm" />
            Über uns
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance Sports GmbH: Pionier der digitalen Bewegungstherapie seit 2012
        </h1>

        <p class="text-xl md:text-2xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Unermüdliche Innovationskraft – und das bereits seit 2012
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-6 rounded-2xl bg-white hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate shadow-lg" style={`animation-delay: ${0.4 + index * 0.1}s;`}>
              <div class="w-12 h-12 mx-auto rounded-xl bg-[#02308C] flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
                <Icon name={stat.icon} size="md" class="text-white" />
              </div>
              <div class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300">
                {stat.value}
              </div>
              <div class="text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Company Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
            <Icon name="building" size="sm" />
            Unser Unternehmen
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
            Pioniere der digitalen Bewegungsanalyse
          </h2>
        </div>

        <div class="space-y-6 text-lg text-foreground-muted leading-relaxed">
          <p>
            Pixformance Sports GmbH wurde 2012 gegründet und ist der Pionier in digitaler Bewegungsanalyse und Echtzeit-Feedback für Physiotherapie, Rehakliniken und Fitness. Unter der Leitung von CEO <span class="font-bold text-[#02308C]">Valerie Bures-Bönström</span> hat das Unternehmen die Pixformance Station als FDA Klasse 2 zertifiziertes Medizinprodukt entwickelt — klinisch validiert an der Charité Berlin und der Oxford Brookes University, und als EU-Forschungspartner im FORTEe-Projekt aktiv. Mit über 6.000 Installationen in Physiotherapiepraxen, Rehakliniken und Fitnessstudios weltweit und 2,5 Millionen Trainierenden pro Jahr setzt Pixformance neue Maßstäbe in der digitalen Bewegungstherapie.
          </p>

          <p>
            Unsere patentierte Technologie revolutioniert die Art und Weise, wie Menschen trainieren.
            Mit über <span class="font-bold text-[#02308C]">6.000 Installationen weltweit</span> und mehr als
            <span class="font-bold text-[#02308C]">2,5 Millionen Trainierenden</span> setzen wir neue Maßstäbe in
            Physiotherapie, Klinik, Fitness und betrieblichem Gesundheitsmanagement.
          </p>

          <p>
            Unser interdisziplinäres Team verbindet technologische Exzellenz mit tiefem Verständnis
            für die Bedürfnisse unserer Kunden. Wir arbeiten kontinuierlich daran, die beste
            Technologie für digitale Bewegungsanalyse bereitzustellen und damit Gesundheits- und
            Fitnessexperten zu befähigen, ihr volles Potential zu verwirklichen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinical Credentials Section -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container">
      <div class="max-w-4xl mx-auto" data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 text-[#02308C]">
          Klinische Validierung &amp; regulatorische Zulassung
        </h2>
        <p class="text-lg text-foreground-muted leading-relaxed">
          Die Pixformance Station ist als FDA Klasse 2 Medizinprodukt in den USA zugelassen. Das System wurde klinisch validiert durch Studien an der Charité Berlin (Neurologie, Orthopädie) und der Oxford Brookes University (Sportmedizin, Rehabilitation). Pixformance ist EU-Forschungspartner im FORTEe-Projekt zur digitalen Rehabilitation in Europa. Klinische Studien der Hochschule Fresenius belegen die Wirksamkeit bei Multiple Sklerose, Parkinson, Muskeldystrophie und Brustkrebsnachsorge.
        </p>
      </div>
    </div>
  </section>

  <!-- Management Board Section -->

  <!-- Team Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="users" size="sm" />
          Unser Team
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Die Menschen hinter Pixformance
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {team.map((member, index) => (
          <Card
            variant="elevated"
            padding="none"
            class="overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 hover:scale-105 group bg-white"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="relative h-80 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 group-hover:from-[#6BDBD1]/80 transition-all duration-500"></div>
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                style={member.imagePosition ? `object-position: ${member.imagePosition}` : undefined}
                loading="lazy"
              />

              <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                <h3 class="font-bold text-xl text-white mb-1 group-hover:translate-x-2 transition-transform duration-300">
                  {member.name}
                </h3>
                <p class="text-white/90 text-sm font-semibold">
                  {member.role}
                </p>
              </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-6xl font-bold text-white leading-tight">
          Werden Sie Teil unserer Erfolgsgeschichte
        </h2>

        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Kontaktieren Sie uns für eine unverbindliche Beratung und erfahren Sie,
          wie Pixformance Ihr Unternehmen revolutionieren kann.
        </p>

        <div class="flex flex-wrap gap-4 justify-center pt-4">
          <Button
            size="lg"
            href="/testen"
            class="bg-black text-white hover:bg-black/80"
          >
            Jetzt Kontakt aufnehmen
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/konzept"
            class="border-2 border-black text-black hover:bg-black hover:text-white"
          >
            Unser Konzept entdecken
          </Button>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Hero Entry Animation */
  @keyframes hero-entry {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-animate {
    opacity: 0;
    animation: hero-entry 0.8s ease-out forwards;
  }

  /* Scroll Animation Styles */
  [data-scroll] {
    opacity: 0;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  [data-scroll].is-visible {
    opacity: 1;
  }

  /* Fade In Up */
  [data-scroll="fade-up"] {
    transform: translateY(30px);
  }

  [data-scroll="fade-up"].is-visible {
    transform: translateY(0);
  }

  /* Scale In */
  [data-scroll="scale"] {
    transform: scale(0.9);
  }

  [data-scroll="scale"].is-visible {
    transform: scale(1);
  }

  /* Stagger delays */
  [data-scroll][data-delay="1"] {
    transition-delay: 0.1s;
  }

  [data-scroll][data-delay="2"] {
    transition-delay: 0.2s;
  }

  [data-scroll][data-delay="3"] {
    transition-delay: 0.3s;
  }

  [data-scroll][data-delay="4"] {
    transition-delay: 0.4s;
  }

  [data-scroll][data-delay="5"] {
    transition-delay: 0.5s;
  }

  [data-scroll][data-delay="6"] {
    transition-delay: 0.6s;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  // Observe all elements with data-scroll attribute
  document.querySelectorAll('[data-scroll]').forEach((el) => {
    observer.observe(el);
  });
</script>
