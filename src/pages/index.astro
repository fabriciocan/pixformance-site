---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';

const stats = [
  { value: '2.5M+', label: 'Trainierende / Jahr', icon: 'users' },
  { value: '6.000+', label: 'Installationen weltweit', icon: 'activity' },
  { value: '700+', label: 'Funktionelle Übungen', icon: 'zap' },
  { value: '25', label: 'Analysierte Gelenkpunkte in Echtzeit', icon: 'crosshair' },
];

const features = [
  {
    icon: 'camera',
    title: 'Die integrierte 2D Full-HD Kamera erfasst 25 Gelenkpunkte',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Scanpunkte-2.gif',
  },
  {
    icon: 'monitor',
    title: 'Virtueller Personal Trainer zeigt Übungen am Display',
    gradient: 'from-[#6BDBD1] to-[#02308C]',
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Physiotherapie-Training-mobil-1.gif',
  },
  {
    icon: 'message-square',
    title: 'Textliches und visuelles Feedback am Bildschirm',
    gradient: 'from-[#02308C] to-[#6BDBD1]',
    image: '/images/Pixformance-Live-Feedback-Digitales-Trainingsgeraet-Bewegungsanalyse-Korrektur-Hinweis-2.gif',
  },
  {
    icon: 'award',
    title: 'Patentierte Technologie: Feedback in Echtzeit',
    gradient: 'from-[#6BDBD1] to-[#86C9BC]',
    image: '/images/Live-Feedback-EN-2022.png',
  },
];

const testimonials = [
  {
    name: 'Gabriele Buchstein',
    role: 'Leitende Physiotherapeutin',
    company: 'Sauerlandklinik Hachen',
    quote: 'Die Patienten sind begeistert und sehr motiviert. Davon profitieren auch wir als Therapeuten, da die Patienten dadurch besser und zielgerichteter ihre Übungen ausführen.',
    image: '/images/testimonials/gabriele-buchstein.webp',
  },
  {
    name: 'Christoph Schneider',
    role: 'Therapieleitung',
    company: 'Niederrhein-Klinik',
    quote: 'Auf der Suche nach einer Möglichkeit, die Patienten selbstständig aktiv werden zu lassen, haben wir uns für Pixformance entschieden.',
    image: '/images/testimonials/christoph-schneider.webp',
  },
  {
    name: 'Heike Schaible',
    role: 'Inhaberin',
    company: 'Physiotherapie Praxis',
    quote: 'Ich will mit Pixformance einen zweiten Selbstzahlerbereich aufbauen und damit vor allem meinen Mitarbeitenden eine einfachere und abwechslungsreichere Arbeit bieten.',
    image: '/images/testimonials/heike-schaible.webp',
  },
  {
    name: 'Erwin Kuglmeier',
    role: 'Inhaber',
    company: 'Fitnessclub California',
    quote: 'Meine Mitglieder können mit Pixformance individuell angeleitet und für das Training motiviert werden. Das Handling ist sehr einfach!',
    image: '/images/testimonials/erwin-kuglmeier.webp',
  },
  {
    name: 'Kim Essink',
    role: 'Inhaberin',
    company: 'Fitnessclub Essink',
    quote: 'Wir haben uns bewusst für Pixformance entschieden, weil wir uns sicher waren, dass sich unser Investment schnell auszahlen würde.',
    image: '/images/testimonials/kim-essink.webp',
  },
  {
    name: 'Christoph Oratsch',
    role: 'Leitung Therapie',
    company: 'AUVA Unfallkrankenhaus',
    quote: 'Von Patientenseite kommt ein großes Interesse gegenüber der Pixformance Stationen. Viele kommen von sich aus und wollen ein Trainingsprogramm.',
    image: '/images/testimonials/christoph-oratsch.webp',
  },
];

const solutions = [
  {
    title: 'PHYSIOTHERAPIE',
    href: '/physiotherapie',
    icon: 'heart',
    color: '#02308C',
    image: '/images/losungen/Physiotherapie.jpg',
    objectPosition: 'center',
  },
  {
    title: 'KLINIK',
    href: '/klinik',
    icon: 'activity',
    color: '#6BDBD1',
    image: '/images/losungen/klinik.jpg',
    objectPosition: 'center top',
    objectFit: 'cover',
  },
  {
    title: 'FITNESS',
    href: '/fitness',
    icon: 'zap',
    color: '#02308C',
    image: '/images/Pixformance-Fitness-Digitales-Sportgeraet-Fitnessstudio-eroeffnen-eGym-voll-vernetzt.jpg',
    objectPosition: 'center',
  },
  {
    title: 'BGM',
    href: '/firmen-fitness',
    icon: 'users',
    color: '#6BDBD1',
    image: '/images/Pixformance-225402_BGM_Pixformance_Funktionelles-Training_Milon_Virtuelles-Training_Sport-im-Buero-bearbeitet.jpg',
    objectPosition: 'center',
  },
];

const partners = [
  'Oxford Brookes University',
  'Charité',
  'Sauerlandklinik',
  'Mrs.Sporty',
  'Medical Park',
  'FemmeFit',
];
---

<BaseLayout
  title="Pixformance — Digitales Bewegungstherapiesystem für Physiotherapie, Rehakliniken & Fitness"
  description="Pixformance ist das vollvernetzte digitale Bewegungstherapiesystem für Physiotherapiepraxen, Rehakliniken und Fitnessstudios: 2D Full-HD Kamera analysiert 25 Gelenkpunkte in Echtzeit. Weltweit in 6.000+ Einrichtungen im Einsatz."
  image="https://www.pixformance.com/images/Pixformance-Station-Konzept-voll-vernetzt-Digitales-Trainingsgeraet-Funktionelles-Training-eGym.jpg"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Pixformance — Digitales Bewegungstherapiesystem für Physiotherapie, Rehakliniken & Fitness",
      "description": "Vollvernetztes digitales Bewegungstherapiesystem. 2D Full-HD Kamera analysiert 25 Gelenkpunkte in Echtzeit. 6.000+ Installationen weltweit.",
      "url": "https://pixformance.com",
      "isPartOf": {"@type": "WebSite", "url": "https://pixformance.com"}
    },
    {
      "@context": "https://schema.org",
      "@type": "MedicalDevice",
      "name": "Pixformance Station",
      "description": "Digitales Bewegungstherapiegerät mit patentierter 2D Full-HD Kamera und Echtzeit-Analyse von 25 Gelenkpunkten. Eingesetzt in Physiotherapiepraxen, Rehakliniken und Fitnessstudios. Klinisch validiert an der Charité Berlin und Oxford Brookes University.",
      "manufacturer": {"@type": "Organization", "name": "Pixformance Sports GmbH", "url": "https://pixformance.com"},
      "medicalSpecialty": ["Physiotherapie", "Rehabilitation", "Neurologie", "Orthopädie", "Sportmedizin"],
      "image": "https://pixformance.com/images/Pixformance-Station-Konzept-voll-vernetzt-Digitales-Trainingsgeraet-Funktionelles-Training-eGym.jpg"
    },
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Pixformance 360° Konzept",
      "description": "Vollvernetztes digitales Bewegungstherapiesystem bestehend aus der Pixformance Station (Hardware mit 2D Full-HD Kamera und 25-Gelenkpunkt-Analyse), der Pixformance Online Plattform (700+ funktionelle Übungen, Patientenverwaltung, Trainingsdokumentation) und der Pixformance Web App (Heimtraining und Telerehabilitation). Eingesetzt in Physiotherapiepraxen, Rehakliniken, Krankenhäusern und Fitnessstudios.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web, iOS, Android",
      "offers": {"@type": "Offer", "availability": "https://schema.org/InStock"}
    }
  ]}
>
  <Fragment slot="head">
    <!-- Preload LCP hero image to eliminate resource load delay -->
    <link rel="preload" href="/images/header-2-1350.webp" as="image" fetchpriority="high" media="(min-width: 769px)" />
    <link rel="preload" href="/images/hero-mobile.webp" as="image" fetchpriority="high" media="(max-width: 768px)" />
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/" />
    <link rel="alternate" hreflang="en" href="https://www.pixformance.com/en/" />
    <link rel="alternate" hreflang="fr" href="https://www.pixformance.com/fr/" />
    <link rel="alternate" hreflang="nl" href="https://www.pixformance.com/nl/" />
    <link rel="alternate" hreflang="it" href="https://www.pixformance.com/it/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/" />
  </Fragment>

  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero Section -->
  <section class="bg-white overflow-hidden">

    <!-- Hero Image -->
    <div class="relative w-full hero-animate" style="animation-delay: 0.1s;">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/hero-mobile.webp" type="image/webp">
        <source media="(min-width: 769px)" srcset="/images/header-2-1350.webp" type="image/webp">
        <img
          src="/images/header-2-1350.webp"
          alt="Pixformance digitale Fitnessgeräte"
          class="w-full object-cover h-auto md:h-170"
          loading="eager"
          fetchpriority="high"
          width="1350"
          height="895"
        />
      </picture>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
    </div>

    <!-- Hero Text -->
    <div class="container pt-6 pb-12 md:pb-16 -mt-16">
      <div class="max-w-5xl mx-auto text-center space-y-5 cursor-default">

        <p class="font-display text-xl md:text-xl lg:text-xl font-normal leading-tight hero-animate" style="animation-delay: 0.3s;">
          Digitale Fitnessgeräte & Therapiegeräte
          <span class="text-[#02308C] font-bold"> von Pixformance</span>
        </p>

        <p class="text-2xl md:text-3xl font-bold text-[#02308C] hero-animate" style="animation-delay: 0.4s;">
          Das digitale Bewegungstherapiesystem für Physiotherapie, Reha und Fitness
        </p>

        <p class="text-sm md:text-base text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.5s;">
          Pixformance verbindet digitales Training, intelligente Bewegungsanalyse und direktes Echtzeit-Feedback in einem vollvernetzten System. Weltweit wird Pixformance bereits in über 1.100 Einrichtungen eingesetzt – darunter Physiotherapiepraxen, Rehakliniken und Fitnessstudios.
        </p>

        <p class="text-sm md:text-base text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.55s;">
          Die Pixformance Station analysiert mithilfe einer 2D-Full-HD-Kamera mit integriertem Tiefensensor 25 Gelenkpunkte von Trainierenden und unterstützt sie mit visuellem sowie textlichem Echtzeit-Feedback während der Übungsausführung.
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center pt-2 hero-animate" style="animation-delay: 0.6s;">
          <Button
            size="lg"
            href="/testen"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Unverbindlich testen
            <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform duration-300" />
          </Button>
          <Button
            size="lg"
            variant="outline"
            href="/konzept"
            class="group hover:shadow-lg hover:scale-105 transition-all duration-300"
          >
            Mehr erfahren
            <Icon name="play-circle" size="sm" class="group-hover:scale-110 transition-transform duration-300" />
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 pt-6 max-w-4xl mx-auto">
          {stats.map((stat, index) => (
            <div class="group space-y-2 p-4 sm:p-6 rounded-2xl hover:bg-[#02308C]/5 transition-all duration-300 hover:scale-105 cursor-pointer hero-animate" style={`animation-delay: ${0.7 + index * 0.1}s;`}>
              <div class="text-3xl md:text-4xl font-bold text-[#02308C] group-hover:scale-110 transition-transform duration-300">
                {stat.value}
              </div>
              <div class="text-xs sm:text-sm text-foreground-muted">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Partner Logos with headline -->
      <div class="hero-animate mt-12" style="animation-delay: 1.1s;">
        <p class="text-center font-bold text-lg md:text-xl mb-6 text-gray-800">
          Führende Einrichtungen vertrauen auf Pixformance
        </p>
        <div class="clients-track-wrapper overflow-hidden">
          <div class="clients-track flex items-center">
            {[...Array(2)].map(() => [
              { file: 'Logo-Charite.png',                    label: 'Charité' },
              { file: 'Logo-Essink-Sportscentrum-1.png',     label: 'Essink Sportscentrum' },
              { file: 'Logo-Femme-Fit-1.png',                label: 'Femme Fit' },
              { file: 'Logo-Gesundheitsrondell-Reharondell.png', label: 'Gesundheitsrondell Reharondell' },
              { file: 'Logo-GiB-Gesundheit-in-Bewegung-1.png', label: 'GiB Gesundheit in Bewegung' },
              { file: 'Logo-Medical-Park.png',               label: 'Medical Park' },
              { file: 'Logo-MrsSporty-Mrs-Sporty.png',       label: 'Mrs. Sporty' },
              { file: 'Logo-Therapiezentrum-Rombach.png',    label: 'Therapiezentrum Rombach' },
              { file: 'AMT_LOGO.webp',                       label: 'AMT' },
            ].map((logo) => (
              <img
                src={`/images/clients/${logo.file}`}
                alt={logo.label}
                class="h-44 w-auto max-w-[220px] object-contain opacity-90 hover:opacity-100 transition-all duration-300 shrink-0 mr-12"
                loading="lazy"
                width="220"
                height="176"
              />
            )))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div class="space-y-6" data-scroll="slide-left">
          <div class="inline-block text-center md:text-left w-full">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
              <Icon name="target" size="sm" />
              Unsere Mission
            </span>
          </div>

          <h2 class="font-display text-2xl md:text-4xl lg:text-5xl font-bold leading-tight break-words text-center md:text-left">
            Das 360° Pixformance Konzept: Station, Online Plattform und Web App
          </h2>

          <p class="text-lg text-foreground-muted leading-relaxed text-center md:text-left">
            Das Pixformance 360° Konzept besteht aus drei vernetzten Komponenten: Die Pixformance Station analysiert Bewegungen in Echtzeit und gibt sofortiges Korrekturfeedback. Die Online Plattform ermöglicht Therapeuten und Trainern die Erstellung individueller Programme aus über 700 funktionellen Übungen. Die Web App ermöglicht Patienten und Mitgliedern den Zugriff auf ihre Programme zu Hause — für lückenlose Betreuung zwischen den Terminen.
          </p>

          <div class="grid md:grid-cols-2 gap-6 pt-4">
            <div class="space-y-3 flex flex-col items-center text-center md:items-start md:text-left">
              <div class="w-12 h-12 rounded-xl bg-[#02308C] flex items-center justify-center">
                <Icon name="check" size="md" class="text-white" />
              </div>
              <h3 class="font-bold text-lg">Virtueller Personal Trainer</h3>
              <p class="text-sm text-foreground-muted">
                Professionelle Anleitung für jeden Trainierenden.
              </p>
            </div>

            <div class="space-y-3 flex flex-col items-center text-center md:items-start md:text-left">
              <div class="w-12 h-12 rounded-xl bg-[#6BDBD1] flex items-center justify-center">
                <Icon name="zap" size="md" class="text-white" />
              </div>
              <h3 class="font-bold text-lg">Echtzeit-Korrektur</h3>
              <p class="text-sm text-foreground-muted">
                Sicheres und effektives Training garantiert.
              </p>
            </div>
          </div>
        </div>

        <div class="relative" data-scroll="slide-right">
          <img
            src="/images/Digital-Training-Device-eHealth-Telemedicine-Feedback-Pixformance-Station-2020-EN-mobil-web.png"
            alt="Pixformance Station"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
            width="800"
            height="555"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-[#6BDBD1]">
    <div class="container">
      <div class="text-center mb-12" data-scroll="fade-up">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white uppercase leading-tight">
          Digitale Fitnessgeräte mit<br/>Echtzeit-Korrektur
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Image -->
        <div class="flex justify-center" data-scroll="slide-left">
          <img
            src="/images/Pixformance-Echtzeit-Feedback.webp"
            alt="Pixformance Echtzeit-Feedback"
            class="w-full max-w-lg h-auto object-contain"
            loading="lazy"
            width="512"
            height="398"
          />
        </div>

        <!-- Feature List -->
        <ul class="space-y-8" data-scroll="slide-right">
          {features.map((feature, index) => (
            <li class="flex items-start gap-5 group" data-delay={index + 1}>
              <div class="shrink-0 w-12 h-12 rounded-xl bg-white/20 border border-white/30 flex items-center justify-center group-hover:bg-white/30 transition-colors duration-300">
                <Icon name={feature.icon} size="md" class="text-white" />
              </div>
              <div>
                <p class="text-white font-medium text-lg leading-snug">
                  {feature.title}
                </p>
              </div>
            </li>
          ))}
          <li class="pt-4 border-t border-white/20">
            <p class="text-white/80 text-sm leading-relaxed">
              Pixformance ist als FDA Klasse 2 Medizinprodukt in den USA zugelassen, EU-Forschungspartner im FORTEe-Projekt und in der Charité Berlin sowie der Oxford Brookes University im klinischen Einsatz.
            </p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="message-circle" size="sm" />
          Kundenstimmen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold">
          Was unsere Kunden sagen
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((testimonial, index) => (
          <Card
            variant="elevated"
            padding="lg"
            class="bg-white hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 group relative overflow-hidden"
            data-scroll="scale"
            data-delay={Math.min(index + 1, 6)}
          >
            <div class="absolute inset-0 bg-gradient-to-br from-[#02308C]/0 to-[#6BDBD1]/0 group-hover:from-[#02308C]/5 group-hover:to-[#6BDBD1]/5 transition-all duration-500"></div>

            <div class="relative space-y-4">
              <div class="flex items-center gap-3">
                <div class="relative">
                  <div class="absolute inset-0 bg-[#02308C] rounded-full blur-lg opacity-0 group-hover:opacity-60 transition-opacity duration-500"></div>
                  <img
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="relative w-16 h-16 rounded-full object-cover ring-2 ring-white shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-500"
                    loading="lazy"
                    width="64"
                    height="64"
                  />
                </div>
                <div>
                  <div class="font-bold group-hover:text-[#02308C] transition-colors duration-300">{testimonial.name}</div>
                  <div class="text-sm text-foreground-muted">{testimonial.role}</div>
                  <div class="text-sm text-[#02308C] font-semibold">{testimonial.company}</div>
                </div>
              </div>

              <div class="relative">
                <Icon name="quote" size="lg" class="text-[#6BDBD1]/20 absolute -top-1 -left-1" />
                <p class="text-sm text-foreground-muted italic leading-relaxed pl-6 relative">
                  "{testimonial.quote}"
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-8" data-scroll="fade-up">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C] mb-6">
          <Icon name="grid" size="sm" />
          Unsere Lösungen
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">
          Eine Technologie — vier Anwendungsbereiche
        </h2>
        <p class="text-lg text-foreground-muted max-w-3xl mx-auto">
          Das Pixformance System wird in vier verschiedenen Bereichen eingesetzt, jeweils mit spezifischen Vorteilen für die jeweilige Einrichtung.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {solutions.map((solution, index) => (
          <a
            href={solution.href}
            class="group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-4"
            data-scroll="fade-up"
            data-delay={index + 1}
          >
            <div class="relative h-80">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent z-10"></div>
              <div class={`absolute inset-0 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500`} style={`background: linear-gradient(to top, ${solution.color}dd, transparent);`}></div>
              <img
                src={solution.image}
                alt={solution.title}
                class={`w-full h-full group-hover:scale-110 transition-transform duration-700 ${solution.objectFit === 'contain' ? 'object-contain' : 'object-cover'}`}
                style={`object-position: ${solution.objectPosition}`}
                loading="lazy"
                width="300"
                height="320"
              />

<div class="absolute bottom-0 left-0 right-0 p-6 z-20">
                <h3 class="font-bold text-lg text-white mb-2 group-hover:translate-x-2 transition-transform duration-300">
                  {solution.title}
                </h3>
                <div class="flex items-center gap-2 text-white text-sm font-semibold opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-300">
                  <span>Mehr erfahren</span>
                  <Icon name="arrow-right" size="sm" class="group-hover:translate-x-2 transition-transform" />
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, #6BDBD1 80%, white 100%)"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center space-y-8" data-scroll="fade-up">
