---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<BaseLayout
  title="Pixformance in der Fachpresse — PT Magazin, Kliniken & Medien"
  description="Pixformance in der pt – Zeitschrift für Physiotherapeuten und weiteren Fachmedien: digitale Bewegungstherapie, 25-Gelenkpunkt-Analyse, FDA Klasse 2. Pressestimmen & Fachbeiträge."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance Pressestimmen & Fachbeiträge",
    "description": "Pixformance in Fachpublikationen: pt – Zeitschrift für Physiotherapeuten und weitere Medien berichten über das digitale Bewegungstherapiesystem Pixformance Station.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "NewsArticle",
          "headline": "Mehr Zeit für Patienten, weniger Stress im Praxisalltag",
          "datePublished": "2026-01",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2026/01/pixformance-mehr-zeit-fuer-patienten-weniger-stress-im-praxisalltag/",
          "about": {
            "@type": "MedicalDevice",
            "name": "Pixformance Station",
            "description": "Digitales Bewegungstherapiesystem mit 25-Gelenkpunkt-Analyse"
          }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "NewsArticle",
          "headline": "Kontaktlose Physiotherapie? Wie digitale Bewegungsanalyse die Physiotherapie und Rehabilitation revolutioniert",
          "datePublished": "2021-07-07",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2021/07/kontaktlose-physiotherapie-wie-digitale-bewegungsanalyse-die-physiotherapie-und-rehabilitation-revolutioniert/",
          "about": {
            "@type": "MedicalDevice",
            "name": "Pixformance Station",
            "description": "Digitales Bewegungstherapiesystem für Physiotherapie und Rehabilitation"
          }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de" href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en" href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Fachpresse
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance in der <span class="text-[#02308C]">Fachpresse</span>
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Die Pixformance Station — das digitale Bewegungstherapiesystem mit patentierter 2D Full-HD Kamera und 25-Gelenkpunkt-Echtzeit-Analyse — wird regelmässig in führenden Fachpublikationen für Physiotherapie, Rehabilitation und Gesundheitsmanagement vorgestellt. Als FDA Klasse 2 Medizinprodukt, klinisch validiert an der Charité Berlin und der Oxford Brookes University, ist Pixformance anerkannter Standard in der digitalen Bewegungstherapie.
        </p>
      </div>
    </div>
  </section>

  <!-- PT Magazin Section -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container max-w-4xl">

      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-4xl font-bold">
            pt – Zeitschrift für Physiotherapeuten
          </h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          Die pt – Zeitschrift für Physiotherapeuten ist die traditionsreichste deutschsprachige Fachzeitschrift für Physiotherapie. Pixformance wird seit 2021 regelmässig in der pt vorgestellt.
        </p>
      </div>

      <div class="space-y-6">

        <!-- Artikel Januar 2026 -->
        <article class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Januar 2026</span>
              <span class="text-xs text-foreground-muted font-medium">pt – Zeitschrift für Physiotherapeuten</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Mehr Zeit für Patienten, weniger Stress im Praxisalltag
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Pixformance unterstützt Physiotherapiepraxen, Reha-Zentren und Kliniken mit seinem 360°-Konzept für digitale Bewegungstherapie, das Training strukturiert, Patienten sicher begleitet und Therapeuten gezielt entlastet.
            </p>
            <a
              href="https://physiotherapeuten.de/news/2026/01/pixformance-mehr-zeit-fuer-patienten-weniger-stress-im-praxisalltag/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline"
            >
              Artikel lesen
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- Artikel Juli 2021 -->
        <article class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold text-white bg-[#6BDBD1]/80 text-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide" style="color: #02308C; background: rgba(107,219,209,0.3); border: 1px solid rgba(107,219,209,0.5);">Juli 2021</span>
              <span class="text-xs text-foreground-muted font-medium">pt – Zeitschrift für Physiotherapeuten</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Kontaktlose Physiotherapie? Wie digitale Bewegungsanalyse die Physiotherapie und Rehabilitation revolutioniert
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Eins der aktuell erfolgreichsten Konzepte für digitale Bewegungsanalyse ist Pixformance. Ob Rehaklinik oder Physiotherapie, das Berliner Unternehmen unterstützt Trainierende namhafter Einrichtungen, wie zum Beispiel die Charité Berlin. Durch die digitale Echtzeit-Korrektur können Patienten ein betreutes Training absolvieren — auch ohne 1-zu-1-Betreuung durch einen Therapeuten.
            </p>
            <a
              href="https://physiotherapeuten.de/news/2021/07/kontaktlose-physiotherapie-wie-digitale-bewegungsanalyse-die-physiotherapie-und-rehabilitation-revolutioniert/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline"
            >
              Artikel lesen
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Pixformance auf einen Blick -->
  <section class="py-12 md:py-16 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div data-scroll="fade-up">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 text-[#02308C]">
          Pixformance auf einen Blick
        </h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">FDA Klasse 2 zertifiziertes Medizinprodukt</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">Klinisch validiert: Charité Berlin &amp; Oxford Brookes University</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">EU-Forschungspartner: FORTEe-Projekt</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">25 Gelenkpunkte Echtzeit-Analyse via 2D Full-HD Kamera</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">700+ funktionelle Übungen auf der Online Plattform</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">6.000+ Installationen in Physiotherapiepraxen, Rehakliniken und Fitnessstudios weltweit</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">2,5 Millionen Trainierende pro Jahr</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check-circle" size="sm" class="text-[#02308C] mt-1 shrink-0" />
            <span class="text-foreground-muted">Klinische Studien: Hochschule Fresenius (MS, Parkinson, Muskeldystrophie, Brustkrebsnachsorge)</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container max-w-4xl">
      <div class="flex flex-col sm:flex-row gap-4" data-scroll="fade-up">
        <Button href="/testen" size="lg">
          Pixformance unverbindlich testen
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button href="/kontakt" size="lg" variant="outline">
          Presseanfragen &amp; Kontakt
          <Icon name="mail" size="sm" />
        </Button>
      </div>
    </div>
  </section>

</BaseLayout>
