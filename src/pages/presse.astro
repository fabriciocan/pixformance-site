---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeaderWithDropdown from '@/components/layout/HeaderWithDropdown.astro';
import Footer from '@/components/layout/Footer.astro';
import PixformanceLogo from '@/components/PixformanceLogo.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<BaseLayout
  title="Pixformance in Wissenschaft & Presse — Klinische Studien, Peer-reviewed Publikationen & Fachpresse"
  description="Pixformance Station klinisch validiert: 7 Studien der Hochschule Fresenius & DHfPG, publiziert in Pädiatrische Praxis (2021;95:680–693), JMIR Formative Research (2025) und BMC Cancer (2025). EU-Forschungsprojekt FORTEe (Horizont 2020, €6,3 Mio.). Nachgewiesene Wirksamkeit bei MS, Parkinson, Mamma-Ca, Muskeldystrophie und Geriatrie."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Pixformance — Wissenschaftliche Studien & Fachpublikationen",
    "description": "Klinisch validierte Studien der Hochschule Fresenius Frankfurt und DHfPG, peer-reviewte Publikationen in Pädiatrische Praxis, JMIR Formative Research und BMC Cancer, EU-Forschungsprojekt FORTEe sowie Fachbeiträge der pt Zeitschrift belegen die Wirksamkeit der Pixformance Station in Neurologie, Onkologie, Geriatrie und Rehabilitation.",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Get strong to fight childhood cancer (FORTEe): Rationale and design of a randomized controlled exercise trial",
          "description": "Randomisierte kontrollierte Studie zur digitalen Bewegungstherapie bei Kinderkrebs. Pixformance (Tobias Baader) als Technologiepartner. 16 Partnerinstitutionen aus 8 Ländern unter Leitung der Universitätsmedizin Mainz. EU Horizont 2020, €6,3 Mio. Förderung. Oxford Brookes University als akademischer Partner.",
          "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/",
          "datePublished": "2025-08-07",
          "publisher": { "@type": "Organization", "name": "BMC Cancer" },
          "author": [
            { "@type": "Person", "name": "Marie Astrid Neu" },
            { "@type": "Person", "name": "Tobias Baader" },
            { "@type": "Person", "name": "Joerg Faber" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Use of a Technology-Based Fall Prevention Program With Visual Feedback in Early Geriatric Rehabilitation",
          "description": "Machbarkeitsstudie mit 30 geriatrischen Patienten (März–Juni 2024). Pixformance Station 3x/Woche 20 Min. Primärendpunkt: ≥80% Teilnahme an 6 Trainings in 2 Wochen — erreicht. Sekundärendpunkte: Berg Balance Scale, Timed Up and Go Test, Functional Independence Measure, Barthel Index.",
          "url": "https://formative.jmir.org/2025/1/e66692",
          "datePublished": "2025-02-11",
          "publisher": { "@type": "Organization", "name": "JMIR Formative Research" },
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Einfluss eines Kräftigungsprogrammes mit visuellem Feedback auf die Kondition eines Jungen mit Muskeldystrophie Emery-Dreifuss",
          "description": "Einzelfallstudie Hochschule Fresenius Frankfurt (Jung M., Faustmann M., 2021). 10-jähriger Patient mit Emery-Dreifuss Muskeldystrophie, 8 Monate, ABAB-Prinzip. Signifikante Steigerung der Ausdauerleistung (6MWT). Pixformance als Motivator und Übungskontrolle bestätigt. Veröffentlicht in Pädiatrische Praxis 2021;95:680–693.",
          "datePublished": "2021-01-01",
          "publisher": { "@type": "Organization", "name": "Pädiatrische Praxis", "issn": "0030-9338" },
          "author": [
            { "@type": "Person", "name": "M. Jung" },
            { "@type": "Person", "name": "M. Faustmann" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Bringt die Anwendung von Pixformance einen positiven Effekt auf die Gehfähigkeit eines MS-Patienten?",
          "description": "Einzelfallstudie Hochschule Fresenius Frankfurt (Zientz M., Jung M., 2018). 16 Wochen, Multiple Sklerose. Gehfähigkeit verbessert (Timed Up And Go Test, 10 Meter Walk Test). Gleichgewicht verbessert (Berg Balance Scale, Functional Reach Test). Effekt hielt nach Trainingspausen an. Lebensqualität MSQOL-54 verbessert nach beiden Trainingsphasen.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "Hochschule Fresenius Frankfurt" },
          "author": [
            { "@type": "Person", "name": "Maya Zientz" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Untersuchung des Effekts von Pixformance auf die obere Extremität bei einer Patientin nach Mamma-Ca",
          "description": "Einzelfallstudie Hochschule Fresenius Frankfurt (Schall K., Jung M., 2017). 11 Wochen, 3x/Woche, Brustkrebsnachsorge. Flexion +20°, Abduktion +15°. Muskelkraft Deltoideus + Pectoralis von Stufe 3 auf 4. Einbeinstand +4 bis 4,5 Sekunden pro Bein. Allgemeiner Gesundheitszustand SF-12 verbessert.",
          "datePublished": "2017-01-01",
          "publisher": { "@type": "Organization", "name": "Hochschule Fresenius Frankfurt" },
          "author": [
            { "@type": "Person", "name": "K. Schall" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 6,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Welchen Effekt auf das Gleichgewicht, die Gehfähigkeit und Lebensqualität hat der Einsatz von Pixformance bei Patienten mit Parkinson-Syndrom?",
          "description": "Prospektive interventionelle Beobachtungsstudie Hochschule Fresenius Frankfurt (Teschner L., Stuke Y., Jung M., 2018). 24 Wochen, 4 Teilnehmer, ABAB-Schema. Deutliche Gleichgewichtsverbesserung (Functional Reach Test). Steigerung der Gehfähigkeit über den Studienzeitraum.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "Hochschule Fresenius Frankfurt" },
          "author": [
            { "@type": "Person", "name": "L. Teschner" },
            { "@type": "Person", "name": "Y. Stuke" },
            { "@type": "Person", "name": "M. Jung" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 7,
        "item": {
          "@type": "ScholarlyArticle",
          "name": "Empirische Überprüfung der Trainingseffekte eines standardisierten Trainingsprogramms am Beispiel von Mrs. Sporty und Pixformance",
          "description": "Studie Deutsche Hochschule für Prävention und Gesundheitsmanagement (Loch M., Barth B., 2018). 23 Frauen, 8 Wochen, 2-3x/Woche. Verbesserungen in allen Bereichen: Körpergewicht, Körperfettgehalt, BMI, Muskelmasse, Bauch- und Hüftumfang sowie Arm- und Beinumfang.",
          "datePublished": "2018-01-01",
          "publisher": { "@type": "Organization", "name": "Deutsche Hochschule für Prävention und Gesundheitsmanagement" },
          "author": [
            { "@type": "Person", "name": "Meike Loch" },
            { "@type": "Person", "name": "B. Barth" }
          ],
          "about": { "@type": "Organization", "name": "Pixformance Sports GmbH" }
        }
      },
      {
        "@type": "ListItem",
        "position": 8,
        "item": {
          "@type": "NewsArticle",
          "headline": "Mehr Zeit für Patienten, weniger Stress im Praxisalltag",
          "datePublished": "2026-01-01",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2026/01/pixformance-mehr-zeit-fuer-patienten-weniger-stress-im-praxisalltag/",
          "about": { "@type": "MedicalDevice", "name": "Pixformance Station" }
        }
      },
      {
        "@type": "ListItem",
        "position": 9,
        "item": {
          "@type": "NewsArticle",
          "headline": "Kontaktlose Physiotherapie? Wie digitale Bewegungsanalyse die Physiotherapie und Rehabilitation revolutioniert",
          "datePublished": "2021-07-07",
          "publisher": {
            "@type": "Organization",
            "name": "pt – Zeitschrift für Physiotherapeuten",
            "url": "https://physiotherapeuten.de"
          },
          "url": "https://physiotherapeuten.de/news/2021/07/kontaktlose-physiotherapie-wie-digitale-bewegungsanalyse-die-physiotherapie-und-rehabilitation-revolutioniert/",
          "about": { "@type": "MedicalDevice", "name": "Pixformance Station" }
        }
      }
    ]
  }}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="de"        href="https://www.pixformance.com/presse/" />
    <link rel="alternate" hreflang="en"        href="https://www.pixformance.com/en/press/" />
    <link rel="alternate" hreflang="fr"        href="https://www.pixformance.com/fr/presse/" />
    <link rel="alternate" hreflang="nl"        href="https://www.pixformance.com/nl/pers/" />
    <link rel="alternate" hreflang="it"        href="https://www.pixformance.com/it/stampa/" />
    <link rel="alternate" hreflang="x-default" href="https://www.pixformance.com/en/press/" />
  </Fragment>

  <HeaderWithDropdown slot="header" position="sticky">
    <PixformanceLogo slot="logo" />
  </HeaderWithDropdown>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#02308C]/10 to-[#6BDBD1]/10 overflow-hidden py-12 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <div class="inline-block hero-animate" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#02308C]/10 border border-[#02308C]/20 text-sm font-bold text-[#02308C]">
            <Icon name="file-text" size="sm" />
            Wissenschaft &amp; Presse
          </span>
        </div>

        <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight hero-animate" style="animation-delay: 0.2s;">
          Pixformance in <span class="text-[#02308C]">Wissenschaft &amp; Presse</span>
        </h1>

        <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto hero-animate" style="animation-delay: 0.3s;">
          Die Pixformance Station — als FDA Klasse 2 Medizinprodukt entwickelt — ist durch 7 klinische Studien validiert und in internationalen peer-reviewten Fachzeitschriften publiziert. EU-Forschungsprojekt FORTEe (Horizont 2020, €6,3 Mio.), Partnerschaften mit Universitätsmedizin Mainz, Oxford Brookes University und Hochschule Fresenius Frankfurt belegen die Wirksamkeit in Neurologie, Onkologie, Geriatrie und Rehabilitation.
        </p>
      </div>
    </div>
  </section>

  <!-- Sektion 1: Peer-Reviewed Wissenschaftliche Publikationen -->
  <section class="py-12 md:py-20 bg-[#02308C]/5">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-4xl font-bold">Peer-Reviewed Wissenschaftliche Publikationen</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          Pixformance ist Gegenstand publizierter Studien in internationalen medizinischen Fachzeitschriften.
        </p>
      </div>
      <div class="space-y-6">

        <!-- BMC Cancer 2025 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">August 2025</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">RCT · BMC Cancer · PubMed</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Pädiatrische Onkologie</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              FORTEe — Randomisierte kontrollierte Studie: Bewegungstherapie bei Kinderkrebs
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-3">
              EU Horizont 2020 Forschungsprojekt (€6,3 Mio.). 16 Partnerinstitutionen aus 8 Ländern unter Leitung der Universitätsmedizin Mainz. Pixformance (Tobias Baader) als Technologiepartner für digitale Bewegungstherapie bei Kindern und Jugendlichen in der onkologischen Behandlung. Akademischer Partner: Oxford Brookes University.
            </p>
            <p class="text-sm italic text-foreground-muted mb-4">Autoren: Neu MA, Baader T, Faber J et al.</p>
            <a href="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC12330123/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Studie lesen (PubMed / BMC Cancer)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- JMIR 2025 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">Februar 2025</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">Peer-reviewed · JMIR Formative Research</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Geriatrie</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Digitales Sturzpräventionsprogramm in der geriatrischen Frührehabilitation
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Machbarkeitsstudie mit 30 geriatrischen Patienten (März–Juni 2024). Pixformance Station 3x wöchentlich, 20 Minuten. Primärendpunkt Machbarkeit erreicht (≥80% Teilnahme). Sekundärendpunkte: Berg Balance Scale, Timed Up and Go Test, Functional Independence Measure, Barthel Index.
            </p>
            <a href="https://formative.jmir.org/2025/1/e66692" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#02308C] font-semibold hover:underline">
              Studie lesen (JMIR Formative Research)
              <Icon name="external-link" size="sm" />
            </a>
          </div>
        </article>

        <!-- Pädiatrische Praxis 2021 -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2021</span>
              <span class="text-xs font-bold text-white px-3 py-1 rounded-full uppercase tracking-wide" style="background-color: #C41E3A;">Indexierte Fachzeitschrift · Pädiatrische Praxis</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Muskeldystrophie</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Kräftigungsprogramm mit visuellem Feedback bei Emery-Dreifuss Muskeldystrophie
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Hochschule Fresenius Frankfurt (Jung M., Faustmann M.). Einzelfallstudie: 10-jähriger Patient, 8 Monate, ABAB-Prinzip. Signifikante Steigerung der Ausdauerleistung (6MWT). Pixformance als Motivator und selbstständige Übungskontrolle.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <p class="text-foreground-muted text-sm leading-relaxed">
                Signifikante Steigerung Ausdauerleistung (6-Minuten-Gehtest). Positive Beeinflussung der Symptomprogression.
              </p>
            </div>
            <p class="text-sm italic text-foreground-muted">Pädiatrische Praxis 2021;95:680–693</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Sektion 2: Klinische Studien Hochschule Fresenius Frankfurt -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container max-w-4xl">
      <div class="mb-10" data-scroll="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-1 h-10 bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-full"></div>
          <h2 class="font-display text-3xl md:text-4xl font-bold">Klinische Studien — Hochschule Fresenius Frankfurt</h2>
        </div>
        <p class="text-lg text-foreground-muted leading-relaxed pl-5">
          In Zusammenarbeit mit der Hochschule Fresenius Frankfurt wurden Einzelfall- und Beobachtungsstudien zur Wirksamkeit der Pixformance Station in Neurologie, Onkologie und Geriatrie durchgeführt.
        </p>
      </div>
      <div class="space-y-6">

        <!-- MS -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2018</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Multiple Sklerose · Hochschule Fresenius</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Positive Effekte auf Gehfähigkeit und Lebensqualität bei MS
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Zientz M., Jung M. (2018). Einzelfallstudie, 16 Wochen, Wechsel Trainings-/Pausenphasen.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Gehfähigkeit verbessert — Timed Up And Go Test + 10 Meter Walk Test</li>
                <li>✓ Gleichgewicht verbessert — Berg Balance Scale + Functional Reach Test</li>
                <li>✓ Trainingseffekt hielt auch nach 4-wöchigen Pausen an</li>
                <li>✓ Lebensqualität MSQOL-54: mentale und körperliche Gesundheit gestiegen</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Mamma-Ca -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2017</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Brustkrebsnachsorge · Hochschule Fresenius</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Verbesserung von Kraft, Mobilität und Gleichgewicht nach Mamma-Karzinom
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Schall K., Jung M. (2017). Einzelfallstudie, 11 Wochen, 3x/Woche.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
              <ul class="space-y-1 text-sm text-foreground-muted">
                <li>✓ Flexion +20°, Abduktion +15°</li>
                <li>✓ Muskelkraft Deltoideus + Pectoralis: von Stufe 3 auf 4</li>
                <li>✓ Einbeinstand: +4 bis 4,5 Sekunden pro Bein</li>
                <li>✓ Allgemeiner Gesundheitszustand verbessert (SF-12)</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Parkinson -->
        <article class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group" data-scroll="fade-up">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[#02308C] to-[#6BDBD1] rounded-l-2xl"></div>
          <div class="pl-4">
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="text-xs font-bold text-white bg-[#02308C] px-3 py-1 rounded-full uppercase tracking-wide">2018</span>
              <span class="text-xs font-bold text-[#02308C] bg-[#02308C]/10 px-3 py-1 rounded-full uppercase tracking-wide">Morbus Parkinson · Hochschule Fresenius</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3 group-hover:text-[#02308C] transition-colors duration-300">
              Signifikante Gleichgewichtsverbesserung bei Parkinson-Syndrom
            </h3>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Teschner L., Stuke Y., Jung M. (2018). Prospektive Beobachtungsstudie, 24 Wochen, 4 Teilnehmer, ABAB-Schema.
            </p>
            <div class="bg-[#02308C]/5 border border-[#02308C]/20 rounded-xl p-4 mb-4">
